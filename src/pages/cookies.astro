---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Cookies Policy | Ambit" description="How Ambit uses cookies and similar technologies on this website, including categories of cookies, your control options, and legal basis for processing.">
  <Navbar />

  <main style="background-color: #0F172A; min-height: 100vh;">

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden" style="background-color: #060D18; border-bottom: 1px solid #1E293B;">
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
      <div class="relative max-w-4xl mx-auto px-6 lg:px-12 py-24">
        <div class="flex items-center gap-2 mb-6">
          <a href="/" class="text-xs transition-colors hover:opacity-80" style="color: #475569;">Home</a>
          <svg class="w-3 h-3" style="color: #334155;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-xs" style="color: #64748B;">Cookies Policy</span>
        </div>
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Legal</p>
        <h1 class="text-4xl lg:text-5xl font-black mb-4" style="color: #F8FAFC;">Cookies Policy</h1>
        <p class="text-sm" style="color: #475569;">Last updated: April 2026</p>
      </div>
    </section>

    <!-- ===== CONTENT ===== -->
    <section class="max-w-4xl mx-auto px-6 lg:px-12 py-16 lg:py-24">

      <!-- Sections -->
      <div class="space-y-12">

        <!-- 1 -->
        <div id="introduction" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">1</span>
            Introduction
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            This Cookies Policy explains how Ambit uses cookies and similar technologies on this website.
          </p>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            This policy should be read together with our <a href="/privacy" class="transition-colors hover:opacity-80" style="color: #93C5FD;">Privacy Policy</a> and <a href="/terms" class="transition-colors hover:opacity-80" style="color: #93C5FD;">Terms of Use</a>. It sets out what cookies are, how they are used, and how you can control their use.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Where required by applicable laws, including UK data protection regulations, non-essential cookies are only used with your consent.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 2 -->
        <div id="what-are-cookies" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">2</span>
            What Are Cookies
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            Cookies are small text files placed on your device when you access a website. They are widely used to ensure websites function properly, improve performance, and provide insight into user behaviour.
          </p>
          <p class="text-sm font-semibold mb-3" style="color: #94A3B8;">Cookies may:</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              enable core functionality
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              remember user preferences
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              support analytics and performance tracking
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              assist with security and session management
            </li>
          </ul>
          <p class="text-sm font-semibold mb-3" style="color: #94A3B8;">Cookies can be:</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              <span><span style="color: #94A3B8;" class="font-medium">Session cookies</span>, which expire when you close your browser</span>
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              <span><span style="color: #94A3B8;" class="font-medium">Persistent cookies</span>, which remain until deleted or expired</span>
            </li>
          </ul>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 3 -->
        <div id="categories" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-6 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">3</span>
            Categories of Cookies We Use
          </h2>

          <div class="space-y-4">

            <!-- 3.1 -->
            <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
              <h3 class="text-sm font-bold mb-3" style="color: #F8FAFC;">3.1 Strictly Necessary Cookies</h3>
              <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
                These cookies are essential for the operation of the website. They support core functionality such as:
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  page navigation
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  access to secure areas
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  form submission
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  security and fraud prevention
                </li>
              </ul>
              <p class="text-xs font-semibold px-2 py-1 rounded inline-block" style="background-color: #1E293B; color: #94A3B8;">These cookies do not require consent.</p>
            </div>

            <!-- 3.2 -->
            <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
              <h3 class="text-sm font-bold mb-3" style="color: #F8FAFC;">3.2 Performance and Analytics Cookies</h3>
              <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
                These cookies help us understand how users interact with the website. They provide aggregated information such as:
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  pages visited
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  time spent on pages
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  navigation paths
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  system performance
                </li>
              </ul>
              <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
                This data is used to improve website structure, usability, and performance.
              </p>
              <p class="text-xs font-semibold px-2 py-1 rounded inline-block" style="background-color: #1E293B; color: #94A3B8;">Only used where consent is provided, where required by law.</p>
            </div>

            <!-- 3.3 -->
            <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
              <h3 class="text-sm font-bold mb-3" style="color: #F8FAFC;">3.3 Functionality Cookies</h3>
              <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
                These cookies enable the website to remember user preferences and selections, including:
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  regional settings
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  form inputs
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  interface preferences
                </li>
              </ul>
              <p class="text-sm leading-relaxed" style="color: #64748B;">
                They enhance user experience but are not essential to basic operation.
              </p>
            </div>

            <!-- 3.4 -->
            <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
              <h3 class="text-sm font-bold mb-3" style="color: #F8FAFC;">3.4 Marketing and Tracking Cookies</h3>
              <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
                These cookies may be used to:
              </p>
              <ul class="space-y-2 mb-4">
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  measure effectiveness of marketing activity
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  understand user engagement across platforms
                </li>
                <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  support future advertising and remarketing
                </li>
              </ul>
              <p class="text-xs font-semibold px-2 py-1 rounded inline-block" style="background-color: #1E293B; color: #94A3B8;">May be set by third-party providers. Only used where consent is provided.</p>
            </div>

          </div>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 4 -->
        <div id="third-party" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">4</span>
            Third-Party Technologies
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            We may use third-party providers to support website functionality, analytics, and performance monitoring.
          </p>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            These providers may set cookies or similar technologies. Examples include analytics tools, CRM systems, and performance tracking platforms.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Each third party operates under its own privacy and cookie policies. Users are encouraged to review these policies where relevant.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 5 -->
        <div id="purpose" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">5</span>
            Purpose of Cookie Use
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            Cookies are used to:
          </p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              maintain website functionality and security
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              ensure stable and consistent performance
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              analyse usage and improve user experience
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              support internal operational processes
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Cookies are not used to access personal information beyond what is outlined in our <a href="/privacy" class="transition-colors hover:opacity-80" style="color: #93C5FD;">Privacy Policy</a>.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 6 -->
        <div id="legal-basis" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">6</span>
            Legal Basis for Processing
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            The use of cookies is based on the following:
          </p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              Strictly necessary cookies are used based on legitimate interest to operate the website
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              All other cookies are used based on user consent where required by applicable law
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Users in jurisdictions such as the United Kingdom will be presented with a cookie consent mechanism before non-essential cookies are placed.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 7 -->
        <div id="managing" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">7</span>
            Managing Cookies
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            Users can control cookie usage through:
          </p>
          <ul class="space-y-2 mb-5">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              the cookie consent banner presented on the website
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              browser settings which allow blocking or deleting cookies
            </li>
          </ul>
          <p class="text-sm font-semibold mb-3" style="color: #94A3B8;">Most browsers allow users to:</p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              refuse cookies
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              delete stored cookies
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              manage site-specific permissions
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Disabling certain cookies may affect the functionality and performance of the website.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 8 -->
        <div id="retention" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">8</span>
            Retention of Cookies
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            Cookies are retained only for as long as necessary for their intended purpose.
          </p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              Session cookies are removed when the browser is closed
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              Persistent cookies remain until expiry or deletion
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Retention periods are proportionate to the purpose of the cookie.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 9 -->
        <div id="data-protection" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">9</span>
            Data Protection
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            Any personal data collected through cookies is handled in accordance with our <a href="/privacy" class="transition-colors hover:opacity-80" style="color: #93C5FD;">Privacy Policy</a>.
          </p>
          <p class="text-sm font-semibold mb-3" style="color: #94A3B8;">We apply appropriate technical and organisational measures to ensure:</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              data security
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              restricted access
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              compliance with applicable data protection laws
            </li>
          </ul>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 10 -->
        <div id="updates" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">10</span>
            Updates to This Policy
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            This Cookies Policy may be updated to reflect changes in:
          </p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              legal or regulatory requirements
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              website functionality
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              use of technologies
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            The most current version will always be available on this page.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 11 - Contact -->
        <div id="contact" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-6 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">11</span>
            Contact
          </h2>
          <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <p class="text-sm leading-relaxed mb-5" style="color: #64748B;">
              For any questions regarding this Cookies Policy or use of cookies, contact:
            </p>
