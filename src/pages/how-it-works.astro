---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="How It Works | Ambit Accounting & Bookkeeping" description="From discovery to delivery, Ambit makes outsourcing accounting and bookkeeping easy, accurate, and stress-free. See our simple 5-step process.">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[80vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=1800&q=80"
        alt="How it works"
        class="w-full h-full object-cover"
        style="opacity: 0.1;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 50%, #1a4480 100%); opacity: 0.93;"></div>
    </div>

    <div class="absolute top-24 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.14;"></div>
    <div class="absolute bottom-16 left-12 w-64 h-64 rounded-full blur-3xl" style="background: #3B82F6; opacity: 0.07;"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12 py-32 text-center">

      <div
        x-show="visible"
        x-transition:enter="transition duration-700"
        x-transition:enter-start="opacity-0 -translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-8"
        style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
      >
        <svg class="w-3.5 h-3.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Our Approach

      </div>

      <h1
        x-show="visible"
        x-transition:enter="transition duration-700 delay-100"
        x-transition:enter-start="opacity-0 translate-y-6"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-4xl lg:text-6xl xl:text-7xl font-black leading-none mb-8 text-white"
        style="letter-spacing: -0.03em;"
      >
       How Work Is Structured
      </h1>

      <p
        x-show="visible"
        x-transition:enter="transition duration-700 delay-200"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-xl leading-relaxed mb-10 max-w-2xl mx-auto"
        style="color: #94A3B8;"
      >
        A defined approach to understanding requirements, aligning workflows, and ensuring delivery remains consistent across teams, systems, and jurisdictions.
      </p>

      <div
        x-show="visible"
        x-transition:enter="transition duration-700 delay-300"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="flex flex-wrap justify-center gap-4 mb-16"
      >
        <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
          Book Free Consultation
        </a>
        <a href="#process" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
          View Process
        </a>
      </div>

      <!-- Step pills -->
      <div
        x-show="visible"
        x-transition:enter="transition duration-700 delay-400"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        class="flex flex-wrap justify-center gap-3"
      >
        {['01 Understanding', '02 Structuring', '03 Onboarding', '04 Delivery & Review', '05 Continuity'].map(label => (
          <span class="text-xs font-semibold px-4 py-2 rounded-full" style="background-color: #1E293B; color: #64748B; border: 1px solid #334155;">{label}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 28s linear infinite; width: max-content;">
      {[
        '✔ Discovery Call', '✔ Dedicated Staff', '✔ Seamless Onboarding', '✔ Accurate Execution', '✔ Ongoing Support',
        '✔ 12+ Years Experience', '✔ 280+ Clients Helped', '✔ 99.8% Accuracy Rate', '✔ 60% Cost Savings',
        '✔ Discovery Call', '✔ Dedicated Staff', '✔ Seamless Onboarding', '✔ Accurate Execution', '✔ Ongoing Support',
        '✔ 12+ Years Experience', '✔ 280+ Clients Helped', '✔ 99.8% Accuracy Rate', '✔ 60% Cost Savings',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== PROCESS OVERVIEW ===== -->
  <section class="py-20 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">At a Glance</div>
        <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">A Structured Approach to Deliverys</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">Work is not treated as isolated tasks.</p>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;"> Each engagement is designed to integrate into existing systems, maintain consistency across reporting cycles, and hold under scale.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {[
          { step: '01', label: 'Discovery Call', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
          { step: '02', label: 'Hire Staff', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
          { step: '03', label: 'Onboarding', icon: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12' },
          { step: '04', label: 'Execution', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
          { step: '05', label: 'Support', icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z' },
        ].map(({ step, label, icon }) => (
          <div class="flex flex-col items-center text-center p-6 rounded-2xl border hover:shadow-md hover:border-blue-100 transition-all" style="background-color: #FAFAFA; border-color: #E2E8F0;">
            <div class="w-12 h-12 rounded-full flex items-center justify-center text-sm font-black text-white mb-4" style="background-color: #1a4480;">
              {step}
            </div>
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3" style="background-color: #EFF6FF;">
              <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <div class="text-sm font-bold" style="color: #0F172A;">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== STEP-BY-STEP DETAIL ===== -->
  <div id="process">

    <!-- Step 01 – Discovery -->
    <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-3 mb-6">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-lg font-black text-white flex-shrink-0" style="background-color: #1a4480;">01</div>
              <div class="text-xs font-bold uppercase tracking-widest" style="color: #64748B;">First Step</div>
            </div>
            <h2 class="text-4xl font-black text-white mb-6" style="letter-spacing: -0.02em;">Understanding the Requirement</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #94A3B8;">
             Work begins with a detailed review of current systems, workflows, and reporting structures.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #1E293B; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #3B82F6;">Impact</div>
                <div class="text-sm" style="color: #94A3B8;">Clarity on gaps, dependencies, and areas where structure is required.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Review of existing processes and workflows', 'Identification of inconsistencies and bottlenecks', 'Alignment with business structure and reporting needs', 'Definition of scope across functions'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #1E293B;">
                    <svg class="w-3 h-3" style="color: #3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #94A3B8;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=800&q=80" alt="Discovery Call" class="w-full aspect-[4/3] object-cover rounded-2xl" style="opacity: 0.85;" />
            <div class="absolute -bottom-5 -right-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="text-2xl font-black mb-1" style="color: #3B82F6;">Free</div>
              <div class="text-xs" style="color: #64748B;">No obligation call</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 02 – Hire Staff -->
    <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="relative order-2 lg:order-1">
            <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=800&q=80" alt="Hire dedicated staff" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl" />
            <div class="absolute -bottom-5 -left-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #0F172A;">
              <div class="text-2xl font-black mb-1" style="color: #3B82F6;">Certified</div>
              <div class="text-xs" style="color: #64748B;">US accounting professionals</div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <div class="inline-flex items-center gap-3 mb-6">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-lg font-black text-white flex-shrink-0" style="background-color: #1a4480;">02</div>
              <div class="text-xs font-bold uppercase tracking-widest" style="color: #1a4480;">Second Step</div>
            </div>
            <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">Defining the Structure</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
            Processes, workflows, and delivery models are aligned to ensure consistency across teams and systems.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #EFF6FF; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #1a4480;">Impact</div>
                <div class="text-sm" style="color: #374151;">A clear structure that supports reliable execution without dependency on individuals.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Workflow design aligned to existing systems', 'Role definition and responsibility mapping', 'Reporting structure alignment', 'Integration across finance and operational processes'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                    <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #374151;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 03 – Onboarding -->
    <section class="py-24 px-6 lg:px-12 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-3 mb-6">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-lg font-black text-white flex-shrink-0" style="background-color: #1a4480;">03</div>
              <div class="text-xs font-bold uppercase tracking-widest" style="color: #1a4480;">Third Step</div>
            </div>
            <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">Onboarding and Alignment</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
          Systems, access, and workflows are established in a controlled and structured manner.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #EFF6FF; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #1a4480;">Impact</div>
                <div class="text-sm" style="color: #374151;">Smooth transition without disruption to ongoing operations.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['System access and environment setup', 'Process documentation and alignment', 'Data transition and validation', 'Team integration across workflows'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                    <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #374151;">{item}</span>
                </li>
              ))}
            </ul>

            <!-- Software logos -->
            <div class="mt-8 pt-6 border-t border-gray-100">
              <div class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: #64748B;">Supported Platforms</div>
              <div class="flex flex-wrap gap-2">
                {['QuickBooks', 'Xero', 'NetSuite', 'FreshBooks', 'Wave', 'Sage'].map(sw => (
                  <span class="text-xs font-semibold px-3 py-1.5 rounded-lg border" style="background-color: #F8FAFC; border-color: #E2E8F0; color: #374151;">{sw}</span>
                ))}
              </div>
            </div>
          </div>
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80" alt="Onboarding setup" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl" />
            <div class="absolute -bottom-5 -right-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #0F172A;">
              <div class="text-2xl font-black mb-1" style="color: #22C55E;">1 Week</div>
              <div class="text-xs" style="color: #64748B;">Average go-live time</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 04 – Execution -->
    <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="relative order-2 lg:order-1">
            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80" alt="Execution and reporting" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl" />
            <div class="absolute -bottom-5 -left-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #0F172A;">
              <div class="text-2xl font-black mb-1" style="color: #3B82F6;">99.8%</div>
              <div class="text-xs" style="color: #64748B;">Accuracy rate</div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <div class="inline-flex items-center gap-3 mb-6">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-lg font-black text-white flex-shrink-0" style="background-color: #1a4480;">04</div>
              <div class="text-xs font-bold uppercase tracking-widest" style="color: #1a4480;">Fourth Step</div>
            </div>
            <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">Execution & Review</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
              Work is delivered with defined review layers to ensure consistency, accuracy, and compliance.

            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #EFF6FF; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #1a4480;">Impact</div>
                <div class="text-sm" style="color: #374151;">Reliable outputs that remain consistent across periods and teams.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Ongoing execution across defined workflows', 'Multi-level review and validation', 'Reporting aligned to agreed structures', 'Consistency maintained across cycles'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                    <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #374151;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Step 05 – Continuous Support -->
    <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-3 mb-6">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-lg font-black text-white flex-shrink-0" style="background-color: #1a4480;">05</div>
              <div class="text-xs font-bold uppercase tracking-widest" style="color: #64748B;">Final Step</div>
            </div>
            <h2 class="text-4xl font-black text-white mb-6" style="letter-spacing: -0.02em;">Continuous Support</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #94A3B8;">
             Delivery is maintained with continuity, adapting to changes in volume, structure, and regulatory requirements.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #1E293B; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #3B82F6;">Impact</div>
                <div class="text-sm" style="color: #94A3B8;">Long-term stability without operational disruption.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Ongoing delivery and monitoring', 'Adaptation to business changes', 'Support across evolving requirements', 'Continuity across teams and reporting periods'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #1E293B;">
                    <svg class="w-3 h-3" style="color: #3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #94A3B8;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80" alt="Continuous support" class="w-full aspect-[4/3] object-cover rounded-2xl" style="opacity: 0.85;" />
