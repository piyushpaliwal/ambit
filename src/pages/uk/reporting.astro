---
import UKLayout from '../../layouts/UKLayout.astro';
---

<UKLayout title="Monthly Financial Management | Ambit UK" description="Accurate monthly financial reports, cash flow analysis, and actionable insights for UK businesses. HMRC-compliant reporting from dedicated finance experts.">

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[88vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1600&q=80"
        alt="Financial dashboard"
        class="w-full h-full object-cover"
        style="opacity: 0.15;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 50%, #1a4480 100%); opacity: 0.85;"></div>
    </div>

    <!-- Red accent blur (UK identity) -->
    <div class="absolute top-20 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #DC2626; opacity: 0.06;"></div>
    <div class="absolute bottom-20 left-20 w-64 h-64 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.15;"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: Text -->
        <div>
          <div
            x-show="visible"
            x-transition:enter="transition duration-700"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6"
            style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
          >
            <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-4 h-3 object-cover rounded-sm" />
            UK Monthly Financial Management
          </div>

          <h1
            x-show="visible"
            x-transition:enter="transition duration-700 delay-100"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-4xl lg:text-5xl xl:text-6xl font-black leading-none mb-6"
            style="color: #F8FAFC; letter-spacing: -0.03em;"
          >
            Take Control of<br />
            <span style="color: #3B82F6;">Your Business</span><br />
            Finances Every Month
          </h1>

          <p
            x-show="visible"
            x-transition:enter="transition duration-700 delay-200"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-lg leading-relaxed mb-10 max-w-xl"
            style="color: #94A3B8;"
          >
            Stay on top of your cash flow, profits, and overall financial health with accurate, timely, and actionable monthly reports. Make smarter decisions without the stress.
          </p>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-4"
          >
            <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
              Speak to a Financial Expert
            </a>
            <a href="#services" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
              Explore Services
            </a>
          </div>
        </div>

        <!-- Right: Floating cards -->
        <div
          x-show="visible"
          x-transition:enter="transition duration-700 delay-400"
          x-transition:enter-start="opacity-0 translate-x-8"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <div class="relative w-full aspect-square max-w-sm mx-auto">
            <img
              src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80"
              alt="Financial reports"
              class="w-full h-full object-cover rounded-2xl"
              style="opacity: 0.7;"
            />

            <!-- Floating badge 1 -->
            <div class="absolute -top-4 -left-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #1a4480;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">Real-Time Insights</div>
                  <div class="text-xs" style="color: #64748B;">Monthly Reports</div>
                </div>
              </div>
            </div>

            <!-- Floating badge 2 -->
            <div class="absolute -bottom-4 -right-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="flex items-center gap-1">
                  <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
                  <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
                  <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-5 h-3.5 object-cover rounded-sm" />
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">Multi-Country</div>
                  <div class="text-xs" style="color: #64748B;">UK · US · Dubai</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 28s linear infinite; width: max-content;">
      {[
        '✔ Accurate Monthly Reports',
        '✔ Real-Time Financial Insights',
        '✔ Multi-Country Expertise (UK | US | Dubai)',
        '✔ Dedicated Finance & Accounting Experts',
        '✔ HMRC-Compliant Reporting',
        '✔ Accurate Monthly Reports',
        '✔ Real-Time Financial Insights',
        '✔ Multi-Country Expertise (UK | US | Dubai)',
        '✔ Dedicated Finance & Accounting Experts',
        '✔ HMRC-Compliant Reporting',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== WHY THIS MATTERS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image side -->
        <div class="relative">
          <img
            src="https://images.unsplash.com/photo-1504868584819-f8e8b4b6d7e3?w=800&q=80"
            alt="Financial analysis"
            class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl"
          />
          <!-- Metric badges -->
          <div class="absolute top-6 -right-6 px-4 py-3 rounded-xl shadow-xl" style="background-color: #0F172A; border: 1px solid #1E293B;">
            <div class="text-2xl font-black" style="color: #3B82F6;">100%</div>
            <div class="text-xs" style="color: #64748B;">Reporting Accuracy</div>
          </div>
          <div class="absolute bottom-6 -left-6 px-4 py-3 rounded-xl shadow-xl" style="background-color: #0F172A; border: 1px solid #1E293B;">
            <div class="text-2xl font-black" style="color: #22C55E;">£0</div>
            <div class="text-xs" style="color: #64748B;">Penalty Record</div>
          </div>
          <div class="absolute bottom-24 -right-6 px-4 py-3 rounded-xl shadow-xl" style="background-color: #0F172A; border: 1px solid #1E293B;">
            <div class="text-2xl font-black" style="color: #F59E0B;">24h</div>
            <div class="text-xs" style="color: #64748B;">Turnaround</div>
          </div>
        </div>

        <!-- Text side -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Why It Matters</div>
          <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">
            Numbers Tell the Truth —<br />Are You Listening?
          </h2>
          <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
            Without clear monthly financial insights, businesses risk poor decision-making, cash flow problems, and missed growth opportunities.
          </p>
          <p class="text-lg leading-relaxed mb-10" style="color: #64748B;">
            With Ambit's Monthly Financial Management, you get <strong style="color: #0F172A;">clarity, control, and foresight</strong> — every single month.
          </p>

          <div class="grid grid-cols-3 gap-6">
            {[
              { val: '100%', label: 'Reporting Accuracy' },
              { val: '£0', label: 'Penalty Record' },
              { val: '3+', label: 'Countries Served' },
            ].map(({ val, label }) => (
              <div class="text-center p-4 rounded-xl" style="background-color: #F8FAFC;">
                <div class="text-2xl font-black mb-1" style="color: #1a4480;">{val}</div>
                <div class="text-xs" style="color: #64748B;">{label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">What We Offer</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Our Monthly Financial Management Services</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
            title: 'Monthly Reporting',
            items: ['Profit & Loss statements', 'Balance sheets', 'Cash flow reports'],
          },
          {
            icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
            title: 'Financial Analysis',
            items: ['Trend analysis & insights', 'Expense & revenue tracking', 'KPI monitoring'],
          },
          {
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            title: 'Advisory & Planning',
            items: ['Actionable recommendations', 'Budgeting & forecasting', 'Strategy alignment with business goals'],
          },
        ].map(({ icon, title, items }) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: #EFF6FF;">
              <svg class="w-6 h-6" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-4" style="color: #0F172A;">{title}</h3>
            <ul class="space-y-2">
              {items.map(item => (
                <li class="flex items-start gap-2 text-sm" style="color: #64748B;">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Ideal For</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Businesses That Want Control</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {[
          { icon: '📈', label: 'Growing SMEs' },
          { icon: '🚀', label: 'Startups & Founders' },
          { icon: '🛒', label: 'E-Commerce Brands' },
          { icon: '💼', label: 'Investor-Backed Companies' },
          { icon: '🌍', label: 'Multinational Businesses' },
        ].map(({ icon, label }) => (
          <div class="flex flex-col items-center text-center p-6 rounded-2xl border border-gray-100 hover:border-blue-100 hover:shadow-sm transition-all" style="background-color: #F8FAFC;">
            <span class="text-3xl mb-3">{icon}</span>
            <span class="text-sm font-semibold" style="color: #0F172A;">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Common Challenges</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Facing Financial Uncertainty?</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Problems -->
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Ambit</h3>
          {[
            'No clear view of monthly profits',
            'Cash flow surprises that derail plans',
            'Missed opportunities for growth',
            'Financial reports that are confusing',
            'Reactive decisions instead of proactive strategy',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border: 1px solid #DC2626; border-left-width: 3px;">
              <span class="text-lg flex-shrink-0">❌</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>

        <!-- Solutions -->
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">With Ambit</h3>
          {[
            'Crystal-clear monthly P&L and balance sheets',
            'Proactive cash flow planning and alerts',
            'Trend analysis revealing new growth levers',
            'Plain-English reports your whole team understands',
            'Monthly advisory calls to drive strategy forward',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border: 1px solid #22C55E; border-left-width: 3px;">
              <span class="text-lg flex-shrink-0">✅</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Our Process</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">4-Step Monthly Financial Management Process</h2>
      </div>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-8 top-0 bottom-0 w-px" style="background-color: #E2E8F0;"></div>

        <div class="space-y-12">
          {[
            { step: '01', title: 'Data Collection', desc: 'Gather all transactions, invoices, bank statements, and financial records for the month.' },
            { step: '02', title: 'Report Generation', desc: 'Produce monthly P&L, balance sheet, and cash flow statements to HMRC/IRS standards.' },
            { step: '03', title: 'Analysis & Insights', desc: 'Highlight trends, risks, and opportunities — with KPI tracking and variance analysis.' },
            { step: '04', title: 'Review & Advisory', desc: 'Share recommendations to improve performance, refine budgets, and align with growth goals.' },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-8 items-start">
              <div class="relative flex-shrink-0">
                <div class="w-16 h-16 rounded-full flex items-center justify-center text-sm font-black border-4 border-white shadow" style="background-color: #1a4480; color: white;">
                  {step}
                </div>
              </div>
              <div class="pt-3">
                <h3 class="text-xl font-bold mb-2" style="color: #0F172A;">{title}</h3>
                <p class="text-base leading-relaxed" style="color: #64748B;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + COUNTRY EXPERTISE ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16">

        <!-- Results / What You Gain -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Impact</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">What You Gain</h2>
          <div class="space-y-4">
            {[
              'Complete clarity on your finances every month',
              'Accurate and HMRC/IRS-compliant reporting',
              'Improved cash flow management and forecasting',
              'Actionable insights for smarter growth decisions',
              'A dedicated expert team — your CFO on demand',
            ].map(item => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #DCFCE7;">
                  <svg class="w-3.5 h-3.5" style="color: #16A34A;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-base" style="color: #374151;">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Country Expertise -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Locations</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">Tailored for Your Location</h2>
          <div class="space-y-4">
            {[
              {
                flag: 'gb', country: 'United Kingdom',
                details: 'HMRC-compliant monthly reporting, VAT-ready analysis, UK GAAP standards',
              },
              {
                flag: 'us', country: 'United States',
                details: 'Federal & state tax-ready financial reports, US GAAP, multi-state compliance',
              },
              {
                flag: 'ae', country: 'Dubai / UAE',
                details: 'IFRS & VAT-compliant monthly statements, FTA-ready reporting',
              },
            ].map(({ flag, country, details }) => (
              <div class="flex items-start gap-4 p-5 rounded-xl bg-white border border-gray-100 shadow-sm">
                <img src={`https://flagcdn.com/w40/${flag}.png`} alt={country} class="w-10 h-7 object-cover rounded flex-shrink-0 mt-0.5" />
                <div>
                  <div class="text-sm font-bold mb-1" style="color: #0F172A;">{country}</div>
                  <div class="text-sm leading-relaxed" style="color: #64748B;">{details}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Testimonials</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Trusted by Businesses Across Borders</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            quote: "Ambit's monthly reports give us total visibility into our finances — we can make decisions confidently every month.",
            name: 'Sarah T.',
            role: 'CEO, London E-Commerce Brand',
          },
          {
            quote: "Their team provides clear insights, not just numbers. It's like having a CFO on demand without the CFO price tag.",
            name: 'James R.',
            role: 'Founder, Manchester SME',
          },
        ].map(({ quote, name, role }) => (
          <div class="p-8 rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
            <!-- Stars -->
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4" style="color: #F59E0B;" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-base leading-relaxed mb-6" style="color: #94A3B8;">"{quote}"</p>
            <div>
              <div class="text-sm font-bold text-white">{name}</div>
              <div class="text-xs" style="color: #64748B;">{role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="py-24 px-6 lg:px-12" style="background: linear-gradient(135deg, #0F172A 0%, #1a4480 100%);">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #94A3B8;">Get Started</div>
      <h2 class="text-4xl lg:text-5xl font-black text-white mb-6" style="letter-spacing: -0.02em;">
        Take Control of Your Business Every Month
      </h2>
