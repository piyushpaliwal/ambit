---
import UKLayout from '../../layouts/UKLayout.astro';
---

<UKLayout
  title="Payroll & CIS – UK"
  description="Accurate, on-time, HMRC-compliant payroll and CIS management for UK businesses. Ambit makes UK payroll stress-free and error-free."
  countryPhone="+44 (0) 20 1234 5678"
  countryEmail="uk@ambit.co.uk"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 580px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] rounded-full opacity-[0.04] blur-3xl" style="background: #DC2626;"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 flex items-center" style="min-height: 580px;">
      <div class="grid lg:grid-cols-2 gap-14 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United Kingdom · Payroll & CIS</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            Payroll &amp; CIS Done Right<br/>
            <span style="color: #93B4D4;">— Every Time</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 460px;">
            Ensure your employees are paid accurately, on time, and fully HMRC-compliant. From payroll to CIS deductions, Ambit makes UK payroll stress-free and error-free.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              Speak to Payroll Expert
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              See How It Works
            </a>
          </div>

          <div class="flex flex-wrap gap-5 pt-8" style="border-top: 1px solid #1E293B;">
            {['On-Time Processing', 'HMRC & CIS Compliant', 'Zero Errors', 'RTI Submissions'].map(t => (
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-xs font-medium" style="color: #64748B;">{t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right -->
        <div class="relative hidden lg:block">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="height: 440px;">
            <img
              src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=900&auto=format&fit=crop&q=80"
              alt="UK payroll management team"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,23,42,0.5) 0%, transparent 60%);"></div>
          </div>
          <div class="absolute -bottom-6 -left-8 rounded-xl px-5 py-4 shadow-xl" style="background: #1a4480; border: 1px solid rgba(255,255,255,0.1);">
            <div class="text-2xl font-bold text-white leading-none mb-0.5">99.9%</div>
            <div class="text-xs font-medium" style="color: #93B4D4;">Payroll Accuracy</div>
          </div>
          <div class="absolute -top-4 -right-4 rounded-xl px-4 py-3 shadow-xl" style="background: #1E293B; border: 1px solid #334155;">
            <div class="text-xl font-bold text-white leading-none mb-0.5">RTI + CIS</div>
            <div class="text-xs" style="color: #64748B;">HMRC Compliant</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex items-center gap-0" style="animation: marquee 28s linear infinite; width: max-content;">
      {[
        'On-Time Payroll Processing',
        'HMRC & CIS Compliant',
        'Accurate Calculations',
        'Dedicated UK Payroll Experts',
        'RTI Submissions',
        'Payslip Generation',
        'CIS Contractor Management',
        'Zero Penalties Guaranteed',
      ].concat([
        'On-Time Payroll Processing',
        'HMRC & CIS Compliant',
        'Accurate Calculations',
        'Dedicated UK Payroll Experts',
        'RTI Submissions',
        'Payslip Generation',
        'CIS Contractor Management',
        'Zero Penalties Guaranteed',
      ]).map(item => (
        <div class="flex items-center gap-3 px-6 whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-white opacity-60 flex-shrink-0"></span>
          <span class="text-xs font-semibold tracking-[0.12em] uppercase text-white opacity-90">{item}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="relative rounded-2xl overflow-hidden shadow-xl order-2 lg:order-1" style="height: 480px;">
          <img
            src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=900&auto=format&fit=crop&q=80"
            alt="Payroll accuracy UK"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.55) 0%, transparent 55%);"></div>
          <div class="absolute bottom-6 left-6 right-6 grid grid-cols-2 gap-3">
            {[
              { num: '99.9%', label: 'Payroll Accuracy' },
              { num: '£0', label: 'Penalty Record' },
              { num: '100%', label: 'On-Time Rate' },
              { num: '24h', label: 'Processing Time' },
            ].map(m => (
              <div class="rounded-lg px-4 py-3" style="background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.1);">
                <div class="text-xl font-bold text-white leading-none mb-0.5">{m.num}</div>
                <div class="text-xs" style="color: #94A3B8;">{m.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Payroll Mistakes Can Cost You More Than You Think
          </h2>
          <div class="w-10 h-px mb-6" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed mb-8" style="color: #475569;">
            Late payments, incorrect deductions, or CIS mistakes can create financial risk and unhappy employees. Ambit handles your payroll accurately, timely, and compliant — so you can focus on growing your business.
          </p>

          <div class="space-y-4">
            {[
              { title: 'Every Payslip. Every Deadline.', desc: 'RTI submissions to HMRC on time, every pay cycle — no delays, no errors, no penalties.' },
              { title: 'CIS That\'s Always Correct', desc: 'Accurate contractor deductions, monthly CIS filings, and full compliance with HMRC construction rules.' },
              { title: 'Happy Employees & Contractors', desc: 'Clear, accurate payslips and on-time payments build trust and reduce HR headaches significantly.' },
            ].map(item => (
              <div class="flex gap-4 p-4 rounded-xl" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-1" style="color: #0F172A;">{item.title}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Our Payroll & CIS Services</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {[
          {
            title: 'Payroll Processing',
            subtitle: 'RTI-compliant salary management',
            img: 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=700&auto=format&fit=crop&q=75',
            points: ['RTI-compliant salary management', 'Payslip generation for employees', 'HMRC reporting & submissions'],
            icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z',
          },
          {
            title: 'CIS Management',
            subtitle: 'Accurate contractor deductions',
            img: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=700&auto=format&fit=crop&q=75',
            points: ['Accurate contractor deductions', 'Monthly CIS filings', 'Compliance with HMRC contractor rules'],
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
          },
          {
            title: 'Advisory & Support',
            subtitle: 'Guidance that actually helps you',
            img: 'https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75',
            points: ['Payroll queries & troubleshooting', 'HMRC correspondence support', 'Payroll audits & optimisation'],
            icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
          },
        ].map(svc => (
          <div class="rounded-2xl overflow-hidden shadow-sm" style="background: white; border: 1px solid #E2E8F0;">
            <div class="relative h-44 overflow-hidden">
              <img src={svc.img} alt={svc.title} class="w-full h-full object-cover" />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,23,42,0.15), rgba(15,23,42,0.75));"></div>
              <div class="absolute bottom-4 left-4 right-4">
                <div class="flex items-center gap-2.5 mb-1">
                  <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0" style="background: #1a4480;">
                    <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={svc.icon}/></svg>
                  </div>
                  <h3 class="text-white font-bold text-sm">{svc.title}</h3>
                </div>
                <p class="text-xs" style="color: #93B4D4;">{svc.subtitle}</p>
              </div>
            </div>
            <div class="p-5">
              <ul class="space-y-2.5">
                {svc.points.map(p => (
                  <li class="flex items-center gap-2.5">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-sm" style="color: #374151;">{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Ideal for UK Businesses of All Sizes
          </h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-3">
            {[
              { label: 'SMEs & Growing Companies', desc: 'Scale your workforce without payroll becoming a bottleneck or compliance risk.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
              { label: 'Construction Businesses (CIS)', desc: 'Full CIS compliance for contractors and subcontractors — deductions, filings, and HMRC correspondence handled.', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
              { label: 'Startups & Agencies', desc: 'Get payroll right from your very first hire — no costly mistakes or manual errors.', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
              { label: 'International Businesses Operating in UK', desc: 'Navigate UK PAYE, NI contributions, and employment law with expert guidance.', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064' },
            ].map(item => (
              <div class="flex items-start gap-4 p-4 rounded-xl transition-all hover:shadow-md" style="border: 1px solid #E2E8F0;">
                <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-0.5" style="color: #0F172A;">{item.label}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative rounded-2xl overflow-hidden shadow-xl hidden lg:block" style="height: 520px;">
          <img
            src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=900&auto=format&fit=crop&q=80"
            alt="UK payroll team"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.65) 0%, transparent 55%);"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="text-white font-bold text-xl mb-2">Serving UK Businesses</div>
            <div class="text-sm" style="color: #93B4D4;">From startups to construction firms nationwide</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-20 lg:py-28" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #93B4D4;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white" style="letter-spacing: -0.02em;">Are Payroll Errors Costing You Time &amp; Money?</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <div class="rounded-2xl p-8" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(239,68,68,0.15);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #EF4444;">Without Ambit</span>
          </div>
          <div class="space-y-4">
            {[
              'Incorrect deductions or late salary payments',
              'Confusing and error-prone CIS rules for contractors',
              'Employee dissatisfaction from payslip inaccuracies',
              'Risk of HMRC penalties and compliance investigations',
              'Hours wasted manually managing payroll each month',
            ].map(p => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
                <span class="text-sm leading-relaxed" style="color: #94A3B8;">{p}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl p-8" style="background: rgba(26,68,128,0.15); border: 1px solid rgba(26,68,128,0.35);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(26,68,128,0.3);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #93B4D4;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #93B4D4;">With Ambit</span>
          </div>
          <div class="space-y-4">
            {[
              'Accurate salaries and deductions processed on time every cycle',
              'Full CIS compliance — contractor deductions handled precisely',
              'Clear, accurate payslips that employees and contractors trust',
              'HMRC-compliant RTI submissions with zero penalty history',
              'Completely managed payroll — zero time burden on your team',
            ].map(s => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm leading-relaxed" style="color: #CBD5E1;">{s}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-16">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">Our Process</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">4-Step Payroll & CIS Process</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="hidden lg:grid grid-cols-4 gap-6 relative">
        <div class="absolute top-[52px] left-[12.5%] right-[12.5%] h-px" style="background: linear-gradient(to right, #1a4480, #1e5ab5, #1a4480);"></div>
        {[
          { num: '01', title: 'Setup Employee & Contractor Data', desc: 'Gather employee contracts, contractor agreements, and all relevant HMRC registration details.' },
          { num: '02', title: 'Process Payroll & CIS Deductions', desc: 'Accurate salary calculations, PAYE, NI contributions, and CIS contractor deductions every cycle.' },
          { num: '03', title: 'HMRC Submission', desc: 'Real-time RTI submissions for employees and monthly CIS returns filed accurately and on time.' },
          { num: '04', title: 'Continuous Support', desc: 'Ongoing payroll management, HMRC correspondence handling, and proactive advisory.' },
        ].map((step, i) => (
          <div class="flex flex-col items-center text-center">
            <div class="relative z-10 w-[104px] h-[104px] rounded-full flex flex-col items-center justify-center mb-6 shadow-lg" style="background: white; border: 2px solid #1a4480;">
              <span class="text-xs font-bold tracking-[0.15em] uppercase mb-0.5" style="color: #94A3B8;">{step.num} / 04</span>
              <span class="text-lg font-bold" style="color: #0F172A;">{i + 1}</span>
            </div>
            <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{step.title}</h3>
            <div class="w-6 h-px mb-3 mx-auto" style="background: #1a4480;"></div>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="lg:hidden space-y-6">
        {[
