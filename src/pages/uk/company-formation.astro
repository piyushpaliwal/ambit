---
import UKLayout from '../../layouts/UKLayout.astro';
---

<UKLayout
  title="Company Formation – UK"
  description="From registration to compliance, Ambit helps entrepreneurs and businesses set up their UK company correctly from day one. Save time, avoid mistakes, and start growing confidently."
  countryPhone="+44 (0) 20 1234 5678"
  countryEmail="uk@ambit.co.uk"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 580px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] rounded-full opacity-[0.04] blur-3xl" style="background: #DC2626;"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 flex items-center" style="min-height: 580px;">
      <div class="grid lg:grid-cols-2 gap-14 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United Kingdom · Company Formation</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            Launch Your Company<br/>the Right Way —<br/>
            <span style="color: #93B4D4;">Hassle-Free</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 460px;">
            From registration to compliance, Ambit helps entrepreneurs and businesses set up their company correctly from day one. Save time, avoid mistakes, and start growing confidently.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              Book Free Consultation
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              See How It Works
            </a>
          </div>

          <div class="flex flex-wrap gap-5 pt-8" style="border-top: 1px solid #1E293B;">
            {['Quick Registration', 'UK · US · UAE', 'Legal Compliance', 'Dedicated Experts'].map(t => (
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-xs font-medium" style="color: #64748B;">{t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right -->
        <div class="relative hidden lg:block">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="height: 440px;">
            <img
              src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=900&auto=format&fit=crop&q=80"
              alt="Company formation consultation UK"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,23,42,0.5) 0%, transparent 60%);"></div>
          </div>
          <div class="absolute -bottom-6 -left-8 rounded-xl px-5 py-4 shadow-xl" style="background: #1a4480; border: 1px solid rgba(255,255,255,0.1);">
            <div class="text-2xl font-bold text-white leading-none mb-0.5">Days</div>
            <div class="text-xs font-medium" style="color: #93B4D4;">Not Months to Launch</div>
          </div>
          <div class="absolute -top-4 -right-4 rounded-xl px-4 py-3 shadow-xl" style="background: #1E293B; border: 1px solid #334155;">
            <div class="flex items-center gap-2">
              {['gb', 'us', 'ae'].map(flag => (
                <img src={`https://flagcdn.com/w20/${flag}.png`} alt={flag} class="w-5 h-3.5 object-cover rounded-sm" />
              ))}
            </div>
            <div class="text-xs mt-1.5" style="color: #64748B;">3 Countries</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex items-center gap-0" style="animation: marquee 28s linear infinite; width: max-content;">
      {[
        'Quick & Accurate Registration',
        'Multi-Country Expertise: UK · US · UAE',
        'Legal & Regulatory Compliance',
        'Dedicated Business Formation Experts',
        'Companies House Filings',
        'VAT Registration',
        'Bank Account Assistance',
        'Audit-Ready from Day One',
      ].concat([
        'Quick & Accurate Registration',
        'Multi-Country Expertise: UK · US · UAE',
        'Legal & Regulatory Compliance',
        'Dedicated Business Formation Experts',
        'Companies House Filings',
        'VAT Registration',
        'Bank Account Assistance',
        'Audit-Ready from Day One',
      ]).map(item => (
        <div class="flex items-center gap-3 px-6 whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-white opacity-60 flex-shrink-0"></span>
          <span class="text-xs font-semibold tracking-[0.12em] uppercase text-white opacity-90">{item}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="relative rounded-2xl overflow-hidden shadow-xl order-2 lg:order-1" style="height: 480px;">
          <img
            src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=900&auto=format&fit=crop&q=80"
            alt="Company formation documents"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.55) 0%, transparent 55%);"></div>
          <div class="absolute bottom-6 left-6 right-6 grid grid-cols-2 gap-3">
            {[
              { num: '£0', label: 'Hidden Fees' },
              { num: '100%', label: 'Compliance Rate' },
              { num: '3', label: 'Countries Covered' },
              { num: '24h', label: 'Avg. Response' },
            ].map(m => (
              <div class="rounded-lg px-4 py-3" style="background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.1);">
                <div class="text-xl font-bold text-white leading-none mb-0.5">{m.num}</div>
                <div class="text-xs" style="color: #94A3B8;">{m.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Starting a Business the Right Way Pays Off
          </h2>
          <div class="w-10 h-px mb-6" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed mb-8" style="color: #475569;">
            Incorrect registration, missing licences, or poor company structure can create headaches and extra costs down the line. Ambit ensures your company is legally compliant, properly structured, and ready to operate from day one.
          </p>

          <div class="space-y-4">
            {[
              { title: 'Right Structure from Day One', desc: 'We advise on the optimal company type — Ltd, LLP, or sole trader — based on your tax goals and growth plans.' },
              { title: 'Companies House & HMRC Handled', desc: 'All incorporation filings, VAT registration, and statutory documentation completed accurately and on time.' },
              { title: 'Compliance Built into the Foundation', desc: 'Licences, permits, and banking assistance set up properly so you can focus entirely on building.' },
            ].map(item => (
              <div class="flex gap-4 p-4 rounded-xl" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-1" style="color: #0F172A;">{item.title}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Our Company Formation Services</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {[
          {
            title: 'Company Registration',
            subtitle: 'Legal incorporation across UK, US & UAE',
            img: 'https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=700&auto=format&fit=crop&q=75',
            points: ['Legal incorporation in UK, US, or Dubai', 'Business name registration', 'Shareholder & director setup'],
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
          },
          {
            title: 'Compliance Setup',
            subtitle: 'All licences, filings & banking',
            img: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=700&auto=format&fit=crop&q=75',
            points: ['Licences and permits guidance', 'Statutory filings and documentation', 'Bank account setup assistance'],
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            title: 'Advisory & Planning',
            subtitle: 'Structure, tax & growth strategy',
            img: 'https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75',
            points: ['Business structure optimisation', 'Tax planning from the start', 'Tailored solutions for startups & SMEs'],
            icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
          },
        ].map(svc => (
          <div class="rounded-2xl overflow-hidden shadow-sm" style="background: white; border: 1px solid #E2E8F0;">
            <div class="relative h-44 overflow-hidden">
              <img src={svc.img} alt={svc.title} class="w-full h-full object-cover" />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,23,42,0.15), rgba(15,23,42,0.75));"></div>
              <div class="absolute bottom-4 left-4 right-4">
                <div class="flex items-center gap-2.5 mb-1">
                  <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0" style="background: #1a4480;">
                    <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={svc.icon}/></svg>
                  </div>
                  <h3 class="text-white font-bold text-sm">{svc.title}</h3>
                </div>
                <p class="text-xs" style="color: #93B4D4;">{svc.subtitle}</p>
              </div>
            </div>
            <div class="p-5">
              <ul class="space-y-2.5">
                {svc.points.map(p => (
                  <li class="flex items-center gap-2.5">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-sm" style="color: #374151;">{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Ideal for Entrepreneurs &amp; Growing Businesses
          </h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-3">
            {[
              { label: 'First-Time Entrepreneurs', desc: 'Get your company set up correctly from the very start — no costly errors to fix later.', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
              { label: 'Startups & Tech Companies', desc: 'Investor-ready structure, proper share allocations, and compliant documentation from day one.', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
              { label: 'International Businesses Expanding to UK', desc: 'Navigate Companies House, HMRC, and UK legal requirements seamlessly from abroad.', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064' },
              { label: 'SMEs Seeking Proper Structure', desc: 'Restructure, formalise, or expand your existing business with the right legal foundation.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
            ].map(item => (
              <div class="flex items-start gap-4 p-4 rounded-xl transition-all hover:shadow-md" style="border: 1px solid #E2E8F0;">
                <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-0.5" style="color: #0F172A;">{item.label}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative rounded-2xl overflow-hidden shadow-xl hidden lg:block" style="height: 520px;">
          <img
            src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=900&auto=format&fit=crop&q=80"
            alt="Entrepreneur launching UK business"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.65) 0%, transparent 55%);"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="text-white font-bold text-xl mb-2">Built for Founders</div>
            <div class="text-sm" style="color: #93B4D4;">From first ventures to global expansion</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-20 lg:py-28" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #93B4D4;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white" style="letter-spacing: -0.02em;">Avoid These Common Company Formation Pitfalls</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <div class="rounded-2xl p-8" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(239,68,68,0.15);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #EF4444;">Without Ambit</span>
          </div>
          <div class="space-y-4">
            {[
              'Incorrect registration documents causing delays or rejections',
              'Legal compliance gaps leading to fines and penalties',
              'Poor company structure affecting tax efficiency and growth',
              'Weeks of wasted time on confusing government processes',
              'Expensive corrections later when mistakes are discovered',
            ].map(p => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
                <span class="text-sm leading-relaxed" style="color: #94A3B8;">{p}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl p-8" style="background: rgba(26,68,128,0.15); border: 1px solid rgba(26,68,128,0.35);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(26,68,128,0.3);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #93B4D4;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #93B4D4;">With Ambit</span>
          </div>
          <div class="space-y-4">
            {[
              'Accurate company documents filed correctly first time',
              'Full legal and regulatory compliance from day one',
              'Optimal tax-efficient company structure for your goals',
              'Launch in days — not weeks — with expert guidance',
              'Audit-ready documentation and peace of mind for founders',
            ].map(s => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm leading-relaxed" style="color: #CBD5E1;">{s}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-16">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">Our Process</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">4-Step Company Formation Process</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="hidden lg:grid grid-cols-4 gap-6 relative">
        <div class="absolute top-[52px] left-[12.5%] right-[12.5%] h-px" style="background: linear-gradient(to right, #1a4480, #1e5ab5, #1a4480);"></div>
        {[
          { num: '01', title: 'Consultation', desc: 'We understand your business goals, target market, and ideal company structure across UK, US, or UAE.' },
          { num: '02', title: 'Registration', desc: 'File all incorporation documents, register at Companies House, and handle HMRC registration accurately.' },
          { num: '03', title: 'Compliance Setup', desc: 'VAT registration, licences, permits, operating agreements, and bank account assistance completed.' },
          { num: '04', title: 'Launch Support', desc: 'Advisory for accounting, tax planning, and ongoing regulatory guidance so you grow with confidence.' },
        ].map((step, i) => (
          <div class="flex flex-col items-center text-center">
            <div class="relative z-10 w-[104px] h-[104px] rounded-full flex flex-col items-center justify-center mb-6 shadow-lg" style="background: white; border: 2px solid #1a4480;">
              <span class="text-xs font-bold tracking-[0.15em] uppercase mb-0.5" style="color: #94A3B8;">{step.num} / 04</span>
              <span class="text-lg font-bold" style="color: #0F172A;">{i + 1}</span>
            </div>
            <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{step.title}</h3>
            <div class="w-6 h-px mb-3 mx-auto" style="background: #1a4480;"></div>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="lg:hidden space-y-6">
        {[
          { num: '01', title: 'Consultation', desc: 'Understand your goals and ideal company structure.' },
          { num: '02', title: 'Registration', desc: 'File incorporation documents and register accurately.' },
          { num: '03', title: 'Compliance Setup', desc: 'VAT, licences, permits, and banking assistance.' },
          { num: '04', title: 'Launch Support', desc: 'Tax, accounting advisory, and ongoing guidance.' },
        ].map((step, i) => (
          <div class="flex gap-5 items-start">
            <div class="w-12 h-12 rounded-full flex-shrink-0 flex items-center justify-center font-bold text-white text-sm" style="background: #1a4480;">{i + 1}</div>
            <div class="pt-1">
              <div class="text-xs font-bold tracking-[0.15em] uppercase mb-1" style="color: #94A3B8;">{step.num} / 04</div>
              <div class="text-sm font-bold mb-1.5" style="color: #0F172A;">{step.title}</div>
              <p class="text-xs leading-relaxed" style="color: #64748B;">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + COUNTRY SECTION ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">The Results</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">What You Get</h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-3 mb-10">
            {[
              'Fully registered and compliant company',
              'Legal & regulatory compliance from day one',
              'Optimally structured business for growth',
              'Complete peace of mind for founders',
            ].map(r => (
              <div class="flex items-center gap-3 py-3 px-4 rounded-xl" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0" style="background: #EFF6FF;">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-sm font-medium" style="color: #0F172A;">{r}</span>
              </div>
            ))}
          </div>

          <!-- Country-specific section -->
          <div class="rounded-2xl p-6" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
            <p class="text-xs font-bold tracking-[0.15em] uppercase mb-5" style="color: #1a4480;">Company Formation Across Borders</p>
            <div class="space-y-4">
              {[
                { flag: 'gb', country: 'United Kingdom', points: ['Ltd company formation', 'VAT registration', 'Companies House filings'] },
                { flag: 'us', country: 'United States', points: ['LLC & Inc. formation', 'EIN registration', 'State compliance'] },
                { flag: 'ae', country: 'Dubai / UAE', points: ['Freezone & Mainland setup', 'Trade licence assistance', 'Corporate banking'] },
              ].map(c => (
                <div class="p-4 rounded-xl" style="background: white; border: 1px solid #E2E8F0;">
                  <div class="flex items-center gap-2.5 mb-3">
                    <img src={`https://flagcdn.com/w20/${c.flag}.png`} alt={c.country} class="w-5 h-3.5 object-cover rounded-sm" />
                    <span class="text-sm font-bold" style="color: #0F172A;">{c.country}</span>
                  </div>
                  <div class="flex flex-wrap gap-x-4 gap-y-1">
                    {c.points.map(p => (
                      <div class="flex items-center gap-1.5">
                        <div class="w-1 h-1 rounded-full flex-shrink-0" style="background: #1a4480;"></div>
                        <span class="text-xs" style="color: #64748B;">{p}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="relative rounded-2xl overflow-hidden shadow-xl hidden lg:block" style="height: 580px;">
          <img
            src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=900&auto=format&fit=crop&q=80"
            alt="Company launch success"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.65) 0%, transparent 50%);"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="text-white font-bold text-xl mb-3">One Partner. Three Markets.</div>
            <div class="flex gap-3">
              {[
                { flag: 'gb', label: 'UK' },
                { flag: 'us', label: 'US' },
                { flag: 'ae', label: 'UAE' },
              ].map(c => (
                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);">
                  <img src={`https://flagcdn.com/w20/${c.flag}.png`} alt={c.label} class="w-4 h-3 object-cover rounded-sm" />
                  <span class="text-xs font-semibold text-white">{c.label}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="absolute top-6 right-6 rounded-xl px-5 py-4 shadow-xl" style="background: rgba(15,23,42,0.9); border: 1px solid rgba(255,255,255,0.1);">
            <div class="text-2xl font-bold text-white leading-none mb-0.5">100%</div>
            <div class="text-xs" style="color: #93B4D4;">Compliance Rate</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="py-20 lg:py-24" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #93B4D4;">Client Feedback</p>
        <h2 class="text-3xl font-bold text-white" style="letter-spacing: -0.02em;">What Our Clients Say</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>
      <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {[
          { quote: 'Ambit made setting up our UK company seamless. We launched within days without any hassle — incredible service.', name: 'Priya K.', role: 'Founder, London Tech Startup' },
          { quote: 'From Dubai company registration to banking, Ambit handled it all perfectly. One partner for all three markets.', name: 'Omar A.', role: 'CEO, Dubai–UK Expansion' },
        ].map(t => (
          <div class="rounded-2xl p-7" style="background: #1E293B; border: 1px solid #334155;">
            <svg class="w-7 h-7 mb-4 opacity-40" fill="currentColor" viewBox="0 0 24 24" style="color: #1a4480;"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed mb-6 italic" style="color: #CBD5E1;">"{t.quote}"</p>
            <div class="flex items-center gap-3 pt-4" style="border-top: 1px solid #334155;">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">{t.name[0]}</div>
              <div>
                <div class="text-sm font-semibold text-white">{t.name}</div>
                <div class="text-xs" style="color: #64748B;">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section id="contact" class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-4xl mx-auto px-6 lg:px-10 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Get Started Today</p>
      <h2 class="text-3xl lg:text-4xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.02em;">
        Start Your Business Confidently
      </h2>
      <p class="text-base leading-relaxed mb-10 mx-auto" style="color: #64748B; max-width: 460px;">
        Accurate registration. Full compliance. Expert guidance from day one.
      </p>

      <div class="flex flex-wrap justify-center gap-4 mb-14">
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5 shadow-lg" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.35);">
          Book Free Consultation
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="tel:+442012345678" class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold rounded border transition-all hover:shadow-md" style="color: #0F172A; border-color: #CBD5E1; background: white;">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call Us Now
        </a>
      </div>

      <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto">
        {[
          { num: '3', label: 'Countries Covered' },
          { num: '100%', label: 'Compliance Rate' },
          { num: '£0', label: 'Hidden Fees' },
        ].map(s => (
          <div class="text-center">
            <div class="text-2xl font-bold mb-1" style="color: #1a4480;">{s.num}</div>
            <div class="text-xs" style="color: #64748B;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

</UKLayout>
