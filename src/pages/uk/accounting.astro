---
import UKLayout from '../../layouts/UKLayout.astro';
---

<UKLayout
  title="Accounting & Bookkeeping – UK"
  description="From daily bookkeeping to financial reporting, Ambit helps UK businesses stay HMRC-compliant, organised, and financially confident — without the stress."
  countryPhone="+44 (0) 20 1234 5678"
  countryEmail="uk@ambit.co.uk"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 580px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] rounded-full opacity-[0.04] blur-3xl" style="background: #DC2626;"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 flex items-center" style="min-height: 580px;">
      <div class="grid lg:grid-cols-2 gap-14 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United Kingdom · Accounting & Bookkeeping</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            Clear Books. Smarter<br/>Decisions.
            <span style="color: #93B4D4;"> Built for<br/>UK Businesses.</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 460px;">
       Structured financial records, reporting, and year-end accounts aligned to UK GAAP and HMRC requirements, ensuring consistency across reporting cycles.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              Speak to an Expert
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              See How It Works
            </a>
          </div>

          <div class="flex flex-wrap gap-5 pt-8" style="border-top: 1px solid #1E293B;">
           {['UK GAAP Certified', 'HMRC Compliant', 'RTI Payroll', 'VAT Specialists', ' Making Tax Digital ready'].map(t => (
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-xs font-medium" style="color: #64748B;">{t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right -->
        <div class="relative hidden lg:block">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="height: 440px;">
            <img
              src="https://images.unsplash.com/photo-1554224154-26032ffc0d07?w=900&auto=format&fit=crop&q=80"
              alt="UK accounting and bookkeeping"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,23,42,0.5) 0%, transparent 60%);"></div>
          </div>
           <div class="absolute -bottom-6 -left-8 rounded-xl px-5 py-4 shadow-xl" style="background: #1a4480; border: 1px solid rgba(255,255,255,0.1);">
            <div class="text-2xl font-bold text-white leading-none mb-0.5">HMRC</div>
            <div class="text-xs font-medium" style="color: #93B4D4;">Fully Compliant</div>
          </div>
          <div class="absolute -top-4 -right-4 rounded-xl px-4 py-3 shadow-xl" style="background: #1E293B; border: 1px solid #334155;">
            <div class="text-xl font-bold text-white leading-none mb-0.5">ISO 27001 Certified</div>
            <div class="text-xs text-center" style="color: #64748B;"> ICO Registered</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
 <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex items-center gap-0" style="animation: marquee 30s linear infinite; width: max-content;">
      {[
        'UK GAAP aligned financial reporting',
        ' HMRC compliance across filings',
        ' RTI payroll and employer obligations',
        'Corporation tax and VAT alignment',
        ' Consistent reporting across periods',
        'Structured financial workflows',
        ' Making Tax Digital readiness',
        'Platform-aligned accounting (Xero, QuickBooks, Sage)',
      ].concat([
           'UK GAAP aligned financial reporting',
        ' HMRC compliance across filings',
        ' RTI payroll and employer obligations',
        'Corporation tax and VAT alignment',
        ' Consistent reporting across periods',
        'Structured financial workflows',
        ' Making Tax Digital readiness',
        'Platform-aligned accounting (Xero, QuickBooks, Sage)',
      ]).map(item => (
        <div class="flex items-center gap-3 px-6 whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-white opacity-60 flex-shrink-0"></span>
          <span class="text-xs font-semibold tracking-[0.12em] uppercase text-white opacity-90">{item}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="relative rounded-2xl overflow-hidden shadow-xl order-2 lg:order-1" style="height: 480px;">
          <img
            src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=900&auto=format&fit=crop&q=80"
            alt="Financial clarity for UK businesses"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.55) 0%, transparent 55%);"></div>
          <div class="absolute bottom-6 left-6 right-6 grid grid-cols-2 gap-3">
            {[
              { num: '100%', label: 'Reporting accuracy' },
              { num: '£0', label: 'Penalty exposure' },
              { num: '24h', label: 'Report Turnaround' },
              { num: '4×', label: 'Faster reconciliation' },
            ].map(m => (
              <div class="rounded-lg px-4 py-3" style="background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.1);">
                <div class="text-xl font-bold text-white leading-none mb-0.5">{m.num}</div>
                <div class="text-xs" style="color: #94A3B8;">{m.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Financial Information Should Be Clear, Consistent, and Usable
          </h2>
          <div class="w-10 h-px mb-6" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed " style="color: #475569;">
         Inconsistent records lead to delayed decisions, rework during tax preparation, and increased compliance risk.
          </p>
          <p class="text-base leading-relaxed" style="color: #475569;">
      Structured accounting ensures financial information remains reliable across reporting, tax, and operational use.
          </p>
        

          <div class="space-y-4">
            {[
              { title: 'Always Audit-Ready', desc: 'Financial records maintained consistently, reducing year-end adjustments and rework.' },
              { title: 'Real-Time Visibility', desc: 'Up-to-date P&L, balance sheet, and cash flow reporting across periods.' },
              { title: 'Reduced Operational Dependency', desc: 'Defined processes reduce reliance on manual intervention and corrections.' },
            ].map(item => (
              <div class="flex gap-4 p-4 rounded-xl" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-1" style="color: #0F172A;">{item.title}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Accounting & Bookkeeping — United Kingdom</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {[
          {
            title: 'Bookkeeping & Ledger Management',
            subtitle: 'Keep your records accurate and up-to-date',
            img: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?w=700&auto=format&fit=crop&q=75',
            points: ['Transaction recording', 'Expense classification', 'Ledger maintenance aligned to UK GAAP'],
            icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z',
          },
          {
            title: 'Reconciliation',
            subtitle: 'Know exactly where your business stands',
            img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=700&auto=format&fit=crop&q=75',
            points: ['Bank reconciliation', 'Credit card reconciliation', 'Control account reconciliation', 'Identification and correction of discrepancies'],
            icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
          },
          {
            title: 'Management Reporting',
            subtitle: 'Stay aligned with UK regulations',
            img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=700&auto=format&fit=crop&q=75',
            points: ['Profit & Loss', 'Balance Sheet', 'Cash flow reporting', 'Structured monthly close'],
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            title: 'Year-End Close',
            subtitle: 'Keep your records accurate and up-to-date',
            img: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?w=700&auto=format&fit=crop&q=75',
            points: ['Finalisation of financial records', 'Adjustments and closing entries', 'Alignment with statutory reporting and tax'],
            icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z',
          },
          {
            title: 'Statutory Accounts',
            subtitle: 'Know exactly where your business stands',
            img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=700&auto=format&fit=crop&q=75',
            points: ['Preparation of statutory financial statements', 'Alignment with Companies House requirements', 'Year-end adjustments and finalisation'],
            icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
          },
          {
            title: 'Confirmation Statement (CS01)',
            subtitle: 'Stay aligned with UK regulations',
            img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=700&auto=format&fit=crop&q=75',
            points: ['Preparation and filing with Companies House', 'Maintenance of statutory company information', 'Alignment with company records and filings'],
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            title: 'Tax Alignment (CT600 Ready)',
            subtitle: 'Keep your records accurate and up-to-date',
            img: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?w=700&auto=format&fit=crop&q=75',
            points: ['Financials structured for corporation tax computation', 'Consistency between accounting and tax', 'Clean handover for CT600 preparation'],
            icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z',
          },
          {
            title: 'Compliance Readiness',
            subtitle: 'Know exactly where your business stands',
            img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=700&auto=format&fit=crop&q=75',
            points: ['HMRC-ready financial records', 'VAT-ready bookkeeping', 'Audit-ready structure'],
            icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
          },
          {
            title: 'Audit Support',
            subtitle: 'Stay aligned with UK regulations',
            img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=700&auto=format&fit=crop&q=75',
            points: ['Preparation of audit-ready financials', 'Supporting schedules and documentation', 'Coordination during audit processes'],
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
        ].map(svc => (
          <div class="rounded-2xl overflow-hidden shadow-sm" style="background: white; border: 1px solid #E2E8F0;">
            <div class="relative h-44 overflow-hidden">
              <img src={svc.img} alt={svc.title} class="w-full h-full object-cover" />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,23,42,0.15), rgba(15,23,42,0.75));"></div>
              <div class="absolute bottom-4 left-4 right-4">
                <div class="flex items-center gap-2.5 mb-1">
                  <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0" style="background: #1a4480;">
                    <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={svc.icon}/></svg>
                  </div>
                  <h3 class="text-white font-bold text-sm">{svc.title}</h3>
                </div>
                <p class="text-xs" style="color: #93B4D4;">{svc.subtitle}</p>
              </div>
            </div>
            <div class="p-5">
              <ul class="space-y-2.5">
                {svc.points.map(p => (
                  <li class="flex items-center gap-2.5">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-sm" style="color: #374151;">{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
          Designed for Businesses Requiring Consistency
          </h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-3">
            {[
              { label: 'Startups & Founders', desc: 'Structured financial setup from the outset, avoiding rework later.', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
              { label: 'SMEs & Scaling Businesses', desc: 'Manage increasing transaction volumes without adding internal complexity.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
              { label: 'E-commerce Businesses', desc: 'Multi-platform reconciliation, VAT alignment, and structured reporting.', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z' },
              { label: 'Service & Consulting Firms', desc: 'Project-based billing, revenue tracking, and consistent monthly close.', icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
              { label: 'Accounting & Tax Firms', desc: 'Support delivery capacity while maintaining consistency across client work.', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z' },
            ].map(item => (
              <div class="flex items-start gap-4 p-4 rounded-xl transition-all hover:shadow-md" style="border: 1px solid #E2E8F0;">
                <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-0.5" style="color: #0F172A;">{item.label}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative rounded-2xl overflow-hidden shadow-xl hidden lg:block" style="height: 540px;">
          <img
            src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=900&auto=format&fit=crop&q=80"
            alt="UK business team"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.65) 0%, transparent 55%);"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="text-white font-bold text-xl mb-2">Trusted Across the UK</div>
            <div class="text-sm" style="color: #93B4D4;">From London startups to established firms</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-20 lg:py-28" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #93B4D4;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white" style="letter-spacing: -0.02em;">Struggling with Your Books?</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <div class="rounded-2xl p-8" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(239,68,68,0.15);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #EF4444;">Without Structured Accounting</span>
          </div>
          <div class="space-y-4">
            {[
              'Disorganised financial records',
              'Limited visibility across performance',
              'Time spent on reconciliation and corrections',
              'Misalignment during tax preparation',
              'Risk of compliance issues',
            ].map(p => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
                <span class="text-sm leading-relaxed" style="color: #94A3B8;">{p}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl p-8" style="background: rgba(26,68,128,0.15); border: 1px solid rgba(26,68,128,0.35);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(26,68,128,0.3);">
