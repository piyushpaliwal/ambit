---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Outsource Accounting & Bookkeeping Services">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 600px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.07] blur-3xl" style="background: #1a4480;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center" style="min-height: 600px;">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-5" style="color: #93B4D4;">Global Accounting & Advisory</p>
          <h1 class="text-4xl sm:text-5xl lg:text-[52px] font-bold leading-[1.1] text-white" style="letter-spacing: -0.02em;">
            Outsource Accounting<br/>& Bookkeeping<br/>
            <span style="color: #93B4D4;">for Global Businesses</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed" style="color: #94A3B8; max-width: 500px;">
            Save time, reduce costs, and get accurate financials with our expert offshore accounting team across UK, US & UAE.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
              Book Free Consultation
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              See How It Works
            </a>
          </div>
          <div class="mt-10 pt-8 flex items-center gap-3" style="border-top: 1px solid #1E293B;">
            <div class="flex -space-x-2">
              {['#1a4480','#2d5fa0','#3d6fad','#4d7fba'].map(c => (
                <div class="w-8 h-8 rounded-full border-2 border-slate-900 flex items-center justify-center text-xs font-bold text-white" style={`background-color: ${c};`}>A</div>
              ))}
            </div>
            <p class="text-sm" style="color: #64748B;">Trusted by <span class="text-white font-semibold">280+ clients</span> across UK, US & UAE</p>
          </div>
        </div>

        <!-- Right image -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 250)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-x-6"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative">
          <div class="absolute -top-4 -right-4 w-full h-full rounded-xl" style="border: 1px solid #1E293B;"></div>
          <img src="/images/hero-professional.png" alt="Professional accountant" class="relative rounded-xl w-full object-cover object-top shadow-2xl" style="max-height: 460px;" />
          <div class="absolute -bottom-5 -left-5 bg-white rounded-xl p-4 shadow-xl border border-gray-100">
            <p class="text-xs text-gray-400 mb-1">Governance-Led Delivery</p>
            <p class="text-sm font-semibold text-gray-900">Structured. Compliant. Reliable.</p>
            <div class="mt-2 flex gap-1">
              <span class="w-2 h-1 rounded-full" style="background-color: #1a4480;"></span>
              <span class="w-6 h-1 rounded-full bg-slate-200"></span>
              <span class="w-3 h-1 rounded-full bg-slate-200"></span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== PAIN POINTS ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">Sound Familiar?</p>
        <h2 class="text-3xl sm:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Is Accounting Slowing You Down?</h2>
        <div class="w-10 h-0.5 mx-auto mt-4" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {[
          { icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Missing Deadlines & Tax Penalties', desc: 'Late filings cost you money and damage your reputation with regulators.' },
          { icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4', title: 'Manual Data Entry Errors', desc: 'Human errors in books create compliance risks and costly corrections.' },
          { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Disorganised Financial Reports', desc: 'Unclear financials make decision-making slow and risky for your business.' },
          { icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Rising Overhead Costs', desc: 'In-house accounting teams are expensive — salaries, benefits, software.' },
        ].map(p => (
          <div class="p-7 rounded-xl border border-gray-100 hover:border-slate-200 hover:shadow-lg transition-all group">
            <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-5" style="background-color: #F1F5F9;">
              <svg class="w-6 h-6 group-hover:scale-110 transition-transform" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={p.icon}/>
              </svg>
            </div>
            <h3 class="text-sm font-bold text-gray-900 mb-2">{p.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a href="#how-it-works" class="inline-flex items-center gap-2 text-sm font-semibold transition-colors" style="color: #1a4480;">
          Let Us Fix This
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="py-20" style="background-color: #F8FAFC;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid lg:grid-cols-3 gap-12 mb-14">
        <div class="lg:col-span-1">
          <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">What We Offer</p>
          <h2 class="text-3xl sm:text-4xl font-bold leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">Our Accounting & Bookkeeping Services</h2>
          <div class="w-10 h-0.5 mt-4 mb-5" style="background-color: #1a4480;"></div>
          <p class="text-gray-500 leading-relaxed text-sm">
            We provide end-to-end accounting solutions tailored for CPA firms, startups, and growing businesses across the UK, US & UAE.
          </p>
          <a href="#contact" class="mt-6 inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
            Get Started
          </a>
        </div>
        <div class="lg:col-span-2 grid sm:grid-cols-2 gap-5">
          {[
            { icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Accounting & Bookkeeping', desc: 'Accurate, real-time financial tracking and record maintenance.' },
            { icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z', title: 'Tax Preparation', desc: 'Federal & state tax filing support across all jurisdictions.' },
            { icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', title: 'Payroll Management', desc: 'Hassle-free payroll processing, compliance & reporting.' },
            { icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z', title: 'Accounts Payable', desc: 'Timely vendor payments and invoice management.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Accounts Receivable', desc: 'Faster collections, invoicing & cash flow management.' },
            { icon: 'M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Financial Reporting', desc: 'Monthly & custom reports with actionable insights.' },
          ].map(s => (
            <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-md hover:border-slate-200 transition-all group flex gap-4">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #E8EEF7;">
                <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={s.icon}/>
                </svg>
              </div>
              <div>
                <h3 class="text-sm font-bold text-gray-900 mb-1">{s.title}</h3>
                <p class="text-xs text-gray-500 leading-relaxed">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY CHOOSE US ===== -->
  <section class="py-20" style="background-color: #0F172A;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #93B4D4;">Our Advantage</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight" style="letter-spacing: -0.02em;">Why Choose Ambit?</h2>
          <div class="w-10 h-px mt-4 mb-6" style="background-color: #1a4480;"></div>
          <p class="text-gray-400 leading-relaxed mb-8">
            We combine deep expertise, dedicated offshore teams, and robust governance to deliver accounting that businesses across UK, US & UAE trust.
          </p>
          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
            Work With Us
          </a>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { num: '20+', label: 'Years of Industry Experience', icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' },
            { num: '60%', label: 'Cost Savings vs In-house', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
            { num: '24/7', label: 'Support & Communication', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
            { num: '100%', label: 'Data Security & Confidentiality', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
            { num: '∞', label: 'Dedicated Offshore Staff', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
            { num: '3+', label: 'Flexible Hiring Models', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
          ].map(w => (
            <div class="p-5 rounded-xl border group hover:border-slate-600 transition-all" style="background-color: #1E293B; border-color: #334155;">
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #1a4480; opacity: 0.8;">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={w.icon}/>
                  </svg>
                </div>
                <div>
                  <p class="text-xl font-bold text-white leading-none mb-1">{w.num}</p>
                  <p class="text-xs text-gray-400 leading-snug">{w.label}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-xl mx-auto mb-16">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">The Process</p>
        <h2 class="text-3xl sm:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">How It Works</h2>
        <div class="w-10 h-0.5 mx-auto mt-4" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 relative">
        <!-- Connecting line desktop -->
        <div class="hidden lg:block absolute top-10 left-[12.5%] right-[12.5%] h-px" style="background: linear-gradient(to right, #1a4480, #93B4D4, #1a4480); opacity: 0.3;"></div>

        {[
          { step: '01', title: 'Discovery Call', desc: 'We understand your business needs, current processes, and accounting challenges in detail.' },
          { step: '02', title: 'Hire Dedicated Staff', desc: 'Interview and select from our vetted pool of accounting professionals matched to your needs.' },
          { step: '03', title: 'Onboarding', desc: 'Smooth transition of tasks with full documentation, system access, and team introductions.' },
          { step: '04', title: 'Execution & Delivery', desc: 'Accurate, timely accounting delivered with regular reporting and direct communication.' },
        ].map((s, i) => (
          <div class="relative text-center group">
            <div class="w-20 h-20 rounded-2xl mx-auto mb-6 flex flex-col items-center justify-center shadow-sm border border-gray-100 bg-white group-hover:shadow-md group-hover:border-slate-200 transition-all relative z-10">
              <span class="text-xs font-bold tracking-widest" style="color: #1a4480;">{s.step}</span>
              <span class="text-xs text-gray-400 mt-0.5">Step</span>
            </div>
            <h3 class="text-sm font-bold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-xs text-gray-500 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="py-16" style="background-color: #1E293B;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        {[
          { val: '500', suffix: '+', label: 'Clients Served', sub: 'Across UK, US & UAE' },
          { val: '20', suffix: '+', label: 'Years Experience', sub: 'Deep domain expertise' },
          { val: '250', suffix: '+', label: 'Accounting Experts', sub: 'Dedicated professionals' },
          { val: '1M', suffix: '+', label: 'Transactions Processed', sub: 'Accurate every time' },
        ].map(s => (
          <div class="py-4">
            <p class="text-5xl font-bold text-white">{s.val}<span class="text-3xl">{s.suffix}</span></p>
            <div class="w-8 h-px mx-auto my-3" style="background-color: #1a4480;"></div>
            <p class="text-sm font-semibold text-gray-300">{s.label}</p>
            <p class="text-xs mt-1" style="color: #475569;">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRIES ===== -->
  <section id="industries" class="py-20" style="background-color: #F8FAFC;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-xl mx-auto mb-14">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">Sectors</p>
        <h2 class="text-3xl sm:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Industries We Serve</h2>
        <div class="w-10 h-0.5 mx-auto mt-4" style="background-color: #1a4480;"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z', label: 'CPA Firms', desc: 'Offload overflow work during busy seasons.' },
          { icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', label: 'E-commerce Businesses', desc: 'Sales tax, inventory & multi-platform reconciliation.' },
          { icon: 'M13 10V3L4 14h7v7l9-11h-7z', label: 'Startups', desc: 'Lean finance setup from day one.' },
          { icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', label: 'Real Estate', desc: 'Property accounts, rental income & compliance.' },
          { icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', label: 'Healthcare', desc: 'HIPAA-compliant billing and financial reporting.' },
          { icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5', label: 'Small & Medium Businesses', desc: 'Scalable accounting as your business grows.' },
        ].map(ind => (
          <div class="bg-white p-6 rounded-xl border border-gray-100 hover:shadow-md hover:border-slate-200 transition-all group flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: #E8EEF7;">
              <svg class="w-5 h-5 group-hover:scale-110 transition-transform" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={ind.icon}/>
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-gray-900 mb-1">{ind.label}</h3>
              <p class="text-xs text-gray-500 leading-relaxed">{ind.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SOFTWARE EXPERTISE ===== -->
  <section class="py-16 bg-white" style="border-top: 1px solid #E2E8F0; border-bottom: 1px solid #E2E8F0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-2" style="color: #1a4480;">Technology</p>
        <h2 class="text-2xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Tools & Software We Use</h2>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-6">
        {[
          { name: 'QuickBooks', abbr: 'QB' },
