---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Accounting, Tax & Business Advisory Across Key Markets">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 580px;">
    <!-- Subtle dot pattern -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <!-- Blue glow top-right -->
    <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: #1a4480;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-0 flex items-center" style="min-height: 580px;">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full">

        <!-- Left -->
        <div
          x-data="{ v: false }"
          x-init="setTimeout(() => v = true, 80)"
          x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0"
        >
          <!-- Eyebrow -->
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-5" style="color: #93B4D4;">
            Global Accounting & Advisory
          </p>

          <h1 class="text-4xl sm:text-5xl lg:text-[52px] font-bold leading-[1.1] text-white" style="letter-spacing: -0.02em;">
            Accounting, Tax &<br />
            Business Advisory<br />
            <span style="color: #93B4D4;">Across Key Markets</span>
          </h1>

          <p class="mt-6 text-lg leading-relaxed" style="color: #94A3B8; max-width: 520px;">
            Ambit provides structured accounting, tax compliance, and financial management for businesses operating in the United Kingdom, United States, and United Arab Emirates.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#markets" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
              Select Your Country
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              Book a Consultation
            </a>
          </div>

          <!-- Trust line -->
          <div class="mt-10 flex items-center gap-6 pt-8" style="border-top: 1px solid #1E293B;">
            <div class="text-center">
              <p class="text-2xl font-bold text-white">100+</p>
              <p class="text-xs mt-0.5" style="color: #64748B;">Professionals</p>
            </div>
            <div class="w-px h-10" style="background-color: #1E293B;"></div>
            <div class="text-center">
              <p class="text-2xl font-bold text-white">350+</p>
              <p class="text-xs mt-0.5" style="color: #64748B;">Active Clients</p>
            </div>
            <div class="w-px h-10" style="background-color: #1E293B;"></div>
            <div class="text-center">
              <p class="text-2xl font-bold text-white">3</p>
              <p class="text-xs mt-0.5" style="color: #64748B;">Jurisdictions</p>
            </div>
          </div>
        </div>

        <!-- Right: Image -->
        <div
          x-data="{ v: false }"
          x-init="setTimeout(() => v = true, 250)"
          x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-x-6"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <!-- Frame accent -->
          <div class="absolute -top-4 -right-4 w-full h-full rounded-xl" style="border: 1px solid #1E293B;"></div>
          <img
            src="/images/hero-professional.png"
            alt="Professional"
            class="relative rounded-xl w-full object-cover object-top shadow-2xl"
            style="max-height: 460px;"
          />
          <!-- Floating stat card -->
          <div class="absolute -bottom-5 -left-5 bg-white rounded-xl p-4 shadow-xl border border-gray-100">
            <p class="text-xs text-gray-400 mb-1">Governance-Led Delivery</p>
            <p class="text-sm font-semibold text-gray-900">Structured. Compliant. Reliable.</p>
            <div class="mt-2 flex gap-1">
              <span class="w-2 h-1 rounded-full" style="background-color: #1a4480;"></span>
              <span class="w-6 h-1 rounded-full" style="background-color: #BFDBFE;"></span>
              <span class="w-3 h-1 rounded-full" style="background-color: #BFDBFE;"></span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== ABOUT + CLIENTS ===== -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">

        <div>
          <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">Who We Are</p>
          <h2 class="text-3xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">About Ambit</h2>
          <div class="mt-3 w-10 h-0.5" style="background-color: #1a4480;"></div>
          <p class="mt-5 text-gray-600 leading-relaxed">
            Ambit provides structured accounting, tax compliance, and financial management services for businesses operating across the United Kingdom, United States, and United Arab Emirates.
          </p>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Our governance-led approach ensures accuracy, regulatory compliance, and reliable financial reporting — delivered by dedicated regional teams aligned with local frameworks.
          </p>
          <a href="/about" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold transition-colors" style="color: #1a4480;">
            Read More
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <div>
          <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">Who We Serve</p>
          <h2 class="text-3xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Our Clients</h2>
          <div class="mt-3 w-10 h-0.5" style="background-color: #1a4480;"></div>
          <ul class="mt-5 space-y-3">
            {[
              'Start-ups, SMEs, and established businesses',
              'Accounting firms and strategic CPA partners',
              'International founders entering UK, US, or UAE',
              'E-commerce, retail, hospitality and tech companies',
              'Real estate and property management businesses',
              'Consultants, contractors and professional services',
            ].map(item => (
              <li class="flex items-start gap-3 text-gray-600 text-sm">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== GOVERNANCE STRIP ===== -->
  <section class="py-14" style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0; border-bottom: 1px solid #E2E8F0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">Our Approach</p>
          <h2 class="text-3xl font-bold leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Governance-Led<br/>Financial Delivery
          </h2>
        </div>
        <p class="text-gray-500 leading-relaxed">
          Businesses across the UK, US, and UAE rely on Ambit for structured financial management and compliance.
          Our governance-led workflows and secure systems ensure consistent, accurate financial reporting.
          <strong class="text-gray-700"> Beyond individual services, we function as your complete outsourced finance and accounting department</strong> — from start-up through to established operations.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== OUR SERVICES ===== -->
  <section id="services" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Top service icons -->
      <div class="grid sm:grid-cols-3 gap-6 mb-16">
        {[
          { icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z', label: 'Accounting Services', sub: 'Financial reporting & bookkeeping' },
          { icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z', label: 'Tax Compliance', sub: 'Multi-jurisdiction tax services' },
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Payroll & Filings', sub: 'Payroll management & statutory filings' },
        ].map(s => (
          <div class="p-8 border border-gray-100 rounded-lg hover:border-blue-100 hover:shadow-md transition-all group">
            <div class="w-14 h-14 rounded-lg flex items-center justify-center mb-5" style="background-color: #E8EEF7;">
              <svg class="w-7 h-7 group-hover:scale-110 transition-transform" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={s.icon}/>
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1">{s.label}</h3>
            <p class="text-sm text-gray-500">{s.sub}</p>
          </div>
        ))}
      </div>

      <!-- Services detail -->
      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div>
          <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">What We Offer</p>
          <h2 class="text-3xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Our Services</h2>
          <div class="mt-3 w-10 h-0.5" style="background-color: #1a4480;"></div>
          <p class="mt-5 text-gray-500 leading-relaxed">
            Structured financial management, compliance, and advisory services across all three jurisdictions — designed to scale with your business.
          </p>
          <div class="mt-7 grid grid-cols-2 gap-3">
            {[
              'Accounting & Bookkeeping',
              'CFO Advisory Services',
              'Tax Compliance & Planning',
              'Payroll Management',
              'Company Formation',
              'Financial Reporting',
            ].map(s => (
              <div class="flex items-center gap-3 p-3.5 rounded-lg border border-gray-100 bg-gray-50 text-sm text-gray-700 hover:border-blue-100 hover:bg-blue-50 transition-all group">
                <span class="w-0.5 h-7 rounded-full flex-shrink-0 group-hover:bg-blue-600 transition-colors" style="background-color: #CBD5E1;"></span>
                {s}
              </div>
            ))}
          </div>
        </div>
        <div class="relative">
          <img
            src="/images/team-meeting.png"
            alt="Ambit team"
            class="w-full rounded-lg shadow-lg object-cover"
            style="max-height: 380px;"
          />
          <div class="absolute -bottom-4 -right-4 w-full h-full rounded-lg border border-gray-200 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CHOOSE YOUR MARKET ===== -->
  <section id="markets" class="py-20" style="background-color: #F8FAFC;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-14">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">Global Presence</p>
        <h2 class="text-3xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Choose Your Market</h2>
        <div class="mt-3 w-10 h-0.5 mx-auto" style="background-color: #1a4480;"></div>
        <p class="mt-4 text-gray-500 max-w-lg mx-auto text-sm leading-relaxed">
          Dedicated regional teams aligned with the regulatory frameworks of each jurisdiction. Select your region to explore country-specific services.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-7">

        <!-- UK -->
        <div class="bg-white rounded-lg border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1 group">
          <div class="h-px w-full" style="background-color: #1a4480;"></div>
          <div class="p-8">
            <div class="flex items-center gap-3 mb-5">
              <img src="https://flagcdn.com/w40/gb.png" alt="UK" class="w-10 h-7 object-cover rounded shadow-sm" />
              <div>
                <h3 class="font-bold text-gray-900">United Kingdom</h3>
                <p class="text-xs text-gray-400 mt-0.5">London · Manchester · Edinburgh</p>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed mb-6">
              Accounting, tax, payroll, and compliance services for UK businesses, accounting firms, and international founders.
            </p>
            <ul class="space-y-2.5 mb-8">
              {['UK Statutory Accounts & CT600', 'VAT Registration & Returns', 'Payroll & Auto-Enrolment', 'Self Assessment & PAYE'].map(s => (
                <li class="flex items-center gap-2.5 text-sm text-gray-600">
                  <span class="w-1 h-1 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  {s}
                </li>
              ))}
            </ul>
            <a href="/uk" class="flex items-center justify-center gap-2 w-full py-2.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
              Enter UK Site
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

        <!-- US -->
        <div class="bg-white rounded-lg border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1 group relative">
          <div class="absolute top-4 right-4">
            <span class="px-2.5 py-0.5 text-xs font-semibold rounded-full" style="background-color: #E8EEF7; color: #1a4480;">Most Popular</span>
          </div>
          <div class="h-px w-full" style="background-color: #1a4480;"></div>
          <div class="p-8">
            <div class="flex items-center gap-3 mb-5">
              <img src="https://flagcdn.com/w40/us.png" alt="US" class="w-10 h-7 object-cover rounded shadow-sm" />
              <div>
                <h3 class="font-bold text-gray-900">United States</h3>
                <p class="text-xs text-gray-400 mt-0.5">New York · Delaware · California</p>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed mb-6">
              Accounting, federal and state tax compliance, and financial reporting support for businesses operating in the US market.
            </p>
            <ul class="space-y-2.5 mb-8">
              {['Federal & State Tax Returns', 'GAAP Financial Reporting', 'Payroll & Sales Tax', 'LLC & Corp Formation'].map(s => (
                <li class="flex items-center gap-2.5 text-sm text-gray-600">
                  <span class="w-1 h-1 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  {s}
                </li>
              ))}
            </ul>
            <a href="/us" class="flex items-center justify-center gap-2 w-full py-2.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
              Enter US Site
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

        <!-- UAE -->
        <div class="bg-white rounded-lg border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1 group">
          <div class="h-px w-full" style="background-color: #1a4480;"></div>
          <div class="p-8">
            <div class="flex items-center gap-3 mb-5">
              <img src="https://flagcdn.com/w40/ae.png" alt="UAE" class="w-10 h-7 object-cover rounded shadow-sm" />
              <div>
                <h3 class="font-bold text-gray-900">United Arab Emirates</h3>
                <p class="text-xs text-gray-400 mt-0.5">Dubai · Abu Dhabi · Free Zones</p>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed mb-6">
              Corporate structuring, company formation, accounting, and compliance services for businesses in Dubai and across the UAE.
            </p>
            <ul class="space-y-2.5 mb-8">
              {['Company Formation & Licensing', 'UAE Corporate Tax & VAT', 'Free Zone & Mainland Setup', 'Financial Statements & Audit'].map(s => (
                <li class="flex items-center gap-2.5 text-sm text-gray-600">
                  <span class="w-1 h-1 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
                  {s}
                </li>
              ))}
            </ul>
            <a href="/uae" class="flex items-center justify-center gap-2 w-full py-2.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
              Enter UAE Site
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== QUICK FACTS ===== -->
  <section class="py-20" style="background-color: #0F172A;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-14">
        <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #93B4D4;">By The Numbers</p>
        <h2 class="text-3xl font-bold text-white" style="letter-spacing: -0.02em;">Global Capability</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">

        <div
          x-data="counter(100, 2)"
          x-init="startWhenVisible($el)"
          class="text-center"
        >
          <p class="text-5xl font-bold text-white" x-text="count + '+'">0+</p>
          <div class="w-8 h-px mx-auto my-4" style="background-color: #1a4480;"></div>
          <p class="font-semibold text-sm text-gray-300">Professionals</p>
          <p class="mt-1.5 text-xs leading-relaxed" style="color: #475569;">Accountants, tax specialists, and financial professionals across multiple jurisdictions.</p>
        </div>

        <div
          x-data="counter(350, 7)"
          x-init="startWhenVisible($el)"
          class="text-center"
        >
          <p class="text-5xl font-bold text-white" x-text="count + '+'">0+</p>
          <div class="w-8 h-px mx-auto my-4" style="background-color: #1a4480;"></div>
          <p class="font-semibold text-sm text-gray-300">Active Clients</p>
          <p class="mt-1.5 text-xs leading-relaxed" style="color: #475569;">Serving organisations from start-ups to established companies.</p>
        </div>

        <div class="text-center">
          <p class="text-5xl font-bold text-white">3</p>
          <div class="w-8 h-px mx-auto my-4" style="background-color: #1a4480;"></div>
          <p class="font-semibold text-sm text-gray-300">Jurisdictions</p>
          <p class="mt-1.5 text-xs leading-relaxed" style="color: #475569;">Accounting, tax, and compliance aligned with UK, US, and UAE frameworks.</p>
        </div>

        <div class="text-center">
          <p class="text-5xl font-bold text-white">100<span class="text-3xl">%</span></p>
          <div class="w-8 h-px mx-auto my-4" style="background-color: #1a4480;"></div>
          <p class="font-semibold text-sm text-gray-300">Governance-Led</p>
          <p class="mt-1.5 text-xs leading-relaxed" style="color: #475569;">Structured workflows, review processes, and secure systems.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== WHY AMBIT / APPROACH ===== -->
  <section id="approach" class="py-20" style="background-color: #F1F5F9;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <div>
          <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #1a4480;">Our Methodology</p>
          <h2 class="text-3xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Why Ambit?</h2>
          <div class="mt-3 w-10 h-0.5" style="background-color: #1a4480;"></div>
          <p class="mt-5 text-gray-500 leading-relaxed">
            Ambit combines structured accounting delivery with governance-focused advisory to support reliable financial operations.
          </p>
          <a href="/about" class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors" style="color: #1a4480;">
            Know more
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Timeline -->
        <div class="relative pl-6 border-l border-gray-100">
          <div class="space-y-8">
            {[
              { title: 'Accounting and financial reporting', desc: 'Accurate books and compliant financial statements across all jurisdictions.' },
              { title: 'Tax compliance and planning', desc: 'Proactive tax management aligned with UK, US, and UAE regulations.' },
              { title: 'Payroll and statutory filings', desc: 'On-time payroll processing and regulatory submissions.' },
              { title: 'Company formation and structuring', desc: 'End-to-end incorporation support in each market.' },
              { title: 'Financial management oversight', desc: 'Reporting frameworks that give you clear financial visibility.' },
            ].map((item, i) => (
              <div class="relative">
                <span class="absolute -left-[25px] w-2.5 h-2.5 rounded-full border-2 border-white ring-1 mt-1" style="background-color: #1a4480; ring-color: #E2E8F0;"></span>
                <h4 class="text-sm font-semibold text-gray-900 mb-1">{item.title}</h4>
                <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>

          <div class="mt-8 p-4 rounded-lg" style="background-color: #F8FAFC; border: 1px solid #E2E8F0;">
            <p class="text-sm text-gray-500 leading-relaxed">
              This structured approach ensures businesses maintain accurate records, regulatory compliance, and financial visibility.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== REQUEST CONSULTATION ===== -->
  <section class="py-20 bg-white" style="border-top: 1px solid #E2E8F0; border-bottom: 1px solid #E2E8F0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-14 items-center">

        <!-- Left -->
