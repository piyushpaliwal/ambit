---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Outsource Accounting & Bookkeeping Services">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 600px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.07] blur-3xl" style="background: #1a4480;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center" style="min-height: 600px;">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-5" style="color: #93B4D4;">Global Accounting, Tax & Advisory Firm</p>
          <h1 class="text-3xl sm:text-4xl lg:text-[40px] font-bold leading-[1.15] text-white" style="letter-spacing: -0.02em;">
            Accounting, Tax &amp; Business Advisory
            <span style="color: #93B4D4;">for Companies Expanding Across Borders</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed" style="color: #94A3B8; max-width: 500px;">
            From company formation and bookkeeping to business restructuring, payroll, RPO, compliance, and personal or corporate tax returns, we support businesses and individuals across the UK, USA, and UAE with practical, end-to-end financial expertise.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              Book Free Consultation
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#services" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              Explore Our Services
            </a>
          </div>
          <div class="mt-10 pt-8 flex items-center gap-3" style="border-top: 1px solid #1E293B;">
            <div class="flex -space-x-2">
              {['#1a4480','#2d5fa0','#3d6fad','#4d7fba'].map(c => (
                <div class="w-8 h-8 rounded-full border-2 border-slate-900 flex items-center justify-center text-xs font-bold text-white" style={`background-color: ${c};`}>A</div>
              ))}
            </div>
            <p class="text-sm" style="color: #64748B;">Trusted by <span class="text-white font-semibold">500+ clients</span> across UK, USA and UAE</p>
          </div>
        </div>

        <!-- Right image -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 250)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-x-6"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative">
          <div class="absolute -top-4 -right-4 w-full h-full rounded-xl" style="border: 1px solid #1E293B;"></div>
          <img src="/images/hero-professional.png" alt="Professional accountant" class="relative rounded-xl w-full object-cover object-top shadow-2xl" style="max-height: 460px;" />
          <div class="absolute -bottom-5 -left-5 bg-white rounded-xl p-4 shadow-xl border border-gray-100">
            <p class="text-xs text-gray-400 mb-1">500+ Clients Across UK, USA and UAE</p>
            <p class="text-sm font-semibold text-gray-900">Structured. Compliant. Reliable.</p>
            <div class="mt-2 flex gap-1">
              <span class="w-2 h-1 rounded-full" style="background-color: #1a4480;"></span>
              <span class="w-6 h-1 rounded-full bg-slate-200"></span>
              <span class="w-3 h-1 rounded-full bg-slate-200"></span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== PAIN POINTS ===== -->
  <section style="background-color: #F8FAFC;">
    <!-- Centered light header -->
    <div class="pt-20 pb-14 text-center">
      <div class="max-w-3xl mx-auto px-6">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Sound Familiar?</p>
        <h2 class="text-4xl sm:text-5xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.025em;">
          Is Accounting Slowing<br/>Your Business Down?
        </h2>
        <p class="text-sm leading-relaxed mx-auto" style="color: #64748B; max-width: 520px;">
          Delays in your finance function cost more than just time. They affect cash flow, decision-making, and your overall peace of mind. These are common challenges many businesses face, and they can be fixed with the right approach.
        </p>
      </div>
    </div>

    <!-- 4 columns -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Missed Deadlines and Compliance Pressure', desc: 'Filing delays and incomplete compliance can lead to penalties and unnecessary back and forth with regulators.' },
          { icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4', title: 'Errors in Financial Data', desc: 'Manual entries and unstructured systems often lead to mistakes that take time and money to fix later.' },
          { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'No Clear Financial Picture', desc: 'If your reports are not organised, it becomes difficult to understand where the business stands or where it is going.' },
          { icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Rising Costs of Managing Finance Internally', desc: 'Hiring, training, software, and ongoing management make in-house accounting more expensive than most businesses expect.' },
        ].map(p => (
          <div class="bg-white rounded-2xl p-8 hover:-translate-y-1 transition-all" style="border: 1px solid #EEF2F6; box-shadow: 0 2px 16px rgba(15,23,42,0.06);">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-6" style="background-color: #EEF2F8;">
              <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={p.icon}/>
              </svg>
            </div>
            <h3 class="text-sm font-bold mb-2 leading-snug" style="color: #0F172A;">{p.title}</h3>
            <p class="text-sm leading-relaxed" style="color: #94A3B8;">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA strip -->
    <div class="text-center py-10">
      <a href="#contact" class="inline-flex items-center gap-2 text-sm font-semibold transition-colors" style="color: #1a4480;">
        A well-managed finance function should support your growth, not slow it down. Speak to us today
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="flex flex-col lg:flex-row min-h-screen">

    <!-- LEFT: DARK STICKY PANEL -->
    <div class="lg:flex-1 relative" style="background-color: #0F172A;">
      <!-- Subtle dot pattern -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 28px 28px;"></div>
      <!-- Glow -->
      <div class="absolute bottom-0 left-0 w-80 h-80 rounded-full blur-3xl opacity-10" style="background: #1a4480;"></div>

      <div class="relative lg:sticky lg:top-0 lg:h-screen flex flex-col justify-center px-10 xl:px-16 py-24">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-6" style="color: #3B82F6;">What We Offer</p>
        <h2 class="text-4xl xl:text-5xl font-bold leading-tight text-white mb-6" style="letter-spacing: -0.025em;">
          Accounting, Tax &amp;<br/>Financial Management<br/>Services
        </h2>
        <div class="w-10 h-px mb-7" style="background: linear-gradient(to right, #1a4480, #3B82F6);"></div>
        <p class="text-sm leading-relaxed mb-10" style="color: #64748B; max-width: 320px;">
          End-to-end financial support for businesses and individuals across the UK, USA, and UAE. From day-to-day accounting to tax, payroll, and reporting, we help you stay compliant, organised, and in control.
        </p>
        <a href="#contact" class="inline-flex items-center gap-2.5 px-7 py-3.5 text-sm font-semibold rounded-xl self-start transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480, #1e5ab5); box-shadow: 0 4px 20px rgba(26,68,128,0.5); color: white;">
          Get Started Today
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>

        <!-- Bottom trust row -->
        <div class="mt-14 pt-8 border-t flex items-center gap-6" style="border-color: #1E293B;">
          <div class="text-center">
            <p class="text-2xl font-black text-white">500+</p>
            <p class="text-xs mt-0.5" style="color: #475569;">Clients</p>
          </div>
          <div class="w-px h-10" style="background-color: #1E293B;"></div>
          <div class="text-center">
            <p class="text-2xl font-black text-white">20+</p>
            <p class="text-xs mt-0.5" style="color: #475569;">Years</p>
          </div>
          <div class="w-px h-10" style="background-color: #1E293B;"></div>
           <div class="text-center">
            <p class="text-2xl font-black text-white">3</p>
            <p class="text-xs mt-0.5" style="color: #475569;">Markets</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-black text-white">250+</p>
            <p class="text-xs mt-0.5" style="color: #475569;">Staff</p>
          </div>
          <div class="w-px h-10" style="background-color: #1E293B;"></div>
         
        </div>
      </div>
    </div>

    <!-- RIGHT: WHITE SCROLLABLE PANEL -->
    <div class="lg:flex-1 bg-white py-16 px-8 xl:px-16">
      <div>
        {[
          { num: '01', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Accounting & Bookkeeping', desc: 'Accurate and consistent financial records that give you a clear view of your business. We maintain your books, reconcile accounts, and ensure everything is up to date and reliable.' },
          { num: '02', icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z', title: 'Tax Preparation & Filing', desc: 'Complete support for business and personal tax across multiple jurisdictions. We handle filings, ensure compliance, and help you avoid unnecessary penalties.' },
          { num: '03', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', title: 'Payroll Management', desc: 'End-to-end payroll processing with full compliance. From salary calculations to filings and employee reporting, everything is handled accurately and on time.' },
          { num: '04', icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z', title: 'Accounts Payable', desc: 'Structured management of your outgoing payments. We track invoices, manage due dates, and ensure vendors are paid on time without disrupting your cash flow.' },
          { num: '05', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Accounts Receivable', desc: 'Better control over invoicing and collections. We help you stay on top of receivables, reduce delays, and maintain steady cash flow.' },
          { num: '06', icon: 'M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Financial Reporting & Insights', desc: 'Clear, structured reports that help you understand your numbers. From monthly statements to management reports, we give you the information needed to make better decisions.' },
        ].map((s, i) => (
          <div class={`relative py-10 overflow-hidden ${i < 5 ? 'border-b border-gray-100' : ''}`}>
            <!-- Ghost number behind content -->
            <span class="absolute right-0 top-4 font-black leading-none select-none pointer-events-none" style="font-size: 100px; color: rgba(26,68,128,0.04);">{s.num}</span>

            <!-- Number label -->
            <p class="text-xs font-bold tracking-[0.2em] mb-4" style="color: #CBD5E1;">{s.num}.</p>

            <!-- Icon + Title row -->
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #0F172A 0%, #1a4480 100%); box-shadow: 0 6px 16px rgba(26,68,128,0.2);">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={s.icon}/>
                </svg>
              </div>
              <h3 class="text-xl font-bold" style="color: #0F172A; letter-spacing: -0.01em;">{s.title}</h3>
            </div>

            <p class="text-sm leading-relaxed mb-5" style="color: #64748B;">{s.desc}</p>

            <a href="#contact" class="inline-flex items-center gap-1.5 text-xs font-semibold border-b pb-0.5" style="color: #1a4480; border-color: #1a4480;">
              Learn more →
            </a>
          </div>
        ))}
      </div>
    </div>

  </section>

  <!-- ===== MARQUEE STRIP ===== -->
  <div class="py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-0 whitespace-nowrap" style="animation: marquee 30s linear infinite;">
      {[...Array(2)].map(() => (
        <div class="flex items-center gap-0 flex-shrink-0">
          {[
            'Bookkeeping & Accounting',
            'Payroll Management',
            'UK GAAP',
            'HMRC Compliance',
            'US GAAP',
            'IRS Compliance',
            'UAE VAT',
            'FTA Compliance',
            'GDPR Compliant',
            'ICO Registered',
            'Financial Reporting',
            'Company Formation',
          ].map(item => (
            <div class="flex items-center gap-8 px-8">
              <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: rgba(255,255,255,0.75);">{item}</span>
              <span class="w-1 h-1 rounded-full flex-shrink-0" style="background-color: rgba(255,255,255,0.3);"></span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- ===== WHY CHOOSE US ===== -->
  <section class="py-24 overflow-hidden" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: Image -->
        <div class="relative hidden lg:block">
          <div class="absolute -top-6 -left-6 w-full h-full rounded-2xl" style="border: 1px solid #1E293B;"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=700&q=80&auto=format&fit=crop"
              alt="Expert accounting team"
              class="w-full h-[460px] object-cover"
            />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.5) 0%, transparent 60%);"></div>
          </div>
          <!-- Floating badge -->
          <div class="absolute -bottom-6 -right-6 rounded-2xl p-5 shadow-xl border" style="background-color: #1E293B; border-color: #334155;">
            <p class="text-3xl font-black text-white">500<span class="text-xl">+</span></p>
            <p class="text-xs text-gray-400 mt-1">Active Clients</p>
            <div class="flex gap-0.5 mt-2">
              {[1,2,3,4,5].map(() => <svg class="w-3 h-3" style="color: #f59e0b;" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
            </div>
          </div>
        </div>

        <!-- Right: Text + Cards -->
        <div>
          <p class="text-xs font-semibold tracking-[0.15em] uppercase mb-3" style="color: #93B4D4;">Our Advantage</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white leading-tight mb-4" style="letter-spacing: -0.02em;">Why Choose Ambit?</h2>
          <div class="w-8 h-px mb-6" style="background-color: #1a4480;"></div>
          <p class="text-sm leading-relaxed mb-8" style="color: #64748B;">
            We bring together experience, structured processes, and a global team to support businesses across the UK, USA, and UAE.
          </p>

          <div class="grid sm:grid-cols-2 gap-4 mb-8">
            {[
              { num: '20+', label: 'Years of Experience', icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' },
              { num: '500+', label: 'Clients Served', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
              { num: '250+', label: 'Accounting Professionals', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
              { num: '3', label: 'Global Markets', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
              { num: '24/7', label: 'Support & Communication', icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z' },
              { num: '100%', label: 'Data Security & Confidentiality', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
            ].map(w => (
              <div class="p-5 rounded-xl border hover:border-slate-500 hover:-translate-y-0.5 transition-all" style="background-color: #1E293B; border-color: #334155;">
                <div class="flex items-start gap-3">
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
                    <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={w.icon}/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-xl font-bold text-white leading-none mb-1">{w.num}</p>
                    <p class="text-xs leading-snug" style="color: #64748B;">{w.label}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>

