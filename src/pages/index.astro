<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('counter', (target, step) => ({
      count: 0, target, step, started: false,
      start() {
        if (this.started) return;
        this.started = true;
        const iv = setInterval(() => {
          this.count = Math.min(this.count + this.step, this.target);
          if (this.count >= this.target) clearInterval(iv);
        }, 20);
      }
    }));
    Alpine.magic('startWhenVisible', () => (el) => {
      if (!('IntersectionObserver' in window)) return;
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { Alpine.$data(el).start(); obs.unobserve(el); } });
      }, { threshold: 0.3 });
      obs.observe(el);
    });
  });
</script>
