---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | Ambit Accounting & Bookkeeping" description="Get in touch with Ambit. Have questions about outsourcing your accounting or bookkeeping? Our team is ready to help — we respond within 24 hours.">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[70vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=1800&q=80"
        alt="Contact Ambit"
        class="w-full h-full object-cover"
        style="opacity: 0.1;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 55%, #1a4480 100%); opacity: 0.94;"></div>
    </div>

    <div class="absolute top-20 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.13;"></div>
    <div class="absolute bottom-16 left-12 w-64 h-64 rounded-full blur-3xl" style="background: #3B82F6; opacity: 0.07;"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12 py-28 text-center">

      <div
        x-show="visible"
        x-transition:enter="transition duration-700"
        x-transition:enter-start="opacity-0 -translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-8"
        style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
      >
        <svg class="w-3.5 h-3.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Contact Us
      </div>

      <h1
        x-show="visible"
        x-transition:enter="transition duration-700 delay-100"
        x-transition:enter-start="opacity-0 translate-y-6"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-4xl lg:text-6xl xl:text-7xl font-black leading-none mb-8 text-white"
        style="letter-spacing: -0.03em;"
      >
        Get in Touch<br />
        <span style="color: #3B82F6;">with Ambit</span>
      </h1>

      <p
        x-show="visible"
        x-transition:enter="transition duration-700 delay-200"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-xl leading-relaxed mb-10 max-w-2xl mx-auto"
        style="color: #94A3B8;"
      >
        Have questions about outsourcing your accounting or bookkeeping? Our team is ready to help.
      </p>

      <div
        x-show="visible"
        x-transition:enter="transition duration-700 delay-300"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="flex flex-wrap justify-center gap-4 mb-16"
      >
        <a href="#contact-form" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
          Book Free Consultation
        </a>
        <a href="#contact-details" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
          View Contact Details
        </a>
      </div>

      <!-- Response time badges -->
      <div
        x-show="visible"
        x-transition:enter="transition duration-700 delay-400"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        class="flex flex-wrap justify-center gap-4"
      >
        {[
          { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Responds within 24 hours' },
          { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', label: 'Free consultation call' },
          { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'USA · UK · UAE coverage' },
        ].map(({ icon, label }) => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
            <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: #3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
            </svg>
            {label}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 30s linear infinite; width: max-content;">
      {[
        '✔ Free Consultation', '✔ 24-Hour Response', '✔ No Obligation', '✔ USA · UK · UAE',
        '✔ 280+ Clients Helped', '✔ 12+ Years Experience', '✔ CPA-Trained Team', '✔ 99.8% Accuracy',
        '✔ Free Consultation', '✔ 24-Hour Response', '✔ No Obligation', '✔ USA · UK · UAE',
        '✔ 280+ Clients Helped', '✔ 12+ Years Experience', '✔ CPA-Trained Team', '✔ 99.8% Accuracy',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== FORM + DETAILS ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-10">

        <!-- ===== CONTACT FORM ===== -->
        <div id="contact-form">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100" style="padding: 2.5rem;">
            <div class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #1a4480;">Send a Message</div>
            <h2 class="text-3xl font-black mb-2" style="color: #0F172A; letter-spacing: -0.02em;">Reach Out to Us</h2>
            <p class="text-sm mb-8" style="color: #64748B;">Fill in the form below and we'll get back to you within 24 hours.</p>

            <form class="space-y-5" x-data="{ submitted: false }" @submit.prevent="submitted = true">

              <!-- Full Name -->
              <div>
                <label class="block text-xs font-semibold mb-2 uppercase tracking-wide" style="color: #374151;">Full Name <span style="color: #EF4444;">*</span></label>
                <input type="text" placeholder="John Smith" required
                  class="w-full px-4 py-3 rounded-xl text-sm border outline-none"
                  style="border-color: #E2E8F0; color: #0F172A; background-color: #F8FAFC;"
                  onfocus="this.style.borderColor='#1a4480'; this.style.boxShadow='0 0 0 3px rgba(26,68,128,0.12)';"
                  onblur="this.style.borderColor='#E2E8F0'; this.style.boxShadow='none';" />
              </div>

              <!-- Email -->
              <div>
                <label class="block text-xs font-semibold mb-2 uppercase tracking-wide" style="color: #374151;">Email Address <span style="color: #EF4444;">*</span></label>
                <input type="email" placeholder="john@company.com" required
                  class="w-full px-4 py-3 rounded-xl text-sm border outline-none"
                  style="border-color: #E2E8F0; color: #0F172A; background-color: #F8FAFC;"
                  onfocus="this.style.borderColor='#1a4480'; this.style.boxShadow='0 0 0 3px rgba(26,68,128,0.12)';"
                  onblur="this.style.borderColor='#E2E8F0'; this.style.boxShadow='none';" />
              </div>

              <!-- Phone -->
              <div>
                <label class="block text-xs font-semibold mb-2 uppercase tracking-wide" style="color: #374151;">Phone Number</label>
                <input type="tel" placeholder="+1 (555) 000-0000"
                  class="w-full px-4 py-3 rounded-xl text-sm border outline-none"
                  style="border-color: #E2E8F0; color: #0F172A; background-color: #F8FAFC;"
                  onfocus="this.style.borderColor='#1a4480'; this.style.boxShadow='0 0 0 3px rgba(26,68,128,0.12)';"
                  onblur="this.style.borderColor='#E2E8F0'; this.style.boxShadow='none';" />
              </div>

              <!-- Company -->
              <div>
                <label class="block text-xs font-semibold mb-2 uppercase tracking-wide" style="color: #374151;">Company Name</label>
                <input type="text" placeholder="Acme Inc."
                  class="w-full px-4 py-3 rounded-xl text-sm border outline-none"
                  style="border-color: #E2E8F0; color: #0F172A; background-color: #F8FAFC;"
                  onfocus="this.style.borderColor='#1a4480'; this.style.boxShadow='0 0 0 3px rgba(26,68,128,0.12)';"
                  onblur="this.style.borderColor='#E2E8F0'; this.style.boxShadow='none';" />
              </div>

              <!-- Service -->
              <div>
                <label class="block text-xs font-semibold mb-2 uppercase tracking-wide" style="color: #374151;">Service of Interest</label>
                <select class="w-full px-4 py-3 rounded-xl text-sm border outline-none"
                  style="border-color: #E2E8F0; color: #64748B; background-color: #F8FAFC;"
                  onfocus="this.style.borderColor='#1a4480'; this.style.boxShadow='0 0 0 3px rgba(26,68,128,0.12)';"
                  onblur="this.style.borderColor='#E2E8F0'; this.style.boxShadow='none';">
                  <option value="" disabled selected>Select a service...</option>
                  <option>Accounting & Bookkeeping</option>
                  <option>Payroll Management</option>
                  <option>Tax Preparation & Filing</option>
                  <option>Accounts Payable & Receivable</option>
                  <option>Financial Reporting</option>
                  <option>Offshore Accounting Teams</option>
                  <option>Other / Not Sure</option>
                </select>
              </div>

              <!-- Message -->
              <div>
                <label class="block text-xs font-semibold mb-2 uppercase tracking-wide" style="color: #374151;">Message / Requirements <span style="color: #EF4444;">*</span></label>
                <textarea rows="5" placeholder="Tell us about your business and what you're looking for..." required
                  class="w-full px-4 py-3 rounded-xl text-sm border outline-none resize-none"
                  style="border-color: #E2E8F0; color: #0F172A; background-color: #F8FAFC;"
                  onfocus="this.style.borderColor='#1a4480'; this.style.boxShadow='0 0 0 3px rgba(26,68,128,0.12)';"
                  onblur="this.style.borderColor='#E2E8F0'; this.style.boxShadow='none';"></textarea>
              </div>

              <!-- Submit -->
              <button type="submit" x-show="!submitted"
                class="w-full py-4 text-sm font-bold text-white rounded-xl transition-all hover:opacity-90"
                style="background-color: #1a4480;">
                Submit Inquiry
              </button>

              <!-- Success -->
              <div x-show="submitted" x-transition
                class="w-full py-4 rounded-xl text-center flex items-center justify-center gap-3"
                style="background-color: #ECFDF5; border: 1px solid #86EFAC;">
                <svg class="w-5 h-5" style="color: #22C55E;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm font-semibold" style="color: #15803D;">Message sent! We'll be in touch within 24 hours.</span>
              </div>

              <p class="text-xs text-center" style="color: #94A3B8;">
                We'll respond within 24 hours and guide you on the best solution for your business.
              </p>
            </form>
          </div>
        </div>

        <!-- ===== CONTACT DETAILS ===== -->
        <div class="flex flex-col gap-5" id="contact-details">

          <div>
            <div class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #1a4480;">Direct Contact</div>
            <h2 class="text-3xl font-black mb-1" style="color: #0F172A; letter-spacing: -0.02em;">Connect With Us Directly</h2>
            <p class="text-sm mb-6" style="color: #64748B;">Reach our team via email, phone, or choose your region below.</p>
          </div>

          <!-- Contact cards -->
          <!-- Email -->
          <div class="bg-white rounded-2xl border border-gray-100 hover:shadow-md transition-shadow" style="padding: 1.25rem 1.5rem;">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="min-w-0">
                <div class="text-xs font-bold uppercase tracking-widest mb-0.5" style="color: #94A3B8;">Email Us</div>
                <a href="mailto:nishant@ambitsol.co" class="text-sm font-bold hover:underline block truncate" style="color: #0F172A;">nishant@ambitsol.co</a>
                <div class="text-xs" style="color: #94A3B8;">We reply within 24 hours</div>
              </div>
            </div>
          </div>

          <!-- Phone numbers -->
          <div class="bg-white rounded-2xl border border-gray-100 hover:shadow-md transition-shadow" style="padding: 1.25rem 1.5rem;">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #94A3B8;">Call Us</div>
                <div class="space-y-1.5">
                  <a href="tel:+442038132922" class="flex items-center gap-2 text-sm font-bold hover:underline" style="color: #0F172A;">
                    <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-4 h-2.5 object-cover rounded-sm opacity-70 flex-shrink-0" />
                    +44 203 8132 922
                  </a>
                  <a href="tel:+17068949160" class="flex items-center gap-2 text-sm font-bold hover:underline" style="color: #0F172A;">
                    <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-4 h-2.5 object-cover rounded-sm opacity-70 flex-shrink-0" />
                    +1 706-894-9160
                  </a>
                  <a href="tel:+919825016079" class="flex items-center gap-2 text-sm font-bold hover:underline" style="color: #0F172A;">
                    <img src="https://flagcdn.com/w20/in.png" alt="India" class="w-4 h-2.5 object-cover rounded-sm opacity-70 flex-shrink-0" />
                    +91 9825 016 079
                  </a>
                </div>
                <div class="text-xs mt-1.5" style="color: #94A3B8;">Mon – Fri, 9am – 6pm</div>
              </div>
            </div>
          </div>

          <!-- Address -->
          <!-- <div class="bg-white rounded-2xl border border-gray-100 hover:shadow-md transition-shadow" style="padding: 1.25rem 1.5rem;">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div class="min-w-0">
                <div class="text-xs font-bold uppercase tracking-widest mb-0.5" style="color: #94A3B8;">Our Address</div>
                <div class="text-sm font-bold" style="color: #0F172A;">London, United Kingdom</div>
                <div class="text-xs" style="color: #94A3B8;">Serving USA · UK · UAE</div>
              </div>
            </div>
          </div> -->

          <!-- Regional offices -->
          <!-- <div class="rounded-2xl" style="background-color: #0F172A; padding: 1.75rem;">
            <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #64748B;">Regional Coverage</div>
            <div class="space-y-4">
              {[
                { flag: 'us', label: 'United States', detail: 'US Accounting & Tax Services', email: 'us@ambit.com' },
                { flag: 'gb', label: 'United Kingdom', detail: 'UK Accounting & Payroll', email: 'uk@ambit.co.uk' },
                { flag: 'ae', label: 'UAE / Dubai', detail: 'UAE VAT, Payroll & Accounting', email: 'uae@ambit.ae' },
              ].map(({ flag, label, detail, email }) => (
                <div class="flex items-center gap-3 pb-4 border-b last:border-0 last:pb-0" style="border-color: #1E293B;">
                  <img src={`https://flagcdn.com/w20/${flag}.png`} alt={label} class="w-6 h-4 object-cover rounded-sm flex-shrink-0" />
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-bold text-white">{label}</div>
                    <div class="text-xs" style="color: #64748B;">{detail}</div>
                  </div>
                  <a href={`mailto:${email}`} class="text-xs font-medium hover:underline flex-shrink-0" style="color: #3B82F6;">{email}</a>
                </div>
              ))}
            </div>
          </div> -->

          <!-- Response promise -->
          <div class="rounded-2xl border flex items-start gap-4" style="background-color: #EFF6FF; border-color: #BFDBFE; padding: 1.25rem 1.5rem;">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #1a4480;">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <div class="text-sm font-bold mb-1" style="color: #1a4480;">Our Response Promise</div>
              <div class="text-xs leading-relaxed" style="color: #374151;">We respond to every inquiry within <strong>24 hours</strong>. For urgent matters, call us directly.</div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQs ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Common Questions</div>
        <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">Frequently Asked Questions</h2>
        <p class="text-lg" style="color: #64748B;">Still have questions? Read through our FAQs or contact us directly.</p>
      </div>

      <div class="space-y-4" x-data="{ open: null }">
        {[
          { q: 'How quickly can Ambit get started on my accounting?', a: 'Most clients are fully onboarded within 1 week. After our discovery call and agreement on scope, we handle setup, data migration, and software integration so you can hit the ground running.' },
          { q: 'Is my financial data secure with Ambit?', a: 'Absolutely. We follow strict data security protocols, including encrypted file transfers, secure access controls, and NDA agreements with all team members. Your data is always confidential.' },
          { q: 'Do you only serve US businesses?', a: 'We primarily serve US, UK, and UAE businesses. Each region has a dedicated team familiar with local accounting standards, tax regulations, and compliance requirements.' },
          { q: 'Can I scale my accounting team up or down?', a: 'Yes — our offshore staffing model is fully flexible. Whether you need one part-time bookkeeper or a full dedicated accounting team, we can scale to match your business needs.' },
          { q: 'What accounting software do you support?', a: 'We work with all major platforms including QuickBooks, Xero, NetSuite, FreshBooks, Sage, Wave, and more. If you use something else, we\'ll adapt.' },
        ].map(({ q, a }, i) => (
          <div class="rounded-2xl border overflow-hidden" style="border-color: #E2E8F0;">
            <button
              class="w-full flex items-center justify-between text-left px-6 py-5 hover:bg-gray-50 transition-colors"
              @click={`open = open === ${i} ? null : ${i}`}
            >
              <span class="text-sm font-bold pr-4" style="color: #0F172A;">{q}</span>
              <svg
                class="w-4 h-4 flex-shrink-0 transition-transform"
                :class={`open === ${i} ? 'rotate-180' : ''`}
                style="color: #94A3B8;"
                fill="none" viewBox="0 0 24 24" stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div
              x-show={`open === ${i}`}
              x-transition
              class="px-6 pb-5"
            >
              <p class="text-sm leading-relaxed" style="color: #64748B;">{a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="py-24 px-6 lg:px-12" style="background: linear-gradient(135deg, #0F172A 0%, #1a4480 100%);">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #94A3B8;">Start Today</div>
      <h2 class="text-4xl lg:text-5xl font-black text-white mb-6" style="letter-spacing: -0.02em;">
        Let's Simplify Your<br />Accounting Together
      </h2>
      <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: #94A3B8;">
        Join 280+ businesses that trust Ambit for accurate, cost-effective, and reliable accounting solutions.
      </p>
      <a href="#contact-form" class="inline-flex items-center gap-2 px-10 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #3B82F6;">
        Book Free Consultation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

