---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Terms of Use | Ambit" description="Terms governing your use of the Ambit website, including acceptable use, intellectual property, limitation of liability, and governing law.">
  <Navbar />

  <main style="background-color: #0F172A; min-height: 100vh;">

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden" style="background-color: #060D18; border-bottom: 1px solid #1E293B;">
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
      <div class="relative max-w-4xl mx-auto px-6 lg:px-12 py-24">
        <div class="flex items-center gap-2 mb-6">
          <a href="/" class="text-xs transition-colors hover:opacity-80" style="color: #475569;">Home</a>
          <svg class="w-3 h-3" style="color: #334155;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-xs" style="color: #64748B;">Terms of Use</span>
        </div>
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Legal</p>
        <h1 class="text-4xl lg:text-5xl font-black mb-4" style="color: #F8FAFC;">Terms of Use</h1>
        <p class="text-sm" style="color: #475569;">Last updated: April 2026</p>
      </div>
    </section>

    <!-- ===== CONTENT ===== -->
    <section class="max-w-4xl mx-auto px-6 lg:px-12 py-16 lg:py-24">

      <!-- Intro -->
      <div class="mb-12 pb-12" style="border-bottom: 1px solid #1E293B;">
        <p class="text-base leading-relaxed" style="color: #94A3B8;">
          These terms govern your use of this website. By accessing or using this website, you agree to be bound by these terms. If you do not agree, you should not use this website.
        </p>
      </div>

      <!-- Sections -->
      <div class="space-y-12">

        <!-- 1 -->
        <div id="about" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">1</span>
            About this website
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            This website is operated by Ambit ("we", "us", or "our"). It provides general information about our services, capabilities, and areas of expertise.
          </p>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            Access to this website is provided on a temporary basis. We may update, modify, suspend, or withdraw any part of the website without notice.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            We do not guarantee that the website, or any content on it, will always be available or uninterrupted.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 2 -->
        <div id="use" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">2</span>
            Use of the website
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            You may use this website for lawful purposes only.
          </p>
          <p class="text-sm font-semibold mb-3" style="color: #94A3B8;">You agree not to:</p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              misuse the website or attempt to interfere with its operation
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              attempt unauthorised access to any part of the website or related systems
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              introduce malicious or harmful material
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              use the website in any way that could damage its performance or security
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            We reserve the right to restrict or terminate access where these terms are not complied with.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 3 -->
        <div id="ip" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">3</span>
            Intellectual property
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            All content on this website, including text, graphics, design, and structure, is owned by or licensed to Ambit and is protected by applicable intellectual property laws.
          </p>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            You may view, download, or print content for your own internal or personal reference only.
          </p>
          <p class="text-sm font-semibold mb-3" style="color: #94A3B8;">You may not:</p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              reproduce, distribute, or commercially exploit any content
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              modify or adapt materials
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              use content separately from its context
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Our status as the owner of the content must not be removed or altered.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 4 -->
        <div id="no-reliance" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">4</span>
            No reliance on information
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            The content on this website is provided for general information only.
          </p>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            It does not constitute accounting, tax, legal, or professional advice and should not be relied upon as such.
          </p>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            Before taking or refraining from any action based on the content of this website, appropriate professional advice should be obtained.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            We accept no responsibility for any loss arising from reliance on information contained on this website.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 5 -->
        <div id="accuracy" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">5</span>
            Accuracy of information
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            While we aim to ensure that information on this website is accurate and up to date, we make no representations or warranties, express or implied, as to its completeness or accuracy.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Content may be updated or changed at any time without notice.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 6 -->
        <div id="liability" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">6</span>
            Limitation of liability
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            To the extent permitted by law, Ambit excludes all liability for any loss or damage arising from:
          </p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              use of, or inability to use, this website
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              reliance on any content displayed on the website
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              technical inaccuracies or omissions
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Nothing in these terms limits liability where it would be unlawful to do so.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 7 -->
        <div id="third-party" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">7</span>
            Links to third-party websites
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            This website may contain links to third-party websites for convenience.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            We have no control over the content of such websites and accept no responsibility for them or for any loss or damage that may arise from their use.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 8 -->
        <div id="linking" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">8</span>
            Linking to our website
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
            You may link to our homepage provided that:
          </p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              the link is fair and lawful
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              it does not damage our reputation
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              it does not suggest any association or endorsement where none exists
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            We reserve the right to withdraw linking permission at any time.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 9 -->
        <div id="security" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">9</span>
            Website security
          </h2>
          <p class="text-sm font-semibold mb-3" style="color: #94A3B8;">You must not:</p>
          <ul class="space-y-2 mb-4">
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              introduce viruses or malicious code
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              attempt to gain unauthorised access to systems or data
            </li>
            <li class="flex items-start gap-3 text-sm" style="color: #64748B;">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></span>
              disrupt or attack the website
            </li>
          </ul>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Any such activity may be reported to relevant authorities.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 10 -->
        <div id="privacy" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">10</span>
            Privacy
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            We process personal data in accordance with our <a href="/privacy" class="transition-colors hover:opacity-80" style="color: #93C5FD;">Privacy Policy</a>.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            By using this website, you confirm that any data you provide is accurate and that you consent to such processing.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 11 -->
        <div id="changes" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">11</span>
            Changes to these terms
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            We may revise these terms at any time by updating this page.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Continued use of the website constitutes acceptance of any changes.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 12 -->
        <div id="governing-law" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">12</span>
            Governing law
          </h2>
          <p class="text-sm leading-relaxed mb-3" style="color: #64748B;">
            These terms are governed by and construed in accordance with applicable laws of the United Kingdom.
          </p>
          <p class="text-sm leading-relaxed" style="color: #64748B;">
            Any disputes arising in connection with these terms shall be subject to the jurisdiction of the relevant courts.
          </p>
        </div>

        <div style="border-top: 1px solid #1E293B;"></div>

        <!-- 13 - Contact -->
        <div id="contact" class="scroll-mt-24">
          <h2 class="text-lg font-bold mb-6 flex items-center gap-3" style="color: #F8FAFC;">
            <span class="text-xs font-black px-2 py-1 rounded" style="background-color: #1E293B; color: #1a4480;">13</span>
            Contact
          </h2>
          <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <p class="text-sm leading-relaxed mb-5" style="color: #64748B;">
              For any questions regarding these terms:
            </p>
            <a
              href="mailto:nishant@ambitsol.co"
              class="inline-flex items-center gap-3 text-sm font-semibold transition-opacity hover:opacity-80"
              style="color: #93C5FD;"
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              nishant@ambitsol.co
            </a>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>
