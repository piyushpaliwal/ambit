---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us | Ambit Accounting & Bookkeeping" description="Ambit — your trusted accounting and bookkeeping partner for US, UK, and UAE businesses. 12+ years of experience, 280+ clients, and a mission to simplify finance.">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[88vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1800&q=80"
        alt="Ambit team"
        class="w-full h-full object-cover"
        style="opacity: 0.15;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 45%, #1a4480 100%); opacity: 0.9;"></div>
    </div>

    <div class="absolute top-20 right-24 w-96 h-96 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.12;"></div>
    <div class="absolute bottom-20 left-16 w-72 h-72 rounded-full blur-3xl" style="background: #3B82F6; opacity: 0.07;"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12 py-32 text-center">

      <div
        x-show="visible"
        x-transition:enter="transition duration-700"
        x-transition:enter-start="opacity-0 -translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-8"
        style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
      >
        <svg class="w-3.5 h-3.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        About Ambit
      </div>

      <h1
        x-show="visible"
        x-transition:enter="transition duration-700 delay-100"
        x-transition:enter-start="opacity-0 translate-y-6"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-4xl lg:text-6xl xl:text-7xl font-black leading-none mb-8 text-white"
        style="letter-spacing: -0.03em;"
      >
        Your Trusted Accounting<br />
        <span style="color: #3B82F6;">&amp; Bookkeeping Partner</span><br />
        in the USA
      </h1>

      <p
        x-show="visible"
        x-transition:enter="transition duration-700 delay-200"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-xl leading-relaxed mb-10 max-w-2xl mx-auto"
        style="color: #94A3B8;"
      >
        Empowering businesses with accurate, timely, and cost-effective financial solutions, so you can focus on growth.
      </p>

      <div
        x-show="visible"
        x-transition:enter="transition duration-700 delay-300"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="flex flex-wrap justify-center gap-4 mb-16"
      >
        <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
          Book Free Consultation
        </a>
        <a href="#our-story" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
          Our Story
        </a>
      </div>

      <!-- Stats row -->
      <div
        x-show="visible"
        x-transition:enter="transition duration-700 delay-400"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto pt-12 border-t"
        style="border-color: #1E293B;"
      >
        {[
          { val: '12+', label: 'Years of Experience' },
          { val: '280+', label: 'Businesses Helped' },
          { val: '99.8%', label: 'Accuracy Rate' },
          { val: '60%', label: 'Average Cost Saving' },
        ].map(({ val, label }) => (
          <div>
            <div class="text-3xl font-black text-white mb-1">{val}</div>
            <div class="text-xs" style="color: #64748B;">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 30s linear infinite; width: max-content;">
      {[
        '✔ 12+ Years Experience',
        '✔ 280+ Businesses Helped',
        '✔ USA · UK · UAE Coverage',
        '✔ 99.8% Accuracy Rate',
        '✔ CPA-Trained Professionals',
        '✔ 60% Cost Reduction',
        '✔ 12+ Years Experience',
        '✔ 280+ Businesses Helped',
        '✔ USA · UK · UAE Coverage',
        '✔ 99.8% Accuracy Rate',
        '✔ CPA-Trained Professionals',
        '✔ 60% Cost Reduction',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== OUR STORY ===== -->
  <section id="our-story" class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="relative">
          <img
            src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=800&q=80"
            alt="Ambit team collaboration"
            class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl"
          />
          <div class="absolute top-6 -right-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #3B82F6;">2012</div>
            <div class="text-xs" style="color: #64748B;">Founded</div>
          </div>
          <div class="absolute bottom-6 -left-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #22C55E;">280+</div>
            <div class="text-xs" style="color: #64748B;">Clients Served</div>
          </div>
        </div>

        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Who We Are</div>
          <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">Our Story</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: #64748B;">
            Ambit was founded with a simple mission: to simplify accounting and bookkeeping for US businesses. With over <strong style="color: #0F172A;">12 years of experience</strong>, we've helped <strong style="color: #0F172A;">280+ businesses</strong> streamline their financial processes, reduce operational costs, and gain real-time financial clarity.
          </p>
          <p class="text-lg leading-relaxed" style="color: #64748B;">
            Our offshore accounting model combines highly skilled professionals, cutting-edge technology, and a commitment to client success. We don't just handle numbers — we provide insights that help your business <strong style="color: #0F172A;">grow smarter and faster</strong>.
          </p>

          <!-- Country flags -->
          <div class="flex items-center gap-4 mt-10">
            <span class="text-xs font-semibold uppercase tracking-widest" style="color: #64748B;">Serving</span>
            {[
              { flag: 'us', label: 'USA' },
              { flag: 'gb', label: 'UK' },
              { flag: 'ae', label: 'UAE' },
            ].map(({ flag, label }) => (
              <div class="flex items-center gap-2 px-3 py-2 rounded-lg" style="background-color: #F8FAFC; border: 1px solid #E2E8F0;">
                <img src={`https://flagcdn.com/w20/${flag}.png`} alt={label} class="w-5 h-3.5 object-cover rounded-sm" />
                <span class="text-xs font-semibold" style="color: #374151;">{label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MISSION & VISION ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8 items-stretch">

        <!-- Mission -->
        <div class="bg-white rounded-2xl p-10 shadow-sm border border-gray-100 flex flex-col">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: #EFF6FF;">
            <svg class="w-6 h-6" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Our Mission</div>
          <h3 class="text-2xl font-black mb-4" style="color: #0F172A;">Simplify. Empower. Grow.</h3>
          <p class="text-base leading-relaxed mb-8" style="color: #64748B;">
            To deliver accurate, efficient, and scalable accounting solutions to US businesses while ensuring confidentiality, reliability, and personalised service.
          </p>
          <ul class="space-y-3 mt-auto">
            {[
              'Reduce accounting costs without compromising quality',
              'Provide real-time financial insights for better decisions',
              'Offer flexible offshore staffing solutions tailored to your needs',
              'Ensure compliance with US tax and financial regulations',
            ].map(item => (
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #EFF6FF;">
                  <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-sm leading-relaxed" style="color: #374151;">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Vision -->
        <div class="rounded-2xl p-10 flex flex-col" style="background-color: #0F172A;">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: #1E293B;">
            <svg class="w-6 h-6" style="color: #3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Our Vision</div>
          <h3 class="text-2xl font-black mb-4 text-white">The Most Trusted Offshore Accounting Partner</h3>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8;">
            To be the most trusted offshore accounting partner for US businesses, setting new standards in accuracy, efficiency, and innovation in bookkeeping and financial management.
          </p>
          <div class="grid grid-cols-2 gap-4 pt-8 border-t mt-auto" style="border-color: #1E293B;">
            {[
              { val: '12+', label: 'Years of Experience' },
              { val: '280+', label: 'Businesses Helped' },
              { val: '99.8%', label: 'Accuracy Rate' },
              { val: '60%', label: 'Cost Savings' },
            ].map(({ val, label }) => (
              <div>
                <div class="text-2xl font-black mb-1" style="color: #3B82F6;">{val}</div>
                <div class="text-xs" style="color: #64748B;">{label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY AMBIT ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Why Choose Us</div>
        <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">Why Ambit is Different</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          We understand that accounting is not just about numbers — it's about making smart business decisions.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            title: 'Expert Team',
            desc: 'Certified accounting professionals with deep USA accounting and tax experience across all industries.',
          },
          {
            icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z',
            title: 'Technology-Driven',
            desc: 'AI-assisted dashboards and real-time reporting so you always have full financial visibility.',
          },
          {
            icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
            title: 'Cost-Effective',
            desc: 'Save up to 60% compared to in-house accounting — without sacrificing quality or compliance.',
          },
          {
            icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
            title: 'Reliable & Transparent',
            desc: '99.8% accuracy with timely delivery — you always know exactly where your finances stand.',
          },
          {
            icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
            title: 'Flexible Engagement',
            desc: 'Scale your accounting resources up or down as your business evolves — no long-term lock-in.',
          },
          {
            icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
            title: 'Client-Centric',
            desc: 'We adapt our processes to fit your business — not the other way around. Your success is our metric.',
          },
        ].map(({ icon, title, desc }) => (
          <div class="p-8 rounded-2xl border border-gray-100 hover:shadow-md hover:border-blue-100 transition-all" style="background-color: #FAFAFA;">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background-color: #EFF6FF;">
              <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <h3 class="text-base font-bold mb-2" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== OUR TEAM ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">The People</div>
        <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">Meet the People Behind Ambit</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          A team of chartered accountants, CPA-trained professionals, and offshore accounting experts committed to your financial success.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            name: 'Nishant Sharma',
            role: 'Founder & CEO',
            img: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80',
            tag: 'Leadership',
          },
          {
            name: 'Coming Soon',
            role: 'Head of Accounting Services',
            img: null,
            tag: 'Accounting',
          },
          {
            name: 'Coming Soon',
            role: 'Senior CPA Consultant',
            img: null,
            tag: 'Tax & Compliance',
          },
          {
            name: 'Coming Soon',
            role: 'Offshore Operations Lead',
            img: null,
            tag: 'Operations',
          },
        ].map(({ name, role, img, tag }) => (
          <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="h-48 relative" style="background-color: #1E293B;">
              {img ? (
                <img src={img} alt={name} class="w-full h-full object-cover object-top" style="opacity: 0.85;" />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <div class="w-20 h-20 rounded-full flex items-center justify-center" style="background-color: #334155;">
                    <svg class="w-10 h-10" style="color: #64748B;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  </div>
                </div>
              )}
              <div class="absolute top-3 left-3">
                <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background-color: rgba(26,68,128,0.85); color: white;">{tag}</span>
              </div>
            </div>
            <div class="p-5">
              <div class="text-sm font-bold mb-1" style="color: #0F172A;">{name}</div>
              <div class="text-xs" style="color: #64748B;">{role}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW WE WORK ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Our Approach</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">How We Work</h2>
      </div>

      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-px" style="background-color: #1E293B;"></div>
        <div class="space-y-10">
          {[
            { step: '01', title: 'Discovery', desc: 'We take time to deeply understand your business needs, challenges, and financial goals.' },
            { step: '02', title: 'Customised Planning', desc: 'Design accounting solutions specifically tailored for your operations, industry, and scale.' },
            { step: '03', title: 'Execution', desc: 'Accurate bookkeeping, tax management, payroll, and financial reporting — delivered on time, every time.' },
            { step: '04', title: 'Insights & Reporting', desc: 'Actionable financial insights and clear reports to help you make confident, data-driven decisions.' },
            { step: '05', title: 'Ongoing Support', desc: 'Continuous assistance, proactive advisory, and the ability to scale your accounting team as you grow.' },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-8 items-start">
              <div class="relative flex-shrink-0">
                <div class="w-16 h-16 rounded-full flex items-center justify-center text-sm font-black border-4 shadow" style="background-color: #1a4480; color: white; border-color: #0F172A;">
                  {step}
                </div>
              </div>
              <div class="pt-3">
                <h3 class="text-xl font-bold mb-2 text-white">{title}</h3>
                <p class="text-base leading-relaxed" style="color: #94A3B8;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIAL ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Client Impact</div>
        <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">Our Clients Speak</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">
          Over the years, we've helped businesses save time, reduce costs, and gain clarity in their financials. Our success is measured by the success of our clients.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {[
          { val: 'Time Saved', stat: '10h+', sub: 'per week on average' },
          { val: 'Cost Reduced', stat: '60%', sub: 'vs in-house accounting' },
          { val: 'Accuracy', stat: '99.8%', sub: 'financial reporting rate' },
        ].map(({ val, stat, sub }) => (
          <div class="text-center p-8 rounded-2xl border border-gray-100" style="background-color: #F8FAFC;">
            <div class="text-3xl font-black mb-2" style="color: #1a4480;">{stat}</div>
            <div class="text-sm font-bold mb-1" style="color: #0F172A;">{val}</div>
            <div class="text-xs" style="color: #64748B;">{sub}</div>
          </div>
        ))}
      </div>

      <!-- Featured testimonial -->
      <div class="p-10 rounded-2xl" style="background-color: #0F172A; border: 1px solid #1E293B;">
        <div class="flex gap-1 mb-6">
          {[1,2,3,4,5].map(() => (
