---
import UAELayout from '../../../../layouts/UAELayout.astro';
---

<UAELayout title="UAE Business Formation | Freezone & Mainland Company Setup | Ambit" description="Company setup structured for regulatory compliance, tax alignment, and operational readiness across UAE Freezone and Mainland jurisdictions. Corporate tax and VAT registration included.">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(26,68,128,0.18) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-12 py-24 lg:py-32">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase" style="background-color: rgba(26,68,128,0.25); border: 1px solid rgba(26,68,128,0.4); color: #93C5FD;">
          <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-4 h-3 object-cover rounded-sm" />
          United Arab Emirates · Business Formation
        </div>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight mb-6" style="color: #F8FAFC;">
        Business Formation
        <span class="block" style="color: #93C5FD;">United Arab Emirates</span>
      </h1>

      <p class="text-lg md:text-xl max-w-2xl mb-12 leading-relaxed" style="color: #94A3B8;">
        Company setup structured to ensure regulatory compliance, tax alignment, and operational readiness across Freezone and Mainland jurisdictions.
      </p>

      <div class="flex flex-wrap gap-3 mb-14">
        {['IFRS Aligned', 'FTA Compliant', 'UAE Labour Law Aligned', 'VAT Compliant', 'Corporate Tax Ready'].map(label => (
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">{label}</span>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          Speak to an Expert
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#process" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-semibold transition-all hover:opacity-80" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITY MARQUEE ===== -->
  <div class="overflow-hidden py-4" style="background-color: #0F172A; border-top: 1px solid #1E293B; border-bottom: 1px solid #1E293B;">
    <div class="flex gap-12 whitespace-nowrap animate-marquee text-xs font-semibold tracking-widest uppercase" style="color: #ffffff;">
      {[
        'IFRS-aligned financial reporting',
        'FTA compliance across VAT and corporate tax',
        'UAE Labour Law payroll alignment',
        'Corporate tax and VAT structuring',
        'Consistent reporting across periods',
        'Structured financial workflows',
        'Freezone and Mainland alignment',
        'Platform-aligned accounting',
        'IFRS-aligned financial reporting',
        'FTA compliance across VAT and corporate tax',
        'UAE Labour Law payroll alignment',
        'Corporate tax and VAT structuring',
        'Consistent reporting across periods',
        'Structured financial workflows',
        'Freezone and Mainland alignment',
        'Platform-aligned accounting',
      ].map(item => (
        <span class="flex items-center gap-3">
          <span class="w-1 h-1 rounded-full inline-block" style="background-color: #1a4480;"></span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ===== CERTIFICATION BLOCK ===== -->
  <section style="background-color: #060D18; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-10">
      <div class="flex flex-wrap items-center gap-6">
        <span class="text-xs font-bold tracking-widest uppercase" style="color: #334155;">Certified</span>
        {['ISO 27001 Certified', 'FTA Registered'].map(cert => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background-color: #0F172A; border: 1px solid #1E293B;">
            <svg class="w-4 h-4" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            <span class="text-xs font-semibold" style="color: #94A3B8;">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== METRICS STRIP ===== -->
  <section style="background-color: #0F172A; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { metric: 'Structured', label: 'Company setup', sub: 'Freezone and Mainland coverage' },
          { metric: 'Regulatory', label: 'Alignment', sub: 'UAE compliance from day one' },
          { metric: 'Tax-aware', label: 'Foundation', sub: 'CT and VAT aligned from setup' },
          { metric: 'Operational', label: 'Readiness', sub: 'Ready to trade without delays' },
        ].map(({ metric, label, sub }) => (
          <div class="text-center lg:text-left">
            <div class="text-3xl lg:text-4xl font-black mb-1" style="color: #F8FAFC;">{metric}</div>
            <div class="text-sm font-semibold mb-1" style="color: #93C5FD;">{label}</div>
            <div class="text-xs" style="color: #475569;">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight max-w-3xl" style="color: #F8FAFC;">
          How a Business Is Structured in the UAE Determines Compliance and Tax Position
        </h2>
        <p class="mt-4 text-base max-w-2xl leading-relaxed" style="color: #64748B;">
          Business formation in the UAE is not limited to registration. The choice between Freezone and Mainland, along with licensing and operational structure, directly impacts tax exposure, VAT treatment, and compliance obligations. A structured setup avoids future rework and ensures alignment from the outset.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            title: 'Correct Structure from Day One',
            body: 'Entity setup aligned with business model and operational needs.',
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
          },
          {
            title: 'Alignment with Tax and Compliance',
            body: 'Formation aligned with corporate tax, VAT, and regulatory frameworks.',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            title: 'Operational Readiness',
            body: 'Business structured to begin operations without delays.',
            icon: 'M13 10V3L4 14h7v7l9-11h-7z',
          },
        ].map(({ title, body, icon }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-6" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}/></svg>
            </div>
            <h3 class="text-base font-bold mb-3" style="color: #F8FAFC;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Business Formation Services</h2>
        <p class="mt-3 text-base max-w-2xl" style="color: #64748B;">End-to-end company setup across all UAE jurisdictions with compliance and tax built in from the start.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            num: '01',
            title: 'Company Incorporation',
            points: [
              'Company registration across UAE jurisdictions',
              'Documentation and incorporation support',
              'Alignment with regulatory requirements',
            ],
          },
          {
            num: '02',
            title: 'Freezone and Mainland Structuring',
            points: [
              'Assessment of Freezone versus Mainland setup',
              'Selection based on operational and tax considerations',
              'Alignment with business activity and scale',
            ],
          },
          {
            num: '03',
            title: 'Freezone Setup',
            points: [
              'Formation within Freezones such as DMCC, DIFC, ADGM, JAFZA',
              'Understanding of Freezone-specific compliance requirements',
              'Alignment with qualifying income conditions',
            ],
          },
          {
            num: '04',
            title: 'Mainland Setup',
            points: [
              'Licensing through Department of Economic Development',
              'Ability to operate across UAE markets',
              'Alignment with corporate tax framework',
            ],
          },
          {
            num: '05',
            title: 'Corporate Tax and VAT Registration',
            points: [
              'Corporate tax registration with FTA',
              'VAT registration and setup',
              'Alignment with compliance requirements',
            ],
          },
          {
            num: '06',
            title: 'Entity Structuring',
            points: [
              'Shareholding and ownership structuring',
              'Alignment with operational and financial requirements',
              'Structuring for scalability',
            ],
          },
          {
            num: '07',
            title: 'Group and Multi-Entity Structuring',
            points: [
              'Holding and subsidiary structures',
              'Alignment across multiple entities',
              'Consistency in reporting and compliance',
            ],
          },
          {
            num: '08',
            title: 'UAE Entry for International Businesses',
            points: [
              'Setup for foreign-owned businesses',
              'Alignment with UAE regulatory requirements',
              'Structuring for cross-border operations',
            ],
          },
          {
            num: '09',
            title: 'Compliance Framework Alignment',
            points: [
              'Alignment with UAE regulatory environment',
              'UBO and KYC considerations',
              'Documentation structured for ongoing compliance',
            ],
          },
        ].map(({ num, title, points }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="flex items-start gap-5">
              <span class="text-4xl font-black leading-none flex-shrink-0" style="color: #1E293B;">{num}</span>
              <div class="flex-1">
                <h3 class="text-sm font-bold mb-4" style="color: #F8FAFC;">{title}</h3>
                <ul class="space-y-2">
                  {points.map(point => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed" style="color: #64748B;">
                      <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Designed for Businesses Establishing or Expanding in the UAE</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {[
          {
            title: 'Startups and Founders',
            body: 'Structured setup aligned with long-term growth.',
          },
          {
            title: 'Growing Businesses',
            body: 'Expansion into UAE with proper structuring.',
          },
          {
            title: 'International Businesses',
            body: 'Entry into UAE with compliant and scalable structure.',
          },
          {
            title: 'Multi-Entity Groups',
            body: 'Establishing or restructuring group structures.',
          },
        ].map(({ title, body }) => (
          <div class="rounded-xl p-8 flex items-start gap-4" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM / SOLUTION ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Without vs. With Structured Formation</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #374151;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Structured Formation</h3>
          <ul class="space-y-4">
            {[
              'Incorrect jurisdiction selection',
              'Misalignment with tax requirements',
              'Delays in operational readiness',
              'Future restructuring required',
              'Increased compliance complexity',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #374151;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1a4480;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #93C5FD;">With Structured Formation</h3>
          <ul class="space-y-4">
            {[
              'Correct structure from the outset',
              'Alignment with corporate tax and VAT',
              'Clear operational foundation',
              'Reduced need for restructuring',
              'Consistent compliance framework',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section id="process" style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">How Work Is Structured</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Our Process</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          { step: '01', title: 'Understanding', body: 'We review your business model, activities, ownership structure, and intended UAE market to assess setup requirements.' },
          { step: '02', title: 'Structuring', body: 'We advise on Freezone versus Mainland, entity type, shareholding structure, and tax and compliance implications of each option.' },
          { step: '03', title: 'Registration', body: 'We manage the incorporation process including document preparation, authority submissions, and licensing across the relevant UAE jurisdiction.' },
          { step: '04', title: 'Setup and Alignment', body: 'We complete corporate tax and VAT registrations, establish accounting processes, and ensure compliance frameworks are in place before operations begin.' },
          { step: '05', title: 'Continuity', body: 'We support ongoing licence renewals, regulatory filings, and compliance requirements as the business grows and its structure evolves.' },
        ].map(({ step, title, body }) => (
          <div class="relative">
            <div class="text-4xl font-black mb-4" style="color: #1E293B;">{step}</div>
            <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + BUILT FOR UAE ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What You Gain</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">The Results</h2>
          <ul class="space-y-4">
            {[
              'Fully registered and compliant entity',
              'Structured financial and tax foundation',
              'Operational readiness from day one',
              'Scalable business structure',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why Ambit</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">Built for the UAE Market</h2>
          <ul class="space-y-4">
            {[
              'Freezone and Mainland structuring expertise',
              'FTA-aligned tax and VAT setup',
              'Multi-entity and cross-border readiness',
              'Integration with accounting and compliance systems',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-12">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Client Feedback</p>
        <h2 class="text-2xl lg:text-3xl font-black" style="color: #F8FAFC;">What Clients Say</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        {[
          {
            quote: 'Our UAE setup was structured correctly from the start. We avoided complications around tax and compliance.',
            name: 'CEO',
            company: 'Technology Company, DMCC Freezone',
          },
          {
            quote: 'Ambit helped us choose the right structure between Freezone and Mainland based on our business model.',
            name: 'Managing Director',
            company: 'Trading Business, Dubai',
          },
        ].map(({ quote, name, company }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <svg class="w-6 h-6 mb-4" style="color: #1a4480;" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed mb-6" style="color: #94A3B8;">{quote}</p>
            <div>
              <div class="text-xs font-bold" style="color: #F8FAFC;">{name}</div>
              <div class="text-xs mt-0.5" style="color: #475569;">{company}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-4xl mx-auto px-6 lg:px-12 py-24 text-center">
      <p class="text-xs font-bold tracking-widest uppercase mb-6" style="color: #1a4480;">Get Started</p>
