---
import UAELayout from '../../../../layouts/UAELayout.astro';
---

<UAELayout title="UAE Financial Management | Reporting, Planning & Analysis | Ambit" description="Structured financial reporting, budgeting, and planning for UAE businesses. IFRS-aligned management accounts, cash flow forecasting, and multi-entity reporting across Freezone and Mainland operations.">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(26,68,128,0.18) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-12 py-24 lg:py-32">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase" style="background-color: rgba(26,68,128,0.25); border: 1px solid rgba(26,68,128,0.4); color: #93C5FD;">
          <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-4 h-3 object-cover rounded-sm" />
          United Arab Emirates · Financial Management
        </div>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight mb-6" style="color: #F8FAFC;">
        United Arab Emirates ·
        <span class="block" style="color: #93C5FD;">Financial Management</span>
      </h1>

      <p class="text-lg md:text-xl max-w-2xl mb-12 leading-relaxed" style="color: #94A3B8;">
        Structured reporting, analysis, and planning to provide clarity across business performance, enabling informed decisions and control across UAE operations.
      </p>

      <div class="flex flex-wrap gap-3 mb-14">
        {['IFRS Aligned', 'FTA Compliant', 'UAE Labour Law Aligned', 'VAT Compliant', 'Corporate Tax Ready'].map(label => (
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">{label}</span>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          Speak to an Expert
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#process" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-semibold transition-all hover:opacity-80" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITY MARQUEE ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex gap-12 whitespace-nowrap animate-marquee text-xs font-semibold tracking-widest uppercase text-white">
      {[
        'FRS-aligned financial reporting',
        ' FTA compliance across VAT and corporate tax',
        'UAE Labour Law payroll alignment',
        ' Corporate tax and VAT structuring',
        ' Consistent reporting across periods',
        ' Structured financial workflows',
        ' Freezone and Mainland alignment',
        'Platform-aligned accounting (Zoho, Xero, QuickBooks)',
       'FRS-aligned financial reporting',
        ' FTA compliance across VAT and corporate tax',
        'UAE Labour Law payroll alignment',
        ' Corporate tax and VAT structuring',
        ' Consistent reporting across periods',
        ' Structured financial workflows',
        ' Freezone and Mainland alignment',
        'Platform-aligned accounting (Zoho, Xero, QuickBooks)',
      ].map(item => (
        <span class="flex items-center gap-3">
          <span class="w-1 h-1 rounded-full inline-block bg-white opacity-60"></span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ===== CERTIFICATION BLOCK ===== -->
  <section style="background-color: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-10">
      <div class="flex flex-wrap items-center gap-6">
        <span class="text-xs font-bold tracking-widest uppercase" style="color: #94A3B8;">Certified</span>
        {['ISO 27001 Certified', 'FTA Registered'].map(cert => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <svg class="w-4 h-4" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            <span class="text-xs font-semibold" style="color: #475569;">{cert}</span>
          </div>
        ))}
        <div class="ml-auto hidden lg:flex items-center gap-8">
          {[
            { metric: 'Clear', label: 'Financial visibility' },
            { metric: 'Structured', label: ' Reporting cycles' },
            { metric: 'Informed', label: 'Decision-making' },
            { metric: 'Forward-looking', label: 'Planning' },
          ].map(({ metric, label }) => (
            <div class="text-center">
              <div class="text-lg font-black" style="color: #1a4480;">{metric}</div>
              <div class="text-xs" style="color: #64748B;">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center mb-16">
        <div class="relative hidden lg:block">
          <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80" alt="UAE financial management reporting" class="rounded-2xl w-full object-cover shadow-lg" style="height: 420px; object-position: center;" />
          <div class="absolute top-6 -right-5 bg-white rounded-xl px-4 py-3 shadow-lg" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-bold mb-0.5" style="color: #0F172A;">IFRS Aligned</p>
            <p class="text-xs" style="color: #94A3B8;">Management Reporting</p>
          </div>
          <div class="absolute -bottom-5 left-6 rounded-xl px-4 py-3 shadow-lg" style="background: #0F172A; border: 1px solid #1E293B;">
            <p class="text-xs font-bold text-white mb-0.5">Real-time KPIs</p>
            <p class="text-xs" style="color: #475569;">Multi-Entity</p>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">Financial Reporting Should Support Decisions</h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed" style="color: #64748B;">Financial data is often available but not structured for decision-making. Without consistent reporting and analysis, it becomes difficult to understand performance, manage cash flow, or plan ahead. Structured financial management provides clarity across performance and supports better control across Freezone and Mainland entities.</p>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            title: 'Clarity Across Performance',
            body: 'Consistent reporting across revenue, costs, and profitability.',
            icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
          },
          {
            title: 'Forward Visibility',
            body: 'Planning and forecasting aligned with financial position.',
            icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
          },
          {
            title: 'Control Over Financial Outcomes',
            body: 'Structured insight supports cost, margin, and cash flow management.',
            icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
          },
        ].map(({ title, body, icon }) => (
          <div class="rounded-xl p-8 shadow-sm" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-6" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}/></svg>
            </div>
            <h3 class="text-base font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #0F172A;">Financial Management — United Arab Emirates</h2>
        <!-- <p class="mt-3 text-base max-w-2xl" style="color: #64748B;">Reporting, planning, and analysis structured for UAE business operations.</p> -->
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            num: '01',
            title: 'Management Reporting',
            points: [
              'Monthly management accounts',
              'Profit and Loss, Balance Sheet, Cash flow',
              'Structured reporting packs',
            ],
          },
          {
            num: '02',
            title: 'Variance Analysis',
            points: [
              'Budget versus actual comparison',
              'Identification of performance gaps',
              'Explanation of key movements',
            ],
          },
          {
            num: '03',
            title: 'Budgeting and Forecasting',
            points: [
              'Annual budgeting',
              'Rolling forecasts',
              'Alignment with business plans',
            ],
          },
          {
            num: '04',
            title: 'Cash Flow Planning',
            points: [
              'Cash flow forecasting',
              'Liquidity tracking',
              'Working capital visibility',
            ],
          },
          {
            num: '05',
            title: 'Performance Analysis',
            points: [
              'Margin and profitability analysis',
              'Cost structure evaluation',
              'Revenue trend analysis',
              'Tracking of dividends and retained earnings alignment',
            ],
          },
          {
            num: '06',
            title: 'Scenario Modelling',
            points: [
              'Financial impact of business decisions',
              'Growth and cost scenarios',
              'Planning under different assumptions',
            ],
          },
          {
            num: '07',
            title: 'Group and Intercompany Reporting',
            points: [
              'Intercompany reconciliation',
              'Multi-entity reporting alignment',
              'Consolidation support',
            ],
          },
          {
            num: '08',
            title: 'KPI and Dashboard Reporting',
            points: [
              'Key performance indicators',
              'Custom reporting dashboards',
              'Consistent tracking across periods',
            ],
          },
        ].map(({ num, title, points }) => (
          <div class="rounded-xl p-8 bg-white shadow-sm" style="border: 1px solid #E2E8F0;">
            <div class="flex items-start gap-5">
              <span class="text-4xl font-black leading-none flex-shrink-0" style="color: #E2E8F0;">{num}</span>
              <div class="flex-1">
                <h3 class="text-sm font-bold mb-4" style="color: #0F172A;">{title}</h3>
                <ul class="space-y-2">
                  {points.map(point => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed" style="color: #64748B;">
                      <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #0F172A;">Designed for Businesses Requiring Financial Visibility and Control</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {[
          {
            title: 'Growing SMEs',
            body: 'Structured reporting and visibility as complexity increases.',
          },
          {
            title: 'Founder-Led Businesses',
            body: 'Clarity across financial performance and planning.',
          },
          {
            title: 'Multi-Entity Businesses',
            body: 'Consistency across reporting and financial control.',
          },
          {
            title: 'International Businesses in UAE',
            body: 'Alignment across cross-border financial structures.',
          },
        ].map(({ title, body }) => (
          <div class="rounded-xl p-8 flex items-start gap-4 shadow-sm" style="background-color: #F8FAFC; border: 1px solid #E2E8F0;">
            <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM / SOLUTION ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Without vs. With Structured Financial Management</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #374151;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Structured Financial Management</h3>
          <ul class="space-y-4">
            {[
              'Limited visibility across performance',
              'Reactive decision-making',
              'Uncertain cash flow position',
              'Inconsistent reporting',
              'Lack of forward planning',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #374151;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1a4480;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #93C5FD;">With Structured Financial Management</h3>
          <ul class="space-y-4">
            {[
              'Clear performance visibility',
              'Consistent reporting cycles',
              'Planned decision-making',
              'Controlled cash flow',
              'Forward-looking financial insight',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section id="process" style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">How Work Is Structured</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #0F172A;">Our Process</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          { step: '01', title: 'Understanding', body: 'We review your current financial reporting, accounting structure, business entities, and what decisions need to be supported.' },
          { step: '02', title: 'Structuring', body: 'We design the reporting framework including management account format, KPIs, budget structure, and consolidation approach.' },
          { step: '03', title: 'Onboarding', body: 'We connect with your accounting systems, establish data flows, and set up reporting templates and dashboard structures.' },
          { step: '04', title: 'Execution and Review', body: 'We deliver management accounts and reporting packs each period, with variance analysis and commentary included.' },
          { step: '05', title: 'Continuity', body: 'We maintain the reporting cycle, update forecasts as conditions change, and evolve the framework as the business grows.' },
        ].map(({ step, title, body }) => (
          <div class="relative p-6 rounded-xl shadow-sm" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <div class="text-4xl font-black mb-4" style="color: #1a4480;">{step}</div>
            <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + BUILT FOR UAE ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;"> The Results</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #0F172A;">What You Gain</h2>
          <ul class="space-y-4">
            {[
              'Clear financial visibility',
              'Consistent reporting and analysis',
              'Better planning capability',
              'Informed business decisions',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Built for UAE Market</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #0F172A;">Built for the UAE Market</h2>
          <ul class="space-y-4">
            {[
              'IFRS-aligned reporting',
              'Integration with accounting, VAT, and corporate tax',
              'Multi-entity and multi-currency support',
              'Freezone and Mainland alignment',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-12">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Client Feedback</p>
        <h2 class="text-2xl lg:text-3xl font-black" style="color: #0F172A;">What Clients Say</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        {[
          {
            quote: 'Financial reporting is now structured and supports real decision-making across our UAE operations.',
            name: 'Managing Director',
            company: 'Multi-Entity Business, Dubai',
          },
          {
            quote: 'We now have clarity across cash flow and performance, which has improved planning significantly.',
            name: 'Founder',
            company: 'Technology Company, UAE',
          },
        ].map(({ quote, name, company }) => (
          <div class="rounded-xl p-8 shadow-sm" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <svg class="w-6 h-6 mb-4" style="color: #1a4480;" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed mb-6" style="color: #64748B;">{quote}</p>
            <div>
              <div class="text-xs font-bold" style="color: #0F172A;">{name}</div>
              <div class="text-xs mt-0.5" style="color: #64748B;">{company}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
