---
import UAELayout from '../../../../layouts/UAELayout.astro';
---

<UAELayout title="Accounting & Bookkeeping Dubai | IFRS & UAE VAT Compliant | Ambit" description="IFRS-compliant accounting and UAE VAT-ready bookkeeping for Dubai businesses. Accurate financial reporting, daily bookkeeping, and expert advisory from dedicated UAE accountants.">

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[88vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=1600&q=80"
        alt="Dubai accounting"
        class="w-full h-full object-cover"
        style="opacity: 0.15;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 50%, #1a4480 100%); opacity: 0.88;"></div>
    </div>

    <div class="absolute top-20 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.07;"></div>
    <div class="absolute bottom-20 left-20 w-64 h-64 rounded-full blur-3xl" style="background: #16A34A; opacity: 0.06;"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left -->
        <div>
          <div
            x-show="visible"
            x-transition:enter="transition duration-700"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6"
            style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
          >
            <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-4 h-3 object-cover rounded-sm" />
            United Arab Emirates · Accounting & Bookkeeping
          </div>

          <h1
            x-show="visible"
            x-transition:enter="transition duration-700 delay-100"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-4xl lg:text-5xl xl:text-6xl font-black leading-none mb-6"
            style="color: #F8FAFC; letter-spacing: -0.03em;"
          >
            United Arab Emirates<br />
            <span style="color: #1a4480;">Accounting & Bookkeeping</span></h1>

          <p
            x-show="visible"
            x-transition:enter="transition duration-700 delay-200"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-lg leading-relaxed mb-10 max-w-xl"
            style="color: #94A3B8;"
          >
            Structured financial records, reporting, and year-end accounts aligned with IFRS standards and UAE regulatory requirements, ensuring consistency across Freezone and Mainland entities.
          </p>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-4"
          >
            <button onclick="document.getElementById('consult-modal').style.display='flex'" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105 cursor-pointer" style="background-color: #1a4480; border: none;">
              Speak to an Expert
            </button>
            <a href="#services" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
              See How It Works
            </a>
          </div>
           <!-- Trust pills -->
          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-400"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            class="flex flex-wrap gap-3 mt-10"
          >
            {['IFRS Aligned', 'FTA Compliant', 'UAE Labour Law Aligned', 'VAT Compliant', 'Corporate Tax Ready'].map(tag => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: rgba(26,68,128,0.12); color: #1a4480; border: 1px solid rgba(26,68,128,0.25);">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Floating cards -->
        <div
          x-show="visible"
          x-transition:enter="transition duration-700 delay-400"
          x-transition:enter-start="opacity-0 translate-x-8"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <div class="relative w-full max-w-sm mx-auto">
            <img
              src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80"
              alt="Financial records"
              class="w-full aspect-square object-cover rounded-2xl"
              style="opacity: 0.65;"
            />

            <div class="absolute -top-5 -left-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #1a4480;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">ISO 27001 Certified</div>
                  <div class="text-xs" style="color: #64748B;"> FTA Registered</div>
                </div>
              </div>
            </div>

           
          </div>
        </div>

      </div>
    </div>
  </section>
    <!-- ===== METRICS STRIP ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { metric: 'Accurate', label: 'Financial records' },
          { metric: 'Consistent', label: 'Reporting cycles' },
          { metric: 'US GAAP', label: 'Aligned' },
          { metric: 'Audit-ready', label: 'Structure' },
        ].map(({ metric, label, sub }) => (
          <div class="text-center lg:text-left">
            <div class="text-3xl lg:text-4xl font-black mb-1" style="color: #F8FAFC;">{metric}</div>
            <div class="text-sm font-semibold mb-1" style="color: #93C5FD;">{label}</div>
            <div class="text-xs" style="color: #475569;">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 30s linear infinite; width: max-content;">
      {[
        '✔ IFRS-Aligned Financial Reporting',
        '✔ FTA compliance across VAT and corporate tax',
        '✔ UAE Labour Law Payroll alignment',
        '✔ Corporate tax and VAT structuring',
        '✔ Consistent reporting across periods',
        '✔ Structured financial workflows',
        '✔ Freezone and Mainland alignment',
        '✔ Platform-aligned accounting (Zoho, Xero, QuickBooks)',
         '✔ IFRS-Aligned Financial Reporting',
        '✔ FTA compliance across VAT and corporate tax',
        '✔ UAE Labour Law Payroll alignment',
        '✔ Corporate tax and VAT structuring',
        '✔ Consistent reporting across periods',
        '✔ Structured financial workflows',
        '✔ Freezone and Mainland alignment',
        '✔ Platform-aligned accounting (Zoho, Xero, QuickBooks)',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center mb-16">
        <div class="relative hidden lg:block">
          <img src="https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=800&q=80" alt="UAE accounting and bookkeeping" class="rounded-2xl w-full object-cover shadow-lg" style="height: 420px; object-position: center;" />
          <div class="absolute top-6 -right-5 bg-white rounded-xl px-4 py-3 shadow-lg" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-bold mb-0.5" style="color: #0F172A;">UAE Compliant</p>
            <p class="text-xs" style="color: #94A3B8;">FTA Aligned</p>
          </div>
          <div class="absolute -bottom-5 left-6 rounded-xl px-4 py-3 shadow-lg" style="background: #0F172A; border: 1px solid #1E293B;">
            <p class="text-xs font-bold text-white mb-0.5">IFRS Ready</p>
            <p class="text-xs" style="color: #475569;">Multi-Entity</p>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">Accounting in the UAE Requires Alignment Across Standards and Jurisdictions</h2>
          <div class="w-10 h-px " style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed" style="color: #64748B;">Accounting in the UAE extends beyond bookkeeping. Financial records must align with IFRS, VAT regulations, and corporate tax requirements across Freezone and Mainland entities.</p>
          <p class="text-base leading-relaxed" style="color: #64748B;">Without structured accounting, inconsistencies across entities and reporting periods create compliance risk and limit financial visibility.</p>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
            title: 'Consistency Across Entities',
            desc: 'Financial records aligned across Freezone and Mainland structures.',
          },
          {
            icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
            title: 'IFRS-Aligned Reporting',
            desc: 'Financial statements prepared in line with international standards.',
          },
          {
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            title: 'Regulatory Readiness',
            desc: 'Accounting structured to support VAT and corporate tax compliance.',
          },
        ].map(({ icon, title, desc }) => (
          <div class="p-8 rounded-2xl shadow-sm" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: #1a4480;">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">What We Offer</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Accounting & Bookkeeping <br> — United Arab Emirates</h2>
        <p class="text-lg mt-4 max-w-2xl mx-auto" style="color: #64748B;">
          End-to-end accounting and financial reporting for UAE businesses, built around IFRS standards and FTA compliance.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
  {[
    {
      num: '01',
      title: 'Bookkeeping & Ledger Management',
      bullets: [
        'Transaction recording',
        'Expense classification',
        'Ledger maintenance aligned to IFRS',
        'Chart of accounts structuring aligned with business model and reporting requirements',
      ],
    },
    {
      num: '02',
      title: 'Reconciliation',
      bullets: [
        'Bank reconciliation',
        'Multi-currency reconciliation',
        'Control account reconciliation',
        'Identification and correction of discrepancies',
      ],
    },
    {
      num: '03',
      title: 'Management Reporting',
      bullets: [
        'Profit and Loss',
        'Balance Sheet',
        'Cash flow reporting',
        'Structured monthly close',
        'Revenue recognition aligned with IFRS principles',
      ],
    },
    {
      num: '04',
      title: 'Year-End Close',
      bullets: [
        'Finalisation of financial records',
        'Adjustments and closing entries',
        'Accruals, prepayments, and provisions aligned with IFRS',
      ],
    },
    {
      num: '05',
      title: 'IFRS Financial Statements',
      bullets: [
        'Preparation of IFRS-compliant financial statements',
        'Consistency across reporting periods',
        'Alignment with audit and regulatory expectations',
      ],
    },
    {
      num: '06',
      title: 'Fixed Assets & Depreciation',
      bullets: [
        'Fixed asset register maintenance',
        'Depreciation in line with IFRS',
        'Alignment with financial reporting and tax',
      ],
    },
    {
      num: '07',
      title: 'Tax and VAT Alignment',
      bullets: [
        'Financials structured for VAT and corporate tax',
        'Consistency between accounting and filings',
        'Clean handover for tax and VAT reporting',
        'Maintenance of supporting documentation in line with FTA requirements',
      ],
    },
    {
      num: '08',
      title: 'Group and Intercompany Accounting',
      bullets: [
        'Intercompany reconciliation',
        'Multi-entity reporting alignment',
        'Consolidation support',
      ],
    },
    {
      num: '09',
      title: 'Audit Support',
      bullets: [
        'Preparation of audit-ready financials',
        'Supporting schedules and documentation',
        'Coordination during audit processes',
      ],
    },
  ].map(({ num, title, bullets }) => (
    <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
      <div class="text-xs font-black mb-4" style="color: #1a4480;">{num}</div>
      <h3 class="text-base font-bold mb-3" style="color: #0F172A;">{title}</h3>
      <ul class="space-y-1">
        {bullets.map((point) => (
          <li class="text-sm leading-relaxed flex gap-2" style="color: #64748B;">
            <span style="color: #1a4480; margin-top: 2px;">●</span>
            <span>{point}</span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Who We Serve</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Designed for Businesses Operating <br> Across UAE Structures</h2>
       
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            icon: '🏢',
            title: 'Freezone Companies',
            desc: 'Accounting aligned with Freezone regulatory and reporting requirements.',
          },
          {
            icon: '🏙️',
            title: 'Mainland Businesses',
            desc: ' Structured financial records aligned with UAE compliance frameworks.',
          },
          {
            icon: '🌐',
            title: 'Multi-Entity Businesses',
            desc: ' Consistency across entities, jurisdictions, and reporting cycles.',
          },
          {
            icon: '✈️',
            title: 'International Businesses in UAE',
            desc: '  IFRS-aligned accounting for cross-border reporting and operations.',
          },
        ].map(({ icon, title, desc }) => (
          <div class="flex gap-6 p-8 rounded-2xl" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <span class="text-3xl flex-shrink-0">{icon}</span>
            <div>
              <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Common Challenges</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">The Cost of Getting<br />Accounting Wrong in UAE</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Structured Accounting</h3>
          {[
            'Inconsistent financial records across entities',
            'Misalignment with VAT and corporate tax',
            'Limited visibility across performance',
            'Audit readiness issues',
            'Increased compliance risk',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border-left: 3px solid #DC2626;">
              <span class="text-lg flex-shrink-0">❌</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>

       <div class="space-y-4">
  <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">With Structured Accounting</h3>
  {[
    'Clean and consistent financial records',
    'Alignment across VAT, corporate tax, and reporting',
    'Reliable financial visibility',
    'Audit-ready documentation',
    'Controlled compliance',
  ].map(item => (
    <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border-left: 3px solid #22C55E;">
      <span class="text-lg flex-shrink-0">✅</span>
      <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
    </div>
  ))}
</div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-4xl mx-auto px-6 lg:px-12 py-24">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Our Process</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">4-Step Accounting &<br />Bookkeeping Process</h2>
      </div>

      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-px" style="background-color: #E2E8F0;"></div>
        <div class="space-y-12">
          {[
            
          {
            step: '01', title: 'Understanding',
            desc: 'We review your current setup, systems, and workflows to identify where structure and consistency are needed.',
            icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
          },
          {
            step: '02', title: 'Structuring',
            desc: 'Scope, processes, and delivery model are defined and aligned to your environment and reporting requirements.',
            icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
          },
          {
            step: '03', title: 'Onboarding',
            desc: 'Systems, access, and workflows are established in a controlled manner, ready for consistent delivery from day one.',
            icon: 'M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z',
          },
          {
            step: '04', title: 'Delivery & Review',
            desc: 'Work is executed with defined review layers ensuring accuracy, consistency, and alignment across reporting periods.',
            icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
          },
          {
            step: '05', title: 'Continuity',
            desc: 'Delivery is maintained and adapted to changes in volume, structure, or requirements without disruption.',
            icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
          }
          ].map(({ step, title, desc }) => (
            <div class="flex gap-8 items-start">
              <div class="relative flex-shrink-0">
                <div class="w-16 h-16 rounded-full flex items-center justify-center text-sm font-black border-4 border-white shadow" style="background-color: #1a4480; color: white;">
                  {step}
                </div>
              </div>
              <div class="pt-3">
                <h3 class="text-xl font-bold mb-2" style="color: #0F172A;">{title}</h3>
                <p class="text-base leading-relaxed" style="color: #64748B;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + UAE SPECIFIC ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Results</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">What You Gain</h2>
