---
import UAELayout from '../../../../layouts/UAELayout.astro';
---

<UAELayout title="UAE VAT Compliance | FTA VAT Registration & Filing | Ambit" description="VAT registration, reporting, and filing structured across transactions for UAE businesses. FTA-compliant VAT returns, reconciliation, and freezone handling.">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden" style="background-color: #0F172A;">
    <!-- Grid background -->
    <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(26,68,128,0.18) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-12 py-24 lg:py-32">
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase" style="background-color: rgba(26,68,128,0.25); border: 1px solid rgba(26,68,128,0.4); color: #93C5FD;">
          <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-4 h-3 object-cover rounded-sm" />
          United Arab Emirates · VAT Compliance
        </div>
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight mb-6" style="color: #F8FAFC;">
        United Arab Emirates · 
        <span class="block" style="color: #93C5FD;">VAT Compliance</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl max-w-2xl mb-12 leading-relaxed" style="color: #94A3B8;">
    VAT registration, reporting, and filing structured across transactions to ensure accuracy, consistency, and alignment with Federal Tax Authority requirements.
      </p>

      <!-- Trust pills -->
      <div class="flex flex-wrap gap-3 mb-14">
        {['IFRS Aligned', 'FTA Compliant', 'UAE Labour Law Aligned', 'VAT Compliant', 'Corporate Tax Ready'].map(label => (
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">{label}</span>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          Speak to an Expert
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#process" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-semibold transition-all hover:opacity-80" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITY MARQUEE ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex gap-12 whitespace-nowrap animate-marquee text-xs font-semibold tracking-widest uppercase text-white">
      {[
        'IFRS-aligned financial reporting',
        'FTA compliance across VAT and corporate tax',
        'UAE Labour Law payroll alignment',
        'Corporate tax and VAT structuring',
        'Consistent reporting across periods',
        'Structured financial workflows',
        'Freezone and Mainland alignment',
        'Platform-aligned accounting',
        'IFRS-aligned financial reporting',
        'FTA compliance across VAT and corporate tax',
        'UAE Labour Law payroll alignment',
        'Corporate tax and VAT structuring',
        'Consistent reporting across periods',
        'Structured financial workflows',
        'Freezone and Mainland alignment',
        'Platform-aligned accounting',
      ].map(item => (
        <span class="flex items-center gap-3">
          <span class="w-1 h-1 rounded-full inline-block bg-white opacity-60"></span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ===== CERTIFICATION BLOCK ===== -->
  <section style="background-color: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-10">
      <div class="flex flex-wrap items-center gap-6">
        <span class="text-xs font-bold tracking-widest uppercase" style="color: #94A3B8;">Standards</span>
        {['ISO 27001 Certified', 'FTA Registered'].map(cert => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <svg class="w-4 h-4" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            <span class="text-xs font-semibold" style="color: #475569;">{cert}</span>
          </div>
        ))}
        <div class="ml-auto hidden lg:flex items-center gap-8">
          {[
            { metric: 'Accurate', label: 'VAT reporting' },
            { metric: 'On-time', label: 'Every filing period' },
            { metric: 'FTA', label: 'Aligned' },
          ].map(({ metric, label }) => (
            <div class="text-center">
              <div class="text-lg font-black" style="color: #1a4480;">{metric}</div>
              <div class="text-xs" style="color: #64748B;">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center mb-16">
        <div class="relative hidden lg:block">
          <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=80" alt="UAE VAT compliance" class="rounded-2xl w-full object-cover shadow-lg" style="height: 420px; object-position: center;" />
          <div class="absolute top-6 -right-5 bg-white rounded-xl px-4 py-3 shadow-lg" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-bold mb-0.5" style="color: #0F172A;">FTA Registered</p>
            <p class="text-xs" style="color: #94A3B8;">VAT Compliant</p>
          </div>
          <div class="absolute -bottom-5 left-6 rounded-xl px-4 py-3 shadow-lg" style="background: #0F172A; border: 1px solid #1E293B;">
            <p class="text-xs font-bold text-white mb-0.5">5% UAE VAT</p>
            <p class="text-xs" style="color: #475569;">Structured & Filed</p>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">VAT Requires Accuracy at Transaction Level</h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed" style="color: #64748B;">VAT compliance in the UAE depends on how transactions are recorded, classified, and reconciled. Errors in VAT treatment, incorrect classification, or incomplete reconciliation can lead to penalties and compliance issues. A structured VAT process ensures accuracy at the source and consistency across filings.</p>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            title: 'Transaction-Level Accuracy',
            body: 'Correct VAT treatment applied at the point of entry.',
            icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
          },
          {
            title: 'FTA Compliance',
            body: 'Returns prepared and submitted in line with UAE VAT regulations.',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          },
          {
            title: 'Clean Reconciliation',
            body: 'VAT control accounts aligned with financial records across periods.',
            icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4',
          },
        ].map(({ title, body, icon }) => (
          <div class="rounded-xl p-8 shadow-sm" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-6" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}/></svg>
            </div>
            <h3 class="text-base font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #0F172A;">VAT Compliance — United Arab Emirates</h2>
        <p class="mt-3 text-base max-w-2xl" style="color: #64748B;">End-to-end VAT management across all UAE business types and structures.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            num: '01',
            title: 'VAT Registration',
            points: [
              'Registration with the Federal Tax Authority',
              'Threshold and voluntary registration assessment',
              'Alignment with business activity and structure',
            ],
          },
          {
            num: '02',
            title: 'VAT Record Management',
            points: [
              'Transaction classification',
              'VAT code application',
              'Input and output VAT tracking',
            ],
          },
          {
            num: '03',
            title: 'VAT Returns',
            points: [
              'Preparation of VAT returns',
              'Review before submission',
              'Filing in line with FTA deadlines',
            ],
          },
          {
            num: '04',
            title: 'VAT Reconciliation',
            points: [
              'VAT control account reconciliation',
              'Identification of discrepancies',
              'Adjustment tracking',
            ],
          },
          {
            num: '05',
            title: 'VAT Refunds and Recovery',
            points: [
              'Identification of reclaimable input VAT',
              'Preparation and submission of refund claims',
              'Alignment with FTA requirements',
            ],
          },
          {
            num: '06',
            title: 'VAT Treatment and Classification',
            points: [
              'Standard-rated, zero-rated, and exempt supplies',
              'Correct classification across transactions',
              'Consistency across financial records',
            ],
          },
          {
            num: '07',
            title: 'Freezone and Designated Zone VAT Handling',
            points: [
              'VAT implications for Designated Zones',
              'Treatment of intra-zone and mainland transactions',
              'Alignment with UAE VAT framework',
            ],
          },
          {
            num: '08',
            title: 'VAT Grouping',
            points: [
              'VAT group registration',
              'Alignment across related entities',
              'Consolidated VAT reporting',
            ],
          },
          {
            num: '09',
            title: 'Compliance Support',
            points: [
              'FTA-ready documentation',
              'Support during VAT reviews or audits',
              'Ongoing compliance monitoring',
            ],
          },
        ].map(({ num, title, points }) => (
          <div class="rounded-xl p-8 bg-white shadow-sm" style="border: 1px solid #E2E8F0;">
            <div class="flex items-start gap-5">
              <span class="text-4xl font-black leading-none flex-shrink-0" style="color: #E2E8F0;">{num}</span>
              <div class="flex-1">
                <h3 class="text-sm font-bold mb-4" style="color: #0F172A;">{title}</h3>
                <ul class="space-y-2">
                  {points.map(point => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed" style="color: #64748B;">
                      <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #0F172A;">Designed for VAT-Registered UAE Businesses</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {[
          {
            title: 'Freezone Companies',
            body: 'VAT treatment aligned with Freezone and Designated Zone requirements.',
          },
          {
            title: 'Mainland Businesses',
            body: 'Consistent VAT compliance across operations.',
          },
          {
            title: 'E-commerce and Trading Businesses',
            body: 'High-volume transaction handling and reconciliation.',
          },
          {
            title: 'Multi-Entity Businesses',
            body: 'VAT grouping and consolidated reporting alignment.',
          },
        ].map(({ title, body }) => (
          <div class="rounded-xl p-8 flex items-start gap-4 shadow-sm" style="background-color: #F8FAFC; border: 1px solid #E2E8F0;">
            <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM / SOLUTION ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Without vs. With Structured VAT Compliance</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Without -->
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #374151;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Structured VAT Compliance</h3>
          <ul class="space-y-4">
            {[
              'Incorrect VAT classification',
              'Filing errors and missed deadlines',
              'Reconciliation gaps',
              'Misinterpretation of Freezone rules',
              'Increased compliance risk',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #374151;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- With -->
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1a4480;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #93C5FD;">With Structured VAT Compliance</h3>
          <ul class="space-y-4">
            {[
              'Accurate VAT treatment across transactions',
              'Timely filing of returns',
              'Clean reconciliations',
              'Clarity across Freezone and Mainland implications',
              'Controlled compliance',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section id="how-it-works" class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-16">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">Our Process</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Simple Process. Powerful Results.</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="hidden lg:grid grid-cols-5 gap-6 relative">
        <div class="absolute top-[52px] left-[12.5%] right-[12.5%] h-px" style="background: linear-gradient(to right, #1a4480, #1e5ab5, #1a4480);"></div>
        {[
          
          {
            step: '01', title: 'Understanding',
            desc: 'We review your current setup, systems, and workflows to identify where structure and consistency are needed.',
            icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
          },
          {
            step: '02', title: 'Structuring',
            desc: 'Scope, processes, and delivery model are defined and aligned to your environment and reporting requirements.',
            icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
          },
          {
            step: '03', title: 'Onboarding',
            desc: 'Systems, access, and workflows are established in a controlled manner, ready for consistent delivery from day one.',
            icon: 'M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z',
          },
          {
            step: '04', title: 'Delivery & Review',
            desc: 'Work is executed with defined review layers ensuring accuracy, consistency, and alignment across reporting periods.',
            icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
          },
          {
            step: '05', title: 'Continuity',
            desc: 'Delivery is maintained and adapted to changes in volume, structure, or requirements without disruption.',
            icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
          }
        ].map((step, i) => (
          <div class="flex flex-col items-center text-center">
            <div class="relative z-10 w-[104px] h-[104px] rounded-full flex flex-col items-center justify-center mb-6 shadow-lg" style="background: white; border: 2px solid #1a4480;">
       
              <span class="text-lg font-bold" style="color: #0F172A;">{i + 1}</span>
            </div>
            <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{step.title}</h3>
            <div class="w-6 h-px mb-3 mx-auto" style="background: #1a4480;"></div>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="lg:hidden space-y-6">
        {[
          { num: '01', title: 'Setup & Review', desc: 'Understand your current system and design the right approach.' },
          { num: '02', title: 'Organise', desc: 'Clean your books, catch up backlogs, and structure data properly.' },
          { num: '03', title: 'Manage', desc: 'Daily bookkeeping, reconciliation, and monthly reporting.' },
          { num: '04', title: 'Support', desc: 'Dedicated manager, real-time insights, and HMRC guidance.' },
        ].map((step, i) => (
          <div class="flex gap-5 items-start">
            <div class="w-12 h-12 rounded-full flex-shrink-0 flex items-center justify-center font-bold text-white text-sm" style="background: #1a4480;">{i + 1}</div>
            <div class="pt-1">
              <div class="text-xs font-bold tracking-[0.15em] uppercase mb-1" style="color: #94A3B8;">{step.num} / 04</div>
              <div class="text-sm font-bold mb-1.5" style="color: #0F172A;">{step.title}</div>
              <p class="text-xs leading-relaxed" style="color: #64748B;">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + BUILT FOR UAE ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Results -->
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Results </p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #0F172A;">What You Gain</h2>
          <ul class="space-y-4">
            {[
              'Accurate VAT filings',
              'Reduced compliance risk',
              'Consistent reporting across entities',
              'Confidence in VAT position',
