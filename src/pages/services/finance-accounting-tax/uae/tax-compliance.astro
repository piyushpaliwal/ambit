---
import UAELayout from '../../../../layouts/UAELayout.astro';
---

<UAELayout title="UAE Tax Compliance | Corporate Tax & VAT | Ambit" description="FTA-compliant corporate tax registration, computation, and filing for UAE businesses. Freezone, mainland, and multi-entity coverage with ongoing advisory.">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden" style="background-color: #0F172A;">
    <!-- Grid background -->
    <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(26,68,128,0.18) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-12 py-24 lg:py-32">
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase" style="background-color: rgba(26,68,128,0.25); border: 1px solid rgba(26,68,128,0.4); color: #93C5FD;">
          <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-4 h-3 object-cover rounded-sm" />
          United Arab Emirates · Tax Compliance
        </div>
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight mb-6" style="color: #F8FAFC;">
        Tax Compliance
        <span class="block" style="color: #93C5FD;">United Arab Emirates</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl max-w-2xl mb-12 leading-relaxed" style="color: #94A3B8;">
        Corporate tax structured for FTA compliance. We handle registration, computation, filing, and documentation so your UAE operations remain fully aligned with current and evolving tax regulations.
      </p>

      <!-- Trust pills -->
      <div class="flex flex-wrap gap-3 mb-14">
        {['IFRS Aligned', 'FTA Compliant', 'UAE Labour Law Aligned', 'VAT Compliant', 'Corporate Tax Ready'].map(label => (
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">{label}</span>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          Book a Free Consultation
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/services/finance-accounting-tax/uae/overview" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-semibold transition-all hover:opacity-80" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
          View All UAE Services
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITY MARQUEE ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex gap-12 whitespace-nowrap animate-marquee text-xs font-semibold tracking-widest uppercase text-white">
      {['Corporate Tax Registration', 'CT Computation', 'FTA Filing', 'VAT Returns', 'Transfer Pricing', 'Freezone Tax', 'Tax Documentation', 'Compliance Review', 'Corporate Tax Registration', 'CT Computation', 'FTA Filing', 'VAT Returns', 'Transfer Pricing', 'Freezone Tax', 'Tax Documentation', 'Compliance Review'].map(item => (
        <span class="flex items-center gap-3">
          <span class="w-1 h-1 rounded-full inline-block bg-white opacity-60"></span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ===== METRICS STRIP ===== -->
  <section style="background-color: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-10">
      <div class="flex flex-wrap items-center gap-8">
        <span class="text-xs font-bold tracking-widest uppercase" style="color: #94A3B8;">Standards</span>
        {[
          { metric: 'Accurate', label: 'Tax computation' },
          { metric: 'Compliant', label: 'Filings, on-time' },
          { metric: 'Structured', label: 'Audit-ready docs' },
          { metric: 'FTA', label: 'Aligned' },
        ].map(({ metric, label }) => (
          <div class="flex items-center gap-3 px-4 py-2 rounded-lg" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <div class="text-sm font-black" style="color: #1a4480;">{metric}</div>
            <div class="text-xs" style="color: #64748B;">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center mb-16">
        <div class="relative hidden lg:block">
          <img src="https://images.unsplash.com/photo-1554224154-26032ffc0d07?w=800&q=80" alt="UAE corporate tax compliance" class="rounded-2xl w-full object-cover shadow-lg" style="height: 420px; object-position: center;" />
          <div class="absolute top-6 -right-5 bg-white rounded-xl px-4 py-3 shadow-lg" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-bold mb-0.5" style="color: #0F172A;">CT Registered</p>
            <p class="text-xs" style="color: #94A3B8;">FTA Compliant</p>
          </div>
          <div class="absolute -bottom-5 left-6 rounded-xl px-4 py-3 shadow-lg" style="background: #0F172A; border: 1px solid #1E293B;">
            <p class="text-xs font-bold text-white mb-0.5">Freezone Ready</p>
            <p class="text-xs" style="color: #475569;">Mainland Aligned</p>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">Tax Compliance in the UAE Requires More Than Filing</h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed" style="color: #64748B;">With corporate tax now applicable across UAE entities, getting it right requires understanding not just the rules but how they interact with your structure, jurisdiction, and financial reporting.</p>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            title: 'Alignment with Financial Reporting',
            body: 'Corporate tax in the UAE is computed from financial statements prepared under IFRS or IFRS for SMEs. Errors or inconsistencies in your books flow directly into your tax position. Getting accounting right is the foundation of tax compliance.',
          },
          {
            title: 'Jurisdiction Awareness',
            body: 'Freezone entities, mainland companies, and branches each operate under different tax conditions. The rules around qualifying income, exempt income, and group structures require precise treatment depending on where your business is incorporated and what it does.',
          },
          {
            title: 'Compliance Readiness',
            body: 'The FTA expects not just accurate returns but well-maintained supporting records. Transfer pricing documentation, election forms, and audit trails must be in place before filing. Compliance is built through the year, not assembled at the deadline.',
          },
        ].map(({ title, body }) => (
          <div class="rounded-xl p-8 shadow-sm" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-6" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-base font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What We Do</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #0F172A;">Tax Compliance Services</h2>
        <p class="mt-3 text-base max-w-2xl" style="color: #64748B;">End-to-end coverage across UAE corporate tax and VAT obligations.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            num: '01',
            title: 'Corporate Tax Registration',
            body: 'We handle the end-to-end registration process with the FTA for corporate tax purposes. This includes determining the correct taxable person classification, preparing the required entity information, and completing registration within the mandatory timelines for your incorporation date.',
          },
          {
            num: '02',
            title: 'Corporate Tax Computation',
            body: 'We prepare the full corporate tax computation from your audited or management accounts. This includes identifying taxable income, applying applicable exemptions, calculating deductible and non-deductible items, and computing the final tax liability in line with the UAE Corporate Tax Law.',
          },
          {
            num: '03',
            title: 'Corporate Tax Return Filing',
            body: 'We prepare and submit corporate tax returns to the FTA through the EmaraTax portal. Returns are reviewed for accuracy before submission, with all supporting schedules and disclosures included as required by FTA guidelines.',
          },
          {
            num: '04',
            title: 'VAT Return Preparation and Filing',
            body: 'We prepare and file quarterly or monthly VAT returns based on your registration type. This includes reconciling output tax, validating input tax recovery, identifying exempt and zero-rated supplies, and ensuring returns balance to your financial records before submission.',
          },
          {
            num: '05',
            title: 'Freezone Tax Analysis',
            body: 'Freezone entities face specific conditions to maintain Qualifying Free Zone Person status and access the 0% tax rate on qualifying income. We analyse your activities, income streams, and substance requirements to assess your position and advise on maintaining eligibility.',
          },
          {
            num: '06',
            title: 'Transfer Pricing Documentation',
            body: 'Related party transactions must be supported by documentation demonstrating that they are conducted on arm\'s length terms. We prepare transfer pricing reports, disclosures, and supporting analyses in line with OECD guidelines and UAE CT Law requirements.',
          },
          {
            num: '07',
            title: 'Small Business Relief Assessment',
            body: 'Businesses with revenues below AED 3 million may qualify for Small Business Relief under the UAE CT Law. We assess your eligibility, advise on the election process, and ensure the correct treatment is applied in your tax return.',
          },
          {
            num: '08',
            title: 'Tax Group Formation and Administration',
            body: 'UAE entities under common ownership may apply to form a Tax Group, enabling group-level tax consolidation. We advise on eligibility, manage the application process, and administer the group tax position including intercompany eliminations and group return filing.',
          },
          {
            num: '09',
            title: 'Election and Notification Filings',
            body: 'The UAE CT Law requires specific elections and notifications to be filed by prescribed deadlines including transitional year elections, exemption elections, and accounting basis choices. We track all applicable elections for your entity and ensure timely submission.',
          },
          {
            num: '10',
            title: 'Ongoing Compliance Support',
            body: 'Tax compliance is not limited to the annual return. We provide year-round support including responding to FTA queries, preparing voluntary disclosures, supporting tax audits, and advising on regulatory updates that affect your tax position.',
          },
        ].map(({ num, title, body }) => (
          <div class="rounded-xl p-8 bg-white shadow-sm" style="border: 1px solid #E2E8F0;">
            <div class="flex items-start gap-5">
              <span class="text-4xl font-black leading-none flex-shrink-0" style="color: #E2E8F0;">{num}</span>
              <div>
                <h3 class="text-sm font-bold mb-3" style="color: #0F172A;">{title}</h3>
                <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #0F172A;">Built for UAE Business Structures</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {[
          {
            title: 'Freezone Entities',
            body: 'Companies operating within UAE freezones with qualifying activities, managing the interplay between freezone regulations and FTA requirements, and seeking to maintain Qualifying Free Zone Person status and 0% corporate tax eligibility.',
          },
          {
            title: 'Mainland Companies',
            body: 'LLC and branch structures subject to 9% corporate tax on taxable income above AED 375,000, requiring complete tax registration, computation, documentation, and annual return filing with the FTA.',
          },
          {
            title: 'Multi-Entity and Group Structures',
            body: 'Businesses operating across multiple UAE entities, freezones, or jurisdictions, where tax group considerations, intercompany transactions, and transfer pricing require coordinated management across the full structure.',
          },
          {
            title: 'International Businesses Expanding into the UAE',
            body: 'Foreign companies establishing UAE presence for the first time, needing to understand their corporate tax obligations, registration timelines, accounting requirements, and how UAE tax interacts with their home jurisdiction obligations.',
          },
        ].map(({ title, body }) => (
          <div class="rounded-xl p-8" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <h3 class="text-sm font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM / SOLUTION ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Difference</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Without Ambit vs. With Ambit</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Without -->
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #374151;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Ambit</h3>
          <ul class="space-y-4">
            {[
              'Corporate tax registrations missed or filed late, resulting in FTA penalties that could have been avoided.',
              'Tax computations prepared without proper alignment to audited accounts, creating discrepancies that trigger FTA review.',
              'Freezone entities losing qualifying income status due to activities or transactions that were not assessed before they occurred.',
              'Transfer pricing documentation gaps leaving related party transactions exposed during an FTA audit.',
              'Year-end scramble to gather records and prepare filings, with elections and notifications missed because no one was tracking the calendar.',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #374151;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- With -->
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1a4480;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #93C5FD;">With Ambit</h3>
          <ul class="space-y-4">
            {[
              'Registration completed on time with correct entity classification and all FTA requirements met from the first filing period.',
              'Tax computations built directly from your financial records with full reconciliation between your accounts and tax return.',
              'Freezone tax position analysed and monitored throughout the year so qualifying income status is maintained and issues are caught early.',
              'Transfer pricing documentation prepared and maintained as part of the annual compliance cycle, not as an afterthought.',
              'Compliance calendar managed end-to-end with all elections, notifications, and filings tracked and submitted before deadlines.',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section style="background-color: #F8FAFC; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">How We Work</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #0F172A;">Our Process</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          { step: '01', title: 'Understanding', body: 'We review your entity structure, incorporation details, activities, and existing tax registrations to establish your compliance baseline.' },
          { step: '02', title: 'Structuring', body: 'We identify your applicable tax obligations, elections available, and any structural considerations that affect your tax position.' },
          { step: '03', title: 'Onboarding', body: 'We connect with your accounting systems or take over record management, establish the compliance calendar, and confirm responsibility boundaries.' },
          { step: '04', title: 'Execution and Review', body: 'We prepare computations, returns, and documentation on schedule. All submissions are reviewed before filing and copies retained for your records.' },
          { step: '05', title: 'Continuity', body: 'We monitor regulatory changes, track election renewal dates, and maintain your documentation through each compliance cycle without disruption.' },
        ].map(({ step, title, body }) => (
          <div class="relative p-6 rounded-xl shadow-sm" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <div class="text-4xl font-black mb-4" style="color: #1a4480;">{step}</div>
            <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + BUILT FOR UAE ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Results -->
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What You Can Expect</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #0F172A;">Results</h2>
          <ul class="space-y-4">
            {[
              'Full FTA registration completed within required timelines with no penalties.',
              'Corporate tax returns filed accurately and on time for every applicable period.',
              'VAT returns reconciled to your financial records and submitted without errors.',
              'Transfer pricing documentation in place before the filing deadline.',
              'Freezone tax position reviewed and maintained throughout the year.',
              'Compliance calendar managed proactively with no missed elections or notifications.',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Built for UAE -->
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why Ambit</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #0F172A;">Built for the UAE</h2>
          <ul class="space-y-4">
            {[
              'We work exclusively with UAE, UK, and US entities. Your tax compliance is handled by people who know the FTA\'s requirements in detail.',
              'We do not pass your work to generalist staff. Every engagement is managed by a qualified accountant familiar with UAE corporate tax and VAT.',
              'Our processes are designed around IFRS-aligned accounts, which means your financial statements and tax return are prepared from the same source.',
              'We operate on fixed fees with no surprise charges for standard compliance work.',
              'We stay current with FTA updates, ministerial decisions, and guidance notes so you do not need to track regulatory changes yourself.',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section style="background-color: #ffffff; border-top: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-12">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Client Feedback</p>
        <h2 class="text-2xl lg:text-3xl font-black" style="color: #0F172A;">What Clients Say</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            quote: 'Ambit handled our corporate tax registration and first year return filing from scratch. Everything was done on time and we had no issues with the FTA.',
            name: 'Finance Director',
            company: 'Freezone Technology Company, Dubai',
          },
          {
            quote: 'We had been struggling to understand our freezone tax position after the CT Law came in. Ambit gave us a clear analysis and put the right documentation in place.',
            name: 'Managing Partner',
            company: 'Professional Services Firm, DIFC',
          },
          {
            quote: 'The team manages our VAT and corporate tax compliance end to end. Our books and tax returns are always aligned and we never have to chase for updates.',
            name: 'CEO',
            company: 'Trading Group, Sharjah',
          },
        ].map(({ quote, name, company }) => (
          <div class="rounded-xl p-8 shadow-sm" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <svg class="w-6 h-6 mb-4" style="color: #1a4480;" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed mb-6" style="color: #64748B;">{quote}</p>
            <div>
              <div class="text-xs font-bold" style="color: #0F172A;">{name}</div>
              <div class="text-xs mt-0.5" style="color: #64748B;">{company}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-4xl mx-auto px-6 lg:px-12 py-24 text-center">
      <p class="text-xs font-bold tracking-widest uppercase mb-6" style="color: #1a4480;">Get Started</p>
      <h2 class="text-3xl lg:text-4xl font-black mb-6 leading-tight" style="color: #F8FAFC;">
        Ready to Get Your UAE Tax Compliance Right?
      </h2>
      <p class="text-base mb-10 max-w-xl mx-auto leading-relaxed" style="color: #64748B;">
