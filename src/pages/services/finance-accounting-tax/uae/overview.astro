---
import UAELayout from '../../../../layouts/UAELayout.astro';
---

<UAELayout title="UAE Finance, Accounting & Tax | Ambit" description="From Freezone entities to Mainland companies across the UAE, Ambit structures financial operations, compliance, and reporting across VAT, corporate tax, and IFRS requirements.">

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[92vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <!-- Background: Dubai skyline -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1800&q=80"
        alt="Dubai skyline"
        class="w-full h-full object-cover"
        style="opacity: 0.18;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 45%, #1a4480 100%); opacity: 0.9;"></div>
    </div>

    <!-- Gold accent blur -->
    <div class="absolute top-20 right-24 w-96 h-96 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.07;"></div>
    <div class="absolute bottom-20 left-16 w-72 h-72 rounded-full blur-3xl" style="background: #16A34A; opacity: 0.06;"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: Text -->
        <div>
          <!-- City badges -->
          <div
            x-show="visible"
            x-transition:enter="transition duration-600"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-2 mb-6"
          >
            {['United Arab Emirates', 'Finance, Accounting & Tax'].map(tag => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
                <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-3.5 h-2.5 object-cover rounded-sm" />
                {tag}
              </span>
            ))}
          </div>

          <h1
            x-show="visible"
            x-transition:enter="transition duration-700 delay-100"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-4xl lg:text-5xl xl:text-6xl font-black leading-none mb-6"
            style="color: #F8FAFC; letter-spacing: -0.03em;"
          >
            United Arab Emirates ·<br />
            <span style="color: #1a4480;"> Finance,</span><br/>
            Accounting & Tax

          </h1>

          <p
            x-show="visible"
            x-transition:enter="transition duration-700 delay-200"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-lg leading-relaxed mb-10 max-w-xl"
            style="color: #94A3B8;"
          >
            From Freezone entities to Mainland companies across the UAE, Ambit structures financial operations, compliance, and reporting to remain consistent across VAT, corporate tax, and IFRS requirements.
          </p>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-4"
          >
            <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
              Speak to an Expert
            </a>
            <a href="#how-it-works" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
              See How It Works
            </a>
          </div>

          <!-- Trust pills -->
          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-400"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            class="flex flex-wrap gap-3 mt-10"
          >
            {['IFRS Aligned', 'FTA Compliant', 'UAE Labour Law Aligned', 'VAT Compliant', 'Corporate Tax Ready'].map(tag => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: rgba(26,68,128,0.12); color: #1a4480; border: 1px solid rgba(26,68,128,0.25);">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Visual card stack -->
        <div
          x-show="visible"
          x-transition:enter="transition duration-700 delay-400"
          x-transition:enter-start="opacity-0 translate-x-8"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <div class="relative w-full max-w-md mx-auto">
            <img
              src="https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=800&q=80"
              alt="Dubai financial trading"
              class="w-full aspect-[4/3] object-cover rounded-2xl shadow-2xl"
              style="opacity: 0.75;"
            />

           <div class="absolute -top-5 -left-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #1a4480;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">IFRS Compliant</div>
                  <div class="text-xs" style="color: #64748B;">Certified Standards</div>
                </div>
              </div>
            </div>

            
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 30s linear infinite; width: max-content;">
      {[
        '✔ IFRS-Aligned Financial Reporting',
        '✔ FTA compliance across VAT and corporate tax',
        '✔ UAE Labour Law Payroll alignment',
        '✔ Corporate tax and VAT structuring',
        '✔ Consistent reporting across periods',
        '✔ Structured financial workflows',
        '✔ Freezone and Mainland alignment',
        '✔ Platform-aligned accounting (Zoho, Xero, QuickBooks)',
         '✔ IFRS-Aligned Financial Reporting',
        '✔ FTA compliance across VAT and corporate tax',
        '✔ UAE Labour Law Payroll alignment',
        '✔ Corporate tax and VAT structuring',
        '✔ Consistent reporting across periods',
        '✔ Structured financial workflows',
        '✔ Freezone and Mainland alignment',
        '✔ Platform-aligned accounting (Zoho, Xero, QuickBooks)',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== WHY DUBAI COMPANIES TRUST AMBIT ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image -->
        <div class="relative order-2 lg:order-1">
          <img
            src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=800&q=80"
            alt="Dubai business district"
            class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl"
          />
          <!-- Stats overlay -->
          <div class="absolute top-6 -right-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #1a4480;">100%</div>
            <div class="text-xs" style="color: #64748B;">VAT Compliance</div>
          </div>
          <div class="absolute bottom-6 -left-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #22C55E;">AED 0</div>
            <div class="text-xs" style="color: #64748B;">Penalty Record</div>
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Why Ambit</div>
          <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">
            Why UAE Businesses<br />Work With Ambit
          </h2>
          <p class="text-base leading-relaxed mb-8" style="color: #64748B;">
            Operating in the UAE requires alignment across multiple frameworks including VAT, corporate tax, IFRS reporting, and labour law often across Freezone and Mainland structures. Ambit brings structure across financial operations, ensuring consistency across jurisdictions, entities, and reporting cycles without increasing internal complexity.
          </p>

          <div class="space-y-6">
            {[
              {
                icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
                title: 'Jurisdiction-Aware Structuring',
                desc: 'Financial processes aligned with Freezone and Mainland regulatory requirements.',
              },
              {
                icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
                title: 'Regulatory Alignment',
                desc: 'FTA, IFRS, and UAE Labour Law requirements handled within a unified system.',
              },
              {
                icon: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
                title: 'Cross-Border Consistency',
                desc: 'Alignment for businesses operating across UK, US, and UAE structures.',
              },
              {
                icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
                title: 'Operational Control',
                desc: 'Defined processes reduce dependency on manual intervention.',
              },
            ].map(({ icon, title, desc }) => (
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #EFF6FF;">
                  <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="text-base font-bold mb-1" style="color: #0F172A;">{title}</h3>
                  <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FREEZONE VS MAINLAND ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">UAE Business Structures</div>
        <h2 class="text-4xl font-black text-white mb-4" style="letter-spacing: -0.02em;">Freezone vs Mainland<br />Structural Implications</h2>
        <p class="text-base max-w-2xl mx-auto" style="color: #94A3B8;">The UAE operates across multiple jurisdictions, each with distinct regulatory, tax, and operational implications.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-10">
        <!-- Mainland -->
        <div class="rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155; padding: 1.75rem;">
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #3B82F6;">Mainland Companies</div>
          <ul class="space-y-3">
            {[
              'Licensed through Department of Economic Development (DED)',
              'Ability to operate across the UAE without restriction',
              'Subject to UAE corporate tax framework',
            ].map(item => (
              <li class="flex items-start gap-2.5">
                <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(59,130,246,0.15);">
                  <svg class="w-2.5 h-2.5" style="color: #3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-sm" style="color: #94A3B8;">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Freezone -->
        <div class="rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155; padding: 1.75rem;">
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #22C55E;">Freezone Entities</div>
          <ul class="space-y-3">
            {[
              'Established within Freezones such as DMCC, DIFC, ADGM, JAFZA',
              'Potential tax benefits based on qualifying income',
              'Separate regulatory authorities and compliance requirements',
            ].map(item => (
              <li class="flex items-start gap-2.5">
                <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(34,197,94,0.15);">
                  <svg class="w-2.5 h-2.5" style="color: #22C55E;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-sm" style="color: #94A3B8;">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- QFZP -->
        <div class="rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155; padding: 1.75rem;">
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Qualifying Freezone Person</div>
          <ul class="space-y-3">
            {[
              'Assessment of eligibility under UAE Corporate Tax law',
              'Alignment of income streams with qualifying criteria',
              'Ongoing compliance monitoring',
            ].map(item => (
              <li class="flex items-start gap-2.5">
                <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(26,68,128,0.25);">
                  <svg class="w-2.5 h-2.5" style="color: #93B4D4;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-sm" style="color: #94A3B8;">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <!-- Cross-Jurisdiction Structures -->
        <div class="rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155; padding: 1.75rem;">
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #c2da28;">Cross-Jurisdiction Structures</div>
          <ul class="space-y-3">
            {[
              'Businesses operating across Freezone and Mainland entities',
              'Requirement for consistent accounting, VAT, and tax alignment'
            ].map(item => (
              <li class="flex items-start gap-2.5">
                <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(26,68,128,0.25);">
                  <svg class="w-2.5 h-2.5" style="color: #93B4D4;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-sm" style="color: #94A3B8;">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Why it matters -->
      <div class="rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155; padding: 2rem;">
        <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #64748B;">Why This Matters</div>
        <p class="text-sm mb-5" style="color: #94A3B8;">The chosen structure directly impacts:</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          {['Corporate tax exposure', 'VAT treatment', 'Reporting obligations', 'Operational flexibility'].map(item => (
            <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl" style="background-color: #0F172A;">
              <div class="w-2 h-2 rounded-full flex-shrink-0" style="background-color: #1a4480;"></div>
              <span class="text-sm font-medium text-white">{item}</span>
            </div>
          ))}
        </div>
        <p class="text-sm" style="color: #64748B;">Ambit ensures financial and compliance structures are aligned with jurisdictional requirements from the outset.</p>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">What We Offer</div>
        <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">Finance, Accounting &amp; Tax<br />UAE</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">End-to-end financial support for businesses and individuals across the UAE. Structured, compliant, and consistent across VAT, corporate tax, and IFRS requirements.</p>
      </div>

      <!-- Quick nav grid -->
      <!-- <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-16">
        {[
          { num: '01', label: 'Accounting & Bookkeeping', href: '/uae/accounting' },
          { num: '02', label: 'Payroll Management', href: '/uae/payroll' },
          { num: '03', label: 'Tax & VAT Filing', href: '/uae/tax' },
          { num: '04', label: 'Accounts Payable & Receivable', href: '/uae/accounts' },
          { num: '05', label: 'Financial Reporting & Analysis', href: '/uae/reporting' },
          { num: '06', label: 'Offshore Accounting Teams', href: '/uae/offshore' },
        ].map(({ num, label, href }) => (
          <a href={href} class="group flex items-center gap-3 p-4 rounded-xl border border-transparent hover:border-amber-200 hover:shadow-sm transition-all bg-white">
            <span class="text-xs font-black" style="color: #1a4480;">{num}</span>
            <span class="text-sm font-semibold group-hover:text-amber-700 transition-colors" style="color: #374151;">{label}</span>
            <svg class="w-3.5 h-3.5 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div> -->

      <!-- Service cards with images -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            href: '/uae/accounting',
            img: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=600&q=80',
            title: 'Accounting & Bookkeeping',
            sub: 'IFRS Aligned',
            desc: 'IFRS-aligned financial records, reconciliations, and reporting across entities.',
          },
          {
            href: '/uae/payroll',
            img: 'https://images.unsplash.com/photo-1521791136064-7986c2920216?w=600&q=80',
            title: 'Payroll',
            sub: 'UAE Labour Law',
            desc: 'WPS-compliant payroll aligned with UAE Labour Law and workforce requirements.',
          },
          {
            href: '/uae/tax',
            img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&q=80',
            title: 'Tax Compliance (Corporate Tax)',
            sub: 'FTA Compliant',
            desc: 'Corporate tax registration, computation, and filing aligned with UAE regulations.',
          },
          {
            href: '/uae/accounts',
            img: 'https://images.unsplash.com/photo-1567427017947-545c5f8d16ad?w=600&q=80',
            title: 'VAT Compliance',
            sub: 'FTA Registered',
            desc: 'Transaction-level VAT handling, filing, and reconciliation aligned with FTA requirements.',
          },
          {
            href: '/uae/reporting',
            img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80',
            title: 'Financial Management',
            sub: 'IFRS Standards',
            desc: 'Reporting, analysis, forecasting, and performance visibility.',
          },
          {
            href: '/uae/offshore',
            img: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80',
            title: 'Business Formation',
            sub: 'Freezone & Mainland',
            desc: 'Company setup across Mainland and Freezone structures with regulatory and tax alignment.',
          },
        ].map(({ href, img, title, sub, desc }) => (
          <a href={href} class="group block bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="relative h-44 overflow-hidden">
              <img src={img} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.7) 0%, transparent 60%);"></div>
              <span class="absolute bottom-3 left-4 text-xs font-semibold px-2 py-1 rounded-full" style="background-color: rgba(26,68,128,0.85); color: white;">{sub}</span>
            </div>
            <div class="p-5">
              <h3 class="text-base font-bold mb-2 group-hover:text-amber-700 transition-colors" style="color: #0F172A;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PAIN POINTS → SOLUTIONS ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Common Challenges</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Common Challenges Across<br />UAE Businesses</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-12">
        {[
          {
            problem: 'Unclear Freezone vs Mainland implications',
            solution: 'Structured guidance ensures alignment with regulatory and tax frameworks.',
          },
          {
            problem: 'Corporate tax interpretation gaps',
            solution: 'Processes aligned with UAE Corporate Tax law and qualifying income rules.',
          },
          {
            problem: 'VAT and accounting misalignment',
            solution: 'Transaction-level structuring ensures consistency across filings.',
          },
          {
