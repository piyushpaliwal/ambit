---
import UKLayout from "../../../../layouts/UKLayout.astro";
---

<UKLayout
  title="Payroll & CIS – UK"
  description="Accurate, on-time, HMRC-compliant payroll and CIS management for UK businesses. Ambit makes UK payroll stress-free and error-free."
  countryPhone="+44 (0) 20 1234 5678"
  countryEmail="uk@ambit.co.uk"
>
  <!-- ===== HERO ===== -->
  <section
    class="relative overflow-hidden"
    style="background-color: #0F172A; min-height: 580px;"
  >
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
    <div
      class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-3xl"
      style="background: #1a4480;"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[300px] h-[300px] rounded-full opacity-[0.04] blur-3xl"
      style="background: #DC2626;"
    >
    </div>

    <div
      class="relative max-w-6xl mx-auto px-6 lg:px-10 flex items-center"
      style="min-height: 580px;"
    >
      <div class="grid lg:grid-cols-2 gap-14 items-center w-full py-20 lg:py-0">
        <!-- Left -->
        <div
          x-data="{ v: false }"
          x-init="setTimeout(() => v = true, 80)"
          x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0"
        >
          <div
            class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full"
            style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);"
          >
            <img
              src="https://flagcdn.com/w20/gb.png"
              alt="UK"
              class="w-5 h-3.5 object-cover rounded-sm"
            />
            <span
              class="text-xs font-semibold tracking-[0.15em] uppercase"
              style="color: #93B4D4;">United Kingdom · Payroll & CIS</span
            >
          </div>

          <h1
            class="text-4xl sm:text-5xl font-bold leading-[1.08] text-white mb-6"
            style="letter-spacing: -0.02em;"
          >
            United Kingdom<br />
            <span style="color: #93B4D4;">— Payroll</span>
          </h1>
          <p
            class="text-base leading-relaxed mb-8"
            style="color: #94A3B8; max-width: 460px;"
          >
            Payroll structured to ensure accurate processing, compliant submissions, and consistency across workforce payments and reporting cycles.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a
              href="#contact"
              class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5"
              style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);"
            >
             Speak to Payroll Expert
              <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
              >
            </a>
            <a
              href="#how-it-works"
              class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5"
              style="color: #CBD5E1; border-color: #334155;"
            >
              See How It Works
            </a>
          </div>

          <div
            class="flex flex-wrap gap-5 pt-8"
            style="border-top: 1px solid #1E293B;"
          >
            {
              [
                "UK GAAP aligned",
                "HMRC Compliant",
                " RTI payroll aligned",
                "VAT compliant",
                " Making Tax Digital ready",
              ].map((t) => (
                <div class="flex items-center gap-1.5">
                  <svg
                    class="w-3.5 h-3.5 flex-shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    style="color: #3B82F6;"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2.5"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="text-xs font-medium" style="color: #64748B;">
                    {t}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Right -->
        <div class="relative hidden lg:block">
          <div
            class="relative rounded-2xl overflow-hidden shadow-2xl"
            style="height: 440px;"
          >
            <img
              src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=900&auto=format&fit=crop&q=80"
              alt="UK payroll management team"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0"
              style="background: linear-gradient(135deg, rgba(15,23,42,0.5) 0%, transparent 60%);"
            >
            </div>
          </div>
          <div
            class="absolute -bottom-6 -left-8 rounded-xl px-5 py-4 shadow-xl"
            style="background: #1a4480; border: 1px solid rgba(255,255,255,0.1);"
          >
            <div class="text-2xl font-bold text-white leading-none mb-0.5">
              HMRC
            </div>
            <div class="text-xs font-medium" style="color: #93B4D4;">
              Fully Compliant
            </div>
          </div>
          <div
            class="absolute -top-4 -right-4 rounded-xl px-4 py-3 shadow-xl"
            style="background: #1E293B; border: 1px solid #334155;"
          >
            <div class="text-xl font-bold text-white leading-none mb-0.5">
              ISO 27001 Certified
            </div>
            <div class="text-xs text-center" style="color: #64748B;">
              ICO Registered
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div
      class="flex items-center gap-0"
      style="animation: marquee 30s linear infinite; width: max-content;"
    >
      {
        [
          "UK GAAP aligned financial reporting",
          " HMRC compliance across filings",
          " RTI payroll and employer obligations",
          "Corporation tax and VAT alignment",
          " Consistent reporting across periods",
          "Structured financial workflows",
          " Making Tax Digital readiness",
          "Platform-aligned accounting (Xero, QuickBooks, Sage)",
        ]
          .concat([
            "UK GAAP aligned financial reporting",
            " HMRC compliance across filings",
            " RTI payroll and employer obligations",
            "Corporation tax and VAT alignment",
            " Consistent reporting across periods",
            "Structured financial workflows",
            " Making Tax Digital readiness",
            "Platform-aligned accounting (Xero, QuickBooks, Sage)",
          ])
          .map((item) => (
            <div class="flex items-center gap-3 px-6 whitespace-nowrap">
              <span class="w-1.5 h-1.5 rounded-full bg-white opacity-60 flex-shrink-0" />
              <span class="text-xs font-semibold tracking-[0.12em] uppercase text-white opacity-90">
                {item}
              </span>
            </div>
          ))
      }
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div
          class="relative rounded-2xl overflow-hidden shadow-xl order-2 lg:order-1"
          style="height: 480px;"
        >
          <img
            src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=900&auto=format&fit=crop&q=80"
            alt="Payroll accuracy UK"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute inset-0"
            style="background: linear-gradient(to top, rgba(15,23,42,0.55) 0%, transparent 55%);"
          >
          </div>
          <div class="absolute bottom-6 left-6 right-6 grid grid-cols-2 gap-3">
            {
              [
                { num: "Accurate", label: " Payroll processing" },
                { num: "On-time", label: "Submissions" },
                { num: "CIS", label: " Aligned" },
                { num: "RTI", label: "Compliant" },
              ].map((m) => (
                <div
                  class="rounded-lg px-4 py-3"
                  style="background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.1);"
                >
                  <div class="text-xl font-bold text-white leading-none mb-0.5">
                    {m.num}
                  </div>
                  <div class="text-xs" style="color: #94A3B8;">
                    {m.label}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <p
            class="text-xs font-bold tracking-[0.2em] uppercase mb-4"
            style="color: #1a4480;"
          >
            Why It Matters
          </p>
          <h2
            class="text-3xl lg:text-4xl font-bold mb-6 leading-tight"
            style="color: #0F172A; letter-spacing: -0.02em;"
          >
            Payroll Requires Accuracy, Timing, and Control
          </h2>
          <div class="w-10 h-px mb-6" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed " style="color: #475569;">
            Payroll impacts financial reporting, compliance, and payment consistency across the organisation.
          </p>
          <p class="text-base leading-relaxed mb-8" style="color: #475569;">
         A structured payroll process ensures each cycle is processed correctly, deductions are handled consistently, and submissions are made on time.
          </p>

          <div class="space-y-4">
            {
              [
                {
                  title: "Consistent Processing Across Cycles",
                  desc: "Salary, PAYE, National Insurance, and deductions handled in a defined structure.",
                },
                {
                  title: "RTI and HMRC Alignment",
                  desc: "Submissions completed in line with reporting requirements and employer obligations.",
                },
                {
                  title: "Clarity Across Workforce Payments",
                  desc: "Accurate payslips, correct deductions, and consistent payment records.",
                },
              ].map((item) => (
                <div
                  class="flex gap-4 p-4 rounded-xl"
                  style="background: #F8FAFC; border: 1px solid #E2E8F0;"
                >
                  <div
                    class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5"
                    style="background: #EFF6FF;"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      style="color: #1a4480;"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                  </div>
                  <div>
                    <div
                      class="text-sm font-semibold mb-1"
                      style="color: #0F172A;"
                    >
                      {item.title}
                    </div>
                    <div
                      class="text-xs leading-relaxed"
                      style="color: #64748B;"
                    >
                      {item.desc}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p
          class="text-xs font-bold tracking-[0.2em] uppercase mb-3"
          style="color: #1a4480;"
        >
          What We Offer
        </p>
        <h2
          class="text-3xl lg:text-4xl font-bold"
          style="color: #0F172A; letter-spacing: -0.02em;"
        >
      Payroll — United Kingdom
        </h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;">
        </div>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {
          [
            {
              title: "Payroll Processing",
              subtitle: "RTI-compliant salary management",
              img: "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=700&auto=format&fit=crop&q=75",
              points: [
                "Salary and wage calculations",
                "PAYE and National Insurance deductions",
                "Payslip generation",
                "Payroll journals and reporting",
              ],
              icon: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z",
            },
            {
              title: "National Insurance Handling",
              subtitle: "Accurate contractor deductions",
              img: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=700&auto=format&fit=crop&q=75",
              points: [
                "Employer and employee National Insurance calculations",
                "Application of thresholds and categories",
                "Alignment with PAYE and payroll reporting",
              ],
              icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
            },
            {
              title: "RTI Submissions",
              subtitle: "Guidance that actually helps you",
              img: "https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75",
              points: [
                "Full Payment Submission (FPS)",
                "Employer Payment Summary (EPS)",
                "Submission management in line with HMRC deadlines",
              ],
              icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
            },
            {
              title: "CIS Administration",
              subtitle: "Guidance that actually helps you",
              img: "https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75",
              points: [
                "Contractor deduction handling",
                "Monthly CIS returns",
                "Verification and compliance support",
              ],
              icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
            },
            {
              title: "Pensions & Auto-Enrolment",
              subtitle: "Guidance that actually helps you",
              img: "https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75",
              points: [
                "Pension deductions",
                "Auto-enrolment support",
                "Employer contribution handling",
                "Alignment with payroll records",
              ],
              icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
            },
            {
              title: "Statutory Payments",
              subtitle: "Guidance that actually helps you",
              img: "https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75",
              points: [
                "Statutory Sick Pay",
                "Statutory Maternity Pay",
                "Statutory Paternity Pay",
                "Other statutory payroll obligations",
              ],
              icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
            },
            {
              title: "National Insurance Treatment",
              subtitle: "Guidance that actually helps you",
              img: "https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75",
              points: [
                "Application of relevant NI thresholds and reliefs",
                "Consistent treatment across payroll cycles",
                "Alignment with HMRC requirements",
                
              ],
              icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
            },
            {
              title: "Year-End Payroll Compliance",
              subtitle: "Guidance that actually helps you",
              img: "https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75",
              points: [
                "P60 and P45 processing",
                "Payroll year-end review",
                "Reporting alignment",
                
              ],
              icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
            },
            {
              title: "Payroll Support",
              subtitle: "Guidance that actually helps you",
              img: "https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75",
              points: [
                "Payroll queries and adjustments",
                "HMRC correspondence support",
                "Ongoing cycle consistency",
                
              ],
              icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
            },
          ].map((svc) => (
            <div
              class="rounded-2xl overflow-hidden shadow-sm"
              style="background: white; border: 1px solid #E2E8F0;"
            >
              <div class="relative h-44 overflow-hidden">
                <img
                  src={svc.img}
                  alt={svc.title}
                  class="w-full h-full object-cover"
                />
                <div
                  class="absolute inset-0"
                  style="background: linear-gradient(to bottom, rgba(15,23,42,0.15), rgba(15,23,42,0.75));"
                />
                <div class="absolute bottom-4 left-4 right-4">
                  <div class="flex items-center gap-2.5 mb-1">
                    <div
                      class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0"
                      style="background: #1a4480;"
                    >
                      <svg
                        class="w-3.5 h-3.5 text-white"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d={svc.icon}
                        />
                      </svg>
                    </div>
                    <h3 class="text-white font-bold text-sm">{svc.title}</h3>
                  </div>
                  <p class="text-xs" style="color: #93B4D4;">
                    {svc.subtitle}
                  </p>
                </div>
              </div>
              <div class="p-5">
                <ul class="space-y-2.5">
                  {svc.points.map((p) => (
                    <li class="flex items-center gap-2.5">
                      <svg
                        class="w-4 h-4 flex-shrink-0"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        style="color: #1a4480;"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2.5"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      <span class="text-sm" style="color: #374151;">
                        {p}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p
            class="text-xs font-bold tracking-[0.2em] uppercase mb-4"
            style="color: #1a4480;"
          >
            Who We Serve
          </p>
          <h2
            class="text-3xl lg:text-4xl font-bold mb-6 leading-tight"
            style="color: #0F172A; letter-spacing: -0.02em;"
          >
   Designed for Businesses Managing Workforce Payments
          </h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-3">
            {
              [
                {
                  label: "Growing Businesses",
                  desc: " Structured payroll as workforce and reporting requirements expand.",
                  icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
                },
                {
                  label: "Construction Businesses",
                  desc: "CIS handling and contractor payment structures aligned with HMRC.",
                  icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
                },
                {
                  label: "New Employers",
                  desc: "  Payroll set up correctly from the outset.",
                  icon: "M13 10V3L4 14h7v7l9-11h-7z",
                },
                {
                  label: "Multi-Entity Businesses",
                  desc: " Consistency across payroll, reporting, and submissions.",
                  icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064",
                },
              ].map((item) => (
                <div
                  class="flex items-start gap-4 p-4 rounded-xl transition-all hover:shadow-md"
                  style="border: 1px solid #E2E8F0;"
                >
                  <div
                    class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center"
                    style="background: #EFF6FF;"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      style="color: #1a4480;"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d={item.icon}
                      />
                    </svg>
                  </div>
                  <div>
                    <div
                      class="text-sm font-semibold mb-0.5"
                      style="color: #0F172A;"
                    >
                      {item.label}
                    </div>
                    <div
                      class="text-xs leading-relaxed"
                      style="color: #64748B;"
                    >
