---
import UKLayout from '../../../../layouts/UKLayout.astro';
---

<UKLayout title="Monthly Financial Management | Ambit UK" description="Accurate monthly financial reports, cash flow analysis, and actionable insights for UK businesses. HMRC-compliant reporting from dedicated finance experts.">

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[88vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1600&q=80"
        alt="Financial dashboard"
        class="w-full h-full object-cover"
        style="opacity: 0.15;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 50%, #1a4480 100%); opacity: 0.85;"></div>
    </div>

    <!-- Red accent blur (UK identity) -->
    <div class="absolute top-20 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #DC2626; opacity: 0.06;"></div>
    <div class="absolute bottom-20 left-20 w-64 h-64 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.15;"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: Text -->
        <div>
          <div
            x-show="visible"
            x-transition:enter="transition duration-700"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6"
            style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
          >
            <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-4 h-3 object-cover rounded-sm" />
            UK Monthly Financial Management
          </div>

          <h1
            x-show="visible"
            x-transition:enter="transition duration-700 delay-100"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-3xl lg:text-4xl xl:text-5xl font-black leading-none mb-6"
            style="color: #F8FAFC; letter-spacing: -0.03em;"
          >
            United Kingdom <br />
            <span style="color: #3B82F6;">Financial Management
          </h1>

          <p
            x-show="visible"
            x-transition:enter="transition duration-700 delay-200"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-lg leading-relaxed mb-10 max-w-xl"
            style="color: #94A3B8;"
          >
            Structured financial reporting, analysis, and planning designed to provide clarity, control, and visibility across business performance.
          </p>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-4"
          >
            <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
             Speak to an Expert
            </a>
            <a href="#services" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
               See How It Works
            </a>
          </div>
        <div
            class="flex flex-wrap gap-5 pt-8"
            style="border-top: 1px solid #1E293B;"
          >
            {
              [
                "UK GAAP aligned",
                "HMRC Compliant",
                " RTI payroll aligned",
                "VAT compliant",
                " Making Tax Digital ready",
              ].map((t) => (
                <div class="flex items-center gap-1.5">
                  <svg
                    class="w-3.5 h-3.5 flex-shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    style="color: #3B82F6;"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2.5"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="text-xs font-medium" style="color: #64748B;">
                    {t}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Right: Floating cards -->
        <div
          x-show="visible"
          x-transition:enter="transition duration-700 delay-400"
          x-transition:enter-start="opacity-0 translate-x-8"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <div class="relative w-full aspect-square max-w-sm mx-auto">
            <img
              src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80"
              alt="Financial reports"
              class="w-full h-full object-cover rounded-2xl"
              style="opacity: 0.7;"
            />

            <!-- Floating badge 1 -->
            <div
            class="absolute -bottom-6 -left-8 rounded-xl px-5 py-4 shadow-xl"
            style="background: #1a4480; border: 1px solid rgba(255,255,255,0.1);"
          >
          
          </div>
          <div
            class="absolute -top-4 -right-4 rounded-xl px-4 py-3 shadow-xl"
            style="background: #1E293B; border: 1px solid #334155;"
          >
            <div class="text-xl font-bold text-white leading-none mb-0.5">
              ISO 27001 Certified
            </div>
            <div class="text-xs text-center" style="color: #64748B;">
              ICO Registered
            </div>
          </div>

            <!-- Floating badge 2 -->
            <div class="absolute -bottom-4 -right-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="flex items-center gap-1">
                  <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
                  <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
                  <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-5 h-3.5 object-cover rounded-sm" />
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">Multi-Country</div>
                  <div class="text-xs" style="color: #64748B;">UK · US · Dubai</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div
      class="flex items-center gap-0"
      style="animation: marquee 30s linear infinite; width: max-content;"
    >
      {
        [
          "UK GAAP aligned financial reporting",
          " HMRC compliance across filings",
          " RTI payroll and employer obligations",
          "Corporation tax and VAT alignment",
          " Consistent reporting across periods",
          "Structured financial workflows",
          " Making Tax Digital readiness",
          "Platform-aligned accounting (Xero, QuickBooks, Sage)",
        ]
          .concat([
            "UK GAAP aligned financial reporting",
            " HMRC compliance across filings",
            " RTI payroll and employer obligations",
            "Corporation tax and VAT alignment",
            " Consistent reporting across periods",
            "Structured financial workflows",
            " Making Tax Digital readiness",
            "Platform-aligned accounting (Xero, QuickBooks, Sage)",
          ])
          .map((item) => (
            <div class="flex items-center gap-3 px-6 whitespace-nowrap">
              <span class="w-1.5 h-1.5 rounded-full bg-white opacity-60 flex-shrink-0" />
              <span class="text-xs font-semibold tracking-[0.12em] uppercase text-white opacity-90">
                {item}
              </span>
            </div>
          ))
      }
    </div>
  </div>

  <!-- ===== WHY THIS MATTERS ===== -->
    <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div
          class="relative rounded-2xl overflow-hidden shadow-xl order-2 lg:order-1"
          style="height: 480px;"
        >
          <img
            src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=900&auto=format&fit=crop&q=80"
            alt="Payroll accuracy UK"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute inset-0"
            style="background: linear-gradient(to top, rgba(15,23,42,0.55) 0%, transparent 55%);"
          >
          </div>
          <div class="absolute bottom-6 left-6 right-6 grid grid-cols-2 gap-3">
            {
              [
                { num: "Clear", label: "Financial visibility" },
                { num: "Structured", label: "Reporting cycles" },
                { num: "Informed", label: " Decision-making" },
                { num: "Forward-looking", label: "Planning" },
              ].map((m) => (
                <div
                  class="rounded-lg px-4 py-3"
                  style="background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.1);"
                >
                  <div class="text-xl font-bold text-white leading-none mb-0.5">
                    {m.num}
                  </div>
                  <div class="text-xs" style="color: #94A3B8;">
                    {m.label}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <p
            class="text-xs font-bold tracking-[0.2em] uppercase mb-4"
            style="color: #1a4480;"
          >
            Why It Matters
          </p>
          <h2
            class="text-3xl lg:text-4xl font-bold mb-6 leading-tight"
            style="color: #0F172A; letter-spacing: -0.02em;"
          >
            Financial Reporting Should Support Decisions, Not Just Compliance
          </h2>
          <div class="w-10 h-px mb-6" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed " style="color: #475569;">
           Financial data is often available but not structured for decision-making. Without consistent reporting and analysis, it becomes difficult to understand performance, manage cash flow, or plan ahead.
          </p>
          <p class="text-base leading-relaxed mb-8" style="color: #475569;">
         Structured financial management provides clarity across performance, enabling informed decisions and better control.
          </p>

          <div class="space-y-4">
            {
              [
                {
                  title: "Clarity Across Performance",
                  desc: "Consistent reporting across revenue, costs, and profitability.",
                },
                {
                  title: "Forward Visibility",
                  desc: "Planning and forecasting aligned with current financial position.",
                },
                {
                  title: "Control Over Financial Outcomes",
                  desc: "Structured insight supports better cost, margin, and cash flow management.",
                },
              ].map((item) => (
                <div
                  class="flex gap-4 p-4 rounded-xl"
                  style="background: #F8FAFC; border: 1px solid #E2E8F0;"
                >
                  <div
                    class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5"
                    style="background: #EFF6FF;"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      style="color: #1a4480;"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                  </div>
                  <div>
                    <div
                      class="text-sm font-semibold mb-1"
                      style="color: #0F172A;"
                    >
                      {item.title}
                    </div>
                    <div
                      class="text-xs leading-relaxed"
                      style="color: #64748B;"
                    >
                      {item.desc}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
 <section id="services" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">What We Offer</div>
      <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Financial Management — United Kingdom</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {[
        {
          icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
          title: 'Management Reporting',
          items: ['Monthly management accounts', 'Profit & Loss, Balance Sheet, Cash Flow', 'Structured reporting packs'],
        },
        {
          icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
          title: 'Variance Analysis',
          items: ['Budget vs actual comparison', 'Identification of performance gaps', 'Explanation of key movements'],
        },
        {
          icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
          title: 'Budgeting & Forecasting',
          items: ['Annual budgeting', 'Rolling forecasts', 'Alignment with business plans'],
        },
        {
          icon: 'M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12',
          title: 'Cash Flow Planning',
          items: ['Cash flow forecasting', 'Liquidity tracking', 'Working capital visibility'],
        },
        {
          icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
          title: 'Performance Analysis',
          items: ['Margin and profitability analysis', 'Cost structure evaluation', 'Revenue trend analysis', 'Tracking of dividends and retained earnings alignment'],
        },
        {
          icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
          title: 'Group & Intercompany Reporting',
          items: ['Intercompany reconciliation', 'Multi-entity reporting alignment', 'Consolidation support'],
        },
        {
          icon: 'M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z',
          title: 'Scenario Modelling',
          items: ['Financial impact of business decisions', 'Growth and cost scenarios', 'Planning under different assumptions'],
        },
        {
          icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
          title: 'KPI & Dashboard Reporting',
          items: ['Key performance indicators', 'Custom reporting dashboards', 'Consistent tracking across periods'],
        },
      ].map(({ icon, title, items }) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: #EFF6FF;">
            <svg class="w-6 h-6" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-4" style="color: #0F172A;">{title}</h3>
          <ul class="space-y-2">
            {items.map(item => (
              <li class="flex items-start gap-2 text-sm" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;"> Who We Serve</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Designed for Businesses Requiring Financial Visibility and Control</h2>
      </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '📈', label: 'Growing SMEs', desc: 'Need structured reporting and visibility as complexity increases.' },
          { icon: '🚀', label: 'Founder-Led Businesses', desc: 'Require clarity across financial performance and planning.' },
          { icon: '🏢', label: 'Multi-Entity Businesses', desc: 'Consistency across reporting and financial control.' },
          { icon: '💼', label: 'Investor-Backed Companies', desc: 'Require structured reporting and forward-looking insight.' },
        ].map(({ icon, label, desc }) => (
          <div class="flex flex-col items-center text-center p-6 rounded-2xl border border-gray-100 hover:border-blue-100 hover:shadow-sm transition-all" style="background-color: #F8FAFC;">
            <span class="text-3xl mb-3">{icon}</span>
            <span class="text-sm font-semibold mb-2" style="color: #0F172A;">{label}</span>
            <span class="text-xs" style="color: #64748B;">{desc}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">The Challenges</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Facing Financial Uncertainty?</h2>
      </div>

     <div class="grid md:grid-cols-2 gap-12">
        <!-- Problems -->
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Structured Financial Management</h3>
          {[
            'Limited visibility across performance',
            'Reactive decision-making',
            'Uncertain cash flow position',
            'Inconsistent reporting',
            'Lack of forward planning',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border: 1px solid #DC2626; border-left-width: 3px;">
              <span class="text-lg flex-shrink-0">❌</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>

        <!-- Solutions -->
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">With Structured Financial Management</h3>
          {[
            'Clear performance visibility',
            'Consistent reporting cycles',
            'Planned decision-making',
            'Controlled cash flow',
            'Forward-looking financial insight',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border: 1px solid #22C55E; border-left-width: 3px;">
              <span class="text-lg flex-shrink-0">✅</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Our Process</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">4-Step Monthly Financial Management Process</h2>
      </div>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-8 top-0 bottom-0 w-px" style="background-color: #E2E8F0;"></div>

        <div class="space-y-12">
          {[
            { step: '01', title: 'Data Collection', desc: 'Gather all transactions, invoices, bank statements, and financial records for the month.' },
            { step: '02', title: 'Report Generation', desc: 'Produce monthly P&L, balance sheet, and cash flow statements to HMRC/IRS standards.' },
            { step: '03', title: 'Analysis & Insights', desc: 'Highlight trends, risks, and opportunities — with KPI tracking and variance analysis.' },
            { step: '04', title: 'Review & Advisory', desc: 'Share recommendations to improve performance, refine budgets, and align with growth goals.' },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-8 items-start">
              <div class="relative flex-shrink-0">
                <div class="w-16 h-16 rounded-full flex items-center justify-center text-sm font-black border-4 border-white shadow" style="background-color: #1a4480; color: white;">
                  {step}
                </div>
              </div>
              <div class="pt-3">
                <h3 class="text-xl font-bold mb-2" style="color: #0F172A;">{title}</h3>
                <p class="text-base leading-relaxed" style="color: #64748B;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + COUNTRY EXPERTISE ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16">

        <!-- Results / What You Gain -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;"> The Results</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">What You Gain</h2>
         <div class="space-y-3 mb-10">
            {
              [
                "Clear financial visibility",
                "Consistent reporting and analysis",
                "Better planning capability",
                "Informed decision-making",
              ].map((r) => (
                <div
                  class="flex items-center gap-3 py-3 px-4 rounded-xl"
                  style="background: #F8FAFC; border: 1px solid #E2E8F0;"
                >
                  <div
                    class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0"
                    style="background: #EFF6FF;"
                  >
                    <svg
                      class="w-3.5 h-3.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      style="color: #1a4480;"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
