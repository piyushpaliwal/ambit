---
import UKLayout from '../../../../layouts/UKLayout.astro';
---

<UKLayout
  title="VAT Compliance – UK | HMRC VAT Registration & Filing | Ambit"
  description="VAT reporting, registration, and filing structured across transactions, ensuring accuracy, consistency, and alignment with HMRC and Making Tax Digital requirements."
  countryPhone="+44 (0) 20 1234 5678"
  countryEmail="uk@ambit.co.uk"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 580px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] rounded-full opacity-[0.04] blur-3xl" style="background: #DC2626;"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 flex items-center" style="min-height: 580px;">
      <div class="grid lg:grid-cols-2 gap-14 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United Kingdom · VAT Compliance</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            United Kingdom<br />
            <span style="color: #93B4D4;">— VAT Compliance</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 460px;">
            VAT reporting, registration, and filing structured across transactions, ensuring accuracy, consistency, and alignment with HMRC and Making Tax Digital requirements.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              Speak to an Expert
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              See How It Works
            </a>
          </div>

          <div class="flex flex-wrap gap-5 pt-8" style="border-top: 1px solid #1E293B;">
            {['UK GAAP Certified', 'HMRC Compliant', 'RTI Payroll', 'VAT Specialists', 'Making Tax Digital ready'].map(t => (
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-xs font-medium" style="color: #64748B;">{t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right -->
        <div class="relative hidden lg:block">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="height: 440px;">
            <img
              src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=900&auto=format&fit=crop&q=80"
              alt="VAT compliance and filing"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,23,42,0.5) 0%, transparent 60%);"></div>
          </div>
          <div class="absolute -top-4 -right-4 rounded-xl px-4 py-3 shadow-xl" style="background: #1E293B; border: 1px solid #334155;">
            <div class="text-xl font-bold text-white leading-none mb-0.5">ISO 27001 Certified</div>
            <div class="text-xs" style="color: #64748B;">ICO Registered</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== CAPABILITY MARQUEE ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div
      class="flex items-center gap-0"
      style="animation: marquee 30s linear infinite; width: max-content;"
    >
      {[
        'UK GAAP aligned financial reporting',
        'HMRC compliance across filings',
        'RTI payroll and employer obligations',
        'Corporation tax and VAT alignment',
        'Consistent reporting across periods',
        'Structured financial workflows',
        'Making Tax Digital readiness',
        'Platform-aligned accounting (Xero, QuickBooks, Sage)',
        'UK GAAP aligned financial reporting',
        'HMRC compliance across filings',
        'RTI payroll and employer obligations',
        'Corporation tax and VAT alignment',
        'Consistent reporting across periods',
        'Structured financial workflows',
        'Making Tax Digital readiness',
        'Platform-aligned accounting (Xero, QuickBooks, Sage)',
      ].map(item => (
        <div class="flex items-center gap-3 px-6 whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-white opacity-60 flex-shrink-0" />
          <span class="text-xs font-semibold tracking-[0.12em] uppercase text-white opacity-90">{item}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== CERTIFICATION BLOCK ===== -->
  <section style="background-color: #F8FAFC; border-bottom: 1px solid #E2E8F0;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10 py-10">
      <div class="flex flex-wrap items-center gap-6">
        <span class="text-xs font-bold tracking-widest uppercase" style="color: #94A3B8;">Standards</span>
        {['ISO 27001 Certified', 'ICO Registered'].map(cert => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background-color: #ffffff; border: 1px solid #E2E8F0;">
            <svg class="w-4 h-4" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            <span class="text-xs font-semibold" style="color: #475569;">{cert}</span>
          </div>
        ))}
        <div class="ml-auto hidden lg:flex items-center gap-8">
          {[
            { metric: 'Accurate', label: 'VAT reporting' },
            { metric: 'On-time', label: 'Submissions' },
            { metric: 'Consistent', label: 'Reconciliation' },
            { metric: 'MTD', label: 'Aligned' },
          ].map(({ metric, label }) => (
            <div class="text-center">
              <div class="text-base font-bold leading-none mb-0.5" style="color: #0F172A;">{metric}</div>
              <div class="text-xs" style="color: #64748B;">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="relative rounded-2xl overflow-hidden shadow-xl order-2 lg:order-1" style="height: 480px;">
          <img
            src="https://images.unsplash.com/photo-1554224154-26032ffc0d07?w=900&auto=format&fit=crop&q=80"
            alt="VAT compliance review"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.55) 0%, transparent 55%);"></div>
          <div class="absolute bottom-6 left-6 right-6 grid grid-cols-2 gap-3">
            {[
              { num: 'Accurate', label: ' VAT reporting' },
              { num: 'On-time', label: ' Submissions' },
              { num: 'Consistent', label: 'Reconciliation' },
              { num: 'MTD', label: 'Aligned' },
            ].map(m => (
              <div class="rounded-lg px-4 py-3" style="background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.1);">
                <div class="text-xl font-bold text-white leading-none mb-0.5">{m.num}</div>
                <div class="text-xs" style="color: #94A3B8;">{m.label}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            VAT Requires Consistency Across Every Transaction
          </h2>
          <div class="w-10 h-px mb-6" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed mb-2" style="color: #475569;">
            VAT issues rarely arise at the point of filing. They originate from incorrect classification, inconsistent coding, and incomplete reconciliation across transactions.
          </p>
          <p class="text-base leading-relaxed mb-8" style="color: #475569;">
            A structured VAT approach ensures accuracy at the source, allowing returns to be prepared without rework and submitted confidently.
          </p>

          <div class="space-y-4">
            {[
              { title: 'Transaction-Level Accuracy', desc: 'Correct VAT treatment applied at the point of entry.' },
              { title: 'Timely Filing', desc: 'Returns prepared and submitted in line with HMRC deadlines.' },
              { title: 'Clean Reconciliation', desc: 'VAT control accounts aligned with financial records across reporting periods.' },
            ].map(item => (
              <div class="flex gap-4 p-4 rounded-xl" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-1" style="color: #0F172A;">{item.title}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== WHAT WE OFFER ===== -->
  <section class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">VAT Compliance — United Kingdom</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            num: '01',
            title: 'VAT Registration',
            points: ['VAT registration with HMRC', 'Threshold assessment and voluntary registration', 'Setup aligned with business model', 'Guidance on VAT scheme selection'],
          },
          {
            num: '02',
            title: 'VAT Record Management',
            points: ['Transaction classification', 'VAT code application', 'Input and output VAT tracking'],
          },
          {
            num: '03',
            title: 'VAT Returns',
            points: ['Preparation of VAT returns', 'Review before submission', 'Filing in line with HMRC deadlines'],
          },
          {
            num: '04',
            title: 'VAT Reconciliation',
            points: ['VAT control account reconciliation', 'Identification of discrepancies', 'Adjustment tracking'],
          },
          {
            num: '05',
            title: 'VAT Refunds & Recovery',
            points: ['Identification of reclaimable input VAT', 'Preparation and submission of refund claims', 'Alignment with HMRC requirements'],
          },
          {
            num: '06',
            title: 'VAT Schemes & Treatment',
            points: ['Flat Rate Scheme', 'Standard vs Cash Accounting Scheme', 'Partial exemption handling', 'VAT treatment across different transaction types'],
          },
          {
            num: '07',
            title: 'Compliance Support',
            points: ['HMRC-ready VAT records', 'Making Tax Digital alignment', 'Support during VAT queries and reviews'],
          },
        ].map(svc => (
          <div class="rounded-2xl p-6" style="background: #ffffff; border: 1px solid #E2E8F0;">
            <div class="text-3xl font-black mb-3 leading-none" style="color: #E2E8F0;">{svc.num}</div>
            <h3 class="text-sm font-bold mb-4" style="color: #0F172A;">{svc.title}</h3>
            <ul class="space-y-2.5">
              {svc.points.map(p => (
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-xs leading-relaxed" style="color: #64748B;">{p}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Designed for VAT-Registered Businesses
          </h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-3">
            {[
              { label: 'E-commerce & Retail', desc: 'Multi-rate VAT, cross-border transactions, and platform reconciliation.', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z' },
              { label: 'Service-Based Businesses', desc: 'Accurate VAT treatment across invoices and expenses.', icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
              { label: 'Growing SMEs', desc: 'Structured VAT processes as transaction volumes increase.', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
              { label: 'Multi-Entity Businesses', desc: 'Consistency across VAT reporting and reconciliation.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
            ].map(item => (
              <div class="flex items-start gap-4 p-4 rounded-xl transition-all hover:shadow-md" style="border: 1px solid #E2E8F0;">
                <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
                  </svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-0.5" style="color: #0F172A;">{item.label}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative rounded-2xl overflow-hidden shadow-xl hidden lg:block" style="height: 540px;">
          <img
            src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=900&auto=format&fit=crop&q=80"
            alt="VAT-registered businesses team"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.65) 0%, transparent 55%);"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="text-white font-bold text-xl mb-2">Built for Your Business</div>
            <div class="text-sm" style="color: #93B4D4;">From SMEs to multi-entity groups</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-20 lg:py-28" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #93B4D4;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white" style="letter-spacing: -0.02em;">
          Without Structured VAT Compliance
        </h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <div class="rounded-2xl p-8" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(239,68,68,0.15);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #EF4444;">Without Structured VAT Compliance</span>
          </div>
          <div class="space-y-4">
            {['Incorrect VAT classification', 'Filing errors and missed deadlines', 'Reconciliation gaps', 'Increased compliance risk'].map(p => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                <span class="text-sm leading-relaxed" style="color: #94A3B8;">{p}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl p-8" style="background: rgba(26,68,128,0.15); border: 1px solid rgba(26,68,128,0.35);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(26,68,128,0.3);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #93B4D4;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #93B4D4;">With Structured VAT Compliance</span>
          </div>
          <div class="space-y-4">
            {['Accurate transaction-level VAT tracking', 'Timely return submissions', 'Clean reconciliations', 'Reduced compliance exposure'].map(s => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-sm leading-relaxed" style="color: #CBD5E1;">{s}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-16">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">Our Process</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">How Work Is Structured</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="hidden lg:grid grid-cols-5 gap-4 relative">
        <div class="absolute top-[52px] left-[10%] right-[10%] h-px" style="background: linear-gradient(to right, #1a4480, #1e5ab5, #1a4480);"></div>
        {[
          { num: '01', title: 'Understanding', desc: 'We review your VAT position, transaction types, and existing compliance setup.' },
          { num: '02', title: 'Structuring', desc: 'VAT coding, schemes, and record management aligned to your business model.' },
          { num: '03', title: 'Onboarding', desc: 'Systems and processes set up to capture VAT accurately at every transaction.' },
          { num: '04', title: 'Execution & Review', desc: 'Returns prepared, reviewed, and submitted in line with HMRC deadlines.' },
          { num: '05', title: 'Continuity', desc: 'Ongoing reconciliation, support for queries, and MTD alignment maintained.' },
        ].map((step, i) => (
          <div class="flex flex-col items-center text-center">
            <div class="relative z-10 w-[100px] h-[100px] rounded-full flex flex-col items-center justify-center mb-6 shadow-lg" style="background: white; border: 2px solid #1a4480;">
              <span class="text-xs font-bold tracking-[0.15em] uppercase mb-0.5" style="color: #94A3B8;">{step.num} / 05</span>
              <span class="text-lg font-bold" style="color: #0F172A;">{i + 1}</span>
            </div>
            <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{step.title}</h3>
            <div class="w-6 h-px mb-3 mx-auto" style="background: #1a4480;"></div>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="lg:hidden space-y-6">
        {[
          { num: '01', title: 'Understanding', desc: 'Review your VAT position, transaction types, and existing compliance setup.' },
          { num: '02', title: 'Structuring', desc: 'VAT coding, schemes, and record management aligned to your business model.' },
