---
import UKLayout from '../../../../layouts/UKLayout.astro';
---

<UKLayout
  title="UK Accounting Services"
  description="HMRC-compliant accounting, bookkeeping, payroll and tax services for UK businesses. Ambit delivers accurate, cost-effective solutions built for British standards."
  countryPhone="+44 (0) 20 1234 5678"
  countryEmail="uk@ambit.co.uk"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 600px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full opacity-[0.05] blur-3xl" style="background: #1a4480;"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full opacity-[0.04] blur-3xl" style="background: #DC2626;"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 flex items-center" style="min-height: 600px;">
      <div class="grid lg:grid-cols-2 gap-14 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United Kingdom · Accounting Services</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            United Kingdom<br/>
            <span style="color: #93B4D4;">Finance, Accounting & Tax</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 480px;">
            From early-stage businesses to established firms across the UK, Ambit structures accounting, tax, and financial operations to remain consistent, compliant, and reliable across reporting cycles.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#uk-services" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              See Our Services
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#uk-contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              Book Free Consultation
            </a>
          </div>

          <div class="flex flex-wrap gap-5 pt-8" style="border-top: 1px solid #1E293B;">
            {['UK GAAP Certified', 'HMRC Compliant', 'RTI Payroll', 'VAT Specialists', ' Making Tax Digital ready'].map(t => (
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-xs font-medium" style="color: #64748B;">{t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: UK map visual + stats -->
        <div class="relative hidden lg:block">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="height: 440px;">
            <img
              src="https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?w=900&auto=format&fit=crop&q=80"
              alt="London skyline - UK business hub"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,23,42,0.6) 0%, rgba(15,23,42,0.2) 60%, transparent 100%);"></div>

            <!-- City badges -->
            <div class="absolute top-6 left-6 flex flex-col gap-2">
              {['London', 'Manchester', 'Birmingham', 'Edinburgh'].map((city, i) => (
                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold" style="background: rgba(15,23,42,0.8); border: 1px solid rgba(255,255,255,0.1); color: #CBD5E1;">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${i === 0 ? '#3B82F6' : '#475569'};`}></span>
                  {city}
                </div>
              ))}
            </div>
          </div>

          <!-- Floating stats -->
          <div class="absolute -bottom-6 -left-8 rounded-xl px-5 py-4 shadow-xl" style="background: #1a4480; border: 1px solid rgba(255,255,255,0.1);">
            <div class="text-2xl font-bold text-white leading-none mb-0.5">HMRC</div>
            <div class="text-xs font-medium" style="color: #93B4D4;">Fully Compliant</div>
          </div>
          <div class="absolute -top-4 -right-4 rounded-xl px-4 py-3 shadow-xl" style="background: #1E293B; border: 1px solid #334155;">
            <div class="text-lg font-bold text-white leading-none mb-0.5">ISO 27001 Certified</div>
            <div class="text-xs text-center" style="color: #64748B;"> ICO Registered</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex items-center gap-0" style="animation: marquee 30s linear infinite; width: max-content;">
      {[
        'UK GAAP aligned financial reporting',
        ' HMRC compliance across filings',
        ' RTI payroll and employer obligations',
        'Corporation tax and VAT alignment',
        ' Consistent reporting across periods',
        'Structured financial workflows',
        ' Making Tax Digital readiness',
        'Platform-aligned accounting (Xero, QuickBooks, Sage)',
      ].concat([
           'UK GAAP aligned financial reporting',
        ' HMRC compliance across filings',
        ' RTI payroll and employer obligations',
        'Corporation tax and VAT alignment',
        ' Consistent reporting across periods',
        'Structured financial workflows',
        ' Making Tax Digital readiness',
        'Platform-aligned accounting (Xero, QuickBooks, Sage)',
      ]).map(item => (
        <div class="flex items-center gap-3 px-6 whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-white opacity-60 flex-shrink-0"></span>
          <span class="text-xs font-semibold tracking-[0.12em] uppercase text-white opacity-90">{item}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== WHY UK BUSINESSES TRUST AMBIT ===== -->
  <section class="py-24" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">

      <div class="grid lg:grid-cols-2 gap-16 items-center mb-16">
        <div class="relative hidden lg:block">
          <img
            src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=900&auto=format&fit=crop&q=80"
            alt="UK business professionals"
            class="rounded-2xl w-full object-cover shadow-lg"
            style="height: 420px; object-position: center;"
          />
          <div class="absolute top-6 -right-5 bg-white rounded-xl px-4 py-3 shadow-lg" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-bold mb-0.5" style="color: #0F172A;">UK GAAP Certified</p>
            <p class="text-xs" style="color: #94A3B8;">HMRC · RTI · VAT</p>
          </div>
          <div class="absolute -bottom-5 left-6 rounded-xl px-4 py-3 shadow-lg" style="background: #0F172A; border: 1px solid #1E293B;">
            <p class="text-xs font-bold text-white mb-0.5">Making Tax Digital</p>
            <p class="text-xs" style="color: #475569;">MTD Ready</p>
          </div>
        </div>

        <div>
         <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why Ambit</p>
<h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
  Why UK Businesses Work With Ambit
</h2>

<p class="" style="color: #334155;">
 As businesses grow, financial processes often become fragmented across systems, teams, and reporting cycles.
</p>

<p class="mb-4" style="color: #334155;">
 Ambit brings structure across accounting, tax, and financial operations, ensuring consistency and compliance without increasing internal complexity.
</p>


          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-5">
            {[
              { title: 'Structured Delivery', desc: 'Work is aligned to your systems and workflows, ensuring consistency across reporting cycles.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
              { title: 'Regulatory Alignment', desc: 'Accounting, tax, and VAT handled in line with HMRC and UK GAAP requirements.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
              { title: 'Clear Financial Visibility', desc: 'Reporting remains consistent and usable across periods without rework.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
              { title: 'Scalable Support', desc: 'Capacity increases without adding internal complexity.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
            ].map(item => (
              <div class="flex gap-4 items-start p-4 rounded-xl" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
                </div>
                <div>
                  <div class="text-sm font-bold mb-1" style="color: #0F172A;">{item.title}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 pt-8" style="border-top: 1px solid #E2E8F0;">
        {[
          { num: '100%', label: ' Compliance alignment' },
          { num: '£0', label: 'Penalty exposure' },
          { num: '500+', label: ' Clients supported' },
          { num: '24h', label: 'Response Time' },
        ].map(s => (
          <div class="text-center p-5 rounded-xl" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
            <div class="text-2xl font-bold mb-1" style="color: #1a4480;">{s.num}</div>
            <div class="text-xs" style="color: #64748B;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES GRID ===== -->
  <section id="uk-services" class="py-24" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">

      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="color: #0F172A; letter-spacing: -0.02em;">Finance, Accounting & Tax — United Kingdom </h2>
        <p class="text-sm" style="color: #64748B; max-width: 500px; margin: 0 auto;">Each function is structured to ensure consistency, compliance, and continuity across financial operations.</p>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <!-- Quick nav grid -->
      <!-- <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px mb-12" style="background-color: #E2E8F0; border: 1px solid #E2E8F0; border-radius: 16px; overflow: hidden;">
        {[
          { num: '01', label: 'Accounting & Bookkeeping', sub: ' Structured financial records, reconciliations, and reporting aligned to UK GAAP', href: '/uk/accounting' },
          { num: '02', label: 'Payroll', sub: ' Payroll processing aligned with RTI, PAYE, and employer obligations.', href: '/uk/payroll' },
          { num: '03', label: 'Tax Compliance', sub: ' Corporation tax computation and CT600 filing aligned with HMRC requirements.', href: '/uk/tax' },
          { num: '04', label: 'VAT Compliance', sub: ' Transaction-level VAT management, return preparation, and submission aligned with HMRC and Making Tax Digital.', href: '/uk/accounts' },
          { num: '05', label: 'Financial Management', sub: ' Monthly reporting, analysis, and structured financial visibility.', href: '/uk/reporting' },
          { num: '06', label: 'Business Formation', sub: ' Company setup and structuring aligned to UK regulatory requirements.', href: '/uk/offshore' },
        ].map(s => (
          <a href={s.href} class="group flex items-start justify-between gap-4 p-7 transition-all duration-200 hover:bg-slate-50" style="background-color: white;">
            <div class="flex items-start gap-5">
              <span class="text-xs font-black tracking-widest mt-1 flex-shrink-0" style="color: #CBD5E1;">{s.num}</span>
              <div>
                <h3 class="text-sm font-bold mb-1.5 group-hover:text-blue-700 transition-colors leading-snug" style="color: #0F172A;">{s.label}</h3>
                <p class="text-xs leading-relaxed" style="color: #94A3B8;">{s.sub}</p>
              </div>
            </div>
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5 opacity-20 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-200" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        ))}
      </div> -->

      <!-- Service cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { href: '/uk/accounting', title: 'Accounting & Bookkeeping (UK GAAP)', desc: ' Structured bookkeeping and reconciliations aligned to UK GAAP, ensuring clean and reliable financial records.', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z', img: 'https://images.unsplash.com/photo-1554224154-26032ffc0d07?w=600&auto=format&fit=crop&q=70' },
          { href: '/uk/payroll', title: 'Payroll (RTI & HMRC)', desc: 'Accurate payroll processing with RTI submissions, PAYE compliance, and consistent reporting.', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z', img: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&auto=format&fit=crop&q=70' },
          { href: '/uk/tax', title: 'Tax Compliance', desc: ' Corporation tax computation and CT600 filing handled accurately and on time.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&auto=format&fit=crop&q=70' },
          { href: '/uk/accounts', title: 'VAT Compliance', desc: ' VAT return preparation, reconciliation, and submission aligned with HMRC and MTD', icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z', img: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?w=600&auto=format&fit=crop&q=70' },
          { href: '/uk/reporting', title: 'Financial Management', desc: ' Monthly reporting, dashboards, and financial visibility across your business.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&auto=format&fit=crop&q=70' },
          { href: '/uk/offshore', title: 'Business Formation', desc: ' Company incorporation and compliance setup aligned to UK requirements.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', img: 'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=600&auto=format&fit=crop&q=70' },
        ].map(s => (
          <a href={s.href} class="bg-white rounded-2xl group hover:-translate-y-1 transition-all duration-300 flex flex-col overflow-hidden" style="border: 1px solid #EEF2F6; box-shadow: 0 2px 16px rgba(15,23,42,0.05);">
            <div class="relative h-36 overflow-hidden">
              <img src={s.img} alt={s.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent, rgba(15,23,42,0.5));"></div>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <div class="w-9 h-9 rounded-xl flex items-center justify-center mb-4 flex-shrink-0" style="background: linear-gradient(135deg, #0F172A 0%, #1a4480 100%);">
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={s.icon}/>
                </svg>
              </div>
              <h3 class="text-sm font-bold mb-2 leading-snug group-hover:text-blue-700 transition-colors" style="color: #0F172A;">{s.title}</h3>
              <p class="text-xs leading-relaxed flex-1 mb-4" style="color: #64748B;">{s.desc}</p>
              <div class="flex items-center gap-1.5 text-xs font-semibold group-hover:gap-2.5 transition-all" style="color: #1a4480;">
                Learn More
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PAIN POINTS → SOLUTIONS ===== -->
  <section class="py-24" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #93B4D4;">Common Challenges</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6 leading-tight" style="letter-spacing: -0.02em;">
            Common Challenges Across UK Businesses
          </h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-4">
            {[
              { problem: 'Missed HMRC or VAT deadlines', solution: ' Structured processes ensure consistent and timely filings.' },
              { problem: 'Payroll errors and RTI inconsistencies', solution: ' Payroll aligned to RTI requirements reduces errors and rework.' },
              { problem: 'Inconsistent financial records', solution: ' Accounting aligned to UK GAAP improves accuracy and reliability.' },
              { problem: 'Limited financial visibility', solution: ' Structured reporting provides clarity across performance and cash flow.' },
            ].map(item => (
              <div class="rounded-xl p-5" style="background: #1E293B; border: 1px solid #334155;">
                <div class="flex items-start gap-3 mb-3">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
                  <span class="text-xs font-semibold" style="color: #94A3B8;">{item.problem}</span>
                </div>
                <div class="flex items-start gap-3 pl-7">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0 -ml-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-sm font-medium" style="color: #CBD5E1;">{item.solution}</span>
                </div>
              </div>
            ))}
          </div>

          <a href="/contact" class="inline-flex items-center gap-2 mt-8 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
            See How We Can Help Your UK Business
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <div class="relative rounded-2xl overflow-hidden hidden lg:block shadow-2xl" style="height: 520px;">
          <img
            src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=900&auto=format&fit=crop&q=80"
            alt="UK accountant solving business challenges"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.7) 0%, rgba(15,23,42,0.2) 60%);"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="text-white font-bold text-lg mb-2">Every Challenge Has a Solution</div>
            <div class="text-sm" style="color: #93B4D4;">HMRC-compliant. Accurate. On time.</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== INDUSTRY SPOTLIGHT ===== -->
  <section class="py-24" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">Industries We Serve</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Serving a Wide Range of UK Industries</h2>
