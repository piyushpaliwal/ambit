<script is:inline>
  function submitConsultFormUSTC(e) {
    e.preventDefault();
    const btn = document.getElementById('consult-submit-btn-us-tc');
    btn.textContent = 'Sending...';
    btn.disabled = true;
    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: new FormData(e.target)
    }).then(() => {
      document.getElementById('consult-form-us-tc').style.display = 'none';
      document.getElementById('consult-success-us-tc').style.display = 'block';
    }).catch(() => {
      btn.textContent = 'Book Free Consultation';
      btn.disabled = false;
    });
  }
  document.getElementById('consult-modal').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
  });
</script>

