---
import USLayout from '../../../../layouts/USLayout.astro';
---

<USLayout title="US Payroll Services | Employment Tax & Multi-State Payroll | Ambit" description="Payroll processing and employment tax compliance for US businesses. IRS-aligned, multi-state payroll handling, W-2, 1099, Form 941, and state filings managed accurately.">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(26,68,128,0.18) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-12 py-24 lg:py-32">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase" style="background-color: rgba(26,68,128,0.25); border: 1px solid rgba(26,68,128,0.4); color: #93C5FD;">
          <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-4 h-3 object-cover rounded-sm" />
          United States · Payroll
        </div>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight mb-6" style="color: #F8FAFC;">
        Payroll
        <span class="block" style="color: #93C5FD;">United States</span>
      </h1>

      <p class="text-lg md:text-xl max-w-2xl mb-12 leading-relaxed" style="color: #94A3B8;">
        Payroll processing and employment tax compliance structured to ensure accurate employee payments and alignment with IRS and state requirements across all pay cycles.
      </p>

      <div class="flex flex-wrap gap-3 mb-14">
        {['IRS Compliant', 'Federal and State Aligned', 'Multi-State Payroll Ready', 'Employment Tax Compliant', 'Audit-Ready Records'].map(label => (
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">{label}</span>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#process" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          See How It Works
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-semibold transition-all hover:opacity-80" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
          Book Free Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- ===== METRICS STRIP ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { metric: 'Accurate', label: 'Payroll processing', sub: 'Every cycle, every employee' },
          { metric: 'On-time', label: 'Salary payments', sub: 'No delays or disruptions' },
          { metric: 'Compliant', label: 'Tax filings', sub: 'Federal and state aligned' },
          { metric: 'Multi-state', label: 'Coverage', sub: 'All jurisdictions managed' },
        ].map(({ metric, label, sub }) => (
          <div class="text-center lg:text-left">
            <div class="text-3xl lg:text-4xl font-black mb-1" style="color: #F8FAFC;">{metric}</div>
            <div class="text-sm font-semibold mb-1" style="color: #93C5FD;">{label}</div>
            <div class="text-xs" style="color: #475569;">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITY MARQUEE ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex gap-12 whitespace-nowrap animate-marquee text-xs font-semibold tracking-widest uppercase" style="color: #ffffff;">
      {[
        'Payroll processing across pay cycles',
        'Federal and state employment tax compliance',
        'Multi-state payroll handling',
        'Accurate tax withholding and deductions',
        'Quarterly and annual filings',
        'Audit-ready payroll records',
        'Integration with accounting and tax',
        'Ongoing compliance monitoring',
        'Payroll processing across pay cycles',
        'Federal and state employment tax compliance',
        'Multi-state payroll handling',
        'Accurate tax withholding and deductions',
        'Quarterly and annual filings',
        'Audit-ready payroll records',
        'Integration with accounting and tax',
        'Ongoing compliance monitoring',
      ].map(item => (
        <span class="flex items-center gap-3">
          <span class="w-1 h-1 rounded-full inline-block" style="background-color: #1a4480;"></span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ===== CERTIFICATION BLOCK ===== -->
  <section style="background-color: #060D18; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-10">
      <div class="flex flex-wrap items-center gap-6">
        <span class="text-xs font-bold tracking-widest uppercase" style="color: #334155;">Standards</span>
        {['ISO 27001 Certified', 'IRS-Aligned Processes', 'Employment Tax Compliant', 'Multi-State Payroll Ready'].map(cert => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background-color: #0F172A; border: 1px solid #1E293B;">
            <svg class="w-4 h-4" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            <span class="text-xs font-semibold" style="color: #94A3B8;">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight max-w-3xl" style="color: #F8FAFC;">
          Payroll Must Align with Employment Tax and Multi-State Requirements
        </h2>
        <p class="mt-4 text-base max-w-2xl leading-relaxed" style="color: #64748B;">
          Payroll in the United States is closely tied to employment tax compliance across federal and state levels. Each payroll cycle must align with withholding requirements, reporting obligations, and filing deadlines. Without structured payroll processes, businesses face penalties, incorrect filings, and operational disruption.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Employment Tax Compliance', body: 'Payroll aligned with federal and state withholding requirements.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
          { title: 'Multi-State Payroll Handling', body: 'Payroll structured across different state regulations.', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7' },
          { title: 'Accurate Withholding and Reporting', body: 'Correct calculation of taxes and deductions across employees and contractors.', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z' },
          { title: 'Consistent Payroll Cycles', body: 'Reliable and timely payroll processing every period.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
        ].map(({ title, body, icon }) => (
          <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}/></svg>
            </div>
            <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Payroll Services</h2>
        <p class="mt-3 text-base max-w-2xl" style="color: #64748B;">End-to-end payroll and employment tax management across all US business structures.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            num: '01',
            title: 'Payroll Processing',
            points: [
              'Salary and wage calculations',
              'Employee and contractor payments',
              'Allowances and deductions',
              'Payslip generation and reporting',
            ],
          },
          {
            num: '02',
            title: 'Employment Tax Compliance',
            points: [
              'Federal payroll tax filings',
              'State payroll tax filings',
              'Withholding tax calculations',
              'Alignment with IRS requirements',
            ],
          },
          {
            num: '03',
            title: 'Payroll Tax Registrations',
            points: [
              'Federal employer registration alignment',
              'State payroll tax registrations',
              'Unemployment and withholding registrations across states',
            ],
          },
          {
            num: '04',
            title: 'Quarterly and Annual Filings',
            points: [
              'Form 941 filings',
              'Form W-2 preparation',
              'Form 1099 reporting',
              'Year-end payroll compliance',
            ],
          },
          {
            num: '05',
            title: 'Multi-State Payroll Management',
            points: [
              'Payroll across multiple states',
              'State-specific withholding and unemployment tax handling',
              'State-wise compliance and filing requirements',
              'Coordination across jurisdictions',
            ],
          },
          {
            num: '06',
            title: 'Employee and Contractor Classification',
            points: [
              'Classification of employees and contractors',
              'Alignment with IRS guidelines',
              'Consistency across reporting',
            ],
          },
          {
            num: '07',
            title: 'Payroll Reconciliation',
            points: [
              'Payroll account reconciliation',
              'Alignment with financial records',
              'Identification and correction of discrepancies',
            ],
          },
          {
            num: '08',
            title: 'Benefits and Deductions Handling',
            points: [
              'Payroll deductions and benefits tracking',
              'Alignment with payroll and reporting requirements',
            ],
          },
          {
            num: '09',
            title: 'IRS and State Notice Handling',
            points: [
              'Review of IRS and state payroll notices',
              'Identification of discrepancies',
              'Response support',
            ],
          },
          {
            num: '10',
            title: 'Audit Support',
            points: [
              'Payroll documentation and records',
              'Support during IRS or state reviews',
              'Resolution support for discrepancies',
            ],
          },
        ].map(({ num, title, points }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="flex items-start gap-5">
              <span class="text-4xl font-black leading-none flex-shrink-0" style="color: #1E293B;">{num}</span>
              <div class="flex-1">
                <h3 class="text-sm font-bold mb-4" style="color: #F8FAFC;">{title}</h3>
                <ul class="space-y-2">
                  {points.map(point => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed" style="color: #64748B;">
                      <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Designed for US Businesses Managing Workforce Payments</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { title: 'Single-State Businesses', body: 'Payroll aligned with federal and state requirements.' },
          { title: 'Multi-State Businesses', body: 'Consistent payroll handling across jurisdictions.' },
          { title: 'Growing Companies', body: 'Scalable payroll structure as workforce expands.' },
          { title: 'Businesses with Contractors and Employees', body: 'Accurate classification and reporting across workforce types.' },
        ].map(({ title, body }) => (
          <div class="rounded-xl p-8 flex items-start gap-4" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM / SOLUTION ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Without vs. With Structured Payroll</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #374151;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Structured Payroll</h3>
          <ul class="space-y-4">
            {[
              'Incorrect tax withholdings',
              'Missed payroll tax filings',
              'Multi-state payroll confusion',
              'Employee classification errors',
              'Unresolved IRS or state notices',
              'Increased compliance risk',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #374151;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1a4480;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #93C5FD;">With Structured Payroll</h3>
          <ul class="space-y-4">
            {[
              'Accurate payroll processing',
              'Proper employment tax filings',
              'Multi-state compliance',
              'Clear payroll records',
              'Resolution of notices and discrepancies',
              'Controlled compliance',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section id="process" style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">How Work Is Structured</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Our Process</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          { label: '01 / 05', title: 'Understanding', body: 'We review your workforce structure, existing payroll setup, state registrations, and current employment tax compliance position.' },
          { label: '02 / 05', title: 'Structuring', body: 'We establish the payroll framework including pay schedules, withholding structures, multi-state considerations, and filing calendar.' },
          { label: '03 / 05', title: 'Onboarding', body: 'We connect with your payroll and accounting systems, collect employee and contractor data, and complete outstanding registrations.' },
          { label: '04 / 05', title: 'Execution and Review', body: 'We process payroll each cycle, file employment taxes, generate W-2s and 1099s, and reconcile payroll to financial records.' },
          { label: '05 / 05', title: 'Continuity', body: 'We manage ongoing payroll cycles, handle new hires and terminations, respond to notices, and maintain compliance across jurisdictions.' },
        ].map(({ label, title, body }) => (
          <div>
            <div class="text-xs font-bold tracking-widest mb-4" style="color: #1a4480;">{label}</div>
            <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>

      <div class="mt-14">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          Book Free Consultation for Payroll
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + BUILT FOR US ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What You Gain</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">The Results</h2>
          <ul class="space-y-4">
            {[
              'Accurate payroll processing',
              'Compliance with IRS and state requirements',
              'Timely salary payments',
              'Reduced risk of penalties',
              'Structured handling of notices and filings',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why Ambit</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">Built for US Payroll Environment</h2>
          <ul class="space-y-4">
            {[
              'IRS-aligned payroll processing',
              'Federal and state employment tax compliance',
              'Multi-state payroll management',
              'Integration with accounting and tax',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-12">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Client Feedback</p>
        <h2 class="text-2xl lg:text-3xl font-black" style="color: #F8FAFC;">What Clients Say</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        {[
          { quote: 'Payroll is now accurate and always on time. Employment tax filings and notices are handled without any issues.', name: 'HR Director', company: 'Growth Company, United States' },
          { quote: 'Managing payroll across states was complex earlier. Now everything is structured and compliant.', name: 'CFO', company: 'Multi-State Business, United States' },
        ].map(({ quote, name, company }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <svg class="w-6 h-6 mb-4" style="color: #1a4480;" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed mb-6" style="color: #94A3B8;">{quote}</p>
            <div>
              <div class="text-xs font-bold" style="color: #F8FAFC;">{name}</div>
              <div class="text-xs mt-0.5" style="color: #475569;">{company}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

