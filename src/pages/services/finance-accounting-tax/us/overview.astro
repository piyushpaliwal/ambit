---
import USLayout from '../../../../layouts/USLayout.astro';
---

<USLayout title="US Accounting & Bookkeeping Services" description="Ambit delivers accurate, IRS-compliant accounting and bookkeeping services for American businesses — from startups to CPA firms across the United States.">

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 620px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full opacity-[0.04] blur-3xl" style="background: #3B82F6;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center" style="min-height: 620px;">
      <div class="grid lg:grid-cols-2 gap-16 items-center w-full py-24 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <!-- Country badge -->
          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United States</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[54px] font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            Accounting Solutions<br/>Built for American<br/>
            <span style="color: #93B4D4;">Businesses</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 480px;">
            From startups in Silicon Valley to CPA firms across the US, Ambit delivers accurate, IRS-compliant, and cost-effective accounting and bookkeeping services designed for American standards.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#us-services" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              See Our Services
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#us-contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              Book Free Consultation
            </a>
          </div>

          <!-- Trust bar -->
          <div class="flex flex-wrap gap-6 pt-8" style="border-top: 1px solid #1E293B;">
            {[
              { val: 'IRS', label: 'Compliant' },
              { val: 'US GAAP', label: 'Certified' },
              { val: '500+', label: 'US Clients' },
              { val: '20+', label: 'Years Expertise' },
            ].map(t => (
              <div>
                <p class="text-lg font-bold text-white leading-none">{t.val}</p>
                <p class="text-xs mt-1" style="color: #475569;">{t.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Hero image -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 300)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-x-6"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative">
          <div class="absolute -top-4 -right-4 w-full h-full rounded-2xl" style="border: 1px solid #1E293B;"></div>
          <img
            src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=900&q=80"
            alt="US accounting professionals"
            class="relative rounded-2xl w-full object-cover shadow-2xl"
            style="height: 440px; object-position: center;"
          />
          <!-- Floating stat card -->
          <div class="absolute -bottom-5 -left-5 bg-white rounded-xl p-4 shadow-xl" style="border: 1px solid #EEF2F6;">
            <p class="text-xs mb-1" style="color: #94A3B8;">US Businesses Served</p>
            <p class="text-2xl font-black" style="color: #0F172A;">500<span style="color: #1a4480;">+</span></p>
            <div class="mt-2 flex items-center gap-1.5">
              <div class="w-2 h-2 rounded-full" style="background-color: #22C55E;"></div>
              <span class="text-xs" style="color: #64748B;">IRS & US GAAP Compliant</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SERVICES SHOWCASE ===== -->
  <section id="us-services" class="py-20" style="background-color: #0F172A;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: #3B82F6;">What We Do</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white" style="letter-spacing: -0.02em;">US Accounting Services</h2>
        </div>
        <p class="text-sm max-w-sm" style="color: #475569;">Each service has a dedicated page — click to explore in full detail.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px" style="background-color: #1E293B; border: 1px solid #1E293B; border-radius: 16px; overflow: hidden;">
        {[
          { num: '01', label: 'Accounting & Financial Reporting', sub: 'US GAAP bookkeeping, P&L, balance sheets', href: '/us/accounting' },
          { num: '02', label: 'Federal & State Tax Compliance', sub: 'IRS filings, multi-state tax, penalty-free', href: '/us/tax' },
          { num: '03', label: 'Payroll & Employment Tax', sub: 'Federal & state payroll, on-time every time', href: '/us/payroll' },
          { num: '04', label: 'Financial Management', sub: 'Cash flow, budgeting & strategic oversight', href: '/us/financial-management' },
          { num: '05', label: 'Business Formation', sub: 'LLC, Corporation setup & full compliance', href: '/us/business-formation' },
        ].map(s => (
          <a href={s.href} class="group flex items-start justify-between gap-4 p-7 transition-all duration-200 hover:bg-white/[0.04]" style="background-color: #0F172A;">
            <div class="flex items-start gap-5">
              <span class="text-xs font-black tracking-widest mt-1 flex-shrink-0" style="color: #1E293B;">{s.num}</span>
              <div>
                <h3 class="text-base font-bold text-white mb-1.5 group-hover:text-blue-300 transition-colors leading-snug">{s.label}</h3>
                <p class="text-xs leading-relaxed" style="color: #475569;">{s.sub}</p>
              </div>
            </div>
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5 opacity-30 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-200" style="color: #3B82F6;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ===== WHY US BUSINESSES TRUST AMBIT ===== -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Top: image + heading row -->
      <div class="grid lg:grid-cols-2 gap-16 items-center mb-16">

        <!-- Left: image -->
        <div class="relative hidden lg:block">
          <img
            src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=900&q=80"
            alt="US business professionals"
            class="rounded-2xl w-full object-cover shadow-lg"
            style="height: 400px; object-position: center top;"
          />
          <!-- Floating badge -->
          <div class="absolute top-6 -right-5 bg-white rounded-xl px-4 py-3 shadow-lg" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-bold mb-0.5" style="color: #0F172A;">US GAAP Certified</p>
            <p class="text-xs" style="color: #94A3B8;">IRS · Federal · State</p>
          </div>
        </div>

        <!-- Right: heading -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why Ambit</p>
          <h2 class="text-4xl sm:text-5xl font-bold mb-6" style="color: #0F172A; letter-spacing: -0.025em;">
            Why US Businesses<br/>Trust Ambit
          </h2>
          <p class="text-sm leading-relaxed mb-8" style="color: #64748B;">
            We don't just crunch numbers — we embed ourselves into your financial operations as a reliable, US-standards-aligned accounting partner.
          </p>
          <a href="#us-contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
            Talk to a US Specialist
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>

      <!-- Trust pillars grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {[
            { title: 'US GAAP Expertise', desc: 'Our team is fully trained in US accounting and compliance standards — not just familiar, but fluent.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
            { title: 'American Industry Know-How', desc: 'From healthcare to e-commerce, we understand the nuances of US business models and regulations.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9' },
            { title: 'Real-Time Financial Insights', desc: 'Monthly reporting, dashboards, and proactive guidance — so you always know where you stand.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
            { title: 'Scalable Offshore Teams', desc: 'Build a US-compliant accounting team offshore. Reduce overhead without sacrificing quality or accuracy.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
          ].map(p => (
            <div class="p-6 rounded-2xl" style="background-color: #F8FAFC; border: 1px solid #EEF2F6;">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-5" style="background: linear-gradient(135deg, #0F172A, #1a4480);">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={p.icon}/>
                </svg>
              </div>
              <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{p.title}</h3>
              <p class="text-xs leading-relaxed" style="color: #64748B;">{p.desc}</p>
            </div>
          ))}
      </div>

    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="us-services" style="background-color: #F8FAFC;" class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-4xl sm:text-5xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.025em;">Comprehensive Accounting Services for US Businesses</h2>
        <p class="text-sm leading-relaxed" style="color: #64748B;">Every service built around US compliance, IRS standards, and the pace of American business.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { num: '01', href: '/us/accounting', title: 'Accounting & Financial Reporting', desc: 'Precise, timely, and fully compliant bookkeeping aligned with US GAAP — so your financials are always audit-ready.', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z' },
          { num: '02', href: '/us/tax', title: 'Federal & State Tax Compliance', desc: 'Avoid penalties and stay audit-ready with our comprehensive federal and state tax preparation service.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
          { num: '03', href: '/us/payroll', title: 'Payroll & Employment Tax', desc: 'Process payroll accurately and on time with full federal and state compliance — no errors, no delays.', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z' },
          { num: '04', href: '/us/financial-management', title: 'Financial Management', desc: 'Real-time cash flow visibility, strategic budgeting, and financial advisory to help your US business grow.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
          { num: '05', href: '/us/business-formation', title: 'Business Formation', desc: 'From LLC to Corporation — full federal and state registration, EIN setup, compliance, and advisory from day one.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
        ].map(s => (
          <a href={s.href} class="bg-white rounded-2xl p-7 group hover:-translate-y-1 transition-all duration-300 flex flex-col" style="border: 1px solid #EEF2F6; box-shadow: 0 2px 16px rgba(15,23,42,0.05);">
            <div class="flex items-start justify-between mb-6">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #0F172A 0%, #1a4480 100%);">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={s.icon}/>
                </svg>
              </div>
              <span class="text-xs font-black tracking-widest" style="color: rgba(26,68,128,0.15);">{s.num}</span>
            </div>
            <h3 class="text-sm font-bold mb-3 leading-snug flex-1" style="color: #0F172A;">{s.title}</h3>
            <p class="text-xs leading-relaxed mb-5" style="color: #64748B;">{s.desc}</p>
            <div class="inline-flex items-center gap-1 text-xs font-semibold" style="color: #1a4480;">
              Explore Service
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PAIN POINTS ===== -->
  <section class="py-24" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #3B82F6;">Common Challenges</p>
          <h2 class="text-4xl sm:text-5xl font-bold text-white mb-6" style="letter-spacing: -0.025em;">
            US Accounting<br/>Challenges — Solved
          </h2>
          <p class="text-sm leading-relaxed mb-10" style="color: #64748B;">
            American businesses face unique compliance and operational pressures. We've built our service around solving the most critical ones.
          </p>
          <a href="#us-contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.4);">
            See How We Can Help
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Right: pain point cards -->
        <div class="space-y-4">
          {[
            { problem: 'Late IRS or state tax filings', solution: 'We manage all federal and state deadlines — never miss a filing date again.' },
            { problem: 'Payroll errors & compliance risks', solution: 'Fully compliant US payroll services with zero tolerance for errors or delays.' },
            { problem: 'Disorganized or inaccurate books', solution: 'Accurate bookkeeping maintained to US GAAP standards every single month.' },
            { problem: 'Rising in-house staffing costs', solution: 'Scalable offshore accounting teams — US-compliant, cost-effective, and always available.' },
          ].map(p => (
            <div class="rounded-xl p-5 flex items-start gap-4" style="background: #1E293B; border: 1px solid #334155;">
              <div class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5" style="background-color: rgba(26,68,128,0.4);">
                <svg class="w-3 h-3" style="color: #60A5FA;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold mb-1.5 line-through" style="color: #475569;">{p.problem}</p>
                <p class="text-sm leading-relaxed" style="color: #CBD5E1;">{p.solution}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===== INDUSTRIES ===== -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-xl mx-auto mb-16">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Industry Spotlight</p>
        <h2 class="text-4xl sm:text-5xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.025em;">Serving a Wide Range of US Industries</h2>
        <p class="text-sm leading-relaxed" style="color: #64748B;">Specialized knowledge for the sectors that matter most to American business.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { title: 'CPA Firms', desc: 'Streamline client accounting and tax reporting. Handle overflow work during peak tax season without adding headcount.', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z' },
          { title: 'Startups', desc: 'Scalable bookkeeping and investor-ready reporting from day one — so you can focus on building, not balancing.', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
          { title: 'E-Commerce', desc: 'Multi-channel sales reconciliation, inventory tracking, and sales tax compliance across US states.', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
          { title: 'Real Estate', desc: 'Rental income, property accounting, depreciation schedules, and full compliance with US real estate tax law.', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
          { title: 'Healthcare', desc: 'Secure, accurate payroll and billing solutions for healthcare providers navigating complex US compliance requirements.', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
          { title: 'Professional Services', desc: 'Law firms, consultancies, and agencies — clean books, accurate billing, and tax-efficient structures.', icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
        ].map(ind => (
          <div class="rounded-2xl p-7 group hover:-translate-y-1 transition-all duration-300" style="background-color: #F8FAFC; border: 1px solid #EEF2F6;">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background: linear-gradient(135deg, #0F172A 0%, #1a4480 100%);">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={ind.icon}/>
              </svg>
            </div>
            <h3 class="text-sm font-bold mb-2.5" style="color: #0F172A;">{ind.title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{ind.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== IMPACT SNAPSHOT ===== -->
  <section class="py-24" style="background-color: #F8FAFC;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="grid lg:grid-cols-2 gap-16 items-end mb-12">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Case Studies</p>
