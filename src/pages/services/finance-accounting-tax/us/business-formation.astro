---
import USLayout from '../../../../layouts/USLayout.astro';
---

<USLayout title="US Business Formation | Entity Setup & State Registration | Ambit" description="Entity formation, EIN registration, and multi-state structuring for US businesses. IRS-aligned setup for LLCs, S-Corps, and C-Corps with tax and compliance alignment from day one.">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(26,68,128,0.18) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-12 py-24 lg:py-32">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase" style="background-color: rgba(26,68,128,0.25); border: 1px solid rgba(26,68,128,0.4); color: #93C5FD;">
          <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-4 h-3 object-cover rounded-sm" />
          United States · Business Formation
        </div>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight mb-6" style="color: #F8FAFC;">
        Business Formation
        <span class="block" style="color: #93C5FD;">United States</span>
      </h1>

      <p class="text-lg md:text-xl max-w-2xl mb-12 leading-relaxed" style="color: #94A3B8;">
        Entity setup, registration, and structuring aligned with federal and state requirements to ensure compliance, tax efficiency, and operational readiness from day one.
      </p>

      <div class="flex flex-wrap gap-3 mb-14">
        {['IRS Compliant', 'Federal and State Aligned', 'Multi-State Ready', 'Entity Structure Aligned', 'Tax-Ready Setup'].map(label => (
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">{label}</span>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#process" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          See How It Works
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-semibold transition-all hover:opacity-80" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
          Book Free Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- ===== METRICS STRIP ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { metric: 'Structured', label: 'Entity setup', sub: 'LLC, S-Corp, and C-Corp coverage' },
          { metric: 'State-wise', label: 'Registration', sub: 'All jurisdictions handled' },
          { metric: 'Tax-aware', label: 'Foundation', sub: 'IRS and state aligned from day one' },
          { metric: 'Operational', label: 'Readiness', sub: 'Ready to trade without delays' },
        ].map(({ metric, label, sub }) => (
          <div class="text-center lg:text-left">
            <div class="text-3xl lg:text-4xl font-black mb-1" style="color: #F8FAFC;">{metric}</div>
            <div class="text-sm font-semibold mb-1" style="color: #93C5FD;">{label}</div>
            <div class="text-xs" style="color: #475569;">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITY MARQUEE ===== -->
  <div class="overflow-hidden py-4" style="background-color: #0F172A; border-bottom: 1px solid #1E293B;">
    <div class="flex gap-12 whitespace-nowrap animate-marquee text-xs font-semibold tracking-widest uppercase" style="color: #475569;">
      {[
        'Entity formation across states',
        'IRS and EIN registration',
        'State-wise business registrations',
        'Multi-state structuring',
        'Tax-efficient entity setup',
        'Compliance and documentation alignment',
        'Scalable business structures',
        'Integration with accounting and tax',
        'Entity formation across states',
        'IRS and EIN registration',
        'State-wise business registrations',
        'Multi-state structuring',
        'Tax-efficient entity setup',
        'Compliance and documentation alignment',
        'Scalable business structures',
        'Integration with accounting and tax',
      ].map(item => (
        <span class="flex items-center gap-3">
          <span class="w-1 h-1 rounded-full inline-block" style="background-color: #1a4480;"></span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ===== CERTIFICATION BLOCK ===== -->
  <section style="background-color: #060D18; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-10">
      <div class="flex flex-wrap items-center gap-6">
        <span class="text-xs font-bold tracking-widest uppercase" style="color: #334155;">Standards</span>
        {['ISO 27001 Certified', 'IRS-Aligned Processes', 'State-Level Compliance Ready', 'Multi-State Structure Ready'].map(cert => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background-color: #0F172A; border: 1px solid #1E293B;">
            <svg class="w-4 h-4" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            <span class="text-xs font-semibold" style="color: #94A3B8;">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight max-w-3xl" style="color: #F8FAFC;">
          Entity Structure in the US Determines Tax, Compliance, and Scalability
        </h2>
        <p class="mt-4 text-base max-w-2xl leading-relaxed" style="color: #64748B;">
          Business formation in the United States is not limited to registration. The choice of entity type, state of registration, and operational structure directly impacts tax obligations, compliance requirements, and long-term scalability. A poorly structured setup leads to higher taxes, compliance issues, and future restructuring.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Correct Entity Selection', body: 'Structure aligned with business model and growth plans.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
          { title: 'Federal and State Alignment', body: 'Setup aligned with IRS and state-level requirements.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
          { title: 'Tax Positioning from Day One', body: 'Entity structure aligned with tax efficiency and compliance.', icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5' },
          { title: 'Operational Readiness', body: 'Business ready to operate across states without delays.', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
        ].map(({ title, body, icon }) => (
          <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}/></svg>
            </div>
            <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Business Formation Services</h2>
        <p class="mt-3 text-base max-w-2xl" style="color: #64748B;">End-to-end entity setup across federal and state jurisdictions with tax and compliance built in from the start.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            num: '01',
            title: 'Entity Formation',
            points: [
              'Formation of LLC, S-Corp, and C-Corp entities',
              'State-level incorporation',
              'Documentation and filing support',
            ],
          },
          {
            num: '02',
            title: 'EIN and Federal Registration',
            points: [
              'Employer Identification Number (EIN) setup',
              'IRS registration alignment',
              'Federal compliance setup',
            ],
          },
          {
            num: '03',
            title: 'State Registrations',
            points: [
              'State business registrations',
              'Secretary of State filings',
              'Multi-state registration coordination',
            ],
          },
          {
            num: '04',
            title: 'Multi-State Structuring',
            points: [
              'Expansion across multiple states',
              'Alignment with operational presence',
              'Structuring based on nexus and activity',
            ],
          },
          {
            num: '05',
            title: 'Tax Structure Alignment',
            points: [
              'Entity-level tax implications',
              'Alignment with federal and state tax requirements',
              'Structuring for compliance and scalability',
            ],
          },
          {
            num: '06',
            title: 'Sales Tax and Nexus Registration',
            points: [
              'Sales tax registration across states',
              'Nexus-based registration planning',
              'Alignment with business operations',
            ],
          },
          {
            num: '07',
            title: 'Payroll and Employer Setup',
            points: [
              'Employer registration across states',
              'Payroll tax account setup',
              'Alignment with employment tax requirements',
            ],
          },
          {
            num: '08',
            title: 'Business Licenses and Compliance',
            points: [
              'Identification of required licenses',
              'Industry-specific compliance alignment',
              'Ongoing regulatory setup',
            ],
          },
          {
            num: '09',
            title: 'Operating Agreements and Documentation',
            points: [
              'Drafting and structuring of operating agreements',
              'Internal documentation alignment',
              'Ownership and governance clarity',
            ],
          },
          {
            num: '10',
            title: 'Foreign-Owned Business Setup',
            points: [
              'Setup for non-US founders',
              'IRS and regulatory alignment',
              'Structuring for cross-border operations',
            ],
          },
          {
            num: '11',
            title: 'Ongoing Compliance Setup',
            points: [
              'Initial compliance framework',
              'Filing and reporting alignment',
              'Preparation for ongoing obligations',
            ],
          },
        ].map(({ num, title, points }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="flex items-start gap-5">
              <span class="text-4xl font-black leading-none flex-shrink-0" style="color: #1E293B;">{num}</span>
              <div class="flex-1">
                <h3 class="text-sm font-bold mb-4" style="color: #F8FAFC;">{title}</h3>
                <ul class="space-y-2">
                  {points.map(point => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed" style="color: #64748B;">
                      <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Designed for Businesses Setting Up or Expanding in the US</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { title: 'Startups and Founders', body: 'Structured setup aligned with long-term growth.' },
          { title: 'Growing Businesses', body: 'Expansion into new states with proper structuring.' },
          { title: 'International Businesses', body: 'Entry into the US with compliant and scalable structure.' },
          { title: 'Multi-Entity Groups', body: 'Formation and structuring across multiple entities.' },
        ].map(({ title, body }) => (
          <div class="rounded-xl p-8 flex items-start gap-4" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM / SOLUTION ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Without vs. With Structured Formation</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #374151;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Structured Formation</h3>
          <ul class="space-y-4">
            {[
              'Incorrect entity selection',
              'Misalignment with tax requirements',
              'Delays in registrations',
              'Compliance gaps across states',
              'Future restructuring required',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #374151;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1a4480;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #93C5FD;">With Structured Formation</h3>
          <ul class="space-y-4">
            {[
              'Correct entity from the outset',
              'Alignment with federal and state tax',
              'Smooth operational setup',
              'Scalable business structure',
              'Controlled compliance',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section id="process" style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">How Work Is Structured</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Our Process</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          { label: '01 / 05', title: 'Understanding', body: 'We review your business model, intended activities, ownership structure, and states of operation to assess formation requirements.' },
          { label: '02 / 05', title: 'Structuring', body: 'We advise on entity type, state of formation, tax implications, and multi-state structuring considerations.' },
          { label: '03 / 05', title: 'Registration', body: 'We handle entity incorporation, EIN registration, Secretary of State filings, and state-level business registrations.' },
          { label: '04 / 05', title: 'Setup and Alignment', body: 'We complete tax and payroll registrations, establish compliance frameworks, and connect with accounting and reporting systems.' },
          { label: '05 / 05', title: 'Continuity', body: 'We support ongoing annual filings, state renewals, and compliance requirements as the business grows and expands.' },
        ].map(({ label, title, body }) => (
          <div>
            <div class="text-xs font-bold tracking-widest mb-4" style="color: #1a4480;">{label}</div>
            <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>

      <div class="mt-14">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          Book Free Consultation for Business Formation
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + BUILT FOR US ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What You Gain</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">The Results</h2>
          <ul class="space-y-4">
            {[
              'Fully registered and compliant entity',
              'Structured tax and financial foundation',
              'Operational readiness from day one',
              'Scalable structure for growth',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why Ambit</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">Built for US Business Environment</h2>
          <ul class="space-y-4">
            {[
              'IRS-aligned entity setup',
              'Multi-state structuring expertise',
              'Integration with tax, payroll, and accounting',
              'Cross-border readiness for international businesses',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-12">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Client Feedback</p>
        <h2 class="text-2xl lg:text-3xl font-black" style="color: #F8FAFC;">What Clients Say</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        {[
          { quote: 'Ambit helped us choose the right entity and set up across multiple states without complications.', name: 'Co-founder', company: 'Technology Startup, United States' },
          { quote: 'Our US setup was structured correctly from the start. We avoided tax and compliance issues later.', name: 'CEO', company: 'International Business, United States' },
        ].map(({ quote, name, company }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <svg class="w-6 h-6 mb-4" style="color: #1a4480;" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            <p class="text-sm leading-relaxed mb-6" style="color: #94A3B8;">{quote}</p>
            <div>
              <div class="text-xs font-bold" style="color: #F8FAFC;">{name}</div>
              <div class="text-xs mt-0.5" style="color: #475569;">{company}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
