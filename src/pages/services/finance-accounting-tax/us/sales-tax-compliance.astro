---
import USLayout from '../../../../layouts/USLayout.astro';
---

<USLayout title="US Sales Tax Compliance | Nexus & Multi-State Filing | Ambit" description="Sales tax structured across registrations, nexus assessment, and multi-state filings. Accurate compliance across jurisdictions for e-commerce, service, and multi-state businesses.">

  <!-- ===== HERO ===== -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(#1E293B 1px, transparent 1px), linear-gradient(90deg, #1E293B 1px, transparent 1px); background-size: 64px 64px;"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(26,68,128,0.18) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-12 py-24 lg:py-32">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase" style="background-color: rgba(26,68,128,0.25); border: 1px solid rgba(26,68,128,0.4); color: #93C5FD;">
          <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-4 h-3 object-cover rounded-sm" />
          United States · Sales Tax Compliance
        </div>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight mb-6" style="color: #F8FAFC;">
        Sales Tax Compliance
        <span class="block" style="color: #93C5FD;">United States</span>
      </h1>

      <p class="text-lg md:text-xl max-w-2xl mb-12 leading-relaxed" style="color: #94A3B8;">
        Sales tax structured across registrations, nexus, reporting, and filings to ensure accurate compliance across multiple state jurisdictions.
      </p>

      <div class="flex flex-wrap gap-3 mb-14">
        {['Sales Tax Compliant', 'Multi-State Ready', 'Nexus Aligned', 'State-Level Compliance', 'Audit-Ready Documentation'].map(label => (
          <span class="px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">{label}</span>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#process" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          See How It Works
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-lg text-sm font-semibold transition-all hover:opacity-80" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
          Book Free Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- ===== METRICS STRIP ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { metric: 'Accurate', label: 'Sales tax filings', sub: 'State-wise and on-schedule' },
          { metric: 'Multi-state', label: 'Coverage', sub: 'All jurisdictions managed' },
          { metric: 'Nexus', label: 'Aligned', sub: 'Economic and physical tracking' },
          { metric: 'On-time', label: 'Submissions', sub: 'Deadlines tracked across states' },
        ].map(({ metric, label, sub }) => (
          <div class="text-center lg:text-left">
            <div class="text-3xl lg:text-4xl font-black mb-1" style="color: #F8FAFC;">{metric}</div>
            <div class="text-sm font-semibold mb-1" style="color: #93C5FD;">{label}</div>
            <div class="text-xs" style="color: #475569;">{sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITY MARQUEE ===== -->
  <div class="overflow-hidden py-4" style="background-color: #0F172A; border-bottom: 1px solid #1E293B;">
    <div class="flex gap-12 whitespace-nowrap animate-marquee text-xs font-semibold tracking-widest uppercase" style="color: #475569;">
      {[
        'Sales tax registration across states',
        'Nexus assessment and structuring',
        'Multi-state sales tax filings',
        'Transaction-level tax accuracy',
        'Marketplace and platform reconciliation',
        'Audit-ready documentation',
        'Integration with accounting systems',
        'Ongoing compliance monitoring',
        'Sales tax registration across states',
        'Nexus assessment and structuring',
        'Multi-state sales tax filings',
        'Transaction-level tax accuracy',
        'Marketplace and platform reconciliation',
        'Audit-ready documentation',
        'Integration with accounting systems',
        'Ongoing compliance monitoring',
      ].map(item => (
        <span class="flex items-center gap-3">
          <span class="w-1 h-1 rounded-full inline-block" style="background-color: #1a4480;"></span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <!-- ===== CERTIFICATION BLOCK ===== -->
  <section style="background-color: #060D18; border-bottom: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-10">
      <div class="flex flex-wrap items-center gap-6">
        <span class="text-xs font-bold tracking-widest uppercase" style="color: #334155;">Standards</span>
        {['ISO 27001 Certified', 'State-Level Compliance Ready', 'Audit-Ready Documentation', 'Multi-State Reporting Aligned'].map(cert => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg" style="background-color: #0F172A; border: 1px solid #1E293B;">
            <svg class="w-4 h-4" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            <span class="text-xs font-semibold" style="color: #94A3B8;">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY IT MATTERS ===== -->
  <section style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight max-w-3xl" style="color: #F8FAFC;">
          Sales Tax Is Driven by Nexus and State-Level Rules
        </h2>
        <p class="mt-4 text-base max-w-2xl leading-relaxed" style="color: #64748B;">
          Sales tax in the United States is governed at the state level, with each state having its own rules, rates, and filing requirements. Obligations are triggered by nexus, which can arise from physical presence or economic activity across states. Without structured tracking and compliance, businesses risk incorrect filings, penalties, and gaps across jurisdictions.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { title: 'Nexus-Driven Compliance', body: 'Sales tax obligations determined based on business activity across states.', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7' },
          { title: 'State-Level Complexity', body: 'Different rules, rates, and filing requirements across jurisdictions.', icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10' },
          { title: 'Transaction-Level Accuracy', body: 'Correct tax calculation across products, services, and locations.', icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5' },
          { title: 'Ongoing Monitoring', body: 'Nexus and compliance requirements evolve as the business grows.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
        ].map(({ title, body, icon }) => (
          <div class="rounded-xl p-6" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}/></svg>
            </div>
            <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Sales Tax Compliance Services</h2>
        <p class="mt-3 text-base max-w-2xl" style="color: #64748B;">End-to-end sales tax management across state registrations, nexus, filings, and ongoing compliance.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            num: '01',
            title: 'Sales Tax Registration',
            points: [
              'State-wise sales tax registrations',
              'Sales tax permits and setup',
              'Alignment with nexus requirements',
            ],
          },
          {
            num: '02',
            title: 'Nexus Assessment',
            points: [
              'Economic and physical nexus determination',
              'State-wise obligation mapping',
              'Ongoing nexus monitoring as business scales',
            ],
          },
          {
            num: '03',
            title: 'Sales Tax Calculation and Reporting',
            points: [
              'Sales tax calculation across transactions',
              'Alignment with state-specific tax rules',
              'Reporting across jurisdictions',
            ],
          },
          {
            num: '04',
            title: 'Sales Tax Filings',
            points: [
              'Preparation and submission of returns',
              'Filing across multiple states',
              'Deadline tracking and compliance',
            ],
          },
          {
            num: '05',
            title: 'Marketplace and Platform Reconciliation',
            points: [
              'Reconciliation across platforms such as Amazon, Shopify, and others',
              'Alignment between platform reports and filings',
              'Handling marketplace facilitator rules',
            ],
          },
          {
            num: '06',
            title: 'Exemptions and Resale Certificates',
            points: [
              'Identification of exempt transactions',
              'Management of resale certificates',
              'Alignment with state regulations',
            ],
          },
          {
            num: '07',
            title: 'Multi-State Compliance Management',
            points: [
              'Coordination across multiple jurisdictions',
              'Consistent reporting and filing structure',
              'Alignment with business operations',
            ],
          },
          {
            num: '08',
            title: 'Audit Support',
            points: [
              'Preparation of documentation for audits',
              'Support during state audits or reviews',
              'Resolution support for discrepancies',
            ],
          },
          {
            num: '09',
            title: 'Ongoing Compliance Support',
            points: [
              'Monitoring of nexus thresholds',
              'Updates on state-level regulatory changes',
              'Continuous compliance tracking',
            ],
          },
        ].map(({ num, title, points }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="flex items-start gap-5">
              <span class="text-4xl font-black leading-none flex-shrink-0" style="color: #1E293B;">{num}</span>
              <div class="flex-1">
                <h3 class="text-sm font-bold mb-4" style="color: #F8FAFC;">{title}</h3>
                <ul class="space-y-2">
                  {points.map(point => (
                    <li class="flex items-start gap-2 text-sm leading-relaxed" style="color: #64748B;">
                      <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Designed for Businesses with Multi-State Sales Activity</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {[
          { title: 'E-commerce Businesses', body: 'Sales tax compliance across multiple states and platforms.' },
          { title: 'Service Providers', body: 'State-wise tax treatment aligned with service delivery locations.' },
          { title: 'Multi-State Businesses', body: 'Consistent compliance across jurisdictions.' },
          { title: 'Growing Businesses', body: 'Nexus monitoring as operations expand across states.' },
        ].map(({ title, body }) => (
          <div class="rounded-xl p-8 flex items-start gap-4" style="background-color: #0D1829; border: 1px solid #1E293B;">
            <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background-color: #1a4480;">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM / SOLUTION ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Without vs. With Structured Sales Tax Compliance</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #374151;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Structured Sales Tax Compliance</h3>
          <ul class="space-y-4">
            {[
              'Missed state registrations',
              'Incorrect sales tax calculations',
              'Nexus misalignment',
              'Filing errors across states',
              'Increased compliance risk',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #64748B;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #374151;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1a4480;">
          <h3 class="text-sm font-bold uppercase tracking-widest mb-6" style="color: #93C5FD;">With Structured Sales Tax Compliance</h3>
          <ul class="space-y-4">
            {[
              'Accurate state-wise filings',
              'Clear nexus position',
              'Consistent reporting across platforms',
              'Audit-ready documentation',
              'Controlled compliance',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section id="process" style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-14">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">How Work Is Structured</p>
        <h2 class="text-3xl lg:text-4xl font-black leading-tight" style="color: #F8FAFC;">Our Process</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          { label: '01 / 05', title: 'Understanding', body: 'We review your current sales tax registrations, states of operation, transaction volume, and existing nexus positions.' },
          { label: '02 / 05', title: 'Structuring', body: 'We map nexus obligations across states, identify gaps in registrations, and establish the filing framework.' },
          { label: '03 / 05', title: 'Onboarding', body: 'We complete outstanding registrations, connect with your accounting and sales platforms, and set the compliance calendar.' },
          { label: '04 / 05', title: 'Execution and Review', body: 'We prepare and file returns across all applicable states on schedule, with reconciliation and review before submission.' },
          { label: '05 / 05', title: 'Continuity', body: 'We monitor nexus thresholds, track regulatory changes across states, and maintain compliance as your business grows.' },
        ].map(({ label, title, body }) => (
          <div>
            <div class="text-xs font-bold tracking-widest mb-4" style="color: #1a4480;">{label}</div>
            <h3 class="text-sm font-bold mb-2" style="color: #F8FAFC;">{title}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{body}</p>
          </div>
        ))}
      </div>

      <div class="mt-14">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          Book Free Consultation for Sales Tax
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + BUILT FOR US ===== -->
  <section style="background-color: #060D18; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">What You Gain</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">The Results</h2>
          <ul class="space-y-4">
            {[
              'Accurate multi-state sales tax filings',
              'Clear nexus tracking and compliance',
              'Reduced risk of penalties',
              'Alignment across transactions and reporting',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Why Ambit</p>
          <h2 class="text-2xl lg:text-3xl font-black mb-8 leading-tight" style="color: #F8FAFC;">Built for US Sales Tax Environment</h2>
          <ul class="space-y-4">
            {[
              'State-level sales tax compliance',
              'Nexus-based structuring',
              'Multi-state reporting and filings',
              'Integration with accounting and platforms',
            ].map(item => (
              <li class="flex items-start gap-3 text-sm leading-relaxed" style="color: #94A3B8;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section style="background-color: #0F172A; border-top: 1px solid #1E293B;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12 py-24">
      <div class="mb-12">
        <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #1a4480;">Client Feedback</p>
        <h2 class="text-2xl lg:text-3xl font-black" style="color: #F8FAFC;">What Clients Say</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl">
        {[
          { quote: 'Sales tax across multiple states was complex before. Now everything is structured and filed correctly.', name: 'Finance Director', company: 'E-commerce Business, United States' },
          { quote: 'Ambit helped us understand nexus and stay compliant as we expanded across states.', name: 'CFO', company: 'Multi-State Business, United States' },
        ].map(({ quote, name, company }) => (
          <div class="rounded-xl p-8" style="background-color: #0D1829; border: 1px solid #1E293B;">
