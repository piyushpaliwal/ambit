---
import UAELayout from '../../layouts/UAELayout.astro';
---

<UAELayout title="Payroll Management UAE Labour Law | Ambit Dubai" description="UAE Labour Law compliant payroll management for Dubai businesses. Accurate salary processing, gratuity calculations, WPS compliance, and HR advisory.">

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[88vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=1600&q=80"
        alt="Dubai payroll management"
        class="w-full h-full object-cover"
        style="opacity: 0.15;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 50%, #1a4480 100%); opacity: 0.88;"></div>
    </div>

    <!-- Gold accent blurs -->
    <div class="absolute top-20 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.07;"></div>
    <div class="absolute bottom-20 left-20 w-64 h-64 rounded-full blur-3xl" style="background: #16A34A; opacity: 0.06;"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: Text -->
        <div>
          <div
            x-show="visible"
            x-transition:enter="transition duration-700"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6"
            style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
          >
            <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-4 h-3 object-cover rounded-sm" />
            UAE Payroll Management
          </div>

          <h1
            x-show="visible"
            x-transition:enter="transition duration-700 delay-100"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-4xl lg:text-5xl xl:text-6xl font-black leading-none mb-6"
            style="color: #F8FAFC; letter-spacing: -0.03em;"
          >
            Accurate Payroll<br />
            <span style="color: #1a4480;">Under UAE</span><br />
            Labour Law
          </h1>

          <p
            x-show="visible"
            x-transition:enter="transition duration-700 delay-200"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-lg leading-relaxed mb-10 max-w-xl"
            style="color: #94A3B8;"
          >
            Ensure your Dubai business is fully compliant, employees are paid on time, and payroll processes run smoothly with Ambit's expert payroll services.
          </p>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-4"
          >
            <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
              Speak to Our Experts
            </a>
            <a href="#services" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
              Explore Services
            </a>
          </div>
        </div>

        <!-- Right: Floating cards -->
        <div
          x-show="visible"
          x-transition:enter="transition duration-700 delay-400"
          x-transition:enter-start="opacity-0 translate-x-8"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <div class="relative w-full max-w-sm mx-auto">
            <img
              src="https://images.unsplash.com/photo-1554224154-26032ffc0d07?w=800&q=80"
              alt="Payroll processing"
              class="w-full aspect-square object-cover rounded-2xl"
              style="opacity: 0.65;"
            />

            <!-- Badge 1: WPS Compliant -->
            <div class="absolute -top-5 -left-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #1a4480;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">WPS Compliant</div>
                  <div class="text-xs" style="color: #64748B;">UAE Labour Law</div>
                </div>
              </div>
            </div>

            <!-- Badge 2: On-Time -->
            <div class="absolute -bottom-5 -right-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #16A34A;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">100% On-Time</div>
                  <div class="text-xs" style="color: #64748B;">Salary Disbursement</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 28s linear infinite; width: max-content;">
      {[
        '✔ UAE Labour Law Compliant Payroll',
        '✔ Timely Employee Payments',
        '✔ Accurate Tax-Free Calculations',
        '✔ Dedicated Dubai Payroll Experts',
        '✔ WPS Salary Processing',
        '✔ Gratuity & End-of-Service',
        '✔ UAE Labour Law Compliant Payroll',
        '✔ Timely Employee Payments',
        '✔ Accurate Tax-Free Calculations',
        '✔ Dedicated Dubai Payroll Experts',
        '✔ WPS Salary Processing',
        '✔ Gratuity & End-of-Service',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image side -->
        <div class="relative">
          <img
            src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=800&q=80"
            alt="UAE payroll compliance"
            class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl"
          />
          <div class="absolute top-6 -right-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #1a4480;">99.9%</div>
            <div class="text-xs" style="color: #64748B;">Payroll Accuracy</div>
          </div>
          <div class="absolute bottom-6 -left-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #22C55E;">AED 0</div>
            <div class="text-xs" style="color: #64748B;">Compliance Fines</div>
          </div>
          <div class="absolute bottom-24 -right-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #F8FAFC;">100%</div>
            <div class="text-xs" style="color: #64748B;">On-Time Payments</div>
          </div>
        </div>

        <!-- Text side -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Why It Matters</div>
          <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">
            Payroll Mistakes<br />Can Be Costly
          </h2>
          <p class="text-lg leading-relaxed mb-6" style="color: #64748B;">
            Incorrect payroll, delayed payments, or non-compliance with UAE Labour Law can lead to fines, disputes, and low employee satisfaction.
          </p>
          <p class="text-lg leading-relaxed mb-10" style="color: #64748B;">
            Ambit ensures <strong style="color: #0F172A;">accurate, compliant, and hassle-free payroll management</strong> — giving you complete peace of mind.
          </p>

          <div class="grid grid-cols-3 gap-4">
            {[
              { val: '99.9%', label: 'Accuracy' },
              { val: 'AED 0', label: 'Fines' },
              { val: '100%', label: 'On-Time' },
            ].map(({ val, label }) => (
              <div class="text-center p-4 rounded-xl" style="background-color: #F8FAFC;">
                <div class="text-xl font-black mb-1" style="color: #1a4480;">{val}</div>
                <div class="text-xs" style="color: #64748B;">{label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">What We Offer</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Our Payroll Management Services</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z',
            title: 'Salary Processing',
            items: [
              'Employee wages & benefits',
              'Deductions & allowances under UAE Labour Law',
              'Timely WPS salary disbursement',
            ],
          },
          {
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            title: 'Employment Compliance',
            items: [
              'Gratuity calculations',
              'Leave & overtime management',
              'End-of-service settlements',
            ],
          },
          {
            icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
            title: 'Reporting & Advisory',
            items: [
              'Payroll reports & dashboards',
              'HR compliance advisory',
              'Audit-ready documentation',
            ],
          },
        ].map(({ icon, title, items }) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: #EFF6FF;">
              <svg class="w-6 h-6" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-4" style="color: #0F172A;">{title}</h3>
            <ul class="space-y-2">
              {items.map(item => (
                <li class="flex items-start gap-2 text-sm" style="color: #64748B;">
                  <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Ideal For</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Ideal for Dubai Businesses</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '🚀', label: 'SMEs & Startups' },
          { icon: '🏢', label: 'Large Enterprises' },
          { icon: '🏙️', label: 'Freezone & Mainland' },
          { icon: '⚖️', label: 'Full UAE Labour Law Compliance' },
        ].map(({ icon, label }) => (
          <div class="flex flex-col items-center text-center p-6 rounded-2xl border border-gray-100 hover:border-amber-200 hover:shadow-sm transition-all" style="background-color: #F8FAFC;">
            <span class="text-3xl mb-3">{icon}</span>
            <span class="text-sm font-semibold" style="color: #0F172A;">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Common Challenges</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Avoid Common Payroll &<br />Compliance Issues</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Problems -->
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Ambit</h3>
          {[
            'Late or incorrect salary payments',
            'Errors in gratuity or leave calculations',
            'Non-compliance with UAE Labour Law',
            'Time-consuming manual payroll processes',
            'Risk of fines and employee disputes',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border-left: 3px solid #DC2626;">
              <span class="text-lg flex-shrink-0">❌</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>

        <!-- Solutions -->
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">With Ambit</h3>
          {[
            'On-time WPS salary disbursement every cycle',
            'Accurate gratuity, leave & overtime calculations',
            'Full UAE Labour Law & Freezone compliance',
            'Automated, error-free payroll workflows',
            'Audit-ready documentation — zero fines',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border-left: 3px solid #22C55E;">
              <span class="text-lg flex-shrink-0">✅</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Our Process</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">4-Step Payroll Management Process</h2>
      </div>

      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-px" style="background-color: #E2E8F0;"></div>
        <div class="space-y-12">
          {[
            { step: '01', title: 'Employee Data Collection', desc: 'Gather employment contracts, allowances, deductions, and attendance records.' },
            { step: '02', title: 'Payroll Processing', desc: 'Accurate salary calculations with WPS disbursement — wages, benefits, and deductions all handled.' },
            { step: '03', title: 'Compliance Checks', desc: 'UAE Labour Law alignment verified — gratuity, leave balances, overtime, and end-of-service settlements.' },
            { step: '04', title: 'Reporting & Advisory', desc: 'Detailed payroll reports, dashboards, and ongoing HR compliance advisory for your team.' },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-8 items-start">
              <div class="relative flex-shrink-0">
                <div class="w-16 h-16 rounded-full flex items-center justify-center text-sm font-black border-4 border-white shadow" style="background-color: #1a4480; color: white;">
                  {step}
                </div>
              </div>
              <div class="pt-3">
                <h3 class="text-xl font-bold mb-2" style="color: #0F172A;">{title}</h3>
                <p class="text-base leading-relaxed" style="color: #64748B;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + UAE-SPECIFIC ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16">

        <!-- What You Gain -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Impact</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">What You Gain</h2>
          <div class="space-y-4">
            {[
              'Accurate payroll fully aligned with UAE Labour Law',
              'Timely employee payments — every single cycle',
              'Audit-ready documentation for HR & management',
              'Reduced HR and payroll errors',
              'Stress-free compliance — no fines, no disputes',
            ].map(item => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #EFF6FF;">
                  <svg class="w-3.5 h-3.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-base" style="color: #374151;">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- UAE-Specific -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">UAE Expertise</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">Tailored for Dubai Businesses</h2>
          <div class="space-y-4">
            {[
              {
                icon: '⚖️',
                title: 'UAE Labour Law Compliance',
                desc: 'Full alignment with Federal Decree-Law No. 33 of 2021 and all subsequent amendments.',
              },
              {
                icon: '🧾',
                title: 'Gratuity, Leave & Overtime',
                desc: 'Precise end-of-service gratuity, annual leave encashment, and overtime calculations.',
              },
              {
                icon: '🏙️',
                title: 'Freezone & Mainland Expertise',
                desc: 'We handle payroll for both Freezone and Mainland companies across all UAE emirates.',
              },
              {
                icon: '📊',
                title: 'Audit-Ready Reporting',
                desc: 'Monthly payroll reports and dashboards ready for HR, management, and external audits.',
              },
            ].map(({ icon, title, desc }) => (
              <div class="flex items-start gap-4 p-5 rounded-xl bg-white border border-gray-100 shadow-sm">
                <span class="text-2xl flex-shrink-0">{icon}</span>
                <div>
                  <div class="text-sm font-bold mb-1" style="color: #0F172A;">{title}</div>
                  <div class="text-sm leading-relaxed" style="color: #64748B;">{desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Testimonials</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Trusted by Dubai Businesses</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            quote: "Ambit manages our payroll perfectly according to UAE Labour Law — employees are happy and we are fully compliant.",
            name: 'Khalid M.',
            role: 'HR Director, Dubai Mainland Company',
          },
          {
            quote: "Their team ensures timely payroll and accurate compliance reports. Highly recommended for any Dubai business.",
            name: 'Rania A.',
            role: 'CEO, Dubai Freezone Startup',
          },
        ].map(({ quote, name, role }) => (
          <div class="p-8 rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4" style="color: #1a4480;" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-base leading-relaxed mb-6" style="color: #94A3B8;">"{quote}"</p>
            <div class="flex items-center gap-3">
              <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-6 h-4 object-cover rounded-sm" />
              <div>
                <div class="text-sm font-bold text-white">{name}</div>
                <div class="text-xs" style="color: #64748B;">{role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
