---
import UAELayout from '../../layouts/UAELayout.astro';
---

<UAELayout title="Offshore Staffing Solutions Dubai | UAE Accounting & IT Teams | Ambit" description="Cost-effective offshore staffing solutions for Dubai businesses. Skilled accounting, IT, customer support, and HR talent — fully managed and UAE-compliant.">

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[88vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1600&q=80"
        alt="Offshore staffing Dubai"
        class="w-full h-full object-cover"
        style="opacity: 0.15;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 50%, #1a2e0a 100%); opacity: 0.88;"></div>
    </div>

    <div class="absolute top-20 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #D97706; opacity: 0.07;"></div>
    <div class="absolute bottom-20 left-20 w-64 h-64 rounded-full blur-3xl" style="background: #16A34A; opacity: 0.06;"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left -->
        <div>
          <div
            x-show="visible"
            x-transition:enter="transition duration-700"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6"
            style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
          >
            <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-4 h-3 object-cover rounded-sm" />
            Dubai Offshore Staffing Solutions
          </div>

          <h1
            x-show="visible"
            x-transition:enter="transition duration-700 delay-100"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-4xl lg:text-5xl xl:text-6xl font-black leading-none mb-6"
            style="color: #F8FAFC; letter-spacing: -0.03em;"
          >
            Scale Your Workforce<br />
            <span style="color: #D97706;">Efficiently with</span><br />
            Offshore Staffing
          </h1>

          <p
            x-show="visible"
            x-transition:enter="transition duration-700 delay-200"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-lg leading-relaxed mb-10 max-w-xl"
            style="color: #94A3B8;"
          >
            Access skilled talent for your Dubai business without the hassle of local hiring. Ambit provides fully managed offshore staffing solutions to save time, reduce costs, and boost productivity.
          </p>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-4"
          >
            <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #D97706;">
              Get Free Consultation
            </a>
            <a href="#services" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
              Explore Services
            </a>
          </div>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-400"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            class="flex flex-wrap gap-3 mt-10"
          >
            {['Cost-Effective', 'Fully Managed', 'UAE Compliant'].map(tag => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: rgba(217,119,6,0.12); color: #D97706; border: 1px solid rgba(217,119,6,0.25);">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Floating cards -->
        <div
          x-show="visible"
          x-transition:enter="transition duration-700 delay-400"
          x-transition:enter-start="opacity-0 translate-x-8"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <div class="relative w-full max-w-sm mx-auto">
            <img
              src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=800&q=80"
              alt="Remote team management"
              class="w-full aspect-square object-cover rounded-2xl"
              style="opacity: 0.65;"
            />

            <div class="absolute -top-5 -left-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #D97706;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">Global Talent</div>
                  <div class="text-xs" style="color: #64748B;">Fully Managed Teams</div>
                </div>
              </div>
            </div>

            <div class="absolute -bottom-5 -right-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #16A34A;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">60% Cost Saving</div>
                  <div class="text-xs" style="color: #64748B;">vs Local Hiring</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #D97706;">
    <div class="flex gap-12 items-center" style="animation: marquee 28s linear infinite; width: max-content;">
      {[
        '✔ Access Skilled Global Talent',
        '✔ Cost-Effective Staffing Solutions',
        '✔ Fully Managed Operations',
        '✔ Dedicated Dubai Support Team',
        '✔ UAE Labour Policy Compliant',
        '✔ Multi-Lingual Team Capabilities',
        '✔ Access Skilled Global Talent',
        '✔ Cost-Effective Staffing Solutions',
        '✔ Fully Managed Operations',
        '✔ Dedicated Dubai Support Team',
        '✔ UAE Labour Policy Compliant',
        '✔ Multi-Lingual Team Capabilities',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image -->
        <div class="relative">
          <img
            src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=800&q=80"
            alt="Offshore team"
            class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl"
          />
          <div class="absolute top-6 -right-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #D97706;">60%</div>
            <div class="text-xs" style="color: #64748B;">Cost Reduction</div>
          </div>
          <div class="absolute bottom-6 -left-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #22C55E;">48h</div>
            <div class="text-xs" style="color: #64748B;">Team Setup</div>
          </div>
          <div class="absolute bottom-24 -right-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #F8FAFC;">100%</div>
            <div class="text-xs" style="color: #64748B;">Managed by Ambit</div>
          </div>
        </div>

        <!-- Text -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #D97706;">Why It Matters</div>
          <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">
            Flexible Workforce,<br />Faster Growth
          </h2>
          <p class="text-lg leading-relaxed mb-6" style="color: #64748B;">
            Hiring locally in Dubai can be expensive and time-consuming. Offshore staffing allows your business to quickly scale operations, reduce costs, and maintain high-quality output without the administrative burden.
          </p>
          <p class="text-lg leading-relaxed mb-10" style="color: #64748B;">
            Ambit handles everything — <strong style="color: #0F172A;">recruitment, onboarding, compliance, and ongoing management</strong> — so you can focus on growing.
          </p>

          <div class="grid grid-cols-3 gap-4">
            {[
              { val: '60%', label: 'Cost Saving' },
              { val: '48h', label: 'Team Setup' },
              { val: '100%', label: 'Fully Managed' },
            ].map(({ val, label }) => (
              <div class="text-center p-4 rounded-xl" style="background-color: #F8FAFC;">
                <div class="text-xl font-black mb-1" style="color: #D97706;">{val}</div>
                <div class="text-xs" style="color: #64748B;">{label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #D97706;">What We Offer</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Our Offshore Staffing Services</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z',
            title: 'Accounting & Finance',
            items: ['Bookkeeping, payroll & reporting', 'UAE VAT & IFRS-compliant services', 'Cash flow & budgeting support'],
          },
          {
            icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
            title: 'IT & Development',
            items: ['Software development & support', 'Web & mobile app development', 'IT project management'],
          },
          {
            icon: 'M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z',
            title: 'Customer Support & Ops',
            items: ['Call centre & helpdesk support', 'Virtual assistants & admin support', 'Multi-language support for UAE'],
          },
          {
            icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
            title: 'HR & Compliance',
            items: ['Employment management for offshore teams', 'Legal compliance guidance', 'Performance monitoring & reporting'],
          },
        ].map(({ icon, title, items }) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background-color: #FEF3C7;">
              <svg class="w-5 h-5" style="color: #D97706;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <h3 class="text-sm font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <ul class="space-y-2">
              {items.map(item => (
                <li class="flex items-start gap-2 text-xs" style="color: #64748B;">
                  <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" style="color: #D97706;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #D97706;">Ideal For</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Ideal for Dubai Businesses</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '🚀', label: 'SMEs & Startups Scaling Up' },
          { icon: '💰', label: 'Companies Reducing Overhead' },
          { icon: '🌍', label: 'Multinationals Needing Remote Talent' },
          { icon: '🔄', label: 'Businesses Seeking Flexible Staffing' },
        ].map(({ icon, label }) => (
          <div class="flex flex-col items-center text-center p-6 rounded-2xl border border-gray-100 hover:border-amber-200 hover:shadow-sm transition-all" style="background-color: #F8FAFC;">
            <span class="text-3xl mb-3">{icon}</span>
            <span class="text-sm font-semibold" style="color: #0F172A;">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Common Challenges</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Common Challenges Solved</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Ambit</h3>
          {[
            'High local recruitment and employment costs',
            'Limited access to skilled, specialised talent',
            'Heavy administrative and compliance burden',
            'Scaling operations is slow and inefficient',
            'Managing remote teams without the right infrastructure',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border-left: 3px solid #DC2626;">
              <span class="text-lg flex-shrink-0">❌</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>

        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">With Ambit</h3>
          {[
            'Up to 60% cost reduction vs. local hiring',
            'Access to pre-vetted, skilled global professionals',
            'Fully managed compliance and HR administration',
            'Teams onboarded and productive within 48 hours',
            'Dedicated Dubai support with full oversight',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border-left: 3px solid #22C55E;">
              <span class="text-lg flex-shrink-0">✅</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #D97706;">Our Process</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">4-Step Offshore Staffing Process</h2>
      </div>

      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-px" style="background-color: #E2E8F0;"></div>
        <div class="space-y-12">
          {[
            { step: '01', title: 'Requirement Analysis', desc: 'We work with you to identify the exact roles, skills, and experience levels your Dubai business needs.' },
            { step: '02', title: 'Talent Sourcing', desc: 'Recruit and screen top offshore professionals from our global talent network — pre-vetted and ready to go.' },
            { step: '03', title: 'Onboarding & Management', desc: 'Set up teams, integrate workflows and tools, and establish performance monitoring from day one.' },
            { step: '04', title: 'Ongoing Support', desc: 'Continuous performance tracking, HR compliance management, and a dedicated Dubai support team.' },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-8 items-start">
              <div class="relative flex-shrink-0">
                <div class="w-16 h-16 rounded-full flex items-center justify-center text-sm font-black border-4 border-white shadow" style="background-color: #D97706; color: white;">
                  {step}
                </div>
              </div>
              <div class="pt-3">
                <h3 class="text-xl font-bold mb-2" style="color: #0F172A;">{title}</h3>
                <p class="text-base leading-relaxed" style="color: #64748B;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + UAE SPECIFIC ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16">

        <!-- What You Gain -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #D97706;">Impact</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">What You Gain</h2>
          <div class="space-y-4">
            {[
              'Skilled offshore workforce ready for your business',
              'Cost-efficient staffing without local overhead',
              'Seamless management, reporting, and monitoring',
              'Scalable operations that grow with your business',
              'Full compliance — UAE labour policies always met',
            ].map(item => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #FEF3C7;">
                  <svg class="w-3.5 h-3.5" style="color: #D97706;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-base" style="color: #374151;">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- UAE Specific -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #D97706;">UAE Expertise</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">Tailored for Dubai<br />&amp; UAE Businesses</h2>
          <div class="space-y-4">
            {[
              {
                icon: '🇦🇪',
                title: 'UAE Labour Policy Compliant',
                desc: 'All offshore staffing solutions structured in compliance with UAE labour and employment regulations.',
              },
              {
                icon: '💼',
                title: 'Cross-Function Expertise',
                desc: 'Talent across accounting, IT, customer support, and operations — all pre-vetted and UAE-market ready.',
              },
              {
                icon: '🌐',
                title: 'Multi-Lingual Team Capabilities',
                desc: 'Arabic, English, and other language capabilities to serve Dubai\'s diverse and international market.',
              },
              {
                icon: '📊',
                title: 'Audit-Ready Remote Team Reports',
                desc: 'Performance dashboards and compliance documentation maintained for full management visibility.',
              },
            ].map(({ icon, title, desc }) => (
              <div class="flex items-start gap-4 p-5 rounded-xl bg-white border border-gray-100 shadow-sm">
                <span class="text-2xl flex-shrink-0">{icon}</span>
                <div>
                  <div class="text-sm font-bold mb-1" style="color: #0F172A;">{title}</div>
                  <div class="text-sm leading-relaxed" style="color: #64748B;">{desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Testimonials</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Trusted by Dubai Businesses</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            quote: "Ambit helped us build an offshore team seamlessly. Productivity improved and costs went down significantly — exactly what we needed.",
            name: 'Faisal H.',
            role: 'CEO, Dubai Tech Startup',
          },
          {
            quote: "Their team manages everything — recruitment, onboarding, and monitoring. Highly recommended for any Dubai business looking to scale.",
            name: 'Aisha R.',
            role: 'Operations Director, UAE E-Commerce Company',
          },
        ].map(({ quote, name, role }) => (
          <div class="p-8 rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4" style="color: #D97706;" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-base leading-relaxed mb-6" style="color: #94A3B8;">"{quote}"</p>
            <div class="flex items-center gap-3">
              <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-6 h-4 object-cover rounded-sm" />
              <div>
                <div class="text-sm font-bold text-white">{name}</div>
                <div class="text-xs" style="color: #64748B;">{role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
