---
import UAELayout from '../../layouts/UAELayout.astro';
---

<UAELayout title="Accounting & Bookkeeping Dubai | IFRS & UAE VAT Compliant | Ambit" description="IFRS-compliant accounting and UAE VAT-ready bookkeeping for Dubai businesses. Accurate financial reporting, daily bookkeeping, and expert advisory from dedicated UAE accountants.">

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[88vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=1600&q=80"
        alt="Dubai accounting"
        class="w-full h-full object-cover"
        style="opacity: 0.15;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 50%, #1a4480 100%); opacity: 0.88;"></div>
    </div>

    <div class="absolute top-20 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.07;"></div>
    <div class="absolute bottom-20 left-20 w-64 h-64 rounded-full blur-3xl" style="background: #16A34A; opacity: 0.06;"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left -->
        <div>
          <div
            x-show="visible"
            x-transition:enter="transition duration-700"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-6"
            style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
          >
            <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-4 h-3 object-cover rounded-sm" />
            United Arab Emirates · Accounting & Bookkeeping
          </div>

          <h1
            x-show="visible"
            x-transition:enter="transition duration-700 delay-100"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-4xl lg:text-5xl xl:text-6xl font-black leading-none mb-6"
            style="color: #F8FAFC; letter-spacing: -0.03em;"
          >
            Accounting<br />
            <span style="color: #1a4480;">&amp; Bookkeeping</span><br />
            UAE
          </h1>

          <p
            x-show="visible"
            x-transition:enter="transition duration-700 delay-200"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-lg leading-relaxed mb-10 max-w-xl"
            style="color: #94A3B8;"
          >
            Structured financial records, reporting, and year-end accounts aligned with IFRS standards and UAE regulatory requirements, ensuring consistency across Freezone and Mainland entities.
          </p>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-4"
          >
            <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
              Speak to an Expert
            </a>
            <a href="#services" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
              See How It Works
            </a>
          </div>
        </div>

        <!-- Right: Floating cards -->
        <div
          x-show="visible"
          x-transition:enter="transition duration-700 delay-400"
          x-transition:enter-start="opacity-0 translate-x-8"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <div class="relative w-full max-w-sm mx-auto">
            <img
              src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80"
              alt="Financial records"
              class="w-full aspect-square object-cover rounded-2xl"
              style="opacity: 0.65;"
            />

            <div class="absolute -top-5 -left-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #1a4480;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">IFRS Compliant</div>
                  <div class="text-xs" style="color: #64748B;">Certified Standards</div>
                </div>
              </div>
            </div>

            <div class="absolute -bottom-5 -right-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #16A34A;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">UAE VAT Ready</div>
                  <div class="text-xs" style="color: #64748B;">FTA Registered</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 28s linear infinite; width: max-content;">
      {[
        '✔ IFRS Aligned',
        '✔ FTA Compliant',
        '✔ UAE Labour Law Aligned',
        '✔ VAT Compliant',
        '✔ Corporate Tax Ready',
        '✔ Freezone and Mainland Alignment',
        '✔ Audit-Ready Structure',
        '✔ Platform-Aligned Accounting',
        '✔ IFRS Aligned',
        '✔ FTA Compliant',
        '✔ UAE Labour Law Aligned',
        '✔ VAT Compliant',
        '✔ Corporate Tax Ready',
        '✔ Freezone and Mainland Alignment',
        '✔ Audit-Ready Structure',
        '✔ Platform-Aligned Accounting',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 max-w-3xl mx-auto">
        <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Why It Matters</div>
        <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">
          Accounting in the UAE Requires Alignment Across Standards and Jurisdictions
        </h2>
        <p class="text-lg leading-relaxed" style="color: #64748B;">
          UAE businesses operate across Freezone and Mainland structures, each with distinct reporting obligations. Add IFRS requirements, FTA VAT filings, and corporate tax readiness into the mix and accounting becomes a compliance function that demands specialist knowledge. Getting it wrong creates audit exposure, regulatory risk, and financial blind spots.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
            title: 'Consistency Across Entities',
            desc: 'Whether you operate through a Freezone entity, a Mainland LLC, or a holding structure, your books need to reflect consistent, reconciled records that give you a single view of financial performance.',
          },
          {
            icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
            title: 'IFRS-Aligned Reporting',
            desc: 'All financial statements, from profit and loss to balance sheet and cash flow, must be prepared in line with IFRS. This is a baseline expectation for audit, banking, and investor reporting in the UAE.',
          },
          {
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            title: 'Regulatory Readiness',
            desc: 'With VAT at 5%, corporate tax now in effect, and the FTA actively monitoring compliance, your accounting function needs to be ready for scrutiny at any point. Clean, structured books are not optional.',
          },
        ].map(({ icon, title, desc }) => (
          <div class="p-8 rounded-2xl border border-gray-100 shadow-sm" style="background-color: #F8FAFC;">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background-color: #EFF6FF;">
              <svg class="w-6 h-6" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">What We Offer</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Accounting & Bookkeeping Services</h2>
        <p class="text-lg mt-4 max-w-2xl mx-auto" style="color: #64748B;">
          End-to-end accounting and financial reporting for UAE businesses, built around IFRS standards and FTA compliance.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            num: '01',
            title: 'Bookkeeping & Ledger Management',
            desc: 'Day-to-day transaction recording, accounts payable and receivable management, and structured general ledger maintenance aligned with UAE Chart of Accounts requirements.',
          },
          {
            num: '02',
            title: 'Reconciliation',
            desc: 'Monthly bank reconciliation, intercompany account reconciliation, and supplier and customer statement matching to ensure your books are clean, current, and audit-ready.',
          },
          {
            num: '03',
            title: 'Management Reporting',
            desc: 'Monthly and quarterly management accounts including profit and loss, balance sheet, and cash flow statements, structured to give you clear financial visibility.',
          },
          {
            num: '04',
            title: 'Year-End Close',
            desc: 'Full year-end close procedures including prepayments, accruals, depreciation posting, and preparation of trial balance for audit or statutory purposes.',
          },
          {
            num: '05',
            title: 'IFRS Financial Statements',
            desc: 'Preparation of full IFRS-compliant financial statements including notes to accounts, suitable for submission to auditors, banks, and regulatory bodies in the UAE.',
          },
          {
            num: '06',
            title: 'Fixed Assets & Depreciation',
            desc: 'Fixed asset register maintenance, depreciation schedule management, and accounting treatment of additions and disposals in line with IAS 16 and UAE requirements.',
          },
          {
            num: '07',
            title: 'Tax and VAT Alignment',
            desc: 'Accounting entries structured to support accurate VAT returns and corporate tax filing, with clear audit trails and documentation for FTA review at any time.',
          },
          {
            num: '08',
            title: 'Group and Intercompany Accounting',
            desc: 'Consolidation support, intercompany eliminations, and accounting alignment across multiple UAE and international entities for accurate group-level reporting.',
          },
          {
            num: '09',
            title: 'Audit Support',
            desc: 'Full preparation and coordination support for statutory audits, including audit file preparation, auditor liaison, and resolution of queries from external reviewers.',
          },
        ].map(({ num, title, desc }) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="text-xs font-black mb-4" style="color: #1a4480;">{num}</div>
            <h3 class="text-base font-bold mb-3" style="color: #0F172A;">{title}</h3>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Who We Serve</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Built for UAE Business Structures</h2>
        <p class="text-lg mt-4 max-w-xl mx-auto" style="color: #64748B;">
          Our accounting service is structured around how businesses actually operate in the UAE.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            icon: '🏢',
            title: 'Freezone Companies',
            desc: 'Accounting and bookkeeping structured around Freezone-specific requirements, including IFRS reporting, audit preparation, and alignment with Freezone authority expectations across DMCC, DIFC, ADGM, and others.',
          },
          {
            icon: '🏙️',
            title: 'Mainland Businesses',
            desc: 'Full accounting support for Mainland LLCs and branch offices, including VAT-compliant bookkeeping, management accounts, and year-end financial statements prepared for DED compliance and audit.',
          },
          {
            icon: '🌐',
            title: 'Multi-Entity Businesses',
            desc: 'Group accounting support for businesses operating across multiple UAE entities or combining UAE operations with international holding structures, including intercompany accounting and consolidation.',
          },
          {
            icon: '✈️',
            title: 'International Businesses in UAE',
            desc: 'Accounting and financial reporting for overseas businesses establishing or expanding into the UAE, ensuring local compliance while maintaining alignment with the standards required in home jurisdictions.',
          },
        ].map(({ icon, title, desc }) => (
          <div class="flex gap-6 p-8 rounded-2xl border border-gray-100 shadow-sm" style="background-color: #F8FAFC;">
            <span class="text-3xl flex-shrink-0">{icon}</span>
            <div>
              <h3 class="text-lg font-bold mb-3" style="color: #0F172A;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Common Challenges</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">The Cost of Getting<br />Accounting Wrong in UAE</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">Without Ambit</h3>
          {[
            'Books maintained in multiple formats with no consistent standard across entities',
            'Financial statements not IFRS-compliant, creating risk at audit and with lenders',
            'VAT entries recorded incorrectly, leading to FTA penalties and rework',
            'Year-end close takes weeks due to poor records throughout the year',
            'No clear financial picture to support business decisions or investor reporting',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border-left: 3px solid #DC2626;">
              <span class="text-lg flex-shrink-0">❌</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>

        <div class="space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #64748B;">With Ambit</h3>
          {[
            'Consistent, structured books maintained across all UAE entities from day one',
            'IFRS-compliant financial statements ready for audit, banking, and investor review',
            'VAT-aligned accounting with accurate input and output tax recording every period',
            'Smooth year-end close with all reconciliations and schedules prepared in advance',
            'Real-time management reporting that gives you clear visibility and control',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 rounded-xl" style="background-color: #1E293B; border-left: 3px solid #22C55E;">
              <span class="text-lg flex-shrink-0">✅</span>
              <span class="text-sm leading-relaxed" style="color: #94A3B8;">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Our Process</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">4-Step Accounting &<br />Bookkeeping Process</h2>
      </div>

      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-px" style="background-color: #E2E8F0;"></div>
        <div class="space-y-12">
          {[
            { step: '01', title: 'Data Collection', desc: 'Gather invoices, receipts, bank statements, and all financial records for accurate processing.' },
            { step: '02', title: 'Bookkeeping', desc: 'Accurate daily transaction recording, bank reconciliation, and VAT-compliant ledger management.' },
            { step: '03', title: 'Reporting', desc: 'IFRS-compliant monthly, quarterly, and annual P&L, balance sheets, and cash flow reports.' },
            { step: '04', title: 'Advisory & VAT Filing', desc: 'Actionable financial recommendations and fully compliant UAE VAT submissions to the FTA.' },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-8 items-start">
              <div class="relative flex-shrink-0">
                <div class="w-16 h-16 rounded-full flex items-center justify-center text-sm font-black border-4 border-white shadow" style="background-color: #1a4480; color: white;">
                  {step}
                </div>
              </div>
              <div class="pt-3">
                <h3 class="text-xl font-bold mb-2" style="color: #0F172A;">{title}</h3>
                <p class="text-base leading-relaxed" style="color: #64748B;">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RESULTS + UAE SPECIFIC ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16">

        <!-- What You Gain -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Impact</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">What You Gain</h2>
          <div class="space-y-4">
            {[
              'Accurate IFRS-compliant financial reports',
              'VAT-ready accounting and FTA filing',
              'Clear real-time visibility into your finances',
              'Reduced compliance risk and audit exposure',
              'A dedicated Dubai accounting team on demand',
            ].map(item => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #EFF6FF;">
                  <svg class="w-3.5 h-3.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-base" style="color: #374151;">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- UAE Specific -->
        <div>
          <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">UAE Expertise</div>
          <h2 class="text-3xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">Tailored for UAE Accounting<br />&amp; VAT Compliance</h2>
          <div class="space-y-4">
            {[
              {
                icon: '📋',
                title: 'IFRS-Standard Reporting',
                desc: 'All financial statements prepared and maintained to full IFRS requirements.',
              },
              {
                icon: '🧾',
                title: 'UAE VAT Filings & Audit Support',
                desc: 'FTA-registered team handles all VAT returns and supports you through any audit.',
              },
              {
                icon: '🏙️',
                title: 'Freezone & Mainland Expertise',
                desc: 'Deep knowledge of accounting requirements across all UAE business structures.',
              },
              {
                icon: '📊',
                title: 'Audit-Ready Financial Statements',
                desc: 'Books maintained to the highest standard — always ready for internal or external review.',
              },
            ].map(({ icon, title, desc }) => (
              <div class="flex items-start gap-4 p-5 rounded-xl bg-white border border-gray-100 shadow-sm">
                <span class="text-2xl flex-shrink-0">{icon}</span>
                <div>
                  <div class="text-sm font-bold mb-1" style="color: #0F172A;">{title}</div>
                  <div class="text-sm leading-relaxed" style="color: #64748B;">{desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Testimonials</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Trusted by Dubai Businesses</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            quote: "Ambit handles our accounting and VAT compliance perfectly — accurate, timely, and completely stress-free.",
            name: 'Omar H.',
            role: 'Managing Director, Dubai Freezone Company',
          },
          {
            quote: "Their team ensures all reports are IFRS-compliant and VAT-ready. Highly reliable for Dubai operations.",
            name: 'Layla K.',
            role: 'Finance Manager, Abu Dhabi Multinational',
          },
        ].map(({ quote, name, role }) => (
          <div class="p-8 rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4" style="color: #1a4480;" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-base leading-relaxed mb-6" style="color: #94A3B8;">"{quote}"</p>
            <div class="flex items-center gap-3">
              <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-6 h-4 object-cover rounded-sm" />
              <div>
                <div class="text-sm font-bold text-white">{name}</div>
                <div class="text-xs" style="color: #64748B;">{role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
