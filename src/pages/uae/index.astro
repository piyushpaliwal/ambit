---
import UAELayout from '../../layouts/UAELayout.astro';
---

<UAELayout title="Dubai Accounting & Bookkeeping Services | Ambit UAE" description="VAT-compliant accounting, bookkeeping, payroll, and financial reporting for Dubai and UAE businesses. IFRS experts trusted across the GCC.">

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[92vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <!-- Background: Dubai skyline -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1800&q=80"
        alt="Dubai skyline"
        class="w-full h-full object-cover"
        style="opacity: 0.18;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 45%, #1a4480 100%); opacity: 0.9;"></div>
    </div>

    <!-- Gold accent blur -->
    <div class="absolute top-20 right-24 w-96 h-96 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.07;"></div>
    <div class="absolute bottom-20 left-16 w-72 h-72 rounded-full blur-3xl" style="background: #16A34A; opacity: 0.06;"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-24">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: Text -->
        <div>
          <!-- City badges -->
          <div
            x-show="visible"
            x-transition:enter="transition duration-600"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-2 mb-6"
          >
            {['Dubai', 'Abu Dhabi', 'Sharjah', 'UAE'].map(city => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold" style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;">
                <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-3.5 h-2.5 object-cover rounded-sm" />
                {city}
              </span>
            ))}
          </div>

          <h1
            x-show="visible"
            x-transition:enter="transition duration-700 delay-100"
            x-transition:enter-start="opacity-0 translate-y-6"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-4xl lg:text-5xl xl:text-6xl font-black leading-none mb-6"
            style="color: #F8FAFC; letter-spacing: -0.03em;"
          >
            Accounting &<br />
            <span style="color: #1a4480;">Bookkeeping</span><br />
            for Dubai Businesses
          </h1>

          <p
            x-show="visible"
            x-transition:enter="transition duration-700 delay-200"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="text-lg leading-relaxed mb-10 max-w-xl"
            style="color: #94A3B8;"
          >
            From Dubai startups to established companies in the UAE, Ambit delivers accurate, VAT-compliant, and scalable accounting & bookkeeping services tailored for GCC regulations.
          </p>

          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="flex flex-wrap gap-4"
          >
            <a href="#services" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
              Explore Our Services
            </a>
            <a href="/contact" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
              Book Free Consultation
            </a>
          </div>

          <!-- Trust pills -->
          <div
            x-show="visible"
            x-transition:enter="transition duration-700 delay-400"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            class="flex flex-wrap gap-3 mt-10"
          >
            {['UAE VAT Compliant', 'IFRS Certified', 'FTA Registered'].map(tag => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold" style="background-color: rgba(26,68,128,0.12); color: #1a4480; border: 1px solid rgba(26,68,128,0.25);">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Visual card stack -->
        <div
          x-show="visible"
          x-transition:enter="transition duration-700 delay-400"
          x-transition:enter-start="opacity-0 translate-x-8"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative"
        >
          <div class="relative w-full max-w-md mx-auto">
            <img
              src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=800&q=80"
              alt="Dubai financial district"
              class="w-full aspect-[4/3] object-cover rounded-2xl shadow-2xl"
              style="opacity: 0.75;"
            />

            <!-- Floating badge: VAT Compliant -->
            <div class="absolute -top-6 -left-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background-color: #1a4480;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">FTA VAT Compliant</div>
                  <div class="text-xs" style="color: #64748B;">UAE Certified Standards</div>
                </div>
              </div>
            </div>

            <!-- Floating badge: IFRS -->
            <div class="absolute -bottom-6 -right-8 px-4 py-3 rounded-xl shadow-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
              <div class="flex items-center gap-2">
                <div class="flex items-center gap-1">
                  <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-5 h-3.5 object-cover rounded-sm" />
                  <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
                  <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
                </div>
                <div>
                  <div class="text-xs font-bold" style="color: #F8FAFC;">IFRS Expertise</div>
                  <div class="text-xs" style="color: #64748B;">UAE · UK · US</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 30s linear infinite; width: max-content;">
      {[
        '✔ GCC VAT & IFRS Experts',
        '✔ UAE Labour Law Payroll',
        '✔ FTA Registered',
        '✔ Dubai · Abu Dhabi · Sharjah',
        '✔ Zoho UAE · Xero · QuickBooks',
        '✔ Offshore Accounting Teams',
        '✔ GCC VAT & IFRS Experts',
        '✔ UAE Labour Law Payroll',
        '✔ FTA Registered',
        '✔ Dubai · Abu Dhabi · Sharjah',
        '✔ Zoho UAE · Xero · QuickBooks',
        '✔ Offshore Accounting Teams',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== WHY DUBAI COMPANIES TRUST AMBIT ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image -->
        <div class="relative order-2 lg:order-1">
          <img
            src="https://images.unsplash.com/photo-1553444836-bc6c8d340d56?w=800&q=80"
            alt="Dubai business"
            class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl"
          />
          <!-- Stats overlay -->
          <div class="absolute top-6 -right-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #1a4480;">100%</div>
            <div class="text-xs" style="color: #64748B;">VAT Compliance</div>
          </div>
          <div class="absolute bottom-6 -left-6 px-5 py-4 rounded-xl shadow-xl" style="background-color: #0F172A;">
            <div class="text-2xl font-black" style="color: #22C55E;">AED 0</div>
            <div class="text-xs" style="color: #64748B;">Penalty Record</div>
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Why Ambit</div>
          <h2 class="text-4xl font-black mb-8" style="color: #0F172A; letter-spacing: -0.02em;">
            Why Dubai Companies<br />Trust Ambit
          </h2>

          <div class="space-y-6">
            {[
              {
                icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
                title: 'GCC VAT & IFRS Expertise',
                desc: 'Certified accountants trained in UAE VAT regulations and international accounting standards.',
              },
              {
                icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
                title: 'Tailored for UAE Businesses',
                desc: 'From real estate to e-commerce, we understand Dubai\'s unique business environment and GCC compliance needs.',
              },
              {
                icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
                title: 'Real-Time Financial Insights',
                desc: 'Dashboards and monthly reports so you can make informed, confident business decisions.',
              },
              {
                icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
                title: 'Cost-Effective Offshore Teams',
                desc: 'Scale your accounting team while remaining fully UAE-compliant — without the overhead.',
              },
            ].map(({ icon, title, desc }) => (
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #EFF6FF;">
                  <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="text-base font-bold mb-1" style="color: #0F172A;">{title}</h3>
                  <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section id="services" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">What We Offer</div>
        <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">Comprehensive Accounting Services<br />for Dubai Businesses</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">Everything your UAE business needs to stay compliant, organised, and growing.</p>
      </div>

      <!-- Quick nav grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-16">
        {[
          { num: '01', label: 'Accounting & Bookkeeping', href: '/uae/accounting' },
          { num: '02', label: 'Payroll Management', href: '/uae/payroll' },
          { num: '03', label: 'Tax & VAT Filing', href: '/uae/tax' },
          { num: '04', label: 'Accounts Payable & Receivable', href: '/uae/accounts' },
          { num: '05', label: 'Financial Reporting & Analysis', href: '/uae/reporting' },
          { num: '06', label: 'Offshore Accounting Teams', href: '/uae/offshore' },
        ].map(({ num, label, href }) => (
          <a href={href} class="group flex items-center gap-3 p-4 rounded-xl border border-transparent hover:border-amber-200 hover:shadow-sm transition-all bg-white">
            <span class="text-xs font-black" style="color: #1a4480;">{num}</span>
            <span class="text-sm font-semibold group-hover:text-amber-700 transition-colors" style="color: #374151;">{label}</span>
            <svg class="w-3.5 h-3.5 ml-auto opacity-0 group-hover:opacity-100 transition-opacity" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>

      <!-- Service cards with images -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            href: '/uae/accounting',
            img: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=600&q=80',
            title: 'Accounting & Bookkeeping',
            sub: 'IFRS / UAE VAT',
            desc: 'Accurate, up-to-date books compliant with UAE regulations and IFRS standards.',
          },
          {
            href: '/uae/payroll',
            img: 'https://images.unsplash.com/photo-1521791136064-7986c2920216?w=600&q=80',
            title: 'Payroll Management',
            sub: 'UAE Labour Law',
            desc: 'Pay employees on time with full UAE labour law and WPS compliance.',
          },
          {
            href: '/uae/tax',
            img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&q=80',
            title: 'Tax & VAT Filing',
            sub: 'FTA Compliant',
            desc: 'UAE VAT filing, bookkeeping, and tax reporting handled by FTA-registered experts.',
          },
          {
            href: '/uae/accounts',
            img: 'https://images.unsplash.com/photo-1567427017947-545c5f8d16ad?w=600&q=80',
            title: 'Accounts Payable & Receivable',
            sub: 'Cash Flow Management',
            desc: 'Streamline your cash flow and vendor relationships for UAE companies.',
          },
          {
            href: '/uae/reporting',
            img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80',
            title: 'Financial Reporting & Analysis',
            sub: 'IFRS Standards',
            desc: 'Actionable insights and reports to help Dubai businesses grow confidently.',
          },
          {
            href: '/uae/offshore',
            img: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80',
            title: 'Offshore Accounting Teams',
            sub: 'Scalable Solutions',
            desc: 'Build a UAE-compliant accounting team offshore with scalable, cost-effective solutions.',
          },
        ].map(({ href, img, title, sub, desc }) => (
          <a href={href} class="group block bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="relative h-44 overflow-hidden">
              <img src={img} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.7) 0%, transparent 60%);"></div>
              <span class="absolute bottom-3 left-4 text-xs font-semibold px-2 py-1 rounded-full" style="background-color: rgba(26,68,128,0.85); color: white;">{sub}</span>
            </div>
            <div class="p-5">
              <h3 class="text-base font-bold mb-2 group-hover:text-amber-700 transition-colors" style="color: #0F172A;">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PAIN POINTS → SOLUTIONS ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #64748B;">Common Challenges</div>
        <h2 class="text-4xl font-black text-white" style="letter-spacing: -0.02em;">Common Accounting Challenges<br />for Dubai Businesses — Solved</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-12">
        {[
          {
            problem: 'Complex VAT compliance requirements',
            solution: 'We handle all FTA VAT filing accurately and on time — zero penalties.',
          },
          {
            problem: 'Payroll errors and UAE labour law gaps',
            solution: 'UAE-compliant WPS payroll solutions with full labour law adherence.',
          },
          {
            problem: 'Disorganised books and IFRS gaps',
            solution: 'Accurate bookkeeping maintained to IFRS and UAE VAT standards monthly.',
          },
          {
            problem: 'High staffing costs for in-house teams',
            solution: 'Scalable offshore accounting teams at a fraction of the cost — still UAE-compliant.',
          },
        ].map(({ problem, solution }) => (
          <div class="p-6 rounded-2xl" style="background-color: #1E293B; border: 1px solid #334155;">
            <div class="flex items-start gap-3 mb-4">
              <span class="text-xl flex-shrink-0">❌</span>
              <p class="text-sm" style="color: #94A3B8;">{problem}</p>
            </div>
            <div class="flex items-start gap-3 pt-4" style="border-top: 1px solid #334155;">
              <span class="text-xl flex-shrink-0">✅</span>
              <p class="text-sm font-medium" style="color: #F8FAFC;">{solution}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
          See How We Can Help Your Dubai Business
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRY SPOTLIGHT ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Industries</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Serving a Wide Range of UAE Industries</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        {[
          { icon: '🏗️', label: 'Real Estate & Construction', desc: 'Property accounting and VAT reporting' },
          { icon: '🛒', label: 'E-Commerce & Retail', desc: 'Multi-channel sales and inventory reconciliation' },
          { icon: '🏥', label: 'Healthcare & Clinics', desc: 'Secure payroll and billing solutions' },
          { icon: '🚀', label: 'Startups & SMEs', desc: 'Scalable bookkeeping and financial reporting' },
          { icon: '💼', label: 'Professional Services', desc: 'Accurate reporting and VAT compliance' },
        ].map(({ icon, label, desc }) => (
          <div class="flex flex-col items-center text-center p-6 rounded-2xl border border-gray-100 hover:border-amber-200 hover:shadow-sm transition-all" style="background-color: #FAFAFA;">
            <span class="text-4xl mb-3">{icon}</span>
            <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{label}</h3>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CASE STUDY SNAPSHOT ===== -->
  <section class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Impact</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">How We Helped Dubai Businesses Thrive</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          {
            icon: '🛒',
            industry: 'E-Commerce Startup',
            result: '50% fewer errors',
            desc: 'Automated VAT and bookkeeping workflows, reducing manual errors by 50% and ensuring FTA compliance from day one.',
          },
          {
            icon: '🏗️',
            industry: 'Real Estate Company',
            result: 'Monthly clarity',
            desc: 'Simplified monthly financial reporting for a Dubai property firm — full VAT compliance and board-ready reports every month.',
          },
          {
            icon: '💼',
            industry: 'Professional Services',
            result: 'Scaled operations',
            desc: 'Offshore accounting team helped a professional services firm scale its finance function without increasing headcount.',
          },
        ].map(({ icon, industry, result, desc }) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="text-4xl mb-4">{icon}</div>
            <div class="text-xs font-bold uppercase tracking-wider mb-2" style="color: #1a4480;">{industry}</div>
            <div class="text-2xl font-black mb-3" style="color: #0F172A;">{result}</div>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="py-24 px-6 lg:px-12 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">Our Process</div>
        <h2 class="text-4xl font-black" style="color: #0F172A; letter-spacing: -0.02em;">Our Accounting Process<br />for Dubai Businesses</h2>
      </div>

      <div class="relative">
        <div class="absolute left-8 top-0 bottom-0 w-px" style="background-color: #E2E8F0;"></div>
        <div class="space-y-12">
          {[
