---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Industries | Ambit Accounting & Bookkeeping" description="Ambit provides accurate, reliable, and scalable bookkeeping and accounting services for CPA firms, startups, e-commerce, real estate, healthcare, and SMEs across the US.">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section
    class="relative min-h-[80vh] flex items-center overflow-hidden"
    style="background-color: #0F172A;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1800&q=80"
        alt="Industries we serve"
        class="w-full h-full object-cover"
        style="opacity: 0.12;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #0F172A 0%, #0F172A 50%, #1a4480 100%); opacity: 0.92;"></div>
    </div>

    <div class="absolute top-24 right-20 w-80 h-80 rounded-full blur-3xl" style="background: #1a4480; opacity: 0.14;"></div>
    <div class="absolute bottom-16 left-12 w-64 h-64 rounded-full blur-3xl" style="background: #3B82F6; opacity: 0.07;"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12 py-32 text-center">

      <div
        x-show="visible"
        x-transition:enter="transition duration-700"
        x-transition:enter-start="opacity-0 -translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-8"
        style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
      >
        <svg class="w-3.5 h-3.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        Industries We Serve
      </div>

      <h1
        x-show="visible"
        x-transition:enter="transition duration-700 delay-100"
        x-transition:enter-start="opacity-0 translate-y-6"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-4xl lg:text-6xl xl:text-7xl font-black leading-none mb-8 text-white"
        style="letter-spacing: -0.03em;"
      >
        Accounting Solutions<br />
        <span style="color: #3B82F6;">Built for Your Industry</span>
      </h1>

      <p
        x-show="visible"
        x-transition:enter="transition duration-700 delay-200"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-xl leading-relaxed mb-10 max-w-2xl mx-auto"
        style="color: #94A3B8;"
      >
        From CPA firms to startups, Ambit provides accurate, reliable, and scalable bookkeeping and accounting services for US businesses.
      </p>

      <div
        x-show="visible"
        x-transition:enter="transition duration-700 delay-300"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="flex flex-wrap justify-center gap-4 mb-16"
      >
        <a href="/contact" class="px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90 hover:scale-105" style="background-color: #1a4480;">
          Book Free Consultation
        </a>
        <a href="#industries" class="px-8 py-4 text-sm font-semibold rounded-lg border transition-all hover:bg-white/5" style="color: #94A3B8; border-color: #334155;">
          Explore Industries
        </a>
      </div>

      <!-- Industry pill grid -->
      <div
        x-show="visible"
        x-transition:enter="transition duration-700 delay-400"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        class="flex flex-wrap justify-center gap-3"
      >
        {['CPA Firms', 'E-commerce', 'Startups', 'Real Estate', 'Healthcare', 'SMEs'].map(label => (
          <span class="text-xs font-semibold px-4 py-2 rounded-full" style="background-color: #1E293B; color: #64748B; border: 1px solid #334155;">{label}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="w-full py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex gap-12 items-center" style="animation: marquee 30s linear infinite; width: max-content;">
      {[
        '✔ CPA Firms', '✔ E-commerce', '✔ Startups', '✔ Real Estate', '✔ Healthcare', '✔ SMEs',
        '✔ 12+ Years Experience', '✔ 280+ Clients Helped', '✔ 99.8% Accuracy Rate',
        '✔ CPA Firms', '✔ E-commerce', '✔ Startups', '✔ Real Estate', '✔ Healthcare', '✔ SMEs',
        '✔ 12+ Years Experience', '✔ 280+ Clients Helped', '✔ 99.8% Accuracy Rate',
      ].map(item => (
        <span class="text-sm font-semibold text-white whitespace-nowrap">{item}</span>
      ))}
    </div>
  </div>

  <!-- ===== INDUSTRY OVERVIEW GRID ===== -->
  <section class="py-20 px-6 lg:px-12 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #1a4480;">What We Cover</div>
        <h2 class="text-4xl font-black mb-4" style="color: #0F172A; letter-spacing: -0.02em;">6 Industries. One Trusted Partner.</h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: #64748B;">Every industry has unique accounting challenges. Ambit delivers tailored solutions that match your specific needs.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { label: 'CPA Firms', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', desc: 'Client bookkeeping, reconciliations & tax filing support' },
          { label: 'E-commerce', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', desc: 'Sales, inventory & multi-channel payment reconciliation' },
          { label: 'Startups', icon: 'M13 10V3L4 14h7v7l9-11h-7z', desc: 'Budgeting, bookkeeping & financial insights for founders' },
          { label: 'Real Estate', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', desc: 'Property accounting, rental ledgers & compliance reporting' },
          { label: 'Healthcare', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', desc: 'Confidential bookkeeping, payroll & regulatory compliance' },
          { label: 'SMEs', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', desc: 'Flexible, cost-effective accounting & reporting for growth' },
        ].map(({ label, icon, desc }) => (
          <a href={`#${label.toLowerCase().replace(/[\s&()]+/g, '-').replace(/-+/g, '-').replace(/-$/, '')}`}
            class="group flex items-start gap-4 p-6 rounded-2xl border hover:shadow-md hover:border-blue-100 transition-all cursor-pointer"
            style="background-color: #FAFAFA; border-color: #E2E8F0;">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
              <svg class="w-5 h-5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
            </div>
            <div>
              <div class="text-sm font-bold mb-1 group-hover:text-blue-700 transition-colors" style="color: #0F172A;">{label}</div>
              <div class="text-xs leading-relaxed" style="color: #64748B;">{desc}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRY DETAIL SECTIONS ===== -->
  <div id="industries">

    <!-- CPA Firms -->
    <section id="cpa-firms" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Industry 01</div>
            <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">CPA Firms</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
              Ambit supports CPA firms with client bookkeeping, reconciliations, and tax filings, acting as an extension of your team. We handle the volume so you can focus on high-value advisory work.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #EFF6FF; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #1a4480;">Impact</div>
                <div class="text-sm" style="color: #374151;">Faster reports, error-free compliance, and scalable staffing.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Client bookkeeping & ledger management', 'Bank & credit card reconciliations', 'Tax filing support across multiple clients', 'Scalable offshore staffing for peak seasons', 'Error-free financial statements on deadline'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                    <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #374151;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&q=80" alt="CPA Firms" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl" />
            <div class="absolute -bottom-5 -right-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #0F172A;">
              <div class="text-2xl font-black mb-1" style="color: #3B82F6;">3x</div>
              <div class="text-xs" style="color: #64748B;">Faster Reporting</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- E-commerce -->
    <section id="e-commerce" class="py-24 px-6 lg:px-12 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="relative order-2 lg:order-1">
            <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=80" alt="E-commerce" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl" />
            <div class="absolute -bottom-5 -left-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #0F172A;">
              <div class="text-2xl font-black mb-1" style="color: #22C55E;">99.8%</div>
              <div class="text-xs" style="color: #64748B;">Reconciliation Accuracy</div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Industry 02</div>
            <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">E-commerce</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
              We help e-commerce businesses manage sales, inventory, and multiple payment channels, ensuring real-time tracking and smooth reconciliation across platforms like Amazon, Shopify, and more.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #EFF6FF; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #1a4480;">Impact</div>
                <div class="text-sm" style="color: #374151;">Reduced errors, better cash flow visibility, and streamlined operations.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Multi-channel sales & payment reconciliation', 'Inventory accounting & COGS tracking', 'Returns and refunds management', 'Sales tax compliance across states', 'Real-time P&L and cash flow dashboards'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                    <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #374151;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Startups -->
    <section id="startups" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Industry 03</div>
            <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">Startups</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
              Startups need scalable accounting and clear financial insights. Our team provides budgeting, bookkeeping, and reporting, freeing founders to focus on what matters most — growth.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #EFF6FF; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #1a4480;">Impact</div>
                <div class="text-sm" style="color: #374151;">Transparent finances, lower operational costs, and support for scaling.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Founder-friendly bookkeeping from day one', 'Burn rate tracking & runway forecasting', 'Investor-ready financial statements', 'Scalable team as you grow', 'Compliance from seed to Series A'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                    <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #374151;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1559136555-9303baea8ebd?w=800&q=80" alt="Startups" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl" />
            <div class="absolute -bottom-5 -right-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #0F172A;">
              <div class="text-2xl font-black mb-1" style="color: #3B82F6;">60%</div>
              <div class="text-xs" style="color: #64748B;">Cost Savings</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Real Estate -->
    <section id="real-estate" class="py-24 px-6 lg:px-12 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="relative order-2 lg:order-1">
            <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&q=80" alt="Real Estate" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl" />
            <div class="absolute -bottom-5 -left-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #0F172A;">
              <div class="text-2xl font-black mb-1" style="color: #22C55E;">100%</div>
              <div class="text-xs" style="color: #64748B;">Compliance Record</div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Industry 04</div>
            <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">Real Estate</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
              Real estate accounting requires attention to property management, rentals, and compliance. Ambit delivers timely reports and accurate ledgers so you never miss a number.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #EFF6FF; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #1a4480;">Impact</div>
                <div class="text-sm" style="color: #374151;">Smooth cash flow management and risk-free compliance.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Property-level accounting & ledgers', 'Rental income tracking & expense management', 'Mortgage & loan reconciliation', 'Compliance with real estate accounting standards', 'Cash flow forecasting & financial reporting'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                    <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #374151;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Healthcare -->
    <section id="healthcare" class="py-24 px-6 lg:px-12" style="background-color: #F8FAFC;">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #1a4480;">Industry 05</div>
            <h2 class="text-4xl font-black mb-6" style="color: #0F172A; letter-spacing: -0.02em;">Healthcare</h2>
            <p class="text-lg leading-relaxed mb-8" style="color: #64748B;">
              Healthcare providers benefit from confidential, accurate bookkeeping, payroll support, and compliance with industry regulations. We handle the financial complexity so you can focus on patient care.
            </p>
            <div class="p-5 rounded-xl mb-8 flex items-start gap-3" style="background-color: #EFF6FF; border-left: 3px solid #1a4480;">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <div>
                <div class="text-xs font-bold uppercase tracking-widest mb-1" style="color: #1a4480;">Impact</div>
                <div class="text-sm" style="color: #374151;">Efficient billing, accurate payroll, and peace of mind.</div>
              </div>
            </div>
            <ul class="space-y-3">
              {['Confidential financial record management', 'Medical billing & insurance reconciliation', 'Payroll for clinical and admin staff', 'Regulatory compliance & audit support', 'Practice-level financial reporting'].map(item => (
                <li class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: #EFF6FF;">
                    <svg class="w-3 h-3" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-sm" style="color: #374151;">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=800&q=80" alt="Healthcare" class="w-full aspect-[4/3] object-cover rounded-2xl shadow-xl" />
            <div class="absolute -bottom-5 -right-5 px-6 py-5 rounded-2xl shadow-xl" style="background-color: #0F172A;">
              <div class="text-2xl font-black mb-1" style="color: #3B82F6;">100%</div>
              <div class="text-xs" style="color: #64748B;">Data Confidentiality</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SMEs -->
    <section id="smes" class="py-24 px-6 lg:px-12 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="relative order-2 lg:order-1">
