---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    slug: 'restaurant-tax-planning',
    title: 'How Proper Tax Planning Can Keep More Money in Your Restaurant Business',
    excerpt: 'Discover the key tax strategies, credits, and deductions every restaurant owner should know — from Section 179 equipment write-offs to the FICA Tip Credit.',
    category: 'Tax Planning',
    categoryColor: '#059669',
    date: 'April 15, 2026',
    readTime: '7 min read',
    image: 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=800&auto=format&fit=crop&q=80',
  },
];
---

<Layout title="Blog | Ambit Accounting & Bookkeeping" description="Expert insights on accounting, tax planning, payroll, and financial management for businesses across the UK, US, and UAE.">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section
    class="relative overflow-hidden flex items-center"
    style="background-color: #0F172A; min-height: 420px;"
    x-data="{ visible: false }"
    x-init="setTimeout(() => visible = true, 100)"
  >
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] rounded-full opacity-[0.04] blur-3xl" style="background: #3B82F6;"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12 py-24 text-center">
      <div
        x-show="visible"
        x-transition:enter="transition duration-700"
        x-transition:enter-start="opacity-0 -translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-8"
        style="background-color: #1E293B; color: #94A3B8; border: 1px solid #334155;"
      >
        <svg class="w-3.5 h-3.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        Insights & Guides
      </div>
      <h1
        x-show="visible"
        x-transition:enter="transition duration-700 delay-100"
        x-transition:enter-start="opacity-0 translate-y-6"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-4xl lg:text-6xl font-black leading-none mb-6 text-white"
        style="letter-spacing: -0.03em;"
      >
        Ambit Blog
      </h1>
      <p
        x-show="visible"
        x-transition:enter="transition duration-700 delay-200"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="text-lg max-w-2xl mx-auto"
        style="color: #94A3B8;"
      >
        Expert insights on accounting, tax planning, payroll, and financial management for businesses across the UK, US, and UAE.
      </p>
    </div>
  </section>

  <!-- ===== BLOG GRID ===== -->
  <section class="py-24" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-12">

      <div class="flex items-center justify-between mb-12">
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-2" style="color: #1a4480;">Latest Articles</p>
          <h2 class="text-2xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">{posts.length} Article{posts.length !== 1 ? 's' : ''} Published</h2>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block rounded-2xl overflow-hidden bg-white hover:shadow-xl hover:-translate-y-1 transition-all duration-300" style="border: 1px solid #E2E8F0;">
            <!-- Image -->
            <div class="relative overflow-hidden" style="height: 220px;">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 50%, rgba(15,23,42,0.4) 100%);"></div>
              <div class="absolute top-4 left-4">
                <span class="text-xs font-bold px-3 py-1.5 rounded-full text-white" style={`background-color: ${post.categoryColor};`}>{post.category}</span>
              </div>
            </div>
            <!-- Content -->
            <div class="p-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-xs" style="color: #94A3B8;">{post.date}</span>
                <span class="w-1 h-1 rounded-full" style="background-color: #CBD5E1;"></span>
                <span class="text-xs" style="color: #94A3B8;">{post.readTime}</span>
              </div>
              <h3 class="text-base font-bold leading-snug mb-3 group-hover:text-blue-700 transition-colors" style="color: #0F172A;">{post.title}</h3>
              <p class="text-sm leading-relaxed mb-5" style="color: #64748B;">{post.excerpt}</p>
              <div class="flex items-center gap-2 text-xs font-semibold" style="color: #1a4480;">
                Read Article
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-20" style="background-color: #0F172A;">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #64748B;">Work With Us</p>
      <h2 class="text-3xl lg:text-4xl font-black text-white mb-5" style="letter-spacing: -0.02em;">Have Questions About Your Finances?</h2>
      <p class="text-base mb-10" style="color: #94A3B8;">Our team of accounting and tax specialists is ready to help your business stay compliant and grow confidently.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 text-sm font-bold text-white rounded-lg transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
        Book Free Consultation
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
