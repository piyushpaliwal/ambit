---
import USLayout from '../../layouts/USLayout.astro';
---

<USLayout
  title="Federal & State Tax Compliance – US"
  description="From federal filings to state-specific requirements, Ambit ensures your business is 100% IRS and state-compliant — penalty-free."
  countryPhone="+1 (800) 123 4567"
  countryEmail="us@ambit.co.uk"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 580px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full opacity-[0.04] blur-3xl" style="background: #3B82F6;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center" style="min-height: 580px;">
      <div class="grid lg:grid-cols-2 gap-16 items-center w-full py-24 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United States · Tax Compliance</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[52px] font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            Stay Compliant,<br/>Avoid Penalties,<br/>
            <span style="color: #93B4D4;">Focus on Growth</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 480px;">
            From federal filings to state-specific requirements, Ambit ensures your business is 100% IRS and state-compliant — keeping you worry-free and penalty-free.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              Book Free Tax Consultation
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              See How It Works
            </a>
          </div>

          <div class="flex flex-wrap gap-6 pt-8" style="border-top: 1px solid #1E293B;">
            {['IRS & State Compliance', 'Penalty-Free Filings', 'Federal & State Experts', 'Multi-State Support'].map(t => (
              <div class="flex items-center gap-2">
                <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: rgba(26,68,128,0.4);">
                  <svg class="w-2.5 h-2.5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-xs font-medium" style="color: #94A3B8;">{t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: image -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 300)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-x-6"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative">
          <div class="absolute -top-4 -right-4 w-full h-full rounded-2xl" style="border: 1px solid #1E293B;"></div>
          <img
            src="https://images.unsplash.com/photo-1586281380349-632531db7ed4?w=900&q=80"
            alt="Tax compliance documents"
            class="relative rounded-2xl w-full object-cover shadow-2xl"
            style="height: 420px; object-position: center;"
          />
          <div class="absolute -bottom-5 -left-5 bg-white rounded-xl p-4 shadow-xl" style="border: 1px solid #EEF2F6;">
            <p class="text-xs mb-1" style="color: #94A3B8;">Filing Accuracy Rate</p>
            <p class="text-2xl font-black" style="color: #0F172A;">100<span style="color: #1a4480;">%</span></p>
            <div class="mt-2 flex items-center gap-1.5">
              <div class="w-2 h-2 rounded-full" style="background-color: #22C55E;"></div>
              <span class="text-xs" style="color: #64748B;">Zero penalty record</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex whitespace-nowrap" style="animation: marquee 25s linear infinite;">
      {[...Array(3)].map(() => (
        <div class="flex items-center flex-shrink-0">
          {['IRS & State Compliance', 'Penalty-Free Filings', 'Expert Federal & State Tax Advisors', 'Multi-State Filing Support', 'Audit-Ready Documentation', 'US GAAP Aligned'].map(item => (
            <div class="flex items-center gap-8 px-8">
              <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: rgba(255,255,255,0.75);">{item}</span>
              <span class="w-1 h-1 rounded-full flex-shrink-0" style="background-color: rgba(255,255,255,0.3);"></span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: content -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-4xl sm:text-5xl font-bold mb-6" style="color: #0F172A; letter-spacing: -0.025em;">
            Non-Compliance Can<br/>Cost More Than<br/>You Think
          </h2>
          <p class="text-sm leading-relaxed mb-5" style="color: #64748B;">
            Late or incorrect federal and state tax filings can result in significant fines, penalties, and IRS audits — all of which drain time, money, and energy from your business.
          </p>
          <p class="text-sm leading-relaxed mb-8" style="color: #64748B;">
            Ambit provides accurate, timely, and legally compliant tax filings across all required federal and state jurisdictions, so your business stays safe, clean, and stress-free.
          </p>

          <div class="grid grid-cols-2 gap-4 mb-8">
            {[
              { val: '$10K+', label: 'Avg IRS penalty avoided' },
              { val: '50+', label: 'States we file in' },
              { val: '100%', label: 'On-time filing rate' },
              { val: '20+', label: 'Years tax expertise' },
            ].map(s => (
              <div class="p-4 rounded-xl" style="background-color: #F8FAFC; border: 1px solid #EEF2F6;">
                <p class="text-2xl font-black mb-1" style="color: #1a4480;">{s.val}</p>
                <p class="text-xs" style="color: #64748B;">{s.label}</p>
              </div>
            ))}
          </div>

          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
            Get Protected Today
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Right: image -->
        <div class="relative hidden lg:block">
          <img
            src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=900&q=80"
            alt="Tax compliance team"
            class="rounded-2xl w-full object-cover shadow-lg"
            style="height: 480px; object-position: center top;"
          />
          <div class="absolute top-6 -right-5 bg-white rounded-xl px-4 py-3 shadow-lg" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-bold mb-0.5" style="color: #0F172A;">Multi-State Filing</p>
            <p class="text-xs" style="color: #94A3B8;">All 50 US states covered</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-24" style="background-color: #F8FAFC;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">What We Provide</p>
        <h2 class="text-4xl sm:text-5xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.025em;">Our Federal &amp; State Tax Compliance Services</h2>
        <p class="text-sm leading-relaxed" style="color: #64748B;">End-to-end tax compliance — federal, state, and everything in between.</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-6">
        {[
          {
            num: '01',
            title: 'Federal Tax Filing',
            img: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=600&q=80',
            icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
            points: ['IRS corporate tax filings', 'Income tax reporting', 'Quarterly estimated payments'],
          },
          {
            num: '02',
            title: 'State Tax Filing',
            img: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=600&q=80',
            icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064',
            points: ['Multi-state compliance', 'Sales tax & excise tax filing', 'State-specific reporting & registrations'],
          },
          {
            num: '03',
            title: 'Advisory & Support',
            img: 'https://images.unsplash.com/photo-1521791136064-7986c2920216?w=600&q=80',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            points: ['Tax planning for liability reduction', 'Audit support & correspondence', 'Risk management & compliance consulting'],
          },
        ].map(s => (
          <div class="bg-white rounded-2xl overflow-hidden group hover:-translate-y-1 transition-all duration-300" style="border: 1px solid #EEF2F6; box-shadow: 0 2px 20px rgba(15,23,42,0.06);">
            <div class="relative overflow-hidden" style="height: 180px;">
              <img src={s.img} alt={s.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.7) 0%, transparent 60%);"></div>
              <div class="absolute bottom-4 left-5 flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2);">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={s.icon}/>
                  </svg>
                </div>
                <span class="text-xs font-black tracking-widest text-white opacity-40">{s.num}</span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-base font-bold mb-4" style="color: #0F172A;">{s.title}</h3>
              <ul class="space-y-2.5">
                {s.points.map(p => (
                  <li class="flex items-start gap-2.5">
                    <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #EEF2F8;">
                      <svg class="w-2.5 h-2.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <span class="text-xs leading-relaxed" style="color: #64748B;">{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: image -->
        <div class="relative hidden lg:block">
          <img
            src="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=900&q=80"
            alt="US business team meeting"
            class="rounded-2xl w-full object-cover shadow-lg"
            style="height: 500px; object-position: center top;"
          />
          <div class="absolute -bottom-5 -right-5 bg-white rounded-xl p-5 shadow-xl" style="border: 1px solid #EEF2F6; max-width: 190px;">
            <p class="text-3xl font-black mb-1" style="color: #1a4480;">500+</p>
            <p class="text-xs leading-snug" style="color: #64748B;">US businesses filing penalty-free with Ambit</p>
          </div>
        </div>

        <!-- Right -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Ideal For</p>
          <h2 class="text-4xl sm:text-5xl font-bold mb-6" style="color: #0F172A; letter-spacing: -0.025em;">Designed for US Businesses</h2>
          <p class="text-sm leading-relaxed mb-10" style="color: #64748B;">Whether you operate in one state or fifty, our tax compliance service scales with your obligations and complexity.</p>

          <div class="space-y-3">
            {[
              { label: 'SMEs with Multi-State Operations', desc: 'Compliance across every jurisdiction you operate in', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064' },
              { label: 'Startups & Fast-Growing Companies', desc: 'Build compliance habits right from the start', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
              { label: 'E-Commerce & Service Providers', desc: 'Sales tax nexus, excise filings, and state registrations', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
              { label: 'Corporations Needing IRS Compliance', desc: 'Corporate tax filings, quarterly estimates, and more', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9' },
              { label: 'International Businesses in the US', desc: 'US tax compliance for foreign entities and subsidiaries', icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9' },
            ].map(item => (
              <div class="flex items-center gap-4 p-4 rounded-xl transition-all hover:-translate-x-1 duration-200" style="background-color: #F8FAFC; border: 1px solid #EEF2F6;">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #0F172A, #1a4480);">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={item.icon}/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold" style="color: #0F172A;">{item.label}</p>
                  <p class="text-xs" style="color: #94A3B8;">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-24 relative overflow-hidden" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: problems -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #3B82F6;">Common Mistakes</p>
          <h2 class="text-4xl sm:text-5xl font-bold text-white mb-6" style="letter-spacing: -0.025em;">Avoid These Tax Compliance Mistakes</h2>
          <p class="text-sm leading-relaxed mb-10" style="color: #64748B;">These are the most common — and costly — compliance failures we see in US businesses every day.</p>

          <div class="space-y-3 mb-10">
            {[
              'Missed federal or state filing deadlines',
              'Incorrect filings leading to IRS penalties',
              'Multi-state tax confusion and missed registrations',
              'Lack of audit-ready documentation',
            ].map(p => (
              <div class="flex items-start gap-3 p-4 rounded-xl" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.1);">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #F87171;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                <span class="text-sm" style="color: #94A3B8;">{p}</span>
              </div>
            ))}
          </div>

          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.4);">
            Fix This With Ambit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Right: solutions -->
        <div class="space-y-3">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-6" style="color: #3B82F6;">How Ambit Solves It</p>
          {[
            { problem: 'Missed deadlines', solution: 'Proactive deadline tracking — every federal and state filing submitted ahead of schedule, every time.' },
            { problem: 'Incorrect filings', solution: 'Every return reviewed by experienced US tax professionals before submission.' },
            { problem: 'Multi-state confusion', solution: 'We manage your nexus analysis, registrations, and filings across all required states.' },
            { problem: 'Not audit-ready', solution: 'Full documentation, organised and stored — so you\'re always prepared if the IRS comes knocking.' },
          ].map(s => (
            <div class="flex items-start gap-4 p-5 rounded-xl" style="background: #1E293B; border: 1px solid #334155;">
              <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(26,68,128,0.5);">
                <svg class="w-3 h-3 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="text-xs font-bold mb-1.5 line-through" style="color: #475569;">{s.problem}</p>
                <p class="text-sm leading-relaxed" style="color: #CBD5E1;">{s.solution}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-xl mb-20">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">The Process</p>
        <h2 class="text-4xl sm:text-5xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.025em;">4-Step Tax Compliance Process</h2>
        <p class="text-sm leading-relaxed" style="color: #64748B;">From first conversation to ongoing compliance — a clear, structured process.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 relative">
        <div class="hidden lg:block absolute top-3 left-0 right-0 h-px" style="background-color: #E2E8F0;"></div>

        {[
          { step: '01', title: 'Consultation', desc: 'We map your business structure, tax obligations, and filing history across all federal and state levels.' },
          { step: '02', title: 'Review & Analysis', desc: 'We assess your past filings, identify risks or gaps, and establish a compliant baseline going forward.' },
          { step: '03', title: 'Filing & Compliance', desc: 'Accurate, on-time federal and state tax submissions — reviewed by professionals before every submission.' },
          { step: '04', title: 'Ongoing Support', desc: 'Proactive advisory, deadline management, and continuous compliance monitoring throughout the year.' },
        ].map(s => (
          <div class="relative">
            <div class="relative mb-8">
              <div class="w-6 h-6 rounded-full border-2 bg-white relative z-10" style="border-color: #1a4480;">
                <div class="absolute inset-1 rounded-full" style="background-color: #1a4480;"></div>
              </div>
            </div>
            <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #94A3B8;">{s.step} / 04</p>
            <h3 class="text-base font-bold mb-2 leading-snug" style="color: #0F172A;">{s.title}</h3>
            <div class="w-8 h-0.5 mb-3" style="background-color: #1a4480;"></div>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESULTS ===== -->
  <section class="py-24" style="background-color: #F8FAFC;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
