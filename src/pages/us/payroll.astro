---
import USLayout from '../../layouts/USLayout.astro';
---

<USLayout
  title="Payroll & Employment Tax – US"
  description="Accurate payroll processing and full employment tax compliance — keeping your business IRS-compliant and employees satisfied."
  countryPhone="+1 (800) 123 4567"
  countryEmail="us@ambit.co.uk"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 560px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 flex items-center" style="min-height: 560px;">
      <div class="grid lg:grid-cols-2 gap-14 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United States · Payroll</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            Payroll &amp; Employment<br/>Taxes,
            <span style="color: #93B4D4;">Simplified</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 460px;">
            Accurate payroll processing and full employment tax compliance — keeping your business IRS-compliant and your employees satisfied, every single pay cycle.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              Speak to Our Experts
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              See How It Works
            </a>
          </div>

          <div class="flex flex-wrap gap-5 pt-8" style="border-top: 1px solid #1E293B;">
            {['IRS & State Compliant', 'On-Time Every Pay Cycle', 'Multi-State Expertise', 'Dedicated Payroll Team'].map(t => (
              <div class="flex items-center gap-2">
                <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: rgba(26,68,128,0.4);">
                  <svg class="w-2.5 h-2.5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-xs font-medium" style="color: #94A3B8;">{t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: image -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 300)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-x-6"
          x-transition:enter-end="opacity-100 translate-x-0"
          class="hidden lg:block relative">
          <div class="absolute -top-4 -right-4 w-full h-full rounded-2xl" style="border: 1px solid #1E293B;"></div>
          <img
            src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=900&q=80"
            alt="Payroll management team"
            class="relative rounded-2xl w-full object-cover shadow-2xl"
            style="height: 400px; object-position: center;"
          />
          <div class="absolute -bottom-5 -left-5 bg-white rounded-xl p-4 shadow-xl" style="border: 1px solid #EEF2F6;">
            <p class="text-xs mb-1" style="color: #94A3B8;">Payroll Accuracy Rate</p>
            <p class="text-2xl font-black" style="color: #0F172A;">99.9<span style="color: #1a4480;">%</span></p>
            <div class="mt-2 flex items-center gap-1.5">
              <div class="w-2 h-2 rounded-full" style="background-color: #22C55E;"></div>
              <span class="text-xs" style="color: #64748B;">Zero missed payrolls</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="py-4 overflow-hidden" style="background-color: #1a4480;">
    <div class="flex whitespace-nowrap" style="animation: marquee 25s linear infinite;">
      {[...Array(3)].map(() => (
        <div class="flex items-center flex-shrink-0">
          {['IRS & State Payroll Compliance', 'Timely Employee Payments', 'Accurate Employment Tax Calculations', 'Dedicated US Payroll Experts', 'Multi-State Filing', 'Audit-Ready Documentation'].map(item => (
            <div class="flex items-center gap-8 px-8">
              <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: rgba(255,255,255,0.75);">{item}</span>
              <span class="w-1 h-1 rounded-full flex-shrink-0" style="background-color: rgba(255,255,255,0.3);"></span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: image -->
        <div class="relative hidden lg:block">
          <img
            src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=900&q=80"
            alt="Payroll compliance"
            class="rounded-2xl w-full object-cover shadow-lg"
            style="height: 420px; object-position: center;"
          />
          <div class="absolute -bottom-5 -right-5 bg-white rounded-xl p-5 shadow-xl" style="border: 1px solid #EEF2F6; max-width: 200px;">
            <p class="text-3xl font-black mb-1" style="color: #1a4480;">$0</p>
            <p class="text-xs leading-snug" style="color: #64748B;">IRS penalties incurred by our payroll clients</p>
          </div>
        </div>

        <!-- Right -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-4xl sm:text-5xl font-bold mb-6" style="color: #0F172A; letter-spacing: -0.025em;">
            Payroll &amp; Employment<br/>Taxes Don't Have to<br/>Be Stressful
          </h2>
          <p class="text-sm leading-relaxed mb-5" style="color: #64748B;">
            Incorrect payroll or employment tax filings can lead to IRS penalties, state fines, disgruntled employees, and damaging audits — all of which cost far more than getting it right from the start.
          </p>
          <p class="text-sm leading-relaxed mb-8" style="color: #64748B;">
            Ambit handles your payroll and employment taxes accurately, efficiently, and on time — every pay period, every quarter, every year.
          </p>

          <div class="grid grid-cols-2 gap-4 mb-8">
            {[
              { val: '99.9%', label: 'Payroll accuracy rate' },
              { val: '$0', label: 'Avg penalties for clients' },
              { val: '50+', label: 'States we process payroll in' },
              { val: '20+', label: 'Years of payroll expertise' },
            ].map(s => (
              <div class="p-4 rounded-xl" style="background-color: #F8FAFC; border: 1px solid #EEF2F6;">
                <p class="text-2xl font-black mb-1" style="color: #1a4480;">{s.val}</p>
                <p class="text-xs" style="color: #64748B;">{s.label}</p>
              </div>
            ))}
          </div>

          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
            Get Started Today
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-24" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">

      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">What We Provide</p>
        <h2 class="text-4xl sm:text-5xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.025em;">Our Payroll &amp; Employment Tax Services</h2>
        <p class="text-sm leading-relaxed" style="color: #64748B;">Everything your US business needs to run payroll cleanly and stay employment-tax compliant.</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-6">
        {[
          {
            num: '01',
            title: 'Payroll Processing',
            img: 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=600&q=80',
            icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z',
            points: ['Employee salaries & wages', 'Tax withholdings & deductions', 'Payroll reporting & records'],
          },
          {
            num: '02',
            title: 'Employment Tax Compliance',
            img: 'https://images.unsplash.com/photo-1586281380349-632531db7ed4?w=600&q=80',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            points: ['IRS & state employment tax filings', 'Federal & state withholding management', 'Quarterly & annual filings (941, W-2, 1099)'],
          },
          {
            num: '03',
            title: 'Advisory & Support',
            img: 'https://images.unsplash.com/photo-1521791136064-7986c2920216?w=600&q=80',
            icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
            points: ['Tax planning for employment costs', 'Audit support & IRS correspondence', 'Employee reporting guidance'],
          },
        ].map(s => (
          <div class="bg-white rounded-2xl overflow-hidden group hover:-translate-y-1 transition-all duration-300" style="border: 1px solid #EEF2F6; box-shadow: 0 2px 20px rgba(15,23,42,0.06);">
            <div class="relative overflow-hidden" style="height: 180px;">
              <img src={s.img} alt={s.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.75) 0%, transparent 55%);"></div>
              <div class="absolute bottom-4 left-5 flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2);">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={s.icon}/>
                  </svg>
                </div>
                <span class="text-xs font-black tracking-widest text-white opacity-40">{s.num}</span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-base font-bold mb-4" style="color: #0F172A;">{s.title}</h3>
              <ul class="space-y-2.5">
                {s.points.map(p => (
                  <li class="flex items-start gap-2.5">
                    <div class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: #EEF2F8;">
                      <svg class="w-2.5 h-2.5" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <span class="text-xs leading-relaxed" style="color: #64748B;">{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Ideal For</p>
          <h2 class="text-4xl sm:text-5xl font-bold mb-6" style="color: #0F172A; letter-spacing: -0.025em;">Designed for US Businesses of Every Size</h2>
          <p class="text-sm leading-relaxed mb-10" style="color: #64748B;">Whether you have 2 employees or 200, in one state or twenty — our payroll service scales precisely to your needs.</p>

          <div class="space-y-3">
            {[
              { label: 'SMEs & Startups', desc: 'Get payroll right from your very first hire', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
              { label: 'Multi-State Companies', desc: 'Payroll processed correctly across every state jurisdiction', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064' },
              { label: 'E-Commerce & Service Businesses', desc: 'Flexible payroll for contractors, part-time & full-time staff', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z' },
              { label: 'Corporations Needing IRS Compliance', desc: 'Full 941, W-2, and 1099 filing management', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9' },
            ].map(item => (
              <div class="flex items-center gap-4 p-4 rounded-xl transition-all hover:-translate-x-1 duration-200" style="background-color: #F8FAFC; border: 1px solid #EEF2F6;">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #0F172A, #1a4480);">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={item.icon}/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold" style="color: #0F172A;">{item.label}</p>
                  <p class="text-xs" style="color: #94A3B8;">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: image -->
        <div class="relative hidden lg:block">
          <img
            src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=900&q=80"
            alt="US business team"
            class="rounded-2xl w-full object-cover shadow-lg"
            style="height: 500px; object-position: center top;"
          />
          <div class="absolute top-6 -left-5 bg-white rounded-xl px-4 py-3 shadow-lg" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-bold mb-0.5" style="color: #0F172A;">Multi-State Payroll</p>
            <p class="text-xs" style="color: #94A3B8;">50 states covered</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-24 relative overflow-hidden" style="background-color: #0F172A;">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #3B82F6;">Common Mistakes</p>
          <h2 class="text-4xl sm:text-5xl font-bold text-white mb-6" style="letter-spacing: -0.025em;">Avoid These Common Payroll &amp; Tax Mistakes</h2>
          <p class="text-sm leading-relaxed mb-10" style="color: #64748B;">These errors cost US businesses thousands every year — and most are entirely avoidable.</p>

          <div class="space-y-3 mb-10">
            {[
              'Late payroll or employment tax filings',
              'Incorrect employee tax withholdings',
              'IRS or state penalties from non-compliance',
              'Hours wasted on manual payroll processing',
            ].map(p => (
              <div class="flex items-start gap-3 p-4 rounded-xl" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.1);">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: #F87171;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                <span class="text-sm" style="color: #94A3B8;">{p}</span>
              </div>
            ))}
          </div>

          <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.4);">
            Fix This With Ambit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Right: solutions -->
        <div class="space-y-3">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-6" style="color: #3B82F6;">How Ambit Solves It</p>
          {[
            { problem: 'Late filings', solution: 'Every payroll cycle and tax deadline tracked and submitted ahead of time — without exception.' },
            { problem: 'Incorrect withholdings', solution: 'Precise tax withholding calculations for every employee, in every state, every pay period.' },
            { problem: 'IRS & state penalties', solution: 'Full compliance review before every submission — zero penalties for our clients.' },
            { problem: 'Manual payroll drain', solution: 'Fully managed payroll processing — accurate, automated, and ready for your review.' },
          ].map(s => (
            <div class="flex items-start gap-4 p-5 rounded-xl" style="background: #1E293B; border: 1px solid #334155;">
              <div class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(26,68,128,0.5);">
                <svg class="w-3 h-3 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <p class="text-xs font-bold mb-1.5 line-through" style="color: #475569;">{s.problem}</p>
                <p class="text-sm leading-relaxed" style="color: #CBD5E1;">{s.solution}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">

      <div class="max-w-xl mb-20">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">The Process</p>
        <h2 class="text-4xl sm:text-5xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.025em;">4-Step Payroll &amp; Employment Tax Process</h2>
        <p class="text-sm leading-relaxed" style="color: #64748B;">A clear, managed process so payroll is never your problem again.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 relative">
        <div class="hidden lg:block absolute top-3 left-0 right-0 h-px" style="background-color: #E2E8F0;"></div>

        {[
          { step: '01', title: 'Data Collection', desc: 'We gather all employee and contractor details, rates, benefits, and state registrations to build a clean payroll foundation.' },
          { step: '02', title: 'Payroll Processing', desc: 'Accurate salary calculations, benefit deductions, tax withholdings — processed on schedule, every time.' },
          { step: '03', title: 'Employment Tax Filing', desc: 'Federal and state payroll taxes submitted on time — 941s, W-2s, 1099s, and all state-level requirements.' },
          { step: '04', title: 'Ongoing Support', desc: 'Continuous guidance, payroll reporting, audit support, and a direct line to your dedicated payroll expert.' },
        ].map(s => (
          <div class="relative">
            <div class="relative mb-8">
              <div class="w-6 h-6 rounded-full border-2 bg-white relative z-10" style="border-color: #1a4480;">
                <div class="absolute inset-1 rounded-full" style="background-color: #1a4480;"></div>
              </div>
            </div>
            <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #94A3B8;">{s.step} / 04</p>
            <h3 class="text-base font-bold mb-2 leading-snug" style="color: #0F172A;">{s.title}</h3>
            <div class="w-8 h-0.5 mb-3" style="background-color: #1a4480;"></div>
            <p class="text-sm leading-relaxed" style="color: #64748B;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESULTS ===== -->
  <section class="py-24" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">What You Gain</p>
          <h2 class="text-4xl sm:text-5xl font-bold mb-10" style="color: #0F172A; letter-spacing: -0.025em;">The Results You'll See</h2>

          <div class="space-y-4">
            {[
              { title: 'On-time payroll, every pay cycle', desc: 'Employees paid accurately and on schedule — no delays, no disputes.' },
              { title: 'IRS & state employment tax compliance', desc: 'Every filing submitted correctly across all federal and state requirements.' },
              { title: 'Reduced penalties & audit risk', desc: 'Professional review before every submission eliminates costly mistakes.' },
              { title: 'Happy employees & smooth operations', desc: 'Reliable payroll builds trust and keeps your team focused on the work.' },
            ].map(r => (
              <div class="flex items-start gap-4 p-5 bg-white rounded-2xl" style="border: 1px solid #EEF2F6; box-shadow: 0 2px 12px rgba(15,23,42,0.04);">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #0F172A, #1a4480);">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <p class="text-sm font-bold mb-1" style="color: #0F172A;">{r.title}</p>
                  <p class="text-xs leading-relaxed" style="color: #64748B;">{r.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right -->
        <div class="space-y-5">
          <img
            src="https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=900&q=80"
            alt="Payroll results"
            class="rounded-2xl w-full object-cover shadow-md"
            style="height: 240px; object-position: center;"
          />
          <div class="rounded-2xl p-7 bg-white" style="border: 1px solid #EEF2F6;">
            <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-5" style="color: #1a4480;">Tailored for US Payroll Regulations</p>
            <div class="grid grid-cols-2 gap-3">
              {['Federal Payroll Compliance', 'Multi-State Tax Filing', 'QuickBooks · Gusto · ADP', 'Audit-Ready Records'].map(item => (
                <div class="flex items-center gap-2">
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: #1a4480;"></div>
                  <span class="text-xs" style="color: #64748B;">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="py-24" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">

      <div class="text-center max-w-xl mx-auto mb-14">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #3B82F6;">Testimonials</p>
        <h2 class="text-4xl font-bold text-white" style="letter-spacing: -0.025em;">Trusted by US Businesses</h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-6">
        {[
          { quote: "Ambit handles our payroll perfectly — including all employment taxes across multiple states. No stress, no mistakes, and always on time. Couldn't ask for more.", name: 'Michael T.', role: 'Operations Director', location: 'Houston, TX' },
          { quote: "Their team keeps us IRS-compliant every quarter. Highly reliable, highly efficient — and they saved us from a payroll tax issue we didn't even know we had.", name: 'Priya S.', role: 'CFO, Tech Startup', location: 'San Jose, CA' },
        ].map(t => (
          <div class="rounded-2xl p-8" style="background: #1E293B; border: 1px solid #334155;">
            <svg class="w-7 h-7 mb-6 opacity-25" style="color: #3B82F6;" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <p class="text-sm leading-relaxed mb-7" style="color: #94A3B8;">"{t.quote}"</p>
            <div class="flex items-center gap-3" style="border-top: 1px solid #334155; padding-top: 1.25rem;">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-white flex-shrink-0" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">{t.name[0]}</div>
              <div>
                <p class="text-sm font-semibold text-white">{t.name}</p>
                <p class="text-xs" style="color: #475569;">{t.role} · {t.location}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section id="contact" class="py-24" style="background-color: #F8FAFC;">
    <div class="max-w-4xl mx-auto px-6 lg:px-10 text-center">

      <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Get Started</p>
      <h2 class="text-4xl sm:text-5xl font-bold mb-5" style="color: #0F172A; letter-spacing: -0.025em;">
        Simplify Payroll &amp; Employment<br/>Taxes Today
      </h2>
      <p class="text-sm leading-relaxed mb-10 mx-auto" style="color: #64748B; max-width: 460px;">
        Accurate, compliant, and stress-free payroll & employment tax management — so you can focus on growing your business.
      </p>

      <div class="flex flex-wrap justify-center gap-4 mb-14">
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 24px rgba(26,68,128,0.4);">
          Book Free Consultation
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/us" class="inline-flex items-center gap-2 px-8 py-4 text-sm font-semibold rounded border transition-all hover:bg-gray-50" style="color: #0F172A; border-color: #E2E8F0;">
          ← Back to US Services
        </a>
      </div>

      <div class="grid sm:grid-cols-3 gap-6 pt-10 max-w-2xl mx-auto" style="border-top: 1px solid #E2E8F0;">
        {[
          { val: '99.9%', label: 'Payroll Accuracy Rate' },
          { val: '50+', label: 'States Covered' },
          { val: '$0', label: 'Client Penalties' },
        ].map(s => (
          <div>
            <p class="text-3xl font-black mb-1" style="color: #1a4480;">{s.val}</p>
            <p class="text-xs" style="color: #94A3B8;">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</USLayout>
