---
import USLayout from '../../layouts/USLayout.astro';
---

<USLayout
  title="Financial Management – US"
  description="From budgeting to cash flow and strategic planning, Ambit provides comprehensive financial management services to help US businesses grow confidently."
  countryPhone="+1 (800) 123 4567"
  countryEmail="us@ambit.co.uk"
>

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="background-color: #0F172A; min-height: 560px;">
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#94A3B8 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.06] blur-3xl" style="background: #1a4480;"></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-10 flex items-center" style="min-height: 560px;">
      <div class="grid lg:grid-cols-2 gap-14 items-center w-full py-20 lg:py-0">

        <!-- Left -->
        <div x-data="{ v: false }" x-init="setTimeout(() => v = true, 80)" x-show="v"
          x-transition:enter="transition ease-out duration-700"
          x-transition:enter-start="opacity-0 translate-y-6"
          x-transition:enter-end="opacity-100 translate-y-0">

          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
            <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
            <span class="text-xs font-semibold tracking-[0.15em] uppercase" style="color: #93B4D4;">United States · Financial Management</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold leading-[1.08] text-white mb-6" style="letter-spacing: -0.02em;">
            Manage Your Finances<br/>
            <span style="color: #93B4D4;">Smarter, Every Month</span>
          </h1>
          <p class="text-base leading-relaxed mb-8" style="color: #94A3B8; max-width: 460px;">
            From budgeting to cash flow and strategic planning, Ambit provides comprehensive financial management services to help US businesses grow confidently.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1a4480 0%, #1e5ab5 100%); box-shadow: 0 4px 20px rgba(26,68,128,0.45);">
              Book Free Financial Review
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-6 py-3.5 text-sm font-semibold rounded border transition-all hover:bg-white/5" style="color: #CBD5E1; border-color: #334155;">
              See How It Works
            </a>
          </div>

          <div class="flex flex-wrap gap-5 pt-8" style="border-top: 1px solid #1E293B;">
            {['Real-Time Insights', 'IRS Compliant', 'Strategic Advisory', 'Dedicated Experts'].map(t => (
              <div class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-xs font-medium" style="color: #64748B;">{t}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: hero image + floating stat -->
        <div class="relative hidden lg:block">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="height: 420px;">
            <img
              src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=900&auto=format&fit=crop&q=80"
              alt="Financial management dashboard"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(15,23,42,0.4) 0%, transparent 60%);"></div>
          </div>
          <!-- Floating stat -->
          <div class="absolute -bottom-6 -left-8 rounded-xl px-5 py-4 shadow-xl" style="background: #1a4480; border: 1px solid rgba(255,255,255,0.1);">
            <div class="text-2xl font-bold text-white leading-none mb-0.5">100%</div>
            <div class="text-xs font-medium" style="color: #93B4D4;">Reporting Accuracy</div>
          </div>
          <!-- Second float -->
          <div class="absolute -top-4 -right-4 rounded-xl px-4 py-3 shadow-xl" style="background: #1E293B; border: 1px solid #334155;">
            <div class="text-xl font-bold text-white leading-none mb-0.5">US GAAP</div>
            <div class="text-xs" style="color: #64748B;">Compliant Reports</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <div class="overflow-hidden py-4" style="background-color: #1a4480;">
    <div class="flex items-center gap-0" style="animation: marquee 28s linear infinite; width: max-content;">
      {[
        'Real-Time Financial Insights',
        'IRS & State Compliance',
        'Strategic Advisory & Reporting',
        'Dedicated US Finance Experts',
        'Cash Flow Optimization',
        'US GAAP Reporting',
        'Multi-State Support',
        'Budget & Forecast Planning',
      ].concat([
        'Real-Time Financial Insights',
        'IRS & State Compliance',
        'Strategic Advisory & Reporting',
        'Dedicated US Finance Experts',
        'Cash Flow Optimization',
        'US GAAP Reporting',
        'Multi-State Support',
        'Budget & Forecast Planning',
      ]).map(item => (
        <div class="flex items-center gap-3 px-6 whitespace-nowrap">
          <span class="w-1.5 h-1.5 rounded-full bg-white opacity-60 flex-shrink-0"></span>
          <span class="text-xs font-semibold tracking-[0.12em] uppercase text-white opacity-90">{item}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== WHY IT MATTERS ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image -->
        <div class="relative rounded-2xl overflow-hidden shadow-xl order-2 lg:order-1" style="height: 480px;">
          <img
            src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=900&auto=format&fit=crop&q=80"
            alt="Finance team strategy session"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.5) 0%, transparent 60%);"></div>
          <!-- Metric badges -->
          <div class="absolute bottom-6 left-6 right-6 grid grid-cols-2 gap-3">
            {[
              { num: '$0', label: 'Compliance Penalties' },
              { num: '4×', label: 'Faster Reporting' },
              { num: '50+', label: 'States Covered' },
              { num: '24h', label: 'Report Turnaround' },
            ].map(m => (
              <div class="rounded-lg px-4 py-3" style="background: rgba(15,23,42,0.85); border: 1px solid rgba(255,255,255,0.1);">
                <div class="text-xl font-bold text-white leading-none mb-0.5">{m.num}</div>
                <div class="text-xs" style="color: #94A3B8;">{m.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Content -->
        <div class="order-1 lg:order-2">
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Why It Matters</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Make Decisions with Confidence
          </h2>
          <div class="w-10 h-px mb-6" style="background-color: #1a4480;"></div>
          <p class="text-base leading-relaxed mb-8" style="color: #475569;">
            Without clear financial oversight, businesses risk overspending, cash flow problems, and missed growth opportunities. Ambit ensures your finances are transparent, optimized, and aligned with your goals.
          </p>

          <div class="space-y-4">
            {[
              { title: 'Proactive Financial Oversight', desc: 'Monthly reviews and real-time dashboards so you always know where you stand financially.' },
              { title: 'Cash Flow Clarity', desc: 'Understand inflows and outflows, eliminate surprises, and optimize working capital.' },
              { title: 'Strategic Growth Planning', desc: 'Data-driven forecasts and advisory to help you plan confidently for the future.' },
            ].map(item => (
              <div class="flex gap-4 p-4 rounded-xl" style="background: #F8FAFC; border: 1px solid #E2E8F0;">
                <div class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-1" style="color: #0F172A;">{item.title}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">What We Offer</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">Our Financial Management Services</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {[
          {
            title: 'Cash Flow Management',
            img: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?w=700&auto=format&fit=crop&q=75',
            points: ['Track inflows and outflows', 'Optimize working capital', 'Identify financial risks'],
            icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
          },
          {
            title: 'Budgeting & Forecasting',
            img: 'https://images.unsplash.com/photo-1543286386-713bdd548da4?w=700&auto=format&fit=crop&q=75',
            points: ['Create realistic budgets', 'Monitor financial KPIs', 'Strategic forecasts for growth'],
            icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
          },
          {
            title: 'Reporting & Analysis',
            img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=700&auto=format&fit=crop&q=75',
            points: ['Monthly financial statements', 'Profit & Loss reports', 'Balance sheet analysis'],
            icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
          },
          {
            title: 'Advisory & Planning',
            img: 'https://images.unsplash.com/photo-1553484771-047a44eee27a?w=700&auto=format&fit=crop&q=75',
            points: ['Strategic financial planning', 'Tax optimization guidance', 'Performance improvement insights'],
            icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
          },
        ].map(svc => (
          <div class="rounded-2xl overflow-hidden shadow-sm" style="background: white; border: 1px solid #E2E8F0;">
            <div class="relative h-44 overflow-hidden">
              <img src={svc.img} alt={svc.title} class="w-full h-full object-cover" />
              <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(15,23,42,0.2), rgba(15,23,42,0.7));"></div>
              <div class="absolute bottom-4 left-4 flex items-center gap-2.5">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: #1a4480;">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={svc.icon}/></svg>
                </div>
                <h3 class="text-white font-bold text-base">{svc.title}</h3>
              </div>
            </div>
            <div class="p-5">
              <ul class="space-y-2.5">
                {svc.points.map(p => (
                  <li class="flex items-start gap-2.5">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-sm" style="color: #374151;">{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHO IT'S FOR ===== -->
  <section class="py-20 lg:py-28" style="background-color: #ffffff;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color: #1a4480;">Who We Serve</p>
          <h2 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight" style="color: #0F172A; letter-spacing: -0.02em;">
            Ideal for US Businesses of All Sizes
          </h2>
          <div class="w-10 h-px mb-8" style="background-color: #1a4480;"></div>

          <div class="space-y-3">
            {[
              { label: 'SMEs & Startups', desc: 'Build financial clarity from day one with scalable systems.', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
              { label: 'E-Commerce & Service Businesses', desc: 'Manage multi-channel revenue streams and operational costs.', icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z' },
              { label: 'Corporations Needing Strategic Insight', desc: 'Board-ready financial reports and strategic advisory.', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
              { label: 'Investor-Backed Companies', desc: 'Investor-grade reporting, runway analysis, and KPI tracking.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
              { label: 'Businesses Expanding Across States', desc: 'Multi-state cash flow, budgeting, and compliance support.', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064' },
            ].map(item => (
              <div class="flex items-start gap-4 p-4 rounded-xl transition-all hover:shadow-md" style="border: 1px solid #E2E8F0;">
                <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center" style="background: #EFF6FF;">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #1a4480;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
                </div>
                <div>
                  <div class="text-sm font-semibold mb-0.5" style="color: #0F172A;">{item.label}</div>
                  <div class="text-xs leading-relaxed" style="color: #64748B;">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="relative rounded-2xl overflow-hidden shadow-xl hidden lg:block" style="height: 520px;">
          <img
            src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=900&auto=format&fit=crop&q=80"
            alt="Finance team collaboration"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(15,23,42,0.6) 0%, transparent 60%);"></div>
          <div class="absolute bottom-8 left-8 right-8">
            <div class="text-white font-bold text-xl mb-2">Trusted by US Businesses</div>
            <div class="text-sm" style="color: #93B4D4;">From startups to multi-state corporations</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM → SOLUTION ===== -->
  <section class="py-20 lg:py-28" style="background-color: #0F172A;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #93B4D4;">The Challenge</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white" style="letter-spacing: -0.02em;">
          Financial Uncertainty Can Hinder Growth
        </h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">
        <!-- Problems -->
        <div class="rounded-2xl p-8" style="background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.15);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(239,68,68,0.15);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #EF4444;">Without Ambit</span>
          </div>
          <div class="space-y-4">
            {[
              'Cash flow surprises that derail operations',
              'Poor budgeting and forecasting accuracy',
              'Missed tax-saving opportunities',
              'Confusing, hard-to-read financial reports',
              'No strategic visibility into business performance',
            ].map(p => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #EF4444;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
                <span class="text-sm leading-relaxed" style="color: #94A3B8;">{p}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Solutions -->
        <div class="rounded-2xl p-8" style="background: rgba(26,68,128,0.15); border: 1px solid rgba(26,68,128,0.35);">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(26,68,128,0.3);">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #93B4D4;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <span class="text-sm font-bold uppercase tracking-widest" style="color: #93B4D4;">With Ambit</span>
          </div>
          <div class="space-y-4">
            {[
              'Real-time cash flow visibility and working capital optimization',
              'Accurate budgets and forward-looking financial forecasts',
              'Tax-efficient financial structuring and IRS compliance',
              'Clear, executive-ready reports every month',
              'Strategic advisory to drive performance and growth',
            ].map(s => (
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #3B82F6;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm leading-relaxed" style="color: #CBD5E1;">{s}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="py-20 lg:py-28" style="background-color: #F8FAFC;">
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-16">
        <p class="text-xs font-bold tracking-[0.2em] uppercase mb-3" style="color: #1a4480;">Our Process</p>
        <h2 class="text-3xl lg:text-4xl font-bold" style="color: #0F172A; letter-spacing: -0.02em;">4-Step US Financial Management Process</h2>
        <div class="w-10 h-px mx-auto mt-5" style="background-color: #1a4480;"></div>
      </div>

      <!-- Desktop timeline -->
      <div class="hidden lg:grid grid-cols-4 gap-6 relative">
        <div class="absolute top-[52px] left-[12.5%] right-[12.5%] h-px" style="background: linear-gradient(to right, #1a4480, #1e5ab5, #1a4480);"></div>
        {[
          { num: '01', title: 'Data Collection', desc: 'Gather accounting records, bank statements, and transaction history for comprehensive analysis.' },
          { num: '02', title: 'Analysis & Reporting', desc: 'Monthly P&L, balance sheets, and KPI monitoring to give you full financial clarity.' },
          { num: '03', title: 'Budgeting & Forecasting', desc: 'Strategic insights, scenario planning, and forward-looking financial projections.' },
          { num: '04', title: 'Advisory & Support', desc: 'Ongoing recommendations, financial optimization, and strategic guidance for growth.' },
        ].map((step, i) => (
          <div class="flex flex-col items-center text-center">
            <div class="relative z-10 w-[104px] h-[104px] rounded-full flex flex-col items-center justify-center mb-6 shadow-lg" style="background: white; border: 2px solid #1a4480;">
              <span class="text-xs font-bold tracking-[0.15em] uppercase mb-0.5" style="color: #94A3B8;">{step.num} / 04</span>
              <span class="text-lg font-bold" style="color: #0F172A;">{i + 1}</span>
            </div>
            <h3 class="text-sm font-bold mb-2" style="color: #0F172A;">{step.title}</h3>
            <div class="w-6 h-px mb-3 mx-auto" style="background: #1a4480;"></div>
            <p class="text-xs leading-relaxed" style="color: #64748B;">{step.desc}</p>
          </div>
        ))}
      </div>

      <!-- Mobile timeline -->
      <div class="lg:hidden space-y-6">
        {[
          { num: '01', title: 'Data Collection', desc: 'Gather accounting records, bank statements, and transaction history for comprehensive analysis.' },
          { num: '02', title: 'Analysis & Reporting', desc: 'Monthly P&L, balance sheets, and KPI monitoring to give you full financial clarity.' },
          { num: '03', title: 'Budgeting & Forecasting', desc: 'Strategic insights, scenario planning, and forward-looking financial projections.' },
          { num: '04', title: 'Advisory & Support', desc: 'Ongoing recommendations, financial optimization, and strategic guidance for growth.' },
