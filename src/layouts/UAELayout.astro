---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description = 'Ambit – Dubai & UAE Accounting Services',
  countryPhone = '+971 4 123 4567',
  countryEmail = 'uae@ambit.ae',
} = Astro.props;

const currentUrl = Astro.url.pathname;

const services = [
  { label: 'Overview', href: '/services/finance-accounting-tax/uae/overview', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { label: 'Accounting & Bookkeeping', href: '/services/finance-accounting-tax/uae/accounting-bookkeeping', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z' },
  { label: 'Tax Compliance', href: '/services/finance-accounting-tax/uae/tax-compliance', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
  { label: 'VAT Compliance', href: '/services/finance-accounting-tax/uae/vat-compliance', icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5' },
  { label: 'Payroll', href: '/services/finance-accounting-tax/uae/payroll', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z' },
  { label: 'Financial Management', href: '/services/finance-accounting-tax/uae/financial-management', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
  { label: 'Business Formation', href: '/services/finance-accounting-tax/uae/business-formation', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
];
---

<Layout title={title} description={description}>
  <Navbar />

  <div class="flex min-h-screen">

    <!-- ===== LEFT SIDEBAR ===== -->
    <aside class="hidden lg:flex flex-col w-64 xl:w-72 flex-shrink-0 sticky top-16 h-[calc(100vh-64px)]" style="background-color: #0F172A; border-right: 1px solid #1E293B; z-index: 20; position: sticky;">

      <!-- Country header -->
      <div class="px-6 py-6" style="border-bottom: 1px solid #1E293B;">
        <a href="/services/finance-accounting-tax/uae/overview" class="flex items-center gap-3 group">
          <div class="w-8 h-8 rounded-lg overflow-hidden flex-shrink-0 flex items-center justify-center" style="background-color: #1E293B;">
            <img src="https://flagcdn.com/w40/ae.png" alt="UAE" class="w-8 h-5 object-cover" />
          </div>
          <div>
            <div class="text-xs font-black uppercase tracking-widest" style="color: #F8FAFC;">United Arab Emirates</div>
            <div class="text-xs" style="color: #64748B;">Dubai · Abu Dhabi · UAE</div>
          </div>
        </a>
      </div>

      <!-- Nav links -->
      <nav class="flex-1 overflow-y-auto px-4 py-6 space-y-1">
        {services.map(({ label, href, icon }) => {
          const isActive = currentUrl === href || currentUrl === href + '/';
          return (
            <a
              href={href}
              class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all group"
              style={isActive
                ? 'background-color: #1a4480; color: #ffffff;'
                : 'color: #94A3B8;'}
            >
              <svg
                class="w-4 h-4 flex-shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                style={isActive ? 'color: #ffffff;' : 'color: #64748B;'}
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
              <span class="leading-tight">{label}</span>
              {isActive && (
                <svg class="w-3 h-3 ml-auto flex-shrink-0" style="color: #ffffff;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                </svg>
              )}
            </a>
          );
        })}
      </nav>

      <!-- Contact footer -->
      <div class="px-6 py-5" style="border-top: 1px solid #1E293B;">
        <div class="text-xs font-semibold mb-3 uppercase tracking-widest" style="color: #64748B;">UAE Office</div>
        <a href={`tel:${countryPhone}`} class="flex items-center gap-2 text-xs mb-1.5 hover:opacity-80 transition-opacity" style="color: #94A3B8;">
          <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {countryPhone}
        </a>
        <a href={`mailto:${countryEmail}`} class="flex items-center gap-2 text-xs hover:opacity-80 transition-opacity" style="color: #94A3B8;">
          <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: #1a4480;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          {countryEmail}
        </a>
      </div>
    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="flex-1 min-w-0">
      <slot />

      <!-- ===== FOOTER ===== -->
      <Footer />
    </main>

  </div>

  <!-- ===== MOBILE BOTTOM DRAWER ===== -->
  <div
    class="lg:hidden fixed bottom-0 left-0 right-0 z-50"
    style="background-color: #ffffff; border-top: 2px solid #E2E8F0; box-shadow: 0 -4px 24px rgba(0,0,0,0.12);"
    x-data="{ open: false }"
  >
    <!-- Trigger bar -->
    <button
      @click="open = !open"
      class="w-full flex items-center justify-between px-6 py-3.5"
    >
      <div class="flex items-center gap-2">
        <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-5 h-3.5 object-cover rounded-sm" />
        <span class="text-xs font-bold tracking-wide" style="color: #0F172A;">UAE Services</span>
        <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background-color: #EFF6FF; color: #1a4480;">7 services</span>
      </div>
      <svg class="w-4 h-4 transition-transform" :class="open ? 'rotate-180' : ''" style="color: #64748B;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
      </svg>
    </button>

    <!-- Drawer content -->
    <div x-show="open" x-transition style="display:none; border-top: 1px solid #E2E8F0;">
      <div class="grid grid-cols-2 gap-px" style="background-color: #E2E8F0;">
        {services.map(({ label, href, icon }) => {
          const isActive = currentUrl === href || currentUrl === href + '/';
          return (
            <a
              href={href}
              class="flex items-center gap-2 px-4 py-3.5 text-xs font-medium"
              style={isActive
                ? 'background-color: #1a4480; color: #ffffff;'
                : 'background-color: #ffffff; color: #374151;'}
            >
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} />
              </svg>
              {label}
            </a>
          );
        })}
      </div>
      <div class="px-4 py-3" style="border-top: 1px solid #E2E8F0; background-color: #F8FAFC;">
        <a href="/contact" class="flex items-center justify-center gap-2 w-full py-2.5 text-xs font-semibold text-white rounded-lg" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          Book Free Consultation
        </a>
      </div>
    </div>
  </div>

</Layout>
