---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description = 'Ambit – UK Accounting & Tax Services',
  countryPhone = '+44 (0) 20 1234 5678',
  countryEmail = 'uk@ambit.co.uk',
} = Astro.props;

const currentUrl = Astro.url.pathname;

const services = [
  { label: 'Overview', href: '/services/finance-accounting-tax/uk/overview', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { label: 'Accounting & Bookkeeping', href: '/services/finance-accounting-tax/uk/accounting-bookkeeping', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z' },
  { label: 'Tax Compliance', href: '/services/finance-accounting-tax/uk/tax-compliance', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
  { label: 'VAT Compliance', href: '/services/finance-accounting-tax/uk/vat-compliance', icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5' },
  { label: 'Payroll', href: '/services/finance-accounting-tax/uk/payroll', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z' },
  { label: 'Financial Management', href: '/services/finance-accounting-tax/uk/financial-management', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
  { label: 'Business Formation', href: '/services/finance-accounting-tax/uk/business-formation', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
];
---

<Layout title={title} description={description}>
  <Navbar />

  <div class="flex min-h-screen">

    <!-- ===== LEFT SIDEBAR ===== -->
    <aside class="hidden lg:flex flex-col w-64 xl:w-72 flex-shrink-0 sticky top-16 h-[calc(100vh-64px)]" style="background-color: #0F172A; border-right: 1px solid #1E293B; z-index: 20; position: sticky;">

      <!-- Country header -->
      <div class="px-6 py-6" style="border-bottom: 1px solid #1E293B;">
        <a href="/services/finance-accounting-tax/uk/overview" class="flex items-center gap-3 group">
          <div class="w-8 h-8 rounded-lg overflow-hidden flex-shrink-0 flex items-center justify-center" style="background-color: #1E293B;">
            <img src="https://flagcdn.com/w40/gb.png" alt="UK" class="w-8 h-5 object-cover" />
          </div>
          <div>
            <p class="text-white font-bold text-sm leading-none mb-0.5">United Kingdom</p>
            <p class="text-xs" style="color: #475569;">Accounting Services</p>
          </div>
        </a>
      </div>

      <!-- Service links -->
      <nav class="flex-1 overflow-y-auto py-4">
        <p class="text-xs font-bold tracking-[0.2em] uppercase px-6 mb-3" style="color: #334155;">Services</p>
        <ul class="space-y-0.5 px-3">
          {services.map((s, i) => {
            const isActive = currentUrl === s.href || currentUrl === s.href + '/';
            return (
              <li>
                <a
                  href={s.href}
                  class={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-150 ${isActive ? 'text-white' : 'hover:bg-white/5'}`}
                  style={isActive ? 'background-color: #1a4480; color: white;' : 'color: #64748B;'}
                >
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width={isActive ? '2' : '1.6'} d={s.icon}/>
                  </svg>
                  <span class="leading-snug text-xs">{s.label}</span>
                  {isActive && (
                    <svg class="w-3.5 h-3.5 ml-auto flex-shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <!-- CTA at bottom -->
      <div class="p-4" style="border-top: 1px solid #1E293B;">
        <a href="/contact" class="flex items-center justify-center gap-2 w-full py-3 px-4 text-xs font-semibold text-white rounded-lg transition-all hover:opacity-90" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          Book Free Consultation
        </a>
        <div class="mt-3 space-y-1.5 text-xs" style="color: #475569;">
          <div class="flex items-center gap-2">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {countryPhone}
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {countryEmail}
          </div>
        </div>
      </div>

    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="flex-1 min-w-0">
      <slot />
      <Footer countryPhone={countryPhone} countryEmail={countryEmail} />
    </div>

  </div>

  <!-- ===== MOBILE SERVICES DRAWER ===== -->
  <div class="lg:hidden fixed bottom-0 left-0 right-0 z-50" style="background-color: #ffffff; border-top: 2px solid #E2E8F0; box-shadow: 0 -4px 24px rgba(0,0,0,0.12);">
    <div x-data="{ open: false }">
      <button @click="open = !open" class="w-full flex items-center justify-between px-5 py-3.5">
        <div class="flex items-center gap-2.5">
          <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
          <span class="text-xs font-bold tracking-wide" style="color: #0F172A;">UK Services</span>
          <span class="text-xs px-2 py-0.5 rounded-full font-semibold" style="background-color: #EFF6FF; color: #1a4480;">6 pages</span>
        </div>
        <svg class="w-4 h-4 transition-transform duration-200" :class="open ? 'rotate-180' : ''" style="color: #64748B;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
        </svg>
      </button>
      <div x-show="open" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0" style="display:none; border-top: 1px solid #E2E8F0;">
        <div class="grid grid-cols-2 gap-px" style="background-color: #E2E8F0;">
          {services.slice(1).map(s => {
            const isActive = currentUrl === s.href || currentUrl === s.href + '/';
            return (
              <a href={s.href} class="flex items-center gap-2.5 px-4 py-3.5 text-xs font-medium transition-colors" style={`background-color: ${isActive ? '#1a4480' : '#ffffff'}; color: ${isActive ? '#ffffff' : '#374151'};`}>
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d={s.icon}/>
                </svg>
                <span class="leading-snug">{s.label}</span>
              </a>
            );
          })}
        </div>
        <div class="px-4 py-3" style="border-top: 1px solid #E2E8F0; background-color: #F8FAFC;">
          <a href="/contact" class="flex items-center justify-center gap-2 w-full py-2.5 text-xs font-semibold text-white rounded-lg" style="background: linear-gradient(135deg, #1a4480, #1e5ab5);">
            Book Free Consultation
          </a>
        </div>
      </div>
    </div>
  </div>

</Layout>
