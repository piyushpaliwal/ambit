---
---

<!-- TOP COUNTRY BAR -->
<div class="w-full text-sm relative" style="background-color: #1E293B; z-index: 60;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-10">
      <div class="flex items-center" style="divide-color: #334155;">
        <a href="/uk" class="flex items-center gap-2 px-4 h-10 text-gray-300 hover:text-white hover:bg-white/5 transition-all text-xs font-medium tracking-wide uppercase border-r border-slate-700">
          <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm opacity-90" />
          <span>United Kingdom</span>
        </a>
        <a href="/us" class="flex items-center gap-2 px-4 h-10 text-gray-300 hover:text-white hover:bg-white/5 transition-all text-xs font-medium tracking-wide uppercase border-r border-slate-700">
          <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm opacity-90" />
          <span>United States</span>
        </a>
        <a href="/uae" class="flex items-center gap-2 px-4 h-10 text-gray-300 hover:text-white hover:bg-white/5 transition-all text-xs font-medium tracking-wide uppercase">
          <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-5 h-3.5 object-cover rounded-sm opacity-90" />
          <span>UAE</span>
        </a>
      </div>
      <div class="hidden sm:flex items-center gap-6 text-gray-400 text-xs">
        <a href="tel:+442012345678" class="flex items-center gap-1.5 hover:text-white transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          +44 20 1234 5678
        </a>
        <a href="mailto:info@ambit.co.uk" class="flex items-center gap-1.5 hover:text-white transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          info@ambit.co.uk
        </a>
      </div>
    </div>
  </div>
</div>

<!-- MAIN NAVBAR -->
<nav
  x-data="{ mobileOpen: false, scrolled: false, servicesOpen: false }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 10 })"
  :class="scrolled ? 'shadow-lg' : ''"
  class="w-full sticky top-0 z-50 transition-shadow duration-300 bg-white border-b border-gray-100"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 flex-shrink-0">
        <div class="w-9 h-9 rounded flex items-center justify-center" style="background-color: #1a4480;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M3 18L9 6L15 18M6 14H12" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M17 8v10M19.5 10.5L17 8L14.5 10.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <div class="font-bold text-xl tracking-tight leading-none" style="color: #0F172A; letter-spacing: -0.03em;">ambit</div>
          <div class="text-xs leading-none tracking-widest uppercase" style="color: #94A3B8; font-size: 9px;">Tax & Accounting</div>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-0.5">
        <a href="/" class="px-3 py-2 text-sm font-semibold tracking-wide uppercase transition-colors" style="color: #0F172A;">Home</a>
        <a href="/about" class="px-3 py-2 text-sm font-medium tracking-wide uppercase text-gray-500 hover:text-gray-900 transition-colors">About Us</a>

        <!-- Services Mega Dropdown -->
        <div class="relative" x-data="{ open: false }" @mouseenter="open = true" @mouseleave="open = false">
          <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium tracking-wide uppercase text-gray-500 hover:text-gray-900 transition-colors">
            Services
            <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>

          <div
            x-show="open"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 translate-y-1"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-1"
            class="absolute top-full left-1/2 -translate-x-1/2 mt-px w-[640px] bg-white rounded-xl shadow-xl border border-gray-100 p-6 grid grid-cols-3 gap-6"
            style="display:none;"
          >
            <!-- UK -->
            <div>
              <a href="/uk" class="flex items-center gap-2 mb-3 hover:opacity-80 transition-opacity">
                <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
                <span class="text-xs font-bold uppercase tracking-widest" style="color: #1a4480;">United Kingdom</span>
              </a>
              <ul class="space-y-1.5">
                {[
                  ['Accounting & Bookkeeping (UK GAAP)', '/uk/accounting'],
                  ['Payroll Management (RTI & HMRC)', '/uk/payroll'],
                  ['Tax & VAT Filing', '/uk/tax'],
                  ['Monthly Financial Management', '/uk/reporting'],
                  ['Company Formation', '/uk/company-formation'],
                ].map(([label, href]) => (
                  <li><a href={href} class="text-xs text-gray-500 hover:text-gray-900 hover:underline transition-colors block py-0.5">{label}</a></li>
                ))}
              </ul>
            </div>
            <!-- US -->
            <div>
              <a href="/us" class="flex items-center gap-2 mb-3 hover:opacity-80 transition-opacity">
                <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
                <span class="text-xs font-bold uppercase tracking-widest" style="color: #1a4480;">United States</span>
              </a>
              <ul class="space-y-1.5">
                {[
                  ['Accounting & Financial Reporting', '/us/accounting'],
                  ['Federal & State Tax Compliance', '/us/tax'],
                  ['Payroll & Employment Tax', '/us/payroll'],
                  ['Business Formation', '/us/business-formation'],
                  ['Financial Management', '/us/financial-management'],
                ].map(([label, href]) => (
                  <li><a href={href} class="text-xs text-gray-500 hover:text-gray-900 hover:underline transition-colors block py-0.5">{label}</a></li>
                ))}
              </ul>
            </div>
            <!-- UAE -->
            <div>
              <a href="/uae" class="flex items-center gap-2 mb-3 hover:opacity-80 transition-opacity">
                <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-5 h-3.5 object-cover rounded-sm" />
                <span class="text-xs font-bold uppercase tracking-widest" style="color: #1a4480;">Dubai / UAE</span>
              </a>
              <ul class="space-y-1.5">
                {[
                  ['Accounting & Bookkeeping (IFRS)', '/uae/accounting'],
                  ['Payroll Management (UAE Labour Law)', '/uae/payroll'],
                  ['Tax & VAT Filing', '/uae/tax'],
                  ['Accounts Payable & Receivable', '/uae/accounts'],
                  ['Financial Reporting & Analysis', '/uae/reporting'],
                  ['Offshore Accounting Teams', '/uae/offshore'],
                ].map(([label, href]) => (
                  <li><a href={href} class="text-xs text-gray-500 hover:text-gray-900 hover:underline transition-colors block py-0.5">{label}</a></li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <a href="#industries" class="px-3 py-2 text-sm font-medium tracking-wide uppercase text-gray-500 hover:text-gray-900 transition-colors">Industries</a>
        <a href="#how-it-works" class="px-3 py-2 text-sm font-medium tracking-wide uppercase text-gray-500 hover:text-gray-900 transition-colors">How It Works</a>
        <a href="#blog" class="px-3 py-2 text-sm font-medium tracking-wide uppercase text-gray-500 hover:text-gray-900 transition-colors">Blogs</a>
        <a href="/contact" class="px-3 py-2 text-sm font-medium tracking-wide uppercase text-gray-500 hover:text-gray-900 transition-colors">Contact Us</a>
      </div>

      <!-- CTA -->
      <div class="hidden lg:block">
        <a href="/contact" class="px-5 py-2.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
          Book Free Consultation
        </a>
      </div>

      <!-- Mobile toggle -->
      <button @click="mobileOpen = !mobileOpen" class="lg:hidden p-2 text-gray-600 hover:text-gray-900">
        <svg x-show="!mobileOpen" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg x-show="mobileOpen" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display:none;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div x-show="mobileOpen" x-transition class="lg:hidden bg-white border-t border-gray-100" style="display:none;">
    <div class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      <a href="/" class="block px-3 py-2.5 text-sm font-semibold text-gray-900 uppercase tracking-wide">Home</a>
      <a href="/about" class="block px-3 py-2.5 text-sm text-gray-600 uppercase tracking-wide">About Us</a>
      <a href="#" class="block px-3 py-2.5 text-sm text-gray-600 uppercase tracking-wide">Services</a>
      <a href="#industries" class="block px-3 py-2.5 text-sm text-gray-600 uppercase tracking-wide">Industries</a>
      <a href="#how-it-works" class="block px-3 py-2.5 text-sm text-gray-600 uppercase tracking-wide">How It Works</a>
      <a href="#blog" class="block px-3 py-2.5 text-sm text-gray-600 uppercase tracking-wide">Blogs</a>
      <a href="/contact" class="block px-3 py-2.5 text-sm text-gray-600 uppercase tracking-wide">Contact Us</a>
      <div class="pt-2 pb-1">
        <a href="/contact" class="block w-full text-center px-5 py-3 text-sm font-semibold text-white rounded" style="background-color: #1a4480;">Book Free Consultation</a>
      </div>
    </div>
  </div>
</nav>
