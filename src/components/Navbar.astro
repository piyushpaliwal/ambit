---
const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<!-- TOP COUNTRY BAR -->
<div class="w-full text-sm" style="background-color: #1E293B; z-index: 60; position: relative;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-10">
      <div class="flex items-center">
        <a href="/services/finance-accounting-tax/uk/overview" class="flex items-center gap-2 px-4 h-10 text-gray-300 hover:text-white hover:bg-white/5 transition-all text-xs font-medium tracking-wide uppercase border-r border-slate-700">
          <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm opacity-90" />
          <span>United Kingdom</span>
        </a>
        <a href="/services/finance-accounting-tax/us/overview" class="flex items-center gap-2 px-4 h-10 text-gray-300 hover:text-white hover:bg-white/5 transition-all text-xs font-medium tracking-wide uppercase border-r border-slate-700">
          <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm opacity-90" />
          <span>United States</span>
        </a>
        <a href="/services/finance-accounting-tax/uae/overview" class="flex items-center gap-2 px-4 h-10 text-gray-300 hover:text-white hover:bg-white/5 transition-all text-xs font-medium tracking-wide uppercase">
          <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-5 h-3.5 object-cover rounded-sm opacity-90" />
          <span>UAE</span>
        </a>
      </div>
      <div class="hidden sm:flex items-center gap-5 text-gray-400 text-xs">
        <a href="tel:+442038132922" class="flex items-center gap-1.5 hover:text-white transition-colors">
          <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-4 h-2.5 object-cover rounded-sm opacity-70" />
          +44 203 8132 922
        </a>
        <span style="color: #334155;">|</span>
        <a href="tel:+17068949160" class="flex items-center gap-1.5 hover:text-white transition-colors">
          <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-4 h-2.5 object-cover rounded-sm opacity-70" />
          +1 706-894-9160
        </a>
        <span style="color: #334155;">|</span>
        <a href="tel:+919825016079" class="flex items-center gap-1.5 hover:text-white transition-colors">
          <img src="https://flagcdn.com/w20/in.png" alt="India" class="w-4 h-2.5 object-cover rounded-sm opacity-70" />
          +91 9825 016 079
        </a>
      </div>
    </div>
  </div>
</div>

<!-- MAIN NAVBAR -->
<nav
  x-data="{
    mobileOpen: false,
    scrolled: false,
    servicesOpen: false,
    activePillar: 'finance',
    mobileServicesOpen: false,
    mobileFinanceOpen: false,
    mobileUKOpen: false,
    mobileUSOpen: false,
    mobileUAEOpen: false
  }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 10 })"
  :class="scrolled ? 'shadow-lg' : ''"
  class="w-full sticky top-0 z-50 transition-shadow duration-300 bg-white border-b border-gray-100"
  style="position: sticky; top: 0;"
>
  <!-- Nav Bar Row -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0">
        <img src="/images/logo-color.png" alt="Ambit Tax and Accounting Services" class="h-12 w-auto" />
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden lg:flex items-center gap-0.5">
        <a href="/" class={`px-3 py-2 text-sm tracking-wide uppercase transition-colors ${isActive('/') ? 'font-semibold' : 'font-medium text-gray-500 hover:text-gray-900'}`} style={isActive('/') ? 'color: #0F172A;' : ''}>Home</a>
        <a href="/about" class={`px-3 py-2 text-sm tracking-wide uppercase transition-colors ${isActive('/about') ? 'font-semibold' : 'font-medium text-gray-500 hover:text-gray-900'}`} style={isActive('/about') ? 'color: #0F172A;' : ''}>About Us</a>

        <!-- Services trigger -->
        <button
          @mouseenter="servicesOpen = true"
          @click="servicesOpen = !servicesOpen"
          class={`flex items-center gap-1 px-3 py-2 text-sm tracking-wide uppercase transition-colors ${isActive('/services') ? 'font-semibold' : 'font-medium text-gray-500 hover:text-gray-900'}`}
          style={isActive('/services') ? 'color: #0F172A;' : ''}
        >
          Services
          <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="servicesOpen ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>

        <a href="/industries" class={`px-3 py-2 text-sm tracking-wide uppercase transition-colors ${isActive('/industries') ? 'font-semibold' : 'font-medium text-gray-500 hover:text-gray-900'}`} style={isActive('/industries') ? 'color: #0F172A;' : ''}>Industries</a>
        <a href="/how-it-works" class={`px-3 py-2 text-sm tracking-wide uppercase transition-colors ${isActive('/how-it-works') ? 'font-semibold' : 'font-medium text-gray-500 hover:text-gray-900'}`} style={isActive('/how-it-works') ? 'color: #0F172A;' : ''}>How It Works</a>
        <a href="/blog" class={`px-3 py-2 text-sm tracking-wide uppercase transition-colors ${isActive('/blog') ? 'font-semibold' : 'font-medium text-gray-500 hover:text-gray-900'}`} style={isActive('/blog') ? 'color: #0F172A;' : ''}>Blogs</a>
        <a href="/contact" class={`px-3 py-2 text-sm tracking-wide uppercase transition-colors ${isActive('/contact') ? 'font-semibold' : 'font-medium text-gray-500 hover:text-gray-900'}`} style={isActive('/contact') ? 'color: #0F172A;' : ''}>Contact Us</a>
      </div>

      <!-- CTA -->
      <div class="hidden lg:block">
        <a href="/contact" class="px-5 py-2.5 text-sm font-semibold text-white rounded transition-all hover:opacity-90" style="background-color: #1a4480;">
          Book Free Consultation
        </a>
      </div>

      <!-- Mobile toggle -->
      <button @click="mobileOpen = !mobileOpen" class="lg:hidden p-2 text-gray-600 hover:text-gray-900">
        <svg x-show="!mobileOpen" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg x-show="mobileOpen" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="display:none;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- ===== SERVICES MEGA MENU ===== -->
  <!-- Click outside to close -->
  <div
    x-show="servicesOpen"
    @click="servicesOpen = false"
    class="fixed inset-0"
    style="z-index: 40; display: none;"
  ></div>

  <div
    x-show="servicesOpen"
    @mouseleave="servicesOpen = false"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-1"
    class="absolute left-0 right-0 hidden lg:block"
    style="top: 100%; z-index: 50; display: none;"
  >
    <div style="background-color: #0F172A; border-top: 2px solid #1a4480; box-shadow: 0 20px 60px rgba(0,0,0,0.5);">
      <div style="max-width: 1440px; margin: 0 auto; padding: 2.5rem 3rem;">
        <div style="display: grid; grid-template-columns: 240px 260px 1fr; gap: 0;">

          <!-- Col 1: Static Block -->
          <div style="padding-right: 2.5rem; border-right: 1px solid #1E293B;">
            <div class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #475569;">Services</div>
            <h2 class="text-2xl font-black mb-4 leading-tight" style="color: #F8FAFC; letter-spacing: -0.02em;">Three pillars.<br/>One partner.</h2>
            <p class="text-sm leading-relaxed mb-8" style="color: #64748B;">
              Three delivery pillars structured across Finance, Accounting and Tax, Business Process Support, and Workforce Solutions. Designed to integrate into existing systems and workflows, ensuring delivery remains consistent across functions and markets.
            </p>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <a href="/services" class="flex items-center gap-2 px-4 py-2.5 rounded text-sm font-semibold text-white transition-all hover:opacity-90" style="background-color: #1a4480;">
                Explore Services
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
              <a href="/contact" class="flex items-center justify-center px-4 py-2.5 rounded text-sm font-semibold transition-all hover:bg-white/5" style="color: #94A3B8; border: 1px solid #334155;">
                Book a Consultation
              </a>
            </div>
          </div>

          <!-- Col 2: Pillar Tabs -->
          <div style="padding: 0 2rem; border-right: 1px solid #1E293B;">
            <div class="text-xs font-bold uppercase tracking-widest mb-5" style="color: #475569;">Pillars</div>
            <div style="display: flex; flex-direction: column; gap: 0.25rem;">

              <button
                @mouseenter="activePillar = 'finance'"
                class="w-full flex items-center justify-between px-4 py-3 rounded-lg text-left text-sm font-semibold transition-all"
                :style="activePillar === 'finance' ? 'background-color: #1E293B; color: #F8FAFC;' : 'color: #64748B; background: transparent;'"
              >
                <span>Finance, Accounting &amp; Tax</span>
                <svg class="w-4 h-4 flex-shrink-0 ml-2" :style="activePillar === 'finance' ? 'color: #1a4480;' : 'color: #334155;'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </button>

              <button
                @mouseenter="activePillar = 'bpo'"
                class="w-full flex items-center justify-between px-4 py-3 rounded-lg text-left text-sm font-semibold transition-all"
                :style="activePillar === 'bpo' ? 'background-color: #1E293B; color: #F8FAFC;' : 'color: #64748B; background: transparent;'"
              >
                <span>BPO Services</span>
                <svg class="w-4 h-4 flex-shrink-0 ml-2" :style="activePillar === 'bpo' ? 'color: #1a4480;' : 'color: #334155;'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </button>

              <button
                @mouseenter="activePillar = 'rpo'"
                class="w-full flex items-center justify-between px-4 py-3 rounded-lg text-left text-sm font-semibold transition-all"
                :style="activePillar === 'rpo' ? 'background-color: #1E293B; color: #F8FAFC;' : 'color: #64748B; background: transparent;'"
              >
                <span>RPO Services</span>
                <svg class="w-4 h-4 flex-shrink-0 ml-2" :style="activePillar === 'rpo' ? 'color: #1a4480;' : 'color: #334155;'" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </button>

            </div>
          </div>

          <!-- Col 3: Dynamic Panel -->
          <div style="padding-left: 2.5rem;">

            <!-- Finance, Accounting & Tax -->
            <div x-show="activePillar === 'finance'" style="display: none;">
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
                <div class="text-xs font-bold uppercase tracking-widest" style="color: #475569;">Finance, Accounting &amp; Tax</div>
              </div>
              <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem;">

                <!-- UK -->
                <div>
                  <a href="/services/finance-accounting-tax/uk/overview" class="flex items-center gap-2 mb-4 group" style="text-decoration: none;">
                    <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-5 h-3.5 object-cover rounded-sm" />
                    <span class="text-xs font-bold uppercase tracking-widest" style="color: #94A3B8;">United Kingdom</span>
                  </a>
                  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
                    {[
                      ['Overview', '/services/finance-accounting-tax/uk/overview'],
                      ['Accounting & Bookkeeping', '/services/finance-accounting-tax/uk/accounting-bookkeeping'],
                      ['Tax Compliance', '/services/finance-accounting-tax/uk/tax-compliance'],
                      ['VAT Compliance', '/services/finance-accounting-tax/uk/vat-compliance'],
                      ['Payroll', '/services/finance-accounting-tax/uk/payroll'],
                      ['Financial Management', '/services/finance-accounting-tax/uk/financial-management'],
                      ['Business Formation', '/services/finance-accounting-tax/uk/business-formation'],
                    ].map(([label, href]) => (
                      <li>
                        <a
                          href={href}
                          class="text-sm block py-0.5 transition-colors hover:text-white"
                          style="color: #64748B; text-decoration: none;"
                        >{label}</a>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- US -->
                <div>
                  <a href="/services/finance-accounting-tax/us/overview" class="flex items-center gap-2 mb-4 group" style="text-decoration: none;">
                    <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-5 h-3.5 object-cover rounded-sm" />
                    <span class="text-xs font-bold uppercase tracking-widest" style="color: #94A3B8;">United States</span>
                  </a>
                  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
                    {[
                      ['Overview', '/services/finance-accounting-tax/us/overview'],
                      ['Accounting & Bookkeeping', '/services/finance-accounting-tax/us/accounting-bookkeeping'],
                      ['Tax Compliance', '/services/finance-accounting-tax/us/tax-compliance'],
                      ['Sales Tax Compliance', '/services/finance-accounting-tax/us/sales-tax-compliance'],
                      ['Payroll', '/services/finance-accounting-tax/us/payroll'],
                      ['Financial Management', '/services/finance-accounting-tax/us/financial-management'],
                      ['Business Formation', '/services/finance-accounting-tax/us/business-formation'],
                    ].map(([label, href]) => (
                      <li>
                        <a
                          href={href}
                          class="text-sm block py-0.5 transition-colors hover:text-white"
                          style="color: #64748B; text-decoration: none;"
                        >{label}</a>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- UAE -->
                <div>
                  <a href="/services/finance-accounting-tax/uae/overview" class="flex items-center gap-2 mb-4 group" style="text-decoration: none;">
                    <img src="https://flagcdn.com/w20/ae.png" alt="UAE" class="w-5 h-3.5 object-cover rounded-sm" />
                    <span class="text-xs font-bold uppercase tracking-widest" style="color: #94A3B8;">Dubai / UAE</span>
                  </a>
                  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
                    {[
                      ['Overview', '/services/finance-accounting-tax/uae/overview'],
                      ['Accounting & Bookkeeping', '/services/finance-accounting-tax/uae/accounting-bookkeeping'],
                      ['Tax Compliance', '/services/finance-accounting-tax/uae/tax-compliance'],
                      ['VAT Compliance', '/services/finance-accounting-tax/uae/vat-compliance'],
                      ['Payroll', '/services/finance-accounting-tax/uae/payroll'],
                      ['Financial Management', '/services/finance-accounting-tax/uae/financial-management'],
                      ['Business Formation', '/services/finance-accounting-tax/uae/business-formation'],
                    ].map(([label, href]) => (
                      <li>
                        <a
                          href={href}
                          class="text-sm block py-0.5 transition-colors hover:text-white"
                          style="color: #64748B; text-decoration: none;"
                        >{label}</a>
                      </li>
                    ))}
                  </ul>
                </div>

              </div>
            </div>

            <!-- BPO Panel -->
            <div x-show="activePillar === 'bpo'" style="display: none; max-width: 480px;">
              <div class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #475569;">BPO Services</div>
              <h3 class="text-xl font-black mb-4 leading-snug" style="color: #F8FAFC; letter-spacing: -0.02em;">
                Operational support across finance functions and shared services.
              </h3>
              <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
                Operational support across finance functions, shared services, and backend workflows. Designed to integrate into existing systems and maintain consistency across processes.
              </p>
              <p class="text-sm leading-relaxed mb-8" style="color: #64748B;">
                We embed within your existing operations to run defined functions, from transaction processing to reporting workflows, without disrupting how you work.
              </p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
                <a href="/services/bpo" class="flex items-center gap-2 px-5 py-2.5 rounded text-sm font-semibold text-white transition-all hover:opacity-90" style="background-color: #1a4480;">
                  View BPO Services
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <a href="/contact" class="px-5 py-2.5 rounded text-sm font-semibold transition-all hover:bg-white/5" style="color: #94A3B8; border: 1px solid #334155;">
                  Book a Consultation
                </a>
              </div>
            </div>

            <!-- RPO Panel -->
            <div x-show="activePillar === 'rpo'" style="display: none; max-width: 480px;">
              <div class="text-xs font-bold uppercase tracking-widest mb-6" style="color: #475569;">RPO Services</div>
              <h3 class="text-xl font-black mb-4 leading-snug" style="color: #F8FAFC; letter-spacing: -0.02em;">
                Recruitment process outsourcing for growing teams.
              </h3>
              <p class="text-sm leading-relaxed mb-4" style="color: #64748B;">
                Recruitment process outsourcing to support hiring pipelines, candidate evaluation, and end-to-end recruitment operations.
              </p>
              <p class="text-sm leading-relaxed mb-8" style="color: #64748B;">
                Whether you need to scale a finance team, fill specialist roles, or run a continuous hiring programme, our RPO service integrates directly into your talent acquisition function.
              </p>
              <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
                <a href="/services/rpo" class="flex items-center gap-2 px-5 py-2.5 rounded text-sm font-semibold text-white transition-all hover:opacity-90" style="background-color: #1a4480;">
                  View RPO Services
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <a href="/contact" class="px-5 py-2.5 rounded text-sm font-semibold transition-all hover:bg-white/5" style="color: #94A3B8; border: 1px solid #334155;">
                  Book a Consultation
                </a>
              </div>
            </div>

          </div>
          <!-- End Col 3 -->

        </div>
      </div>
    </div>
  </div>
  <!-- End Mega Menu -->

  <!-- Mobile Menu -->
  <div x-show="mobileOpen" x-transition class="lg:hidden border-t border-gray-100" style="background-color: #0F172A; display:none;">
    <div class="px-4 py-3">

      <a href="/" class="flex items-center justify-between px-3 py-3 text-sm font-semibold text-white uppercase tracking-wide border-b" style="border-color: #1E293B;">Home</a>
      <a href="/about" class="flex items-center justify-between px-3 py-3 text-sm uppercase tracking-wide border-b" style="color: #94A3B8; border-color: #1E293B;">About Us</a>

      <!-- L1: Services accordion -->
      <div class="border-b" style="border-color: #1E293B;">
        <button
          @click="mobileServicesOpen = !mobileServicesOpen"
          class="w-full flex items-center justify-between px-3 py-3 text-sm uppercase tracking-wide"
          style="color: #94A3B8;"
        >
          <span>Services</span>
          <svg class="w-4 h-4 transition-transform duration-200" :class="mobileServicesOpen ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>

        <div x-show="mobileServicesOpen" x-transition style="display:none;">

          <!-- L2: Finance, Accounting & Tax accordion -->
          <div class="border-t" style="border-color: #1E293B;">
            <button
              @click="mobileFinanceOpen = !mobileFinanceOpen"
              class="w-full flex items-center justify-between px-5 py-3 text-sm font-medium"
              style="color: #CBD5E1;"
            >
              <span>Finance, Accounting &amp; Tax</span>
              <svg class="w-3.5 h-3.5 transition-transform duration-200" :class="mobileFinanceOpen ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>

            <div x-show="mobileFinanceOpen" x-transition style="display:none; background-color: #0B1120;">

              <!-- L3: United Kingdom accordion -->
              <div class="border-t" style="border-color: #1E293B;">
                <button
                  @click="mobileUKOpen = !mobileUKOpen"
                  class="w-full flex items-center justify-between px-7 py-2.5 text-sm"
                  style="color: #94A3B8;"
                >
                  <span class="flex items-center gap-2">
                    <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-4 h-3 object-cover rounded-sm" />
                    United Kingdom
                  </span>
                  <svg class="w-3 h-3 transition-transform duration-200" :class="mobileUKOpen ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div x-show="mobileUKOpen" style="display:none;">
                  {[
                    ['Overview', '/services/finance-accounting-tax/uk/overview'],
                    ['Accounting & Bookkeeping', '/services/finance-accounting-tax/uk/accounting-bookkeeping'],
                    ['Tax Compliance', '/services/finance-accounting-tax/uk/tax-compliance'],
                    ['VAT Compliance', '/services/finance-accounting-tax/uk/vat-compliance'],
                    ['Payroll', '/services/finance-accounting-tax/uk/payroll'],
                    ['Financial Management', '/services/finance-accounting-tax/uk/financial-management'],
                    ['Business Formation', '/services/finance-accounting-tax/uk/business-formation'],
                  ].map(([label, href]) => (
                    <a href={href} class="block px-10 py-2 text-sm border-t" style="color: #64748B; border-color: #1E293B; text-decoration: none;">{label}</a>
                  ))}
                </div>
              </div>

              <!-- L3: United States accordion -->
              <div class="border-t" style="border-color: #1E293B;">
                <button
                  @click="mobileUSOpen = !mobileUSOpen"
                  class="w-full flex items-center justify-between px-7 py-2.5 text-sm"
                  style="color: #94A3B8;"
                >
                  <span class="flex items-center gap-2">
                    <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-4 h-3 object-cover rounded-sm" />
