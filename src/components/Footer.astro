---
const { countryPhone = '', countryEmail = 'nishant@ambitsol.co' } = Astro.props;
---
<footer style="background-color: #0F172A;" class="border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-10">

      <!-- Brand -->
      <div>
        <div class="mb-5">
          <img src="/images/logo-white.png" alt="Ambit Tax and Accounting Services" class="h-10 w-auto" />
        </div>
        <p class="text-xs leading-relaxed mb-5" style="color: #475569;">Structured accounting, tax, and financial management services across the UK, USA, and UAE.</p>
        <div class="space-y-2 text-xs" style="color: #64748B;">
          <a href="tel:+442038132922" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <img src="https://flagcdn.com/w20/gb.png" alt="UK" class="w-4 h-2.5 object-cover rounded-sm opacity-60 flex-shrink-0" />
            +44 203 8132 922
          </a>
          <a href="tel:+17068949160" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <img src="https://flagcdn.com/w20/us.png" alt="US" class="w-4 h-2.5 object-cover rounded-sm opacity-60 flex-shrink-0" />
            +1 706-894-9160
          </a>
          <a href="tel:+919825016079" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
            <img src="https://flagcdn.com/w20/in.png" alt="India" class="w-4 h-2.5 object-cover rounded-sm opacity-60 flex-shrink-0" />
            +91 9825 016 079
          </a>
          <div class="flex items-center gap-2">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            nishant@ambitsol.co
          </div>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">Quick Links</h4>
        <div class="w-6 h-px mb-4" style="background-color: #1a4480;"></div>
        <ul class="space-y-2.5">
          {[
            ['Home', '/'],
            ['About Us', '/about'],
            ['Services', '/services/finance-accounting-tax/uk/overview'],
            ['Industries', '/industries'],
            ['How It Works', '/how-it-works'],
            ['Blogs', '/blog'],
            ['Contact', '/contact'],
          ].map(([label, href]) => (
            <li><a href={href} class="text-xs transition-colors hover:text-gray-300" style="color: #64748B;">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">Our Services</h4>
        <div class="w-6 h-px mb-4" style="background-color: #1a4480;"></div>
        <ul class="space-y-2.5">
          {[
            ['Accounting & Bookkeeping', '/services/finance-accounting-tax/uk/accounting-bookkeeping'],
            ['Tax Compliance', '/services/finance-accounting-tax/uk/tax-compliance'],
            ['Payroll Services', '/services/finance-accounting-tax/uk/payroll'],
            ['Company Formation', '/services/finance-accounting-tax/uk/business-formation'],
            ['Financial Reporting', '/services/finance-accounting-tax/uk/financial-management'],
            ['Accounts Payable & Receivable', '#'],
            ['Business Advisory', '#'],
          ].map(([label, href]) => (
            <li><a href={href} class="text-xs transition-colors hover:text-gray-300" style="color: #64748B;">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Markets -->
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">Our Markets</h4>
        <div class="w-6 h-px mb-4" style="background-color: #1a4480;"></div>
        <div class="space-y-3 mb-6">
          {[
            { img: 'https://flagcdn.com/w20/gb.png', label: 'United Kingdom', href: '/services/finance-accounting-tax/uk/overview' },
            { img: 'https://flagcdn.com/w20/us.png', label: 'United States', href: '/services/finance-accounting-tax/us/overview' },
            { img: 'https://flagcdn.com/w20/ae.png', label: 'UAE', href: '/services/finance-accounting-tax/uae/overview' },
          ].map(c => (
            <a href={c.href} class="flex items-center gap-2.5 text-xs transition-colors hover:text-gray-300" style="color: #64748B;">
              <img src={c.img} alt={c.label} class="w-5 h-3.5 object-cover rounded-sm opacity-60" />
              {c.label}
            </a>
          ))}
        </div>
        <h4 class="text-white text-sm font-semibold mb-3">Technology We Use</h4>
        <div class="flex flex-wrap gap-2">
          {['QuickBooks', 'Xero', 'NetSuite', 'Sage', 'Zoho Books'].map(t => (
            <span class="px-2.5 py-1 text-xs font-medium rounded text-white" style="background-color: #1E293B; border: 1px solid #334155;">{t}</span>
          ))}
        </div>
      </div>

    </div>
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-top: 1px solid #1E293B;">
      <p class="text-xs" style="color: #475569;">© 2026 Ambit. All rights reserved.</p>
      <div class="flex items-center gap-4 text-xs" style="color: #475569;">
        <a href="/privacy" class="transition-colors hover:opacity-80" style="color: #475569;">Privacy Policy</a>
        <a href="/terms" class="transition-colors hover:opacity-80" style="color: #475569;">Terms of Use</a>
        <a href="/cookies" class="transition-colors hover:opacity-80" style="color: #475569;">Cookies Policy</a>
      </div>
    </div>
  </div>
</footer>
